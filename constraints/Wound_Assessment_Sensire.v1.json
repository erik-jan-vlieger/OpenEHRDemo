{
  "template_id": "Wound_Assessment_Sensire.v1",
  "description": "Constraints voor het Algemeen Wondprotocol — velden verplicht/verboden zetten",
  "constraints": [
    {
      "_comment": "=== WONDDIAGNOSE (problem_diagnosis) ===",
      "archetype": "openEHR-EHR-EVALUATION.problem_diagnosis",
      "rules": [
        { "path": "/data[at0001]/items[at0002]", "occurrences": "1..1", "label": "Probleemnaam (verplicht)" },
        { "path": "/data[at0001]/items[at0009]", "occurrences": "1..1", "label": "Klinische beschrijving (verplicht)" },
        { "path": "/data[at0001]/items[at0012]", "occurrences": "0..1", "label": "Anatomische locatie (optioneel)" },
        { "path": "/data[at0001]/items[at0077]", "occurrences": "1..1", "label": "Datum eerste constatering (verplicht)" },
        { "path": "/data[at0001]/items[at0003]", "occurrences": "0..0", "label": "Datum klinisch erkend (niet nodig)" },
        { "path": "/data[at0001]/items[at0005]", "occurrences": "0..0", "label": "Ernst (niet nodig, gebruiken WCS)" }
      ]
    },
    {
      "_comment": "=== WONDINSPECTIE (exam) — velden die WEL nodig zijn ===",
      "archetype": "openEHR-EHR-OBSERVATION.exam",
      "rules": [
        { "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0004]", "occurrences": "0..1", "label": "Beschrijving (optioneel)" },
        { "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0006]", "occurrences": "0..1", "label": "Klinische interpretatie (optioneel)" }
      ]
    },
    {
      "_comment": "=== LICHAAMSTEMPERATUUR — bij infectieverdenking ===",
      "archetype": "openEHR-EHR-OBSERVATION.body_temperature",
      "rules": [
        { "path": "/data[at0002]/events[at0003]/data[at0001]/items[at0004]", "occurrences": "1..1", "label": "Temperatuur (verplicht indien gemeten)" }
      ]
    },
    {
      "_comment": "=== CONTRA-INDICATIE DEBRIDEMENT ===",
      "archetype": "openEHR-EHR-EVALUATION.contraindication",
      "rules": [
        { "path": "/data[at0001]/items[at0002]", "occurrences": "1..1", "label": "Contra-indicatie naam (verplicht)" }
      ]
    },
    {
      "_comment": "=== VERBANDORDER (therapeutic_item_order) ===",
      "archetype": "openEHR-EHR-INSTRUCTION.therapeutic_item_order",
      "rules": [
        { "path": "/activities[at0001]/description[at0002]/items[at0003]", "occurrences": "1..1", "label": "Item naam (verplicht)" }
      ]
    },
    {
      "_comment": "=== VERWIJZING (service_request) ===",
      "archetype": "openEHR-EHR-INSTRUCTION.service_request",
      "rules": [
        { "path": "/activities[at0001]/description[at0009]/items[at0121]", "occurrences": "1..1", "label": "Service naam (verplicht)" },
        { "path": "/activities[at0001]/description[at0009]/items[at0062]", "occurrences": "1..1", "label": "Reden (verplicht)" }
      ]
    }
  ]
}
