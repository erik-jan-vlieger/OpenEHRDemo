					text = <"Stemmer sign">
					description = <"Clinical test to differentiate lymphoedema from venous oedema by attempting to pinch a skin fold on the dorsal side of the second toe.">
				>
				["at0001"] = <
					text = <"Test result">
					description = <"The result of the Stemmer sign test.">
				>
				["at0002"] = <
					text = <"Positive (lymphoedema)">
					description = <"The skin fold on the dorsal side of the second toe cannot be pinched, indicating lymphoedema.">
				>
				["at0003"] = <
					text = <"Negative (venous oedema)">
					description = <"The skin fold on the dorsal side of the second toe can be pinched, indicating venous oedema.">
				>
