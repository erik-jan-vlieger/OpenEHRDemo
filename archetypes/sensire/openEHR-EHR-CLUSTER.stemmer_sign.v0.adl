archetype (adl_version=1.4; uid=b2c3d4e5-f6a7-8901-bcde-f01234567890)
	openEHR-EHR-CLUSTER.stemmer_sign.v0

concept
	[at0000]	-- Stemmer sign

language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nl"] = <
			language = <[ISO_639-1::nl]>
			author = <
				["name"] = <"Sensire Wondzorg">
				["organisation"] = <"Sensire">
			>
		>
	>

description
	original_author = <
		["name"] = <"Sensire Wondzorg">
		["organisation"] = <"Sensire">
		["date"] = <"2026-03-18">
	>
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the result of the Stemmer sign test, a clinical test used to differentiate lymphoedema from venous oedema. The test involves attempting to pinch a skin fold on the dorsal side of the second toe.">
			use = <"Use to record the presence or absence of the Stemmer sign during assessment of lower limb oedema. A positive result (inability to pinch the skin fold) indicates lymphoedema, while a negative result (skin fold can be pinched) indicates venous oedema. This distinction is important for treatment planning in patients with leg ulcers.">
			misuse = <"Not to be used as a standalone diagnostic test. Should be used in conjunction with other clinical findings and investigations.">
			keywords = <"Stemmer", "sign", "lymphoedema", "venous", "oedema", "skin", "fold", "test">
		>
		["nl"] = <
			language = <[ISO_639-1::nl]>
			purpose = <"Voor het vastleggen van het resultaat van het teken van Stemmer, een klinische test om lymfoedeem te onderscheiden van veneus oedeem. De test bestaat uit het proberen op te pakken van een huidplooi op de dorsale zijde van de tweede teen.">
			use = <"Gebruik om de aan- of afwezigheid van het teken van Stemmer vast te leggen bij beoordeling van onderbeensoedeem. Een positief resultaat (huidplooi niet op te pakken) wijst op lymfoedeem, een negatief resultaat (huidplooi wel op te pakken) wijst op veneus oedeem. Dit onderscheid is belangrijk voor het behandelplan bij patiënten met beenulcera.">
			misuse = <"Niet gebruiken als op zichzelf staande diagnostische test. Moet worden gebruikt in combinatie met andere klinische bevindingen en onderzoeken.">
			keywords = <"Stemmer", "teken", "lymfoedeem", "veneus", "oedeem", "huidplooi", "test">
		>
	>
	lifecycle_state = <"in_development">
	other_details = <
		["licence"] = <"Creative Commons Attribution-ShareAlike 4.0 International">
		["custodian_organisation"] = <"Sensire">
		["original_namespace"] = <"nl.sensire">
		["original_publisher"] = <"Sensire">
	>

definition
	CLUSTER[at0000] matches {	-- Stemmer sign
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0001] occurrences matches {0..1} matches {	-- Test result
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0002,	-- Positive (lymphoedema)
							at0003]	-- Negative (venous oedema)
						}
					}
				}
			}
			ELEMENT[at0004] occurrences matches {0..1} matches {	-- Side tested
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0005,	-- Left
							at0006]	-- Right
						}
					}
				}
			}
			ELEMENT[at0007] occurrences matches {0..1} matches {	-- Clinical description
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0008] occurrences matches {0..1} matches {	-- Comment
				value matches {
					DV_TEXT matches {*}
				}
			}
		}
	}

