				>
				["at0014"] = <
					text = <"Geen compressie - verwijs vaatchirurg">
					description = <"Compressie is gecontra-indiceerd vanwege ernstig arterieel vaatlijden. Verwijs naar vaatchirurg.">
				>
				["at0015"] = <
					text = <"Lichte compressie (UrgoK2 Lite)">
					description = <"Lichte compressietherapie met een verlaagd-druk systeem zoals UrgoK2 Lite.">
				>
				["at0016"] = <
					text = <"Standaard compressie (UrgoK2)">
					description = <"Standaard meerlaags compressietherapie zoals UrgoK2.">
