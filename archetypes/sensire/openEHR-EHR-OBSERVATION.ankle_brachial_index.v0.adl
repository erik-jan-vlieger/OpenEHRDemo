	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Ankle brachial index">
					description = <"The ratio of the systolic blood pressure at the ankle to the systolic blood pressure in the arm, used to assess peripheral arterial disease.">
				>
