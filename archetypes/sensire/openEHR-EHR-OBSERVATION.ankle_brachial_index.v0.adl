					description = <"Clinical interpretation of the ABI value based on established thresholds.">
				>
				["at0009"] = <
					text = <"Severe arterial disease">
					description = <"ABI < 0.6 indicating severe peripheral arterial disease. Compression therapy is contraindicated.">
				>
				["at0010"] = <
					text = <"Mixed arterial/venous disease">
					description = <"ABI 0.6–0.8 indicating mixed arterial and venous disease. Only light compression permitted.">
				>
				["at0011"] = <
					text = <"Normal venous">
					description = <"ABI 0.8–1.3 indicating normal arterial circulation. Standard compression therapy is safe.">
				>
				["at0012"] = <
					text = <"Unreliable (calcified)">
					description = <"ABI > 1.3 suggesting calcified, incompressible arteries. Measurement is unreliable; consult GP for further diagnostics.">
				>
				["at0013"] = <
					text = <"Compression recommendation">
					description = <"The recommended compression therapy based on the ABI value.">
				>
				["at0014"] = <
					text = <"No compression - refer vascular surgeon">
					description = <"Compression is contraindicated due to severe arterial disease. Refer to vascular surgeon.">
				>
				["at0015"] = <
					text = <"Light compression (UrgoK2 Lite)">
					description = <"Light compression therapy using a reduced-pressure system such as UrgoK2 Lite.">
				>
				["at0016"] = <
					text = <"Standard compression (UrgoK2)">
					description = <"Standard multi-layer compression therapy such as UrgoK2.">
				>
				["at0017"] = <
					text = <"Consult GP - unreliable measurement">
					description = <"ABI measurement unreliable due to calcified vessels. Consult GP for further assessment.">
				>
				["at0018"] = <
					text = <"Measurement date">
					description = <"The date when the ABI was measured. Measurements older than 3 months should be repeated.">
				>
				["at0019"] = <
					text = <"Comment">
					description = <"Additional narrative about the ABI measurement not captured in other fields.">
				>
			>
		>
