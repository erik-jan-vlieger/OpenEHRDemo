archetype (adl_version=1.4; uid=a1b2c3d4-e5f6-7890-abcd-ef0123456789)
	openEHR-EHR-OBSERVATION.ankle_brachial_index.v0

concept
	[at0000]	-- Ankle brachial index

language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nl"] = <
			language = <[ISO_639-1::nl]>
			author = <
				["name"] = <"Sensire Wondzorg">
				["organisation"] = <"Sensire">
