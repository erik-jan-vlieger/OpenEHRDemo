description
	original_author = <
		["name"] = <"Sensire Wondzorg">
		["organisation"] = <"Sensire">
		["date"] = <"2026-03-18">
	>
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the ankle-brachial index (ABI), also known as the ankle-arm index (AAI) or enkel-arm index (EAI), as a ratio of the systolic blood pressure at the ankle to the systolic blood pressure in the arm. Used to assess peripheral arterial disease and guide compression therapy decisions in venous ulcer care.">
			use = <"Use to record the ankle-brachial index measurement and its clinical interpretation. The ABI value determines whether compression therapy is safe:
- ABI < 0.6: Severe arterial disease — no compression, refer to vascular surgeon
- ABI 0.6–0.8: Mixed arterial/venous disease — light compression (e.g. UrgoK2 Lite)
- ABI 0.8–1.3: Normal venous — standard compression (e.g. UrgoK2)
- ABI > 1.3: Unreliable measurement (calcified vessels) — consult GP

The measurement should be no older than 3 months. Repeat if clinical status changes.">
			misuse = <"Not to be used to record blood pressure measurements themselves — use OBSERVATION.blood_pressure for that purpose.">
			keywords = <"ankle", "brachial", "index", "ABI", "EAI", "peripheral", "arterial", "vascular", "compression", "ulcer">
		>
		["nl"] = <
			language = <[ISO_639-1::nl]>
			purpose = <"Voor het vastleggen van de enkel-arm index (EAI), de verhouding tussen de systolische bloeddruk ter hoogte van de enkel en de systolische bloeddruk in de arm. Gebruikt voor het beoordelen van perifeer arterieel vaatlijden en het bepalen van compressietherapie bij ulcus cruris.">
			use = <"Gebruik om de enkel-arm index meting en de klinische interpretatie vast te leggen. De EAI-waarde bepaalt of compressietherapie veilig is:
- EAI < 0.6: Ernstig vaatlijden — geen compressie, verwijs naar vaatchirurg
- EAI 0.6–0.8: Gemengd vaatlijden — lichte compressie (bijv. UrgoK2 Lite)
- EAI 0.8–1.3: Veneus normaal — standaard compressie (bijv. UrgoK2)
- EAI > 1.3: Onbetrouwbare meting (verkalkte vaten) — overleg huisarts

De meting mag maximaal 3 maanden oud zijn. Herhaal bij klinische verandering.">
			misuse = <"Niet gebruiken voor het vastleggen van bloeddrukmetingen zelf — gebruik daarvoor OBSERVATION.blood_pressure.">
			keywords = <"enkel", "arm", "index", "EAI", "perifeer", "arterieel", "vasculair", "compressie", "ulcus">
		>
	>
	lifecycle_state = <"in_development">
	other_details = <
		["licence"] = <"Creative Commons Attribution-ShareAlike 4.0 International">
		["custodian_organisation"] = <"Sensire">
		["references"] = <"Sensire Wondzorg Protocol Ulcus Cruris, 2026.">
		["original_namespace"] = <"nl.sensire">
		["original_publisher"] = <"Sensire">
	>

definition
	OBSERVATION[at0000] matches {	-- Ankle brachial index
		data matches {
			HISTORY[at0001] matches {	-- History
				events cardinality matches {1..*; unordered} matches {
					POINT_EVENT[at0002] occurrences matches {0..*} matches {	-- Any point in time event
						data matches {
							ITEM_TREE[at0003] matches {	-- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0004] occurrences matches {0..1} matches {	-- ABI ratio
										value matches {
											DV_QUANTITY matches {
												property matches {[openehr::380]}
												magnitude matches {|0.0..3.0|}
												precision matches {2}
												units matches {"1"}
											}
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {	-- Side
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0006,	-- Left
													at0007]	-- Right
												}
											}
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {	-- Clinical interpretation
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0009,	-- Severe arterial disease
													at0010,	-- Mixed arterial/venous disease
													at0011,	-- Normal venous
													at0012]	-- Unreliable (calcified)
												}
											}
										}
									}
									ELEMENT[at0013] occurrences matches {0..1} matches {	-- Compression recommendation
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0014,	-- No compression - refer vascular surgeon
													at0015,	-- Light compression (UrgoK2 Lite)
													at0016,	-- Standard compression (UrgoK2)
													at0017]	-- Consult GP - unreliable measurement
												}
											}
										}
									}
									ELEMENT[at0018] occurrences matches {0..1} matches {	-- Measurement date
										value matches {
											DV_DATE_TIME matches {*}
										}
									}
									ELEMENT[at0019] occurrences matches {0..1} matches {	-- Comment
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}

