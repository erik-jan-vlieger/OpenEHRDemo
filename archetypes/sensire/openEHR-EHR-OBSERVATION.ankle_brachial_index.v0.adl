					description = <"De datum waarop de EAI is gemeten. Metingen ouder dan 3 maanden moeten herhaald worden.">
				>
				["at0019"] = <
					text = <"Opmerking">
					description = <"Aanvullend verhaal over de EAI-meting dat niet in andere velden is vastgelegd.">
				>
