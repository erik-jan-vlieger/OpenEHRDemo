archetype (adl_version=1.4; uid=e5f6a7b8-c9d0-1234-efab-234567890123)
	openEHR-EHR-CLUSTER.exam_stemmer_test.v0

concept
	[at0000]	-- Stemmer-test

language
	original_language = <[ISO_639-1::nl]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"Erik-Jan Vlieger">
			>
		>
	>

description
	original_author = <
		["name"] = <"Erik-Jan Vlieger">
		["organisation"] = <"Sensire / Het Instituut Bedrijfskunde">
		["email"] = <"info@erik-janvlieger.nl">
		["date"] = <"2026-03-29">
	>
	details = <
		["nl"] = <
			language = <[ISO_639-1::nl]>
			purpose = <"Registratie van het resultaat van de Stemmer-test (Kaposi-Stemmer sign) ter differentiatie tussen lymfoedeem en veneus oedeem bij patiënten met onderbeenoedeem.">
			use = <"Gebruik als genest cluster binnen OBSERVATION.exam.v1 in het 'Examination findings'-slot, specifiek in de sectie 'Oedeem-beoordeling' van het template Ulcus_Cruris_Assessment_Sensire.v1.">
			misuse = <"Niet als zelfstandige observatie; altijd binnen de context van een oedeem-beoordeling gebruiken.">
			keywords = <"Stemmer", "Kaposi-Stemmer", "lymfoedeem", "veneus oedeem", "oedeem", "huidplooi">
			copyright = <"© 2026 Sensire">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Recording of the Stemmer test (Kaposi-Stemmer sign) result for differentiation between lymphoedema and venous oedema.">
			use = <"Use as nested cluster within OBSERVATION.exam.v1.">
			misuse = <"Not as standalone observation.">
			keywords = <"Stemmer", "Kaposi-Stemmer", "lymphoedema", "venous oedema", "oedema">
			copyright = <"© 2026 Sensire">
		>
	>
	lifecycle_state = <"in_development">

definition
	CLUSTER[at0000] matches {	-- Stemmer-test
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0001] matches {	-- Resultaat
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0002,	-- Positief
							at0003]	-- Negatief
						}
					}
				}
			}
			ELEMENT[at0004] occurrences matches {0..1} matches {	-- Testlocatie
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0005,	-- Tweede teen dorsaal links
							at0006]	-- Tweede teen dorsaal rechts
						}
					}
				}
			}
			ELEMENT[at0007] occurrences matches {0..1} matches {	-- Interpretatie
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0008,	-- Lymfoedeem waarschijnlijk
							at0009]	-- Veneus oedeem waarschijnlijk
						}
					}
				}
			}
			ELEMENT[at0010] occurrences matches {0..1} matches {	-- Opmerking
				value matches {
					DV_TEXT matches {*}
				}
			}
		}
	}

ontology
	term_definitions = <
		["nl"] = <
			items = <
				["at0000"] = <text = <"Stemmer-test"> description = <"Test waarbij geprobeerd wordt een huidplooi op te tillen aan de dorsale zijde van de tweede teen. Bij lymfoedeem is dit niet mogelijk (positief resultaat).">
				>
				["at0001"] = <text = <"Resultaat"> description = <"Uitkomst van de Stemmer-test.">>
				["at0002"] = <text = <"Positief"> description = <"Huidplooi niet op te tillen. Passend bij lymfoedeem.">>
				["at0003"] = <text = <"Negatief"> description = <"Huidplooi normaal op te tillen. Passend bij veneus oedeem.">>
				["at0004"] = <text = <"Testlocatie"> description = <"Locatie waar de test is uitgevoerd.">>
				["at0005"] = <text = <"Tweede teen dorsaal links"> description = <"Dorsale zijde van de tweede teen, linkervoet.">>
				["at0006"] = <text = <"Tweede teen dorsaal rechts"> description = <"Dorsale zijde van de tweede teen, rechtervoet.">>
				["at0007"] = <text = <"Interpretatie"> description = <"Klinische interpretatie van het testresultaat.">>
				["at0008"] = <text = <"Lymfoedeem waarschijnlijk"> description = <"Positieve Stemmer-test wijst op lymfoedeem of lymfatische component.">>
				["at0009"] = <text = <"Veneus oedeem waarschijnlijk"> description = <"Negatieve Stemmer-test wijst op primair veneus oedeem.">>
				["at0010"] = <text = <"Opmerking"> description = <"Aanvullende opmerkingen bij de Stemmer-test.">>
			>
		>
		["en"] = <
			items = <
				["at0000"] = <text = <"Stemmer test"> description = <"Test attempting to lift a skin fold on the dorsum of the second toe.">>
				["at0001"] = <text = <"Result"> description = <"Outcome of the Stemmer test.">>
				["at0002"] = <text = <"Positive"> description = <"Skin fold cannot be lifted. Suggestive of lymphoedema.">>
				["at0003"] = <text = <"Negative"> description = <"Skin fold can be lifted normally. Suggestive of venous oedema.">>
				["at0004"] = <text = <"Test location"> description = <"Location where the test was performed.">>
				["at0005"] = <text = <"Second toe dorsum left"> description = <"Dorsal surface of the second toe, left foot.">>
				["at0006"] = <text = <"Second toe dorsum right"> description = <"Dorsal surface of the second toe, right foot.">>
				["at0007"] = <text = <"Interpretation"> description = <"Clinical interpretation of the test result.">>
				["at0008"] = <text = <"Lymphoedema likely"> description = <"Positive Stemmer test suggests lymphoedema.">>
				["at0009"] = <text = <"Venous oedema likely"> description = <"Negative Stemmer test suggests venous oedema.">>
				["at0010"] = <text = <"Comment"> description = <"Additional comments.">>
			>
		>
	>
