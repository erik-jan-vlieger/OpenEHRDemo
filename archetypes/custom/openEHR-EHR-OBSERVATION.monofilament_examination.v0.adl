				["at0016"] = <text = <"Totaalscore"> description = <"Aantal locaties waar het monofilament wél werd waargenomen (0-8 per voet). Score ≤5 wijst op verlies van protectieve sensibiliteit.">>
				["at0017"] = <text = <"Protectieve sensibiliteit verloren"> description = <"Klinisch oordeel: protectieve sensibiliteit is verloren (score ≤5/8 of klinisch beeld).">>
				["at0018"] = <text = <"Opmerking"> description = <"Aanvullende opmerkingen bij het monofilament-onderzoek.">>
				["at0019"] = <text = <"Protocol"> description = <"Protocol van het onderzoek.">>
				["at0020"] = <text = <"Waargenomen"> description = <"De patiënt voelt het monofilament op deze locatie.">>
				["at0021"] = <text = <"Niet waargenomen"> description = <"De patiënt voelt het monofilament niet op deze locatie.">>
				["at0022"] = <text = <"Instrument"> description = <"Gebruikt instrument voor de test.">>
				["at0023"] = <text = <"Semmes-Weinstein 10g monofilament"> description = <"Standaard Semmes-Weinstein 5.07 (10g) monofilament.">>
				["at0024"] = <text = <"Testmethode"> description = <"Beschrijving van de toegepaste testmethode.">>
			>
		>
