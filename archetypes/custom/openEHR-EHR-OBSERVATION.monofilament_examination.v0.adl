archetype (adl_version=1.4; uid=c3d4e5f6-a7b8-9012-cdef-012345678901)
	openEHR-EHR-OBSERVATION.monofilament_examination.v0

concept
	[at0000]	-- Monofilament-onderzoek

language
	original_language = <[ISO_639-1::nl]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"Erik-Jan Vlieger">
			>
		>
	>

description
	original_author = <
		["name"] = <"Erik-Jan Vlieger">
		["organisation"] = <"Sensire / Het Instituut Bedrijfskunde">
		["email"] = <"info@erik-janvlieger.nl">
		["date"] = <"2026-03-29">
	>
	details = <
		["nl"] = <
			language = <[ISO_639-1::nl]>
			purpose = <"Registratie van de Semmes-Weinstein 10g monofilament-test voor detectie van perifere sensorische neuropathie bij diabetes mellitus. Het archetype bevat een plantaire locatiematrix met per testlocatie een resultaat en een berekende totaalscore.">
			use = <"Gebruik als zelfstandig OBSERVATION-archetype binnen het template Diabetic_Foot_Assessment_Sensire.v1. De totaalscore levert input voor automatische Sims-berekening via GDL2. Protocol beschrijft het gebruikte instrument en de testmethode.">
			misuse = <"Niet voor andere sensibiliteitstesten (priktest, vibratietest). Niet voor de interpretatie van het resultaat (gebruik EVALUATION.sims_classification_nl.v0).">
			keywords = <"monofilament", "Semmes-Weinstein", "neuropathie", "sensibiliteit", "diabetes", "voet", "protectieve sensibiliteit">
			copyright = <"© 2026 Sensire">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Recording of the Semmes-Weinstein 10g monofilament test for detection of peripheral sensory neuropathy in diabetes mellitus.">
			use = <"Use as standalone OBSERVATION within Diabetic_Foot_Assessment template.">
			misuse = <"Not for other sensibility tests or interpretation of results.">
			keywords = <"monofilament", "Semmes-Weinstein", "neuropathy", "sensibility", "diabetes", "foot">
			copyright = <"© 2026 Sensire">
		>
	>
	lifecycle_state = <"in_development">

definition
	OBSERVATION[at0000] matches {	-- Monofilament-onderzoek
		data matches {
			HISTORY[at0001] matches {	-- Gebeurtenissen
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {	-- Willekeurig moment
						data matches {
							ITEM_TREE[at0003] matches {	-- Boom
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0004] occurrences matches {1..2} matches {	-- Per voet
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0005] matches {	-- Lateraliteit
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0006,	-- Links
															at0007]	-- Rechts
														}
													}
												}
											}
											ELEMENT[at0008] occurrences matches {0..1} matches {	-- Hallux (grote teen)
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0009] occurrences matches {0..1} matches {	-- Metatarsaalkop 1
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0010] occurrences matches {0..1} matches {	-- Metatarsaalkop 3
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0011] occurrences matches {0..1} matches {	-- Metatarsaalkop 5
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0012] occurrences matches {0..1} matches {	-- Middenvoet mediaal
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0013] occurrences matches {0..1} matches {	-- Middenvoet lateraal
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0014] occurrences matches {0..1} matches {	-- Hiel mediaal
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0015] occurrences matches {0..1} matches {	-- Hiel lateraal
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0020,	-- Waargenomen
															at0021]	-- Niet waargenomen
														}
													}
												}
											}
											ELEMENT[at0016] matches {	-- Totaalscore
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..8|}
													}
												}
											}
											ELEMENT[at0017] occurrences matches {0..1} matches {	-- Protectieve sensibiliteit verloren
												value matches {
													DV_BOOLEAN matches {
														value matches {True, False}
													}
												}
											}
										}
									}
									ELEMENT[at0018] occurrences matches {0..1} matches {	-- Opmerking
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0019] matches {	-- Protocol
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0022] occurrences matches {0..1} matches {	-- Instrument
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0023]	-- Semmes-Weinstein 10g monofilament
								}
							}
						}
					}
					ELEMENT[at0024] occurrences matches {0..1} matches {	-- Testmethode
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

