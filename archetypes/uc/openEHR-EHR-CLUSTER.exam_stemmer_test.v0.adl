archetype (adl_version=2.0.6; rm_release=1.1.0)
    openEHR-EHR-CLUSTER.exam_stemmer_test.v0

concept
    [at0000]

language
    original_language = <[ISO_639-1::nl]>

description
    original_author = <
        ["date"] = <"2026-03-29">
        ["name"] = <"Erik-Jan Vlieger">
        ["organisation"] = <"Sensire">
    >
    lifecycle_state = <"in_development">
    details = <
        ["nl"] = <
            language = <[ISO_639-1::nl]>
            purpose = <"Vastleggen van het resultaat van de Stemmer-test (teken van Stemmer) voor het differentiëren tussen lymfoedeem en veneus oedeem.">
            use = <"Nest in OBSERVATION.exam of een oedeem-beoordelingscluster, als onderdeel van het Ulcus Cruris protocol. De test wordt uitgevoerd op de dorsale zijde van de tweede teen.">
            misuse = <"Niet als definitieve diagnose voor lymfoedeem — is een klinische screeningstest.">
            keywords = <"Stemmer","lymfoedeem","veneus oedeem","huidplooi","oedeem","ulcus cruris">
        >
    >

definition
    CLUSTER[at0000] matches {
        items cardinality matches {1..*; unordered} matches {
            ELEMENT[at0001] matches {    -- Resultaat
                value matches {
                    DV_CODED_TEXT matches {
                        defining_code matches {[local::at0002, at0003, at0004]}
                    }
                }
            }
            ELEMENT[at0005] occurrences matches {0..1} matches {    -- Zijde
                value matches {
                    DV_CODED_TEXT matches {
                        defining_code matches {[local::at0006, at0007, at0008]}
                    }
                }
            }
            ELEMENT[at0009] occurrences matches {0..1} matches {    -- Interpretatie
                value matches {
                    DV_CODED_TEXT matches {
                        defining_code matches {[local::at0010, at0011]}
                    }
                }
            }
            ELEMENT[at0012] occurrences matches {0..1} matches {    -- Opmerking
                value matches {DV_TEXT matches {*}}
            }
        }
    }

ontology
    term_definitions = <
        ["nl"] = <
            items = <
                ["at0000"] = <text = <"Stemmer-test"> description = <"Teken van Stemmer: huidplooimanoeuvre op de dorsale zijde van de tweede teen.">>
                ["at0001"] = <text = <"Resultaat"> description = <"Uitslag van de test.">>
                ["at0002"] = <text = <"Positief"> description = <"Huidplooi niet oppakbaar — wijst op lymfoedeem.">>
                ["at0003"] = <text = <"Negatief"> description = <"Huidplooi wel oppakbaar — wijst op veneus oedeem.">>
                ["at0004"] = <text = <"Niet uitvoerbaar"> description = <"Test kon niet worden uitgevoerd.">>
                ["at0005"] = <text = <"Zijde"> description = <"Welke voet is getest.">>
                ["at0006"] = <text = <"Links"> description = <"Linkervoet.">>
                ["at0007"] = <text = <"Rechts"> description = <"Rechtervoet.">>
                ["at0008"] = <text = <"Bilateraal"> description = <"Beide voeten.">>
                ["at0009"] = <text = <"Interpretatie"> description = <"Klinische interpretatie van het resultaat.">>
                ["at0010"] = <text = <"Suggestief voor lymfoedeem"> description = <"Positieve test — huidtherapeut inschakelen (MLD/kousen).">>
                ["at0011"] = <text = <"Suggestief voor veneus oedeem"> description = <"Negatieve test — veneus oedeem waarschijnlijker.">>
                ["at0012"] = <text = <"Opmerking"> description = <"Aanvullende toelichting.">>
            >
        >
    >
