                <archetype_id><value>openEHR-EHR-ACTION.procedure.v1</value></archetype_id><term_definitions code="at0000"><items id="description">Eine klinische Aktivität, die zur Früherkennung, Untersuchung, Diagnose, Heilung, Therapie, Bewertung oder in Hinsicht auf palliative Maßnahmen durchgeführt wird.</items><items id="text">Prozedur</items></term_definitions><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0002"><items id="description">Identifizierung der Prozedur über den Namen.</items><items id="text">Name der Prozedur</items></term_definitions><term_definitions code="at0003"><items id="description">Strukturierte Informationen über die Prozedur.</items><items id="text">Details zur Prozedur</items></term_definitions><term_definitions code="at0004"><items id="description">Die Prozedur, die durchgeführt werden soll, ist geplant.</items><items id="text">Geplante Prozedur</items></term_definitions><term_definitions code="at0005"><items id="description">Zusätzliche Beschreibung der Aktivität oder der "Pathway"-Verlaufsschritte, die in anderen Bereichen nicht erfasst wurden.</items><items id="text">Kommentar</items></term_definitions><term_definitions code="at0006"><items id="description">Details zu allen Komplikationen, die sich aus der Prozedur ergeben haben.</items><items id="text">Komplikationen</items></term_definitions><term_definitions code="at0007"><items id="description">Der Auftrag für die Prozedur wurde versendet.</items><items id="text">Auftrag für Prozedur versendet</items></term_definitions><term_definitions code="at0014"><items id="description">Grund, warum die angegebene Aktivität für diese Prozedur durchgeführt wurde.</items><items id="text">Grund</items></term_definitions><term_definitions code="at0034"><items id="description">Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Prozedur geplant" (at0004), das korrekt mit dem Status "geplant" verknüpft ist.</items><items id="text">X - Prozedur geplant</items></term_definitions><term_definitions code="at0035"><items id="description">Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Geplante Prozedur" (at0007), das korrekt mit dem Status "geplant" verknüpft ist.</items><items id="text">X - Auftrag für Prozedur versendet</items></term_definitions><term_definitions code="at0036"><items id="description">Ein Termin für die Prozedur wurde geplant.</items><items id="text">geplanter Termin der Prozedur</items></term_definitions><term_definitions code="at0038"><items id="description">Die Prozedur wurde verschoben.</items><items id="text">Prozedur verschoben</items></term_definitions><term_definitions code="at0039"><items id="description">Die geplante Prozedur wurde vor Beginn storniert.</items><items id="text">Prozedur storniert</items></term_definitions><term_definitions code="at0040"><items id="description">Die Prozedur wurde unterbrochen.</items><items id="text">Prozedur unterbrochen</items></term_definitions><term_definitions code="at0041"><items id="description">Die Prozedur wurde abgebrochen.</items><items id="text">Prozedur abgebrochen</items></term_definitions><term_definitions code="at0043"><items id="description">Die Prozedur wurde durchgeführt und alle damit verbundenen klinischen Aktivitäten wurden beendet.</items><items id="text">Prozedur beendet</items></term_definitions><term_definitions code="at0047"><items id="description">Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde durchgeführt.</items><items id="text">Prozedur durchgeführt</items></term_definitions><term_definitions code="at0048"><items id="description">Ausgang der durchgeführten Prozedur.</items><items id="text">Ausgang</items></term_definitions><term_definitions code="at0049"><items id="description">Beschreibung der Prozedur, angepasst an den "Pathway"-Verlaufsschritt.</items><items id="text">Beschreibung</items></term_definitions><term_definitions code="at0053"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0054"><items id="description">Die lokale ID, die dem Auftrag vom Gesundheitsdienstleister oder der Organisation, die die Leistung anfordert, zugewiesen wurde.</items><items id="text">Auftragskennung des Antragstellers</items></term_definitions><term_definitions code="at0055"><items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistung anfordert.</items><items id="text">Antragsteller</items></term_definitions><term_definitions code="at0056"><items id="description">Die ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Leistungsanforderung erhält, zugewiesen wurde. Dies wird auch als "Filler Order Identifier" bezeichnet.</items><items id="text">Auftragskennung des Empfängers</items></term_definitions><term_definitions code="at0057"><items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistungsanforderung erhält.</items><items id="text">Empfänger</items></term_definitions><term_definitions code="at0058"><items id="description">Dringlichkeit der Prozedur.</items><items id="text">Dringlichkeit</items></term_definitions><term_definitions code="at0060"><items id="description">Das Datum und/oder die Uhrzeit, an dem die gesamte Prozedur, oder die letzte Komponente einer mehrstufigen Prozedur, beendet wurde.</items><items id="text">Enddatum/-uhrzeit</items></term_definitions><term_definitions code="at0061"><items id="description">Die Gesamtdauer der Prozedur - diese kann sich aus der aktiven Phase und der Phase, in der die Prozedur unterbrochen wurde, ergeben.</items><items id="text">Gesamtdauer</items></term_definitions><term_definitions code="at0062"><items id="description">Multimediale Darstellung der durchgeführten Prozedur.</items><items id="text">Multimedia</items></term_definitions><term_definitions code="at0063"><items id="description">Anatomische Lokalisation, an der die Prozedur durchgeführt wird.</items><items id="text">Körperstelle</items></term_definitions><term_definitions code="at0064"><items id="description">Zusätzliche Informationen, die erforderlich sind, um lokale Inhalte zu erfassen oder mit anderen Referenzmodellen/Formalismen abzugleichen.</items><items id="text">Erweiterung</items></term_definitions><term_definitions code="at0065"><items id="description">Identifizierung der spezifischen Prozedurmethode oder -technik.</items><items id="text">Methode</items></term_definitions><term_definitions code="at0066"><items id="description">Das Datum und/oder die Uhrzeit für die die Prozedur angesetzt ist.</items><items id="text">Geplantes Datum/Uhrzeit</items></term_definitions><term_definitions code="at0067"><items id="description">Die Art der Prozedur.</items><items id="text">Art der Prozedur</items></term_definitions><term_definitions code="at0068"><items id="description">Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde begonnen.</items><items id="text">Prozedur begonnen</items></term_definitions><term_definitions code="at0069"><items id="description">Schwierigkeiten oder Probleme, die während der Durchführung der Prozedur aufgetreten sind.</items><items id="text">Schwierigkeiten bei der Durchführung der Prozedur</items></term_definitions><term_definitions code="at0070"><items id="description">Der klinische oder prozessbezogene Grund für die Prozedur.</items><items id="text">Indikation</items></term_definitions><term_definitions code="at0071"><items id="description"/><items id="text">*DV_TEXT (en)</items></term_definitions></children>
