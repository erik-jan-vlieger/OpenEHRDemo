                <archetype_id><value>openEHR-EHR-EVALUATION.problem_diagnosis.v1</value></archetype_id><term_definitions code="at0077"><items id="description">Geschatte of precieze datum/tijd dat de eerste tekenen of symptomen van het probleem of de diagnose werden opgemerkt.</items><items id="text">Datum/tijd van aanvang</items></term_definitions><term_definitions code="at0076"><items id="description">*The diagnosis has been confirmed against recognised criteria.(en)</items><items id="text">*Confirmed(en)</items></term_definitions><term_definitions code="at0075"><items id="description">*The diagnosis has been identified with a high level of certainty.(en)</items><items id="text">*Probable(en)</items></term_definitions><term_definitions code="at0074"><items id="description">*The diagnosis has been identified with a low level of certainty.(en)</items><items id="text">*Suspected(en)</items></term_definitions><term_definitions code="at0073"><items id="description">*The level of confidence in the identification of the diagnosis.(en)</items><items id="text">*Diagnostic certainty(en)</items></term_definitions><term_definitions code="at0072"><items id="description">*Narrative description about the course of the problem or diagnosis since onset.(en)</items><items id="text">*Course description(en)</items></term_definitions><term_definitions code="at0071"><items id="description">*Additional information required to capture local content or to align with other reference models/formalisms.(en)</items><items id="text">*Extension(en)</items></term_definitions><term_definitions code="at0070"><items id="description">*The date this problem or diagnosis was last updated.(en)</items><items id="text">*Last updated(en)</items></term_definitions><term_definitions code="at0069"><items id="description">*Additional narrative about the problem or diagnosis not captured in other fields.(en)</items><items id="text">*Comment(en)</items></term_definitions><term_definitions code="at0049"><items id="description">*The problem or diagnosis prevents normal activity or will seriously damage health if left untreated.(en)</items><items id="text">*Severe(en)</items></term_definitions><term_definitions code="at0048"><items id="description">*The problem or diagnosis causes interference with normal activity or will damage health if left untreated.(en)</items><items id="text">*Moderate(en)</items></term_definitions><term_definitions code="at0047"><items id="description">*The problem or diagnosis does not interfere with normal activity or may cause damage to health if left untreated.(en)</items><items id="text">*Mild(en)</items></term_definitions><term_definitions code="at0046"><items id="description">*Structured details for location-, domain-, episode- or workflow-specific aspects of the diagnostic process.(en)</items><items id="text">*Status(en)</items></term_definitions><term_definitions code="at0043"><items id="description">*Details that are additionally required to record as unique attributes of this problem or diagnosis.(en)</items><items id="text">*Specific details(en)</items></term_definitions><term_definitions code="at0039"><items id="description">*A structured anatomical location for the problem or diagnosis.(en)</items><items id="text">*Structured body site(en)</items></term_definitions><term_definitions code="at0032"><items id="description">*@ internal @(en)</items><items id="text">*Tree(en)</items></term_definitions><term_definitions code="at0030"><items id="description">*Estimated or actual date/time of resolution or remission for this problem or diagnosis, as determined by a healthcare professional.(en)</items><items id="text">*Date/time of resolution(en)</items></term_definitions><term_definitions code="at0012"><items id="description">Identificatie van een eenvoudig lichaamsdeel voor de lokatie van het probleem of de diagnose.</items><items id="text">Lichaamsdeel</items></term_definitions><term_definitions code="at0009"><items id="description">Verhalende beschrijving van het probleem of de diagnose.</items><items id="text">Klinische beschrijving</items></term_definitions><term_definitions code="at0005"><items id="description">*An assessment of the overall severity of the problem or diagnosis.(en)</items><items id="text">*Severity(en)</items></term_definitions><term_definitions code="at0003"><items id="description">Geschatte of werkelijke datum/tijd waarop het probleem of de diagnose is herkend door een zorgprofessional.</items><items id="text">Datum/tijd van klinische herkenning</items></term_definitions><term_definitions code="at0002"><items id="description">Identificatie van het probleem of de diagnose bij naam.&#13;
                            </items><items id="text">Naam van het probleem / de diagnose</items></term_definitions><term_definitions code="at0001"><items id="description">*@ internal @(en)</items><items id="text">*structure(en)</items></term_definitions><term_definitions code="at0000"><items id="description">Informatie over een enkele vast te stellen medische aandoening, een letsel, beperking of andere zaak die invloed heeft op de fysieke, mentale en/of het sociale welbevinden van een individu.</items><items id="text">Probleem/Diagnose</items></term_definitions><term_definitions code="at0078"><items id="description">*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</items><items id="text">*Cause (en)</items></term_definitions><term_definitions code="at0079"><items id="description">*Specific variant or subtype of the Diagnosis, if relevant. (en)</items><items id="text">*Variant (en)</items></term_definitions><term_definitions code="at0080"><items id="description"/><items id="text">*DV_TEXT (en)</items></term_definitions></children>
