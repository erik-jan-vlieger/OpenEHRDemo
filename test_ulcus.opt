                <archetype_id><value>openEHR-EHR-INSTRUCTION.service_request.v1</value></archetype_id><term_definitions code="at0000"><items id="description">Verzoek om een gezondheidsgerelateerde dienst of activiteit te leveren door een arts, organisatie of instantie.</items><items id="text">Serviceverzoek</items></term_definitions><term_definitions code="at0001"><items id="description">Huidige Activity</items><items id="text">Huidige Activity</items></term_definitions><term_definitions code="at0008"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0009"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0010"><items id="description">De lokale identificatie die is toegewezen door het aanvragende klinische systeem.</items><items id="text">Identificatie verzoeksaanvrager</items></term_definitions><term_definitions code="at0011"><items id="description">De lokale identificatie die aan het verzoek is toegewezen door de zorgverlener of organisatie die het verzoek voor service ontvangt.</items><items id="text">Identificatie verzoek ontvanger</items></term_definitions><term_definitions code="at0040"><items id="description">*The date/time or description about timing for provision of the requested service/s. (en)</items><items id="text">*Service due (en)</items></term_definitions><term_definitions code="at0062"><items id="description">*The specific problem needing attention or the clinical question that requires investigation. (en)</items><items id="text">Reden voor aanvraag</items></term_definitions><term_definitions code="at0064"><items id="description">*Narrative description about the issue or clinical query that needs resolution.  (en)</items><items id="text">Omschrijving van de reden</items></term_definitions><term_definitions code="at0065"><items id="description">*Description of the intended outcome of the request. (en)</items><items id="text">Bedoeling</items></term_definitions><term_definitions code="at0068"><items id="description">Urgentie van het verzoek om service.</items><items id="text">Urgentie</items></term_definitions><term_definitions code="at0076"><items id="description">Aanvullende informatie volgt op dit verzoek.</items><items id="text">Aanvullende informatie</items></term_definitions><term_definitions code="at0078"><items id="description">Beschrijving van de aanvullende informatie.</items><items id="text">Informatiebeschrijving</items></term_definitions><term_definitions code="at0112"><items id="description">*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</items><items id="text">Uitbreiding</items></term_definitions><term_definitions code="at0116"><items id="description">Taal, vervoer of andere persoonlijke vereisten ter ondersteuning van de aanwezigheid of deelname van de patiënt aan de dienstverlening.</items><items id="text">Vereisten voor patiënt</items></term_definitions><term_definitions code="at0121"><items id="description">*The name of the service/s requested. (en)</items><items id="text">Servicenaam</items></term_definitions><term_definitions code="at0127"><items id="description">De status van het serviceverzoek zoals aangegeven door de aanvrager.</items><items id="text">Status van verzoek</items></term_definitions><term_definitions code="at0128"><items id="description">Details van aanvullende clinici, organisaties of instanties die kopieën van communicatie nodig hebben.</items><items id="text">Distributielijst</items></term_definitions><term_definitions code="at0132"><items id="description">Aanvullende details over de gevraagde service.</items><items id="text">Specifieke details</items></term_definitions><term_definitions code="at0135"><items id="description">Narratieve beschrijving van de gevraagde dienst.</items><items id="text">Omschrijving</items></term_definitions><term_definitions code="at0136"><items id="description">Het verzoek vereist onmiddellijke aandacht.</items><items id="text">Acuut</items></term_definitions><term_definitions code="at0137"><items id="description">Het verzoek vereist geprioriteerde aandacht.</items><items id="text">Urgent</items></term_definitions><term_definitions code="at0138"><items id="description">Het verzoek vereist geen planning met prioriteit.</items><items id="text">Routine</items></term_definitions><term_definitions code="at0141"><items id="description">Details over de zorgverlener of organisatie die de service aanvraagt.</items><items id="text">Aanvrager</items></term_definitions><term_definitions code="at0142"><items id="description">Details over de arts of organisatie die het serviceverzoek ontvangt.</items><items id="text">Ontvanger</items></term_definitions><term_definitions code="at0148"><items id="description">Categorie van de gevraagde service.</items><items id="text">*Service type (en)</items></term_definitions><term_definitions code="at0149"><items id="description">Digital document, image, video or diagram supplied as additional information to support or inform the request.</items><items id="text">Ondersteunende informatie</items></term_definitions><term_definitions code="at0150"><items id="description">Aanvullende opmerking over het serviceverzoek dat niet in andere velden is vastgelegd.</items><items id="text">Opmerking</items></term_definitions><term_definitions code="at0151"><items id="description">Details over een complexe serviceaanvraag die een reeks timings vereist.</items><items id="text">Complexe timing</items></term_definitions><term_definitions code="at0152"><items id="description">*The symptom, sign or diagnosis that necessitates the requested service. (en)</items><items id="text">Klinische indicatie</items></term_definitions><term_definitions code="at0153"><items id="description">*Additional details and instructions about how the services are to be delivered. (en)</items><items id="text">*Order detail (en)</items></term_definitions><term_definitions code="at0154"><items id="description">*Narrative information about the individual and their situation, providing relevant context for the request. (en)</items><items id="text">*Clinical context (en)</items></term_definitions><term_definitions code="at0155"><items id="description">*Details about the designated contact person or organisation and preferred mode of contact for urgent or emergency notifications related to this request. (en)</items><items id="text">*Urgent contact (en)</items></term_definitions><term_definitions code="at0156"><items id="description">*A recommendation from the requester to the receiver about the method of payment for the service. (en)</items><items id="text">*Billing guidance (en)</items></term_definitions><term_definitions code="at0157"><items id="description">*Details about the individual or organisation who will assume responsibility for payment of the service. (en)</items><items id="text">*Responsible payer (en)</items></term_definitions><term_definitions code="at0158"><items id="description">*Advice from the requester to the receiver about the individual's eligibility for the requested service. (en)</items><items id="text">*Eligibility guidance (en)</items></term_definitions></children>
