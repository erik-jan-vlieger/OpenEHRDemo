   subgraph Pijnmanagement [" "]
       direction TB
       PijnTitel["<b>── PIJNMANAGEMENT ──</b><br/><b>(Vóór Wondzorg)</b>"]
       BesluitPijn{{"Is er pijn?<br/>(ALTIS-score)"}}


       BesluitPijnType{{"Type toediening?"}}


       ActieSystemisch["<b>SYSTEMISCH</b><br/>──────────────────<br/>• Paracetamol<br/>• NSAID<br/>• Oxycodon<br/>• Amitriptyline<br/>• Fentanyl neusspray<br/>• Fentanyl pleisters<br/>• Butrans<br/>──────────────────<br/>Wachttijd: 30–60 min"]


       ActieLokaal["<b>LOKAAL</b><br/>──────────────────<br/><b>Snel (10 min):</b><br/>• Lidocaïne druppels<br/>• Lidocaïne spray<br/>──────────────────<br/><b>Traag (45 min):</b><br/>• EMLA zalf<br/>• EMLA pleister"]


       ActiePijnWacht["<b>CHECK:</b><br/>Pijnstilling ingewerkt?<br/>──────────────────<br/>Start handeling<br/>pas daarna"]


       BesluitPijn -- "Nee" --> ActieTissue
       BesluitPijn -- "Ja" --> BesluitPijnType
       BesluitPijnType -- "Systemisch" --> ActieSystemisch --> ActiePijnWacht
       BesluitPijnType -- "Lokaal" --> ActieLokaal --> ActiePijnWacht
ActiePijnWacht --> ActieTissue
   end


   ActieHandWissel1 --> BesluitPijn


   subgraph TIMEBlok [" "]
       direction TB
       TIMETitel["<b>── WONDANALYSE ──</b><br/><b>(TIME + WCS)</b>"]


       ActieTissue["<b>T – Tissue</b><br/>──────────────────<br/>Kleur + kwaliteit<br/>wondbed<br/>Afmeting: l×b×d (cm)<br/>• Vitaal: rood,<br/>  korrelig granulatie<br/>• A-vitaal:<br/>  necrose (zwart)<br/>  fibrine/slough (geel)<br/>  callus / eelt"]


       ActieICheck["<b>I – Infectie</b><br/>──────────────────<br/>Klassieke 5 tekenen:<br/>• Roodheid (rubor)<br/>• Warmte (calor)<br/>• Zwelling (tumor)<br/>• Pijn (dolor)<br/>• Functieverlies<br/>+ Meer vocht<br/>+ Geur / koorts"]


       ActieMoistureCheck["<b>M – Moisture</b><br/>──────────────────<br/>Exsudaatgraad:<br/>Droog – Vochtig – Nat<br/>──────────────────<br/>Saturatiegraad verband<br/>Wisselfrequentie:<br/>o.b.v. vochtproductie"]


       ActieEdgeCheck["<b>E – Edge</b><br/>──────────────────<br/>Wondranden &<br/>wondomgeving:<br/>• Vitaal / a-vitaal<br/>• Rood<br/>• Verweekt wit<br/>• Ondermijningen<br/>• Droog korstig<br/>• Eczeem<br/>• Eelt / callus"]


       BesluitWCS{{"<b>WCS-kleur wond?</b><br/>──────────────<br/>Meest a-vitale<br/>weefsel = eindkleur:<br/>Min. zwart = zwart<br/>Min. geel = geel"}}


       WCSZwart["<b>ZWART</b><br/>Necrose<br/>(droog of nat)"]
       WCSGeel["<b>GEEL</b><br/>Fibrine/slough<br/>(geïnf. of niet)"]
       WCSRood["<b>ROOD</b><br/>Granulerend<br/>(vitaal)"]


       InfoWCS["ℹ️ <b>WCS-resources:</b><br/>──────────────────<br/>wondbedekkers.nl<br/>wcs.nl (online boek)<br/>WCS app + handboek<br/>e-learning wondzorg"]


       ActieTissue --> ActieICheck --> ActieMoistureCheck --> ActieEdgeCheck --> BesluitWCS
       BesluitWCS -.-> InfoWCS
   end




   InfoSkinTear["<b>Skin Tear</b><br/>──────────────────<br/>• Siliconen gaas<br/>• Absorberend verband<br/>• Windsel<br/>→ Zakprotocol<br/>  Skin Tear 1"]


   InfoDecubitus["<b>Decubitus (cat. 2+)</b><br/>──────────────────<br/>• Druk + schuifkrachten<br/>  ontlasten — prioriteit!<br/>• Gladde ondergrond<br/>• Anti-decubitus<br/>  maatregelen<br/>• Vilt + barrièrecrème<br/>→ Richtlijn V&VN<br/>→ Vakgroep Wond"]


   InfoSmetten["<b>Smetten / IAD</b><br/>──────────────────<br/>• Zinkolie / zoete olie<br/>• Huid-op-huid<br/>  voorkomen<br/>• Engels pluksel<br/>  (zachte kant)<br/>• Plooien droog houden<br/>→ Richtlijn V&VN"]


   BesluitWCS -.-> InfoSkinTear
   BesluitWCS -.-> InfoDecubitus
   BesluitWCS -.-> InfoSmetten


