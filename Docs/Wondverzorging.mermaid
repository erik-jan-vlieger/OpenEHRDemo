flowchart TD




   Start["Start: Patiënt met wond<br/>(Algemeen Wondprotocol)"]


   BesluitOncologisch{{"Is het een<br/>oncologische wond?"}}


   InfoOncologisch["⚠️ <b>ONCOLOGISCHE WOND</b><br/>──────────────────<br/>Werkinstructie NIET<br/>geschikt voor<br/>oncologische wonden<br/>──────────────────<br/>Raadpleeg specialistisch<br/>protocol en/of<br/>vakgroep wond"]


   Start --> BesluitOncologisch
   BesluitOncologisch -- "Ja" --> InfoOncologisch
   BesluitOncologisch -- "Nee" --> ActieWerkveld


   subgraph Voorbereiding [" "]
       direction TB
       VoorbereidingTitel["<b>── VOORBEREIDING ──</b>"]
           ActieWerkveld["<b>Stap 1: Werkveld</b><br/><b>& Houding</b><br/>──────────────────<br/>• Ondergrond reinigen<br/>• Schoon werkveld<br/>  aanleggen<br/>• Materialen binnen<br/>  handbereik<br/>• Cliënt: comfortabele<br/>  houding, wond<br/>  bereikbaar<br/>• Geen stofvorming<br/>• Onderlegger plaatsen"]


       ActieMaterialen["<b>Stap 2: Materialen</b><br/>──────────────────<br/>• Aangebroken:<br/>  dichtvouwen, plakken,<br/>  in zakje bewaren<br/>• Max <b>14 dagen</b><br/>  na opening<br/>• Datum opening noteren<br/>  op flesjes/zalven/gel<br/>• Let op bewaarplaats:<br/>  koelkast vs kamertemp<br/>• Bewaren in<br/>  afsluitbare bak"]


       InfoMaterialen["ℹ️ <b>Benodigdheden:</b><br/>──────────────────<br/>3 paar handschoenen<br/>Onderlegger + afvalbak<br/>4 gazen (wondomgeving)<br/>Verbandmateriaal<br/>(zie wondplan)<br/>Zalf/crème + spatel<br/>Schaar + pincet<br/>6 gaasjes + alcohol 70%<br/>Eventueel: schort<br/>+ spatbril"]


       ActieHygiene["<b>Stap 3: Handhygiëne</b><br/>──────────────────<br/>• Handen desinfecteren<br/>• Handschoenen aan<br/>• Eventueel schort<br/>  en/of spatbril<br/>• Afval direct weggooien<br/>• Handhygiëne herhalen<br/>  na aanraken telefoon<br/><i>Cliënten vallen op<br/>niet-hygiënisch werken!</i>"]


       ActieDesinfectie["<b>Stap 4: Schaar</b><br/><b>& Pincet desinfecteren</b><br/>──────────────────<br/>• Overgiet 3 gaasjes<br/>  alcohol 70%<br/>• Houd schaar bij oog<br/>• Desinfecteer bladen<br/>  met 1e gaasje<br/>• Desinfecteer rest<br/>  met 2e gaasje<br/>• Leg schaar op<br/>  3e gaasje"]


       ActieWerkveld --> ActieMaterialen
       ActieMaterialen -.-> InfoMaterialen
       ActieMaterialen --> ActieHygiene --> ActieDesinfectie
   end


   subgraph Wondinspectie [" "]
       direction TB
       InspectieTitel["<b>── WONDINSPECTIE ──</b>"]


       ActieVerbandWeg["<b>Stap 5: Verband</b><br/><b>verwijderen</b><br/>──────────────────<br/>Inspecteer verband:<br/>• Kleur + geur<br/>• Hoeveelheid exsudaat<br/>• Juist absorberend<br/>  materiaal gebruikt?<br/>→ Gooi weg in afvalbak"]


       ActieWondInspectie["<b>Stap 6: Wond</b><br/><b>inspecteren</b><br/>──────────────────<br/>• Grootte: l×b×d (cm)<br/>• Kleur wondbed:<br/>  vitaal / a-vitaal<br/>• Geur<br/>• Wondranden &<br/>  wondomgeving<br/>• Huidconditie rondom<br/>• Exsudaat:<br/>  droog/vochtig/nat<br/>• Oedeem aanwezig?"]


       ActieVerbandWeg --> ActieWondInspectie
   end


   ActieDesinfectie --> ActieVerbandWeg


   BesluitDM{{"Diabetes Mellitus?"}}


   ActieWondInspectie --> BesluitDM


   subgraph DMVoetCheck [" "]
       direction TB
       DMTitel["<b>── DM: VOET- ──</b><br/><b>── INSPECTIE ──</b>"]


       ActieDMVoet["<b>DM Stap A:</b><br/><b>Voetinspectie</b><br/>──────────────────<br/>• Huidkleur + temp.<br/>• Eelt / fissuren<br/>• Standsafwijkingen<br/>• Tussen de tenen!<br/>• Pulsaties palperen<br/>• Gevoel testen<br/>  (monofilament)<br/>• Nagels + schoeisel<br/>• Zwelling / oedeem"]


       InfoDMVoet["ℹ️ <b>Signalen → arts:</b><br/>──────────────────<br/>Pulsaties afwezig<br/>→ vaatonderzoek<br/>Gevoel afwezig<br/>→ neuropathie arts<br/>──────────────────<br/>Temp. asymmetrie<br/>→ Charcot vermoeden<br/>→ Meteen arts!"]


       BesluitCharcot{{"Charcot vermoeden?<br/>──────────────<br/>Rode, warme,<br/>gezwollen voet<br/>zonder trauma?"}}


       ActieArtsCharcot["⚠️ <b>ARTS DEZELFDE DAG</b><br/>──────────────────<br/>Charcot vermoeden:<br/>→ Arts bellen direct<br/>──────────────────<br/>Tussentijds:<br/>• Niet belasten!<br/>• Voet hoogleggen<br/>• Noteer bevindingen<br/>──────────────────<br/>Arts neemt over<br/>Rapporteer in dossier"]


       BesluitPlantair{{"Wond plantair?<br/>──────────────<br/>(Voetzool)"}}


       ActieArtsPlantair["⚠️ <b>ARTS BINNEN 24U</b><br/>──────────────────<br/>Plantaire wond DM:<br/>→ Arts beoordeling<br/>  binnen 24 uur<br/>──────────────────<br/>Tussentijds:<br/>• Schone afdekking<br/>• Geen belasting<br/>• Noteer datum,<br/>  locatie, afmeting<br/>Wondzorg gaat door"]


       ActieDMVoet -.-> InfoDMVoet
       ActieDMVoet --> BesluitCharcot
       BesluitCharcot -- "Ja" --> ActieArtsCharcot
       BesluitCharcot -- "Nee" --> BesluitPlantair
       BesluitPlantair -- "Ja" --> ActieArtsPlantair
   end


   BesluitDM -- "Ja" --> ActieDMVoet
