   subgraph BehandelingBlok [" "]
       direction TB
       BehandelingTitel["<b>── BEHANDELING ──</b><br/><b>(WCS x Vochtigheid)</b>"]


       BesluitVocht{{"<b>Exsudaatniveau?</b>"}}


       ActieDroog["<b>DROGE WOND</b><br/>──────────────────<br/><b>Zwart</b> (geen infectie):<br/>Droog verbinden<br/>─<br/><b>Geel:</b><br/>Debris verwijderen;<br/>vochtig milieu creëren<br/>─<br/><b>Rood</b> (geen infectie):<br/>Beschermen +<br/>groei stimuleren"]


       ActieVochtig["<b>VOCHTIGE WOND</b><br/>──────────────────<br/><b>Zwart:</b><br/>Necrose verwijderen<br/>─<br/><b>Geel:</b><br/>Debris verwijderen;<br/>exsudaat absorberen<br/>─<br/><b>Geel (geïnf.):</b><br/>Uitspoelen +<br/>absorberen +<br/>infectie bestrijden<br/>─<br/><b>Rood:</b><br/>Vochtig milieu<br/>behouden +<br/>beschermen"]


       ActieNat["<b>NATTE WOND</b><br/>──────────────────<br/><b>Zwart:</b><br/>Necrose verwijderen<br/>─<br/><b>Geel:</b><br/>Debris verwijderen +<br/>extra absorberend<br/>verband<br/>─<br/><b>Geel (geïnf.):</b><br/>Uitspoelen + extra<br/>verband + infectie<br/>bestrijden<br/>─<br/><b>Rood:</b><br/>Vochtig milieu +<br/>absorberen +<br/>beschermen"]


       InfoMateriaalkeuze["ℹ️ <b>Materiaalkeuze:</b><br/>──────────────────<br/><b>Rood:</b> siliconen gaas,<br/>schuimverband,<br/>hydrocolloïd<br/><b>Geel:</b> honing, alginaat,<br/>zilver, jodium,<br/>prontosan<br/><b>Zwart:</b> alginaat, zilver,<br/>jodium zalf, honing<br/>──────────────────<br/>wondbedekkers.nl<br/>wcs.nl<br/>──────────────────<br/>⚠️ <b>DM: let op!</b><br/>Geen pleister direct<br/>  op de huid!<br/>Geen strak windsel!<br/>Callus → arts / podo"]


       ActieOmgeving["<b>Wondomgeving</b><br/><b>reinigen</b><br/>──────────────────<br/>• Reinig met natte gazen<br/>• Droog met gaasje<br/>• Bescherm wondranden<br/>  met zalf/crème<br/>  indien nodig<br/>• DM: droge huid<br/>  rondom invetten<br/>  (niet tss. de tenen)"]


       BesluitVocht -- "Droog" --> ActieDroog --> ActieOmgeving
