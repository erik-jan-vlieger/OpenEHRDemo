_definitions><term_definitions code="at0018"><items id="description">Den kliniske begrunnelsen for bruk av utstyret.</items><items id="text">Klinisk indikasjon</items></term_definitions><term_definitions code="at0070"><items id="description">Navn på utstyret som er ordinert.</items><items id="text">Utstyrsnavn</items></term_definitions><term_definitions code="at0092"><items id="description">Navn på kroppstedet hvor utstyret skal brukes.</items><items id="text">Anatomisk lokalisering</items></term_definitions><term_definitions code="at0093"><items id="description">Strukturert beskrivelse av kroppstedet hvor utstyret skal brukes.</items><items id="text">Strukturert anatomisk lokalisering</items></term_definitions><term_definitions code="at0107"><items id="description">Beskrivelse av monitorering ved bruk av utstyret.</items><items id="text">Overvåkningsinstruksjon</items></term_definitions><term_definitions code="at0143"><items id="description">Strukturerte detaljer om utstyret.</items><items id="text">Utstyrsdetaljer</items></term_definitions><term_definitions code="at0148"><items id="description">Den terapeutiske hensikten med bruk av utstyret.</items><items id="text">Terapeutisk hensikt</items></term_definitions><term_definitions code="at0166"><items id="description">Ytterligere detaljer om utstyret som ikke er fanget i andre felt.</items><items id="text">Ytterligere detaljer</items></term_definitions><term_definitions code="at0167"><items id="description">Ytterligere fritekst om ordinering av utstyret som ikke er fanget i andre felt.</items><items id="text">Kommentar</items></term_definitions></children>
