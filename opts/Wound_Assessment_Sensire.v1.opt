                <archetype_id><value>openEHR-EHR-INSTRUCTION.medication_order.v3</value></archetype_id><term_definitions code="at0000"><items id="description">Verschreibung eines Medikaments, Impfstoffs, Ernährungsprodukts oder anderen therapeutischen Mittels für eine bestimmte Person.</items><items id="text">Verordnung von Arzneimittel</items></term_definitions><term_definitions code="at0001"><items id="description">Angaben zur Verordnung.</items><items id="text">Verordnung</items></term_definitions><term_definitions code="at0002"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0004"><items id="description">Eindeutige Kennung der Medikamentenverordnung / des Rezeptes.</items><items id="text">ID der Verordnung</items></term_definitions><term_definitions code="at0005"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0008"><items id="description">Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</items><items id="text">Erweiterung</items></term_definitions><term_definitions code="at0009"><items id="description">Gesamtbeschreibung, wie das verordneten Medikament zu verwenden ist.</items><items id="text">Allgemeine Beschreibung der Anweisungen</items></term_definitions><term_definitions code="at0011"><items id="description">Eine Bedingung für den Beginn der Verwendung des verordneten Arzneimittels.</items><items id="text">Startkriterium für die Verordnung</items></term_definitions><term_definitions code="at0012"><items id="description">Datum und optionale Uhrzeit für den Beginn der Verwendung des verordneten Arzneimittels.</items><items id="text">Beginn der Verordnung</items></term_definitions><term_definitions code="at0013"><items id="description">Datum und optionale Uhrzeit, wann die Verwendung des verordneten Arzneimittels eingestelt werden soll.</items><items id="text">Ende der Verordnung</items></term_definitions><term_definitions code="at0016"><items id="description">Eine Bedingung für das Einstellen der Verwendung des verordneten Arzneimittels.</items><items id="text">Stopkriterium für die Verordnung</items></term_definitions><term_definitions code="at0018"><items id="description">Der klinische Grund für die Verwendung des verordneten Arzneimittels.</items><items id="text">Klinische Indikation</items></term_definitions><term_definitions code="at0044"><items id="description">Ein zusätzlicher Hinweis zur Verwendung oder Lagerung des verordneten Arzneimittels.</items><items id="text">Zusätzliche Anweisung</items></term_definitions><term_definitions code="at0047"><items id="description">Eine maschinenlesbare, berechenbare Textdarstellung der Anweisung.</items><items id="text">Maschinenlesbare Anweisungen</items></term_definitions><term_definitions code="at0050"><items id="description">Der Zeitraum, in dem die Person / der Patient das verordnete Arzneimittel noch vor der Ausstellung dieser Verordnung bereits angewendet hat.</items><items id="text">Dauer der durchgeführten Verordnung</items></term_definitions><term_definitions code="at0051"><items id="description">Details zur maximal zulässigen kumulativen Dosis über einen definierten Zeitraum für das verordnete Arzneimittel.</items><items id="text">Maximale Dosis</items></term_definitions><term_definitions code="at0053"><items id="description">Der Zeitraum, für den die maximale Dosis berechnet wird.</items><items id="text">Zulässige Dauer</items></term_definitions><term_definitions code="at0060"><items id="description">Die Anzahl der Verabreichungen des verordneten Arzneimittels, die im Rahmen der geplanten Gesamtverordnung, bereits vor dieser Ausgabe, durchgeführt wurden.</items><items id="text">Anwendungen durchgeführt</items></term_definitions><term_definitions code="at0062"><items id="description">Angaben über die Arzneimittelsicherheit des verordneten Medikaments.</items><items id="text">Arzneimittelsicherheit</items></term_definitions><term_definitions code="at0064"><items id="description">Bestätigung durch den verschreibenden Arzt, ob die normale Dosis oder andere Sicherheitsgrenzen aufgrund besonderer Umstände überschritten wurden.</items><items id="text">Beabsichtigte Sicherheitsüberschreitung?</items></term_definitions><term_definitions code="at0065"><items id="description">Detaillierte Angaben zur Menge des verordneten Arzneimittels, das abgegeben werden soll.</items><items id="text">Abgabemenge</items></term_definitions><term_definitions code="at0069"><items id="description">Details der Autorisierung für das verordnete Arzneimittel, einschließlich Unterstützung der lokalen Richtlinien zur Selbstverwaltung, Ausgabe und Bestätigung.</items><items id="text">Anweisungen zur Genehmigung</items></term_definitions><term_definitions code="at0070"><items id="description">Name des verordneten Medikaments, Impfstoffs oder anderen therapeutischen / verschreibungsfähigen Mittels.</items><items id="text">Arzneimittel</items></term_definitions><term_definitions code="at0091"><items id="description">Die Angabe darüber, auf welche Art das verordnete Arzneimittel am Körper des Patienten angewendet wird.</items><items id="text">Verabreichungsweg</items></term_definitions><term_definitions code="at0092"><items id="description">Name der Körperstelle, an der das Arzneimittel verabreicht wird.</items><items id="text">Körperstelle</items></term_definitions><term_definitions code="at0093"><items id="description">Strukturierte Beschreibung der Körperstelle, an der das Arzneimittel verabreicht wird.</items><items id="text">Lokalisation</items></term_definitions><term_definitions code="at0094"><items id="description">Die Technik oder das Gerät mit dem das versordnete Arzneimittel verabreicht werden soll.</items><items id="text">Methode der Verabreichung</items></term_definitions><term_definitions code="at0095"><items id="description">Details zu der Vorrichtung mit der das verordnete Arzneimittel verabreicht wird.</items><items id="text">Verabreichungsmittel</items></term_definitions><term_definitions code="at0105"><items id="description">Ein zusätzlicher Hinweis, der sich in erster Linie an die Person/ den Patienten oder Angehörige richtet.</items><items id="text">Patienteninformation</items></term_definitions><term_definitions code="at0106"><items id="description">Ein zusätzlicher Hinweis richtet sich in erster Linie an die Person, die das verordnete Arzneimittel verteilt.</items><items id="text">Abgabehinweis</items></term_definitions><term_definitions code="at0107"><items id="description">Eine zusätzliche Anweisung mit Hinweisen auf die empfohlene oder erforderliche Überwachung bei Verwendung des verordneten Arzneimittels.</items><items id="text">Überwachungshinweis</items></term_definitions><term_definitions code="at0112"><items id="description">Zusammenfassende Informationen zur Verwendung des verordneten Arzneimittels, z. B. aktueller Status oder Schlüsseldaten, die normalerweise in anderen Kontexten außer Verordnung verwendet werden.</items><items id="text">Zusammenfassung der Verordnung</items></term_definitions><term_definitions code="at0113"><items id="description">Detaillierte Angaben zu der gesamten Medikamentenverordnung.</items><items id="text">Detaillierte Angaben zu der Verordnung</items></term_definitions><term_definitions code="at0129"><items id="description">Anweisungen zur Abgabe des verordneten Arzneimittels.</items><items id="text">Anweisungen zur Abgabe</items></term_definitions><term_definitions code="at0130"><items id="description">Die maximale, kumulative Menge an Medikamenten, die innerhalb des zulässigen Zeitraums verabreicht werden sollte.</items><items id="text">Höchstmenge</items></term_definitions><term_definitions code="at0132"><items id="description">Erlaubnis zum Ersatz durch ein bioäquivalentes Arzneimittel.</items><items id="text">Substitutionsanweisung</items></term_definitions><term_definitions code="at0139"><items id="description">Ein Indikator wie dringlich das verordnete Arzneimittel abgegeben werden soll.</items><items id="text">Priorität</items></term_definitions><term_definitions code="at0143"><items id="description">Strukturierte Angaben über das gesamte Medikament, einschließlich Stärke, Form und Inhaltsstoffe.</items><items id="text">Angaben zur Medikation</items></term_definitions><term_definitions code="at0148"><items id="description">Gesamttherapeutischer Zweck des verordneten Arzneimittels.</items><items id="text">Therapiezweck</items></term_definitions><term_definitions code="at0150"><items id="description">Angaben zur täglichen Gesamtmenge des verordneten Arzneimittels, das verabreicht werden soll.</items><items id="text">Tägliche effektive Gesamtdosis</items></term_definitions><term_definitions code="at0151"><items id="description">Die Gesamtmenge des Arzneimittels, die bei bestimmungsgemäßer Verabreichung täglich angewendet wird.</items><items id="text">Tägliche Gesamtdosis</items></term_definitions><term_definitions code="at0154"><items id="description">Der Grund warum eine Substitution des verordneten Arzneimittels nicht zulässig ist.</items><items id="text">Ablehnungsgrund der Substitution</items></term_definitions><term_definitions code="at0155"><items id="description">Das Datum, ab dem das verordnete Arzneimittel zum ersten Mal abgegeben werden darf.</items><items id="text">Beginn der Abgabe</items></term_definitions><term_definitions code="at0161"><items id="description">Das Datum, ab dem das Rezept für die legale Abgabe des Arzneimittels nicht mehr gültig ist.</items><items id="text">Ablaufdatum der Abgabe</items></term_definitions><term_definitions code="at0162"><items id="description">Der Grund für eine Überschreitung der klinischen Sicherheit oder maximalen Dosis.</items><items id="text">Grund der Überschreitung</items></term_definitions><term_definitions code="at0165"><items id="description">Beschreibung des Grundes für die Erfassung einer täglichen effektiven Gesamtdosis.</items><items id="text">Zweck</items></term_definitions><term_definitions code="at0166"><items id="description">Zusätzliche strukturierte Angaben über verordnetes Arzneimittel, die nicht in anderen Feldern erfasst wurden.</items><items id="text">Zusätzliche Information</items></term_definitions><term_definitions code="at0167"><items id="description">Zusätzliche Kommentare über die Medikamentenverordnung, die nicht in anderen Feldern erfasst wurden.</items><items id="text">Kommentar</items></term_definitions><term_definitions code="at0168"><items id="description">Die Substitution des Arzneimittels mit einem bioequivalenten Arzneimittel ist erlaubt.</items><items id="text">Erlaubt</items></term_definitions><term_definitions code="at0169"><items id="description">Die Substitution des Arzneimittels mit einem bioequivalenten Arzneimittel ist nicht erlaubt.</items><items id="text">Nicht erlaubt</items></term_definitions><term_definitions code="at0170"><items id="description">Weitere detaillierte Angaben zu den Anweisungen zur Abgabe.</items><items id="text">Details der Abgabe</items></term_definitions><term_definitions code="at0171"><items id="description">Ein bekanntes oder anerkanntes Sicherheitsproblem, das für dieses Medikament gilt, wie z. B. eine Allergie, ein Warnhinweis zur Vervielfältigung von Arzneimitteln oder eine Kontraindikation. Dieses Element wird normalerweise nur aufgezeichnet, wenn dieser Sicherheitshinweis außer Kraft gesetzt wird.</items><items id="text">Hinweis zur überschrittenen Sicherheitsgrenze</items></term_definitions><term_definitions code="at0173"><items id="description">Freitextbeschreibung eines bestimmten Teils der Gesamtanweisung.</items><items id="text">Beschreibung der spezifischen Anweisungen</items></term_definitions><term_definitions code="at0174"><items id="description">Eine Beschreibung der Begründung für die Berechnung einer Dosismenge oder Verabreichungsrate, wenn dies von einem anderen Faktor abhängt.</items><items id="text">Begründung der Dosis</items></term_definitions><term_definitions code="at0177"><items id="description">Details zu strukturierten Dosis- und Zeitangaben</items><items id="text">Strukturierte Dosis- und Zeitangaben</items></term_definitions><term_definitions code="at0178"><items id="description">Überschreiten eines bekannten oder anerkannten Sicherheitshinweis des Medikaments, wie z. B. eine Allergie, eine Warnung vor Drogenmissbrauch oder eine Kontraindikation.</items><items id="text">Sicherheitsgrenze überschritten</items></term_definitions><term_definitions code="at0179"><items id="description">Empfehlung an die zukünftigen Verordner/Abgeber über die fortlaufende, langjährige Verordnung.</items><items id="text">Klinische Leitlinie</items></term_definitions></children>
