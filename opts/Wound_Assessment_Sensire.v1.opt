                <archetype_id><value>openEHR-EHR-ACTION.health_education.v1</value></archetype_id><term_definitions code="at0000"><items id="description">Kommunikation zur Verbesserung der Gesundheitskompetenz und der Lebenskompetenzen.</items><items id="text">Gesundheitsberatung</items></term_definitions><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0002"><items id="description">Identifizierung des Themas der Gesundheitsberatung mit Namen.</items><items id="text">Thema</items></term_definitions><term_definitions code="at0003"><items id="description">Beschreibung der Gesundheitsberatung.</items><items id="text">Beschreibung</items></term_definitions><term_definitions code="at0004"><items id="description">Methode, mit der die Gesundheitsberatung der Person erteilt wurde.</items><items id="text">Methode</items></term_definitions><term_definitions code="at0006"><items id="description">Beratung ist geplant, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</items><items id="text">Beratung geplant</items></term_definitions><term_definitions code="at0007"><items id="description">Termin für die Beratung festgelegt.</items><items id="text">Beratung terminiert</items></term_definitions><term_definitions code="at0008"><items id="description">Beratungssitzung oder Material angeboten.</items><items id="text">Beratung angeboten</items></term_definitions><term_definitions code="at0010"><items id="description">Grund, warum der Pathway-Schritt für die identifizierte Gesundheitsberatung durchgeführt wurde.</items><items id="text">Grund</items></term_definitions><term_definitions code="at0013"><items id="description">Alle geplanten Beratungsaktivitäten wurden erfolgreich abgeschlossen.</items><items id="text">Beratung abgeschlossen</items></term_definitions><term_definitions code="at0014"><items id="description">Die Beratung wurde noch vor Beginn verschoben.</items><items id="text">Beratung verschoben</items></term_definitions><term_definitions code="at0015"><items id="description">Die Beratung wurde noch vor Beginn abgesagt.</items><items id="text">Beratung abgesagt</items></term_definitions><term_definitions code="at0016"><items id="description">Die Beratungssitzungen wurde vor Abschluss abgebrochen.</items><items id="text">Beratung nicht abgeschlossen</items></term_definitions><term_definitions code="at0017"><items id="description">Geplante Beratungssitzungen wurden nach Beginn ausgesetzt.</items><items id="text">Beratung unterbrochen</items></term_definitions><term_definitions code="at0018"><items id="description">Beratung wurde empfohlen, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</items><items id="text">Beratung empfohlen</items></term_definitions><term_definitions code="at0019"><items id="description">Beschreibung des Ergebnisses der Gesundheitsberatung.</items><items id="text">Ergebnis</items></term_definitions><term_definitions code="at0020"><items id="description">Nummer der Beratungssitzung in einem Kurs mit mehreren Sitzungen.</items><items id="text">Sitzungsnummer</items></term_definitions><term_definitions code="at0021"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0023"><items id="description">Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</items><items id="text">Erweiterung</items></term_definitions><term_definitions code="at0025"><items id="description">Strukturierte Angaben zum Beratungsmaterial, das der Person zur Verfügung gestellt wird.</items><items id="text">Material</items></term_definitions><term_definitions code="at0026"><items id="description">Datum und / oder Uhrzeit der Durchführung der Beratungsaktivität.</items><items id="text">Termin Datum/Uhrzeit</items></term_definitions><term_definitions code="at0027"><items id="description">Zusätzliche Beschreibung über den Aktivitäts- oder Pflegeschritt, der in anderen Feldern nicht erfasst wurde.</items><items id="text">Kommentar</items></term_definitions><term_definitions code="at0028"><items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Beratung anfordert.</items><items id="text">Anforderer</items></term_definitions><term_definitions code="at0029"><items id="description">Angaben zu dem Gesundheitsdienstleister oder der Organisation, die die Anforderung zur Beratung erhalten hat.</items><items id="text">Empfänger</items></term_definitions><term_definitions code="at0030"><items id="description">Die lokale ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Beratung anfordert, zugewiesen wurde.</items><items id="text">Anforderer ID</items></term_definitions><term_definitions code="at0031"><items id="description">Die ID, die dem Antrag von dem Gesundheitsdienstleister oder der Organisation zugewiesen wurde, die den Antrag auf Beratung erhalten hat. Dies wird auch als Filler Order Identifier bezeichnet.</items><items id="text">Empfänger ID</items></term_definitions><term_definitions code="at0032"><items id="description">Empfänger der Gesundheitsberatung.</items><items id="text">Beratungsempfänger</items></term_definitions><term_definitions code="at0033"><items id="description">Zusätzliche strukturierte Angaben zur Gesundheitsberatung.</items><items id="text">Zusätzliche Angaben</items></term_definitions><term_definitions code="at0034"><items id="description">Angaben zum Dolmetscher.</items><items id="text">Dolmetscher</items></term_definitions><term_definitions code="at0035"><items id="description">Der klinische Grund für die Beratungsaktivität.</items><items id="text">Klinische Indikation</items></term_definitions></children>
