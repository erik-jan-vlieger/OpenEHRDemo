                <archetype_id><value>openEHR-EHR-EVALUATION.contraindication.v1</value></archetype_id><term_definitions code="at0000"><items id="description">Et klinisk tiltak (for eksempel - men ikke begrenset til, en behandling, en prøve eller prosedyre) som ikke må utføres på pasienten på grunn av sannsynlighet eller mulighet for at individet kan påføres skade.</items><items id="text">Kontraindikasjon</items></term_definitions><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0002"><items id="description">Navnet på den kliniske intervensjonen eller type tiltak som ikke bør utføres. For eksempel - men ikke begrenset til, en behandling, en prøve eller prosedyre.</items><items id="text">Kontraindisert intervensjon</items></term_definitions><term_definitions code="at0003"><items id="description">Fritekstbeskrivelse som forklarer forholdet mellom "Klinisk indikasjon" og "Kontraindisert intervensjon".</items><items id="text">Rasjonale</items></term_definitions><term_definitions code="at0004"><items id="description">Dato da kontraindikasjonen sist ble oppdatert.</items><items id="text">Sist oppdatert</items></term_definitions><term_definitions code="at0006"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0007"><items id="description">En indikasjon av potensiale for kritisk organskade eller livstruende konsekvenser.</items><items id="text">Kritikalitet</items></term_definitions><term_definitions code="at0008"><items id="description">Ytterligere informasjon om kontraindikasjonen, som ikke er fanget i andre felt.</items><items id="text">Kommentar</items></term_definitions><term_definitions code="at0009"><items id="description">Dato for neste kliniske evaluering.</items><items id="text">Dato for evaluering</items></term_definitions><term_definitions code="at0010"><items id="description">Utførelse av "Kontraindisert intervensjon" vil sannsynligvis ikke resultere i kritisk organskade eller livstruende konsekvenser for individet eller familiemedlemmet. Fremtidig eksponering for den identifiserte intervensjonen bør regnes som en relativ kontraindikasjon under ordinære kliniske omstendigheter.</items><items id="text">Lav</items></term_definitions><term_definitions code="at0011"><items id="description">Utførelse av "Kontraindisert intervensjon" kan resultere i kritisk organskade eller livstruende konsekvenser. Fremtidig eksponering for den identifiserte intervensjonen bør regnes som en absolutt kontraindikasjon under ordinære kliniske omstendigheter.</items><items id="text">Høy</items></term_definitions><term_definitions code="at0012"><items id="description">Umulig å vurdere med tilgjengelig informasjon.</items><items id="text">Ubestemt</items></term_definitions><term_definitions code="at0013"><items id="description">Kategorisering av "Kontraindisert intervensjon".</items><items id="text">Kategori</items></term_definitions><term_definitions code="at0014"><items id="description">Påstand om hvor sikkert det er at individet har en fremtidig skaderisiko på grunn "Kontraindisert intervensjon".</items><items id="text">Status</items></term_definitions><term_definitions code="at0015"><items id="description">En lav grad av klinisk sikkerhet om utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</items><items id="text">Mistenkt</items></term_definitions><term_definitions code="at0016"><items id="description">En rimelig grad av klinisk sikkerhet at utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</items><items id="text">Sannsynlig</items></term_definitions><term_definitions code="at0017"><items id="description">En stor grad av klinisk sikkerhet at utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</items><items id="text">Bekreftet</items></term_definitions><term_definitions code="at0018"><items id="description">Den tidligere påstanden om at individet ikke bør eksponeres for "Kontraindisert intervensjon" er klinisk revurdert og er ikke lenger vurdert som en aktiv risiko.</items><items id="text">Opphørt</items></term_definitions><term_definitions code="at0019"><items id="description">Den tidligere påstanden om at individet ikke bør eksponeres for "Kontraindisert intervensjon" er avvist med høy grad av klinisk sikkerhet ved testing.</items><items id="text">Avkreftet</items></term_definitions><term_definitions code="at0020"><items id="description">Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.</items><items id="text">Tilleggsinformasjon</items></term_definitions><term_definitions code="at0021"><items id="description">Den kliniske årsaken til at den identifiserte "Kontraindisert intervensjon" ikke skal benyttes eller utføres.</items><items id="text">Klinisk indikasjon</items></term_definitions><term_definitions code="at0022"><items id="description">Dato/Tid når kontraindikasjonen blir aktiv.</items><items id="text">Gyldighetsperiode start</items></term_definitions><term_definitions code="at0023"><items id="description">Dato/Tid når kontraindikasjonen blir inaktiv.</items><items id="text">Gyldighetsperiode slutt</items></term_definitions></children>
        </attributes>
    <archetype_id><value>openEHR-EHR-COMPOSITION.encounter.v1</value></archetype_id><template_id><value>wound_assessment_sensire</value></template_id><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0002"><items id="description">*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</items><items id="text">Extensie</items></term_definitions><term_definitions code="id1"><items id="description">Contactmoment voor wondzorg volgens het Algemeen Wondprotocol Sensire.</items><items id="text">Wondconsult Sensire</items></term_definitions><term_definitions code="id2"><items id="description">Diagnose en classificatie van de wond.</items><items id="text">Wonddiagnose</items></term_definitions><term_definitions code="id3"><items id="description">Lichamelijk onderzoek van de wond volgens TIME-framework.</items><items id="text">Wondinspectie (TIME)</items></term_definitions><term_definitions code="id4"><items id="description">Temperatuurmeting bij infectieverdenking.</items><items id="text">Lichaamstemperatuur</items></term_definitions><term_definitions code="id5"><items id="description">Reiniging, debridement of verband aanleggen.</items><items id="text">Procedure</items></term_definitions><term_definitions code="id6"><items id="description">Toediening van pijnmedicatie.</items><items id="text">Pijnmedicatie</items></term_definitions><term_definitions code="id7"><items id="description">Gezondheidsvoorlichting specifiek voor DM-patiënten.</items><items id="text">DM-voorlichting</items></term_definitions><term_definitions code="id8"><items id="description">Order voor lokaal of systemisch antibacterieel middel.</items><items id="text">Antibacterieel beleid</items></term_definitions><term_definitions code="id9"><items id="description">Order voor verbandmateriaal.</items><items id="text">Verbandorder</items></term_definitions><term_definitions code="id10"><items id="description">Verwijzing naar de vakgroep wondzorg bij stagnatie.</items><items id="text">Verwijzing vakgroep</items></term_definitions><term_definitions code="id11"><items id="description">Zorgplan voor wondbehandeling.</items><items id="text">Wondplan</items></term_definitions><term_definitions code="id12"><items id="description">Klinische samenvatting.</items><items id="text">Samenvatting</items></term_definitions><term_definitions code="id13"><items id="description">Contra-indicaties voor debridement.</items><items id="text">Contra-indicatie debridement</items></term_definitions><term_definitions code="at0000"><items id="description">Contactmoment voor wondzorg volgens het Algemeen Wondprotocol Sensire.</items><items id="text">Wondconsult Sensire</items></term_definitions></definition>
