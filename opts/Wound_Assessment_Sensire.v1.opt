                <archetype_id><value>openEHR-EHR-OBSERVATION.body_temperature.v2</value></archetype_id><term_definitions code="at0000"><items id="description">Een meting van de lichaamstemperatuur, wat een surrogaat is van de kerntemperatuur van het lichaam van een individu.</items><items id="text">Lichaamstemperatuur</items></term_definitions><term_definitions code="at0001"><items id="description">*@ internal @(en)</items><items id="text">*Tree(en)</items></term_definitions><term_definitions code="at0002"><items id="description">*@ internal @(en)</items><items id="text">*History(en)</items></term_definitions><term_definitions code="at0003"><items id="description">Standaard, ongespecificeerd punt in de tijd, of een interval gebeurtenis, die expliciet gedefinieerd kan worden in een template, of terwijl de applicatie loopt.</items><items id="text">Elke gebeurtenis</items></term_definitions><term_definitions code="at0004"><items id="description">De gemeten lichaamstemperatuur (als surrogaat van de kerntemperatuur van het lichaam).</items><items id="text">Temperatuur</items></term_definitions><term_definitions code="at0020"><items id="description">*@ internal @(en)</items><items id="text">*Protocol(en)</items></term_definitions><term_definitions code="at0021"><items id="description">Eenvoudige beschrijving van de locatie van de meting.</items><items id="text">Locatie van de meting</items></term_definitions><term_definitions code="at0022"><items id="description">Temperatuur is gemeten in de mond.</items><items id="text">Mond</items></term_definitions><term_definitions code="at0023"><items id="description">Temperatuur is gemeten in de externe gehoorgang.</items><items id="text">Gehoorgang</items></term_definitions><term_definitions code="at0024"><items id="description">Temperatuur is gemeten op de huid van de axilla met de arm langs het lichaam naar beneden.</items><items id="text">Axilla</items></term_definitions><term_definitions code="at0025"><items id="description">Temperatuur gemeten in het rectum.</items><items id="text">Rectum</items></term_definitions><term_definitions code="at0026"><items id="description">De temperatuur is gemeten in de nasopharynx.</items><items id="text">Nasopharynx</items></term_definitions><term_definitions code="at0027"><items id="description">De temperatuur is gemeten in de urineblaas.</items><items id="text">Urineblaas</items></term_definitions><term_definitions code="at0028"><items id="description">Temperatuur is gemeten in het vaatstelsel.</items><items id="text">Intravasculair</items></term_definitions><term_definitions code="at0029"><items id="description">Informatie over de toestand van de patiënt.</items><items id="text">Toestand</items></term_definitions><term_definitions code="at0030"><items id="description">In hoeverre het individu ontbloot is op het moment van meten.</items><items id="text">Ontbloting</items></term_definitions><term_definitions code="at0031"><items id="description">Geen kleding, onderkleding of bedekking.</items><items id="text">Naakt</items></term_definitions><term_definitions code="at0032"><items id="description">De persoon is bedekt door minder kleding dan gepast zou zijn voor de omgevings omstandigheden.</items><items id="text">Beperkte kleding.</items></term_definitions><term_definitions code="at0033"><items id="description">De persoon is bedekt door een hoeveelheid kleding die gepast is voor de omgevingsomstandigheden.</items><items id="text">Gepaste kleding</items></term_definitions><term_definitions code="at0034"><items id="description">De persoon is bedekt door meer kleding vergeleken dan passend is voor de omgevingsomstandigheden.</items><items id="text">Extra kleding</items></term_definitions><term_definitions code="at0041"><items id="description">Verhalende beschrijving van de omstandigheden waaronder het individu geplaatst is die invloed hebben op de lichaamstemperatuur.</items><items id="text">Beschrijving van de temperatuur stress</items></term_definitions><term_definitions code="at0043"><items id="description">De temperatuur is gemeten op de ontblote huid.</items><items id="text">Huid</items></term_definitions><term_definitions code="at0051"><items id="description">Temperatuur is gemeten in de de vagina.</items><items id="text">Vagina</items></term_definitions><term_definitions code="at0054"><items id="description">Temperatuur is gemeten in de oesophagus.</items><items id="text">Oesophagus</items></term_definitions><term_definitions code="at0055"><items id="description">Temperatuur is gemeten in de liesplooi tussen het been en de buikwand.</items><items id="text">Liesplooi</items></term_definitions><term_definitions code="at0056"><items id="description">Gegevens over de omgevingsfactoren op het moment van de meten van de temperatuur.</items><items id="text">Omgevingsfactoren</items></term_definitions><term_definitions code="at0057"><items id="description">Gegevens over de inspanning van de persoon op het moment van de meting van de temperatuur.</items><items id="text">Inspannign</items></term_definitions><term_definitions code="at0059"><items id="description">Gegevens van het apparaat dat gebruikt is voor het meten van de lichaamstemperatuur.</items><items id="text">Apparaat</items></term_definitions><term_definitions code="at0060"><items id="description">Temperatuur is gemeten op de slaap, boven de arteria temporalis superficialis.</items><items id="text">Slaap</items></term_definitions><term_definitions code="at0061"><items id="description">De temperatuur is gemeten op het voorhoofd.</items><items id="text">Voorhoofd</items></term_definitions><term_definitions code="at0062"><items id="description">Aanvullende informatie benodigd voor het ondervangen van lokale eisen of om te verbinden met andere referentiemodellen/formalismen.</items><items id="text">Uitbreiding</items></term_definitions><term_definitions code="at0063"><items id="description">Extra opmerking over de lichaamstemperatuurmeting die niet gedekt wordt door andere velden.</items><items id="text">Opmerking</items></term_definitions><term_definitions code="at0064"><items id="description">Gestructureerde gegevens over de locatie van meting.</items><items id="text">Gestructureerde meetlocatie</items></term_definitions><term_definitions code="at0065"><items id="description">Huidige dag van de menstruele cyclus.</items><items id="text">Dag van de menstruele cyclus</items></term_definitions><term_definitions code="at0066"><items id="description">Additionele problemen of factoren die invloed kunnen hebben op de meting van de lichaamstemperatuur, niet gedekt door andere velden.</items><items id="text">Beïnvloedende factoren</items></term_definitions></children>
