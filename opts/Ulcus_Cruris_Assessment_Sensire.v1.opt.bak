    <component_terminologies archetype_id="openEHR-EHR-OBSERVATION.ankle_brachial_pressure_index.v0" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="en">
            <items id="at0000">
                <description>Ankle-brachial pressure index (ABPI).</description>
