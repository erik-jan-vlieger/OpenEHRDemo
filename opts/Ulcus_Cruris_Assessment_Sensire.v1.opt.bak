            </items>
            <items id="at0009">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0010">
                <description>*Details about any device used during the physical examination.(en)</description>
                <text>*Device Details(en)</text>
            </items>
            <items id="at0011">
                <description>*Any additional narrative comment not covered by other elements.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0012">
                <description>**(en)</description>
                <text>*Cluster(en)</text>
            </items>
            <items id="at0013">
