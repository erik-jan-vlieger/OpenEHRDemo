            <items id="at0004">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>从医疗保健服务提供着的角度，手工综合并记录关于患者的叙述型摘要或概述，且带有或没有相关联的解释。</description>
                <text>临床提要</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*List(en)</text>
            </items>
            <items id="at0002">
                <description>对于临床所见（临床发现）进行的概括、评估、总结或评价。</description>
