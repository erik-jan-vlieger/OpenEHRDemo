                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="sl">
            <items id="at0000">
                <description>Za dokumentiranje ugotovitev/znakov fizikalnega pregleda subjekta</description>
                <text>Ugotovitve fizičnega pregleda</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Event Series(en)</text>
            </items>
            <items id="at0002">
                <description>Privzeta, nespecificirana točka v času ali intervalni dogodek, ki je lahko eksplicitno definiran v predlogi ali ob izvajanju.</description>
                <text>Dogodek</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
                <description>Opis splošnih ugotovitev opaženih med fizičnim pregledom pacienta.</description>
                <text>Opis</text>
            </items>
            <items id="at0005">
                <description>Strukturirane podrobnosti fizičnega pregleda.</description>
                <text>Podrobnosti pregleda</text>
            </items>
            <items id="at0006">
                <description>Posamezna beseda, besedna zveza ali kratek opis, ki predstavlja klinični pomen in pomembnost ugotovitev fizičnega pregleda.</description>
                <text>Interpretacija</text>
            </items>
            <items id="at0007">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0008">
                <description>Opis morebitnih naključnih dejavnikov, ki so lahko prispevali k ugotovitvam fizičnega pregleda.</description>
                <text>Moteči dejavniki</text>
            </items>
            <items id="at0009">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0010">
                <description>Podrobnosti o katerikoli napravi, uporabljeni med fizičnim pregledom.</description>
                <text>Podrobnosti naprave</text>
            </items>
            <items id="at0011">
                <description>Dodatni zapisi splošnih ugotovitev fizičnega pregleda, ki niso zajete v drugih poljih.</description>
                <text>Komentar</text>
            </items>
            <items id="at0012">
                <description>Dodatne informacije, potrebne za zajemanje lokalne vsebine ali za uskladitev z drugimi referenčnimi modeli/formalizmi.</description>
                <text>Razširitev</text>
            </items>
            <items id="at0013">
                <description>Položaj telesa preiskovanca med pregledom.</description>
                <text>Položaj</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Findings observed during the physical examination of a subject of care.</description>
                <text>Physical examination findings</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.</description>
                <text>Any event</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Narrative description of the overall findings observed during a physical examination of a patient.</description>
                <text>Description</text>
            </items>
            <items id="at0005">
                <description>Structured details of the physical examination.</description>
                <text>Examination detail</text>
            </items>
            <items id="at0006">
                <description>Single word, phrase or brief description which represents the clinical meaning and significance of the physical examination findings.</description>
                <text>Interpretation</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Description of any incidental factors that may have contributed to the physical examination findings.</description>
                <text>Confounding factors</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Details about any device used during the physical examination.</description>
                <text>Device Details</text>
            </items>
            <items id="at0011">
                <description>Additional narrative about the overall physical examination findings not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0012">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0013">
                <description>The body position of the subject during the examination.</description>
                <text>Position</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>对于特定主体对象进行体格检查过程中所获得的发现。</description>
                <text>体格检查发现</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>默认值，未加具体说明的，而可以在特定模板中或在运行时加以明确定义的时刻（时间点）型或时段（时间段、时间区间）型事件。</description>
                <text>任何事件</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>关于特定患者的体格检查过程中所观察到的全部发现的叙述型描述。</description>
                <text>描述</text>
            </items>
            <items id="at0005">
                <description>体格检查的结构化细节。</description>
                <text>检查细节</text>
            </items>
            <items id="at0006">
                <description>用于表示体格检查发现的临床含义和意义的单个词语、短语或简要描述。</description>
                <text>解释</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>关于可能对体格检查发现做出了贡献的任何偶然因素的描述。</description>
                <text>干扰因素</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>关于体格检查过程中所使用的任何装置的细节。</description>
                <text>装置细节</text>
            </items>
            <items id="at0011">
                <description>其他字段之中并未采集的关于全部体格检查发现的叙述型注释。</description>
                <text>注释</text>
            </items>
            <items id="at0012">
                <description>采集本地内容或者与其他参考模型/形式化体系进行映射时所需的额外信息。</description>
                <text>扩展</text>
            </items>
            <items id="at0013">
                <description>*The body position of the subject during the examination.(en)</description>
                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Hallazgos observados durante la examinación física del paciente</description>
                <text>Hallazgos de la examinación física</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</description>
                <text>*Any event(en)</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Descripción narrativa del total de los hallazgos durante la examinación física del paciente</description>
                <text>Descripción</text>
            </items>
            <items id="at0005">
                <description>Detalles estructurados de la examinación física</description>
                <text>Detalles de la examinación</text>
            </items>
            <items id="at0006">
                <description>Descripción corta que representa el significado clínico de los hallazgos</description>
                <text>Interpretación</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descripción de los factores que pueden haber obstruido o dificultado la examinación física y los hallazgos</description>
                <text>Factores de confusión</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalles sobre cualquier dispositivo utilizado durante la examinación física</description>
                <text>Detalles del dispositivo</text>
            </items>
            <items id="at0011">
                <description>Información narrativa adicional sobre los hallazgos durante la examinación física</description>
                <text>Comentario</text>
            </items>
            <items id="at0012">
                <description>Información adicional requerida para registrar contenido local o alinear con otros modelos o formalismos</description>
                <text>Extensión</text>
            </items>
            <items id="at0013">
                <description>*The body position of the subject during the examination.(en)</description>
                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Troballes observades durant l'examen físic del pacient.</description>
                <text>Troballes de l'exploració física</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Esdeveniment predeterminat, en un interval de temps o moment no específic, que es pot definir de forma expressa en una plantilla o en temps d'execució.</description>
                <text>Qualsevol esdeveniment</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Descripció narrativa del total de les troballes durant l'examen físic del pacient.</description>
                <text>Descripció</text>
            </items>
            <items id="at0005">
                <description>Detalls estructurats de l'examen físic.</description>
                <text>Detalls de l'examen</text>
            </items>
            <items id="at0006">
                <description>Una sola paraula, frase o descripció breu que englobi el significat clínic i la importància de les troballes de l'examen físic.</description>
                <text>Interpretació</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descripció dels factors que puguin haver obstruït o dificultat les troballes de l'examen físic.</description>
                <text>Factors de confusió</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalls sobre qualsevol dispositiu utilitzat durant l'examen físic.</description>
                <text>Detalls del dispositiu</text>
            </items>
            <items id="at0011">
                <description>Informació narrativa addicional sobre les troballes durant l'examen físic no registrats a altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0012">
                <description>Informació addicional requerida per registrar contingut local o alinear amb altres models o formalismes.</description>
                <text>Ampliació</text>
            </items>
            <items id="at0013">
                <description>Posició del pacient durant l'examen.</description>
                <text>Posició</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-ACTION.procedure.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Eine klinische Aktivität, die zur Früherkennung, Untersuchung, Diagnose, Heilung, Therapie, Bewertung oder in Hinsicht auf palliative Maßnahmen durchgeführt wird.</description>
                <text>Prozedur</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identifizierung der Prozedur über den Namen.</description>
                <text>Name der Prozedur</text>
            </items>
            <items id="at0003">
                <description>Strukturierte Informationen über die Prozedur.</description>
                <text>Details zur Prozedur</text>
            </items>
            <items id="at0004">
                <description>Die Prozedur, die durchgeführt werden soll, ist geplant.</description>
                <text>Geplante Prozedur</text>
            </items>
            <items id="at0005">
                <description>Zusätzliche Beschreibung der Aktivität oder der "Pathway"-Verlaufsschritte, die in anderen Bereichen nicht erfasst wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0006">
                <description>Details zu allen Komplikationen, die sich aus der Prozedur ergeben haben.</description>
                <text>Komplikationen</text>
            </items>
            <items id="at0007">
                <description>Der Auftrag für die Prozedur wurde versendet.</description>
                <text>Auftrag für Prozedur versendet</text>
            </items>
            <items id="at0014">
                <description>Grund, warum die angegebene Aktivität für diese Prozedur durchgeführt wurde.</description>
                <text>Grund</text>
            </items>
            <items id="at0034">
                <description>Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Prozedur geplant" (at0004), das korrekt mit dem Status "geplant" verknüpft ist.</description>
                <text>X - Prozedur geplant</text>
            </items>
            <items id="at0035">
                <description>Dieses Element ist veraltet, da es fälschlicherweise mit dem Status "initial" verknüpft war - verwenden Sie das neue Element "Geplante Prozedur" (at0007), das korrekt mit dem Status "geplant" verknüpft ist.</description>
                <text>X - Auftrag für Prozedur versendet</text>
            </items>
            <items id="at0036">
                <description>Ein Termin für die Prozedur wurde geplant.</description>
                <text>geplanter Termin der Prozedur</text>
            </items>
            <items id="at0038">
                <description>Die Prozedur wurde verschoben.</description>
                <text>Prozedur verschoben</text>
            </items>
            <items id="at0039">
                <description>Die geplante Prozedur wurde vor Beginn storniert.</description>
                <text>Prozedur storniert</text>
            </items>
            <items id="at0040">
                <description>Die Prozedur wurde unterbrochen.</description>
                <text>Prozedur unterbrochen</text>
            </items>
            <items id="at0041">
                <description>Die Prozedur wurde abgebrochen.</description>
                <text>Prozedur abgebrochen</text>
            </items>
            <items id="at0043">
                <description>Die Prozedur wurde durchgeführt und alle damit verbundenen klinischen Aktivitäten wurden beendet.</description>
                <text>Prozedur beendet</text>
            </items>
            <items id="at0047">
                <description>Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde durchgeführt.</description>
                <text>Prozedur durchgeführt</text>
            </items>
            <items id="at0048">
                <description>Ausgang der durchgeführten Prozedur.</description>
                <text>Ausgang</text>
            </items>
            <items id="at0049">
                <description>Beschreibung der Prozedur, angepasst an den "Pathway"-Verlaufsschritt.</description>
                <text>Beschreibung</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>Die lokale ID, die dem Auftrag vom Gesundheitsdienstleister oder der Organisation, die die Leistung anfordert, zugewiesen wurde.</description>
                <text>Auftragskennung des Antragstellers</text>
            </items>
            <items id="at0055">
                <description>Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistung anfordert.</description>
                <text>Antragsteller</text>
            </items>
            <items id="at0056">
                <description>Die ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Leistungsanforderung erhält, zugewiesen wurde. Dies wird auch als "Filler Order Identifier" bezeichnet.</description>
                <text>Auftragskennung des Empfängers</text>
            </items>
            <items id="at0057">
                <description>Angaben über den Gesundheitsdienstleister oder die Organisation, die die Leistungsanforderung erhält.</description>
                <text>Empfänger</text>
            </items>
            <items id="at0058">
                <description>Dringlichkeit der Prozedur.</description>
                <text>Dringlichkeit</text>
            </items>
            <items id="at0060">
                <description>Das Datum und/oder die Uhrzeit, an dem die gesamte Prozedur, oder die letzte Komponente einer mehrstufigen Prozedur, beendet wurde.</description>
                <text>Enddatum/-uhrzeit</text>
            </items>
            <items id="at0061">
                <description>Die Gesamtdauer der Prozedur - diese kann sich aus der aktiven Phase und der Phase, in der die Prozedur unterbrochen wurde, ergeben.</description>
                <text>Gesamtdauer</text>
            </items>
            <items id="at0062">
                <description>Multimediale Darstellung der durchgeführten Prozedur.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0063">
                <description>Anatomische Lokalisation, an der die Prozedur durchgeführt wird.</description>
                <text>Körperstelle</text>
            </items>
            <items id="at0064">
                <description>Zusätzliche Informationen, die erforderlich sind, um lokale Inhalte zu erfassen oder mit anderen Referenzmodellen/Formalismen abzugleichen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0065">
                <description>Identifizierung der spezifischen Prozedurmethode oder -technik.</description>
                <text>Methode</text>
            </items>
            <items id="at0066">
                <description>Das Datum und/oder die Uhrzeit für die die Prozedur angesetzt ist.</description>
                <text>Geplantes Datum/Uhrzeit</text>
            </items>
            <items id="at0067">
                <description>Die Art der Prozedur.</description>
                <text>Art der Prozedur</text>
            </items>
            <items id="at0068">
                <description>Die Prozedur, oder eine Subprozedur in einem mehrstufigen Vorgehen, wurde begonnen.</description>
                <text>Prozedur begonnen</text>
            </items>
            <items id="at0069">
                <description>Schwierigkeiten oder Probleme, die während der Durchführung der Prozedur aufgetreten sind.</description>
                <text>Schwierigkeiten bei der Durchführung der Prozedur</text>
            </items>
            <items id="at0070">
                <description>Der klinische oder prozessbezogene Grund für die Prozedur.</description>
                <text>Indikation</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="ru">
            <items id="at0000">
                <description>*A clinical activity carried out for screening, investigative, diagnostic, curative, therapeutic, evaluative or palliative purposes.(en)</description>
                <text>*Procedure(en)</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0002">
                <description>*Identification of the procedure by name.(en)</description>
                <text>*Procedure name(en)</text>
            </items>
            <items id="at0003">
                <description>*Structured information about the procedure. Use to capture detailed, structured information about anatomical location, method &amp; technique, equipment used, devices implanted, results, findings etc.(en)</description>
                <text>*Procedure detail(en)</text>
            </items>
            <items id="at0004">
                <description>*</description>
                <text>*Procedure planned (en)</text>
            </items>
            <items id="at0005">
                <description>*Additional narrative about the activity or care pathway step not captured in other fields.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0006">
                <description>*Details about any complication arising from the procedure.(en)</description>
                <text>*Complication(en)</text>
            </items>
            <items id="at0007">
                <description>*</description>
                <text>*Procedure request sent (en)</text>
            </items>
            <items id="at0014">
                <description>*Reason that the activity or care pathway step for the identified procedure was carried out.(en)</description>
                <text>*Reason(en)</text>
            </items>
            <items id="at0034">
                <description>*The procedure to be undertaken is planned.(en)</description>
                <text>*Procedure planned(en)</text>
            </items>
            <items id="at0035">
                <description>*Request for procedure sent.(en)</description>
                <text>*Procedure request sent(en)</text>
            </items>
            <items id="at0036">
                <description>*The procedure has been scheduled.(en)</description>
                <text>*Procedure scheduled(en)</text>
            </items>
            <items id="at0038">
                <description>*The procedure has been postponed.(en)</description>
                <text>*Procedure postponed(en)</text>
            </items>
            <items id="at0039">
                <description>*The planned procedure has been cancelled prior to commencement.(en)</description>
                <text>*Procedure cancelled(en)</text>
            </items>
            <items id="at0040">
                <description>*The procedure has been suspended.(en)</description>
                <text>*Procedure suspended(en)</text>
            </items>
            <items id="at0041">
                <description>*The procedure has been aborted.(en)</description>
                <text>*Procedure aborted(en)</text>
            </items>
            <items id="at0043">
                <description>*The procedure has been performed and all associated clinical activities completed.(en)</description>
                <text>*Procedure completed(en)</text>
            </items>
            <items id="at0047">
                <description>*The procedure, or subprocedure in a multicomponent procedure, has been performed.(en)</description>
                <text>*Procedure performed(en)</text>
            </items>
            <items id="at0048">
                <description>*Outcome of procedure performed.(en)</description>
                <text>*Outcome(en)</text>
            </items>
            <items id="at0049">
                <description>*Narrative description about the procedure, as appropriate for the pathway step.(en)</description>
                <text>*Description(en)</text>
            </items>
            <items id="at0053">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0054">
                <description>*The local ID assigned to the order by the healthcare provider or organisation requesting the service.(en)</description>
                <text>*Requestor order identifier(en)</text>
            </items>
            <items id="at0055">
                <description>Подробности о заказчике (организации), запросившей услугу</description>
                <text>Заказчик</text>
            </items>
            <items id="at0056">
                <description>*The ID assigned to the order by the healthcare provider or organisation receiving the request for service. This is also referred to as Filler Order Identifier.(en)</description>
                <text>*Receiver order identifier(en)</text>
            </items>
            <items id="at0057">
                <description>Подробные сведение об организации, получившей заявку на выполнение процедуры</description>
                <text>Исполнитель</text>
            </items>
            <items id="at0058">
                <description>*Urgency of the procedure.(en)</description>
                <text>*Urgency(en)</text>
            </items>
            <items id="at0060">
                <description>*The date and/or time when the entire procedure, or the last component of a multicomponent procedure,  was finished.(en)</description>
                <text>*Final end date/time(en)</text>
            </items>
            <items id="at0061">
                <description>*The total amount of time taken to complete the procedure, which may include time spent during the active phase of the procedure plus time during which the procedure was suspended.(en)</description>
                <text>*Total duration(en)</text>
            </items>
            <items id="at0062">
                <description>*Mulitimedia representation of a performed procedure.(en)</description>
                <text>*Multimedia(en)</text>
            </items>
            <items id="at0063">
                <description>*Identification of the body site for the procedure.(en)</description>
                <text>*Body site(en)</text>
            </items>
            <items id="at0064">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
            <items id="at0065">
                <description>*Identification of specific method or technique for the procedure.(en)</description>
                <text>*Method(en)</text>
            </items>
            <items id="at0066">
                <description>*The date and/or time on which the procedure is intended to be performed.(en)</description>
                <text>*Scheduled date/time(en)</text>
            </items>
            <items id="at0067">
                <description>*The type of procedure.(en)</description>
                <text>*Procedure type(en)</text>
            </items>
            <items id="at0068">
                <description>*The procedure, or subprocedure in a multicomponent procedure, has been commenced.(en)</description>
                <text>*Procedure commenced(en)</text>
            </items>
            <items id="at0069">
                <description>*Difficulties or issues encountered during the procedure.(en)</description>
                <text>*Procedural difficulty(en)</text>
            </items>
            <items id="at0070">
                <description>*The clinical or process-related reason for the procedure. (en)</description>
                <text>*Indication (en)</text>
            </items>
            <items id="at0071">
                <description>Overall assessment of the impact of a health problem for the specific patient. </description>
                <text>Impact</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>En klinisk aktivitet utförd för screening-, undersökande, diagnostiska, botande, terapeutiska, utvärderande eller palliativa ändamål.</description>
                <text>Åtgärd</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Åtgärdens benämning.</description>
                <text>Benämning på åtgärd</text>
            </items>
            <items id="at0003">
                <description>Strukturerad information om åtgärden.</description>
                <text>Åtgärdsdetaljer</text>
            </items>
            <items id="at0004">
                <description>Den åtgärd som ska genomföras är planerad.</description>
                <text>Åtgärd planerad</text>
            </items>
            <items id="at0005">
                <description>Ytterligare beskrivning av processteget som inte fångas i andra fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0006">
                <description>Detaljer om eventuella komplikationer som uppstår från åtgärden.</description>
                <text>Komplikation</text>
            </items>
            <items id="at0007">
                <description>Förfrågan om åtgärd är skickad.&#13;
</description>
                <text>Förfrågan om åtgärd skickad</text>
            </items>
            <items id="at0014">
                <description>Anledning till att nytt processteg för åtgärden dokumenterats.</description>
                <text>Anledning</text>
            </items>
            <items id="at0034">
                <description>Detta steg har upphört att gälla eftersom det felaktigt var associerat med status "initial". Använd det nya steget "Åtgärd planerad" (at0004) som är korrekt associerat med status "planerad" . &#13;
</description>
                <text>X - Åtgärd planerad</text>
            </items>
            <items id="at0035">
                <description>Detta steg har upphört att gälla eftersom det felaktigt var associerat med status "initial". Använd det nya steget "Åtgärdsförfrågan skickad" (at0007) som är korrekt associerat med status "planerad".</description>
                <text>X - Förfrågan om åtgärd skickad</text>
            </items>
            <items id="at0036">
                <description>Åtgärden är bokad.</description>
                <text>Åtgärd bokad</text>
            </items>
            <items id="at0038">
                <description>Åtgärden är uppskjuten.&#13;
</description>
                <text>Åtgärd uppskjuten</text>
            </items>
            <items id="at0039">
                <description>Den planerade åtgärden är inställd.</description>
                <text>Åtgärd inställd</text>
            </items>
            <items id="at0040">
                <description>Åtgärden är pausad.</description>
                <text>Åtgärd pausad</text>
            </items>
            <items id="at0041">
                <description>Åtgärden är avbruten.&#13;
</description>
                <text>Åtgärd avbruten</text>
            </items>
            <items id="at0043">
                <description>Åtgärden och alla tillhörande kliniska aktiviteter är slutförda.</description>
                <text>Åtgärd slutförd</text>
            </items>
            <items id="at0047">
                <description>Åtgärden är utförd.</description>
                <text>Åtgärd utförd</text>
            </items>
            <items id="at0048">
                <description>Resultat av genomförd åtgärd&#13;
</description>
                <text>Resultat</text>
            </items>
            <items id="at0049">
                <description>Beskrivning av åtgärden, anpassad till det aktuella processteget.</description>
                <text>Beskrivning</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>Beställnings-ID definierat av den aktör som är avsändare av förfrågan av tjänst.</description>
                <text>Beställnings-ID hos avsändare</text>
            </items>
            <items id="at0055">
                <description>Detaljer om den aktör som efterfrågar tjänsten.</description>
                <text>Beställare</text>
            </items>
            <items id="at0056">
                <description>Beställnings-ID definierat av den aktör som tar emot förfrågan av tjänsten.</description>
                <text>Betällnings-ID hos mottagare</text>
            </items>
            <items id="at0057">
                <description>Detaljer om den aktör som tar emot förfrågan av tjänsten.</description>
                <text>Mottagare</text>
            </items>
            <items id="at0058">
                <description>Åtgärdens brådskandegrad.</description>
                <text>Brådskandegrad</text>
            </items>
            <items id="at0060">
                <description>Datumet eller det klockslag då hela åtgärden, eller den sista delåtgärden i åtgärden, slutfördes.</description>
                <text>Datum/tid för färdigställande av åtgärd</text>
            </items>
            <items id="at0061">
                <description>Den totala tid som krävs för att utföra åtgärden, vilket kan inkludera tid som tillbringats under den aktiva fasen av åtgärden plus den tid under vilken åtgärden pausades.</description>
                <text>Total varaktighet</text>
            </items>
            <items id="at0062">
                <description>Multimedierepresentation av utförd åtgärd.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0063">
                <description>Identifiering av anatomisk plats för åtgärden.</description>
                <text>Anatomisk position</text>
            </items>
            <items id="at0064">
                <description>Plats för tilläggsinformation som krävs för lokala anpassningar eller anpassning till andra referensmodeller eller formella krav.</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0065">
                <description>Identifiering av specifik metod eller teknik för åtgärden.</description>
                <text>Metod</text>
            </items>
            <items id="at0066">
                <description>Datum eller tid då åtgärden är tänkt att utföras.</description>
                <text>Bokad datum/tid</text>
            </items>
            <items id="at0067">
                <description>Typ av åtgärd</description>
                <text>Åtgärdstyp</text>
            </items>
            <items id="at0068">
                <description>Åtgärden är påbörjad.</description>
                <text>Åtgärd påbörjad</text>
            </items>
            <items id="at0069">
                <description>Svårigheter eller problem som uppstår under genomförandet av åtgärden.</description>
                <text>Svårigheter med åtgärd</text>
            </items>
            <items id="at0070">
                <description>Den kliniska eller processrelaterade orsaken till åtgärden.</description>
                <text>Indikation</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>A atividade clínica realizada para rastreamento , investigação , diagnóstico , cura , terapêutica, avaliação ou finalidade paliativos.</description>
                <text>Procedimento</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identificação do procedimento pelo nome.</description>
                <text>Nome do procedimento</text>
            </items>
            <items id="at0003">
                <description>São as informações estruturadas sobre o procedimento.</description>
                <text>Detalhes do Procedimento</text>
            </items>
            <items id="at0004">
                <description>*</description>
                <text>*Procedure planned (en)</text>
            </items>
            <items id="at0005">
                <description>Comentários adicionais sobre a atividade ou etapas não informados em outros campos.</description>
                <text>Comentários</text>
            </items>
            <items id="at0006">
                <description>Detalhes sobre alguma complicação decorrente do procedimento</description>
                <text>Complicações</text>
            </items>
            <items id="at0007">
                <description>*</description>
                <text>*Procedure request sent (en)</text>
            </items>
            <items id="at0014">
                <description>Razão pela qual a atividade ou cuidado foi identificada para que o procedimento fosse realizado.</description>
                <text>Justificativa</text>
            </items>
            <items id="at0034">
                <description>O procedimento a ser realizado é planejado</description>
                <text>Plano de procedimento</text>
            </items>
            <items id="at0035">
                <description>Pedido de procedimento enviado.</description>
                <text>Procedimento pedido enviado</text>
            </items>
            <items id="at0036">
                <description>O procedimento foi agendado.</description>
                <text>Procedimento agendado</text>
            </items>
            <items id="at0038">
                <description>O procedimento foi adiado.</description>
                <text>Procedimento adiado</text>
            </items>
            <items id="at0039">
                <description>O procedimento planejado foi cancelado antes do início.</description>
                <text>Procedimento cancelado</text>
            </items>
            <items id="at0040">
                <description>O procedimento foi suspenso.</description>
                <text>Procedimento suspenso</text>
            </items>
            <items id="at0041">
                <description>O procedimento foi abortado.</description>
                <text>Procedimento abortado</text>
            </items>
            <items id="at0043">
                <description>O procedimento foi realizado e todas as atividades clínicas associadas concluídas.</description>
                <text>Procedimento concluído</text>
            </items>
            <items id="at0047">
                <description>O procedimento, ou procedimento secundário no caso de procedimentos sequenciado, foi realizado.</description>
                <text>Procedimento realizado</text>
            </items>
            <items id="at0048">
                <description>Resultado do procedimento realizado.</description>
                <text>Resultado</text>
            </items>
            <items id="at0049">
                <description>Descrição narrativa sobre o procedimento, conforme apropriado para a etapa.</description>
                <text>Descrição</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree(en)</text>
            </items>
            <items id="at0054">
                <description>O ID local atribuído ao pedido realizado pelo profissional de saúde ou organização solicitando o serviço.</description>
                <text>Identificador do pedido do solicitante</text>
            </items>
            <items id="at0055">
                <description>Detalhes sobre o profissional ou organização de saúde que solicitou o serviço.</description>
                <text>Solicitante</text>
            </items>
            <items id="at0056">
                <description>O ID atribuído ao pedido pelo provedor de cuidados de saúde ou organização que recebe o pedido de serviço. Isto é também relacionado ao preenchimento da identificação do pedido.</description>
                <text>Identificador do pedido do destinatário</text>
            </items>
            <items id="at0057">
                <description>Detalhes sobre o profissional ou organização de saúde que recebeu o requerimento para o serviço.</description>
                <text>Destinatário</text>
            </items>
            <items id="at0058">
                <description>Urgência do procedimento.</description>
                <text>Urgência</text>
            </items>
            <items id="at0060">
                <description>A data e/ou hora , quando todo o processo , ou o último componente de um procedimento de múltiplas etapas , foi finalizada.</description>
                <text>Data final / hora</text>
            </items>
            <items id="at0061">
                <description>A quantidade total de tempo necessária para concluir o procedimento, o que pode incluir o tempo gasto durante a fase ativa do procedimento mais o tempo durante o qual o procedimento foi suspenso.</description>
                <text>Duração Total</text>
            </items>
            <items id="at0062">
                <description>Representação multimídia de um procedimento realizado.</description>
                <text>Multimidia</text>
            </items>
            <items id="at0063">
                <description>Identificação do local no corpo onde será realizado o procedimento.</description>
                <text>Localização no corpo</text>
            </items>
            <items id="at0064">
                <description>Informações adicionais necessárias para capturar o conteúdo local ou para se alinhar com outros modelos / formalismos de referência</description>
                <text>Extensão</text>
            </items>
            <items id="at0065">
                <description>Identificação do método específico ou técnica do procedimento.</description>
                <text>Método</text>
            </items>
            <items id="at0066">
                <description>A data e /ou hora em que o processo está previsto para ocorrer.</description>
                <text>Agendamento data/hora</text>
            </items>
            <items id="at0067">
                <description>O tipo do procedimento.</description>
                <text>Tipo do procedimento</text>
            </items>
            <items id="at0068">
                <description>O procedimento, ou procedimento secundário, no caso de procedimentos sequenciados, foi iniciado.</description>
                <text>Procedimento Iniciou</text>
            </items>
            <items id="at0069">
                <description>*Difficulties or issues encountered during the procedure.(en)</description>
                <text>*Procedural difficulty(en)</text>
            </items>
            <items id="at0070">
                <description>*The clinical or process-related reason for the procedure. (en)</description>
                <text>*Indication (en)</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
