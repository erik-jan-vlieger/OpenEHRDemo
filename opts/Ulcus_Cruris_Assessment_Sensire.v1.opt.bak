                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Ytterligere informasjon som er nødvendig for å registrere lokalt innhold/kontekst, eller for å sammenstille med andre referansemodeller/formalismer.</description>
