        <term_definitions language="ca">
            <items id="at0000">
                <description>Detalls sobre una única condició de salut, lesió, discapacitat o qualsevol altre problema identificat que afecti el benestar físic, mental o social d’una persona. </description>
                <text>Problema/Diagnòstic</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identificació del problema o diagnòstic pel nom.</description>
                <text>Nom del Problema/Diagnòstic</text>
            </items>
            <items id="at0003">
                <description>Data/hora estimada o real en què un professional sanitari va declarar el diagnòstic o problema.</description>
                <text>Data/hora del diagnòstic clínic</text>
            </items>
            <items id="at0005">
                <description>Una avaluació de la severitat global del problema o diagnòstic.</description>
                <text>Severitat</text>
            </items>
            <items id="at0009">
                <description>Informació addicional del problema o diagnòstic.</description>
                <text>Descripció clínica</text>
            </items>
            <items id="at0012">
                <description>Identificació de la zona del cos per a la localització del problema o diagnòstic.</description>
                <text>Zona del cos</text>
            </items>
            <items id="at0030">
                <description>Data/hora estimada o real de resolució o remissió d'aquest problema o diagnòstic, determinada per un professional sanitari.</description>
                <text>Data/hora de resolució</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Localització anatòmica estructurada per al problema o diagnòstic.</description>
                <text>Zona del cos estructurada</text>
            </items>
            <items id="at0043">
                <description>Detalls que es requereixen addicionalment per a registrar atributs únics d'aquest problema o diagnòstic.</description>
                <text>Detalls específics</text>
            </items>
            <items id="at0046">
                <description>Detalls estructurats per a aspectes específics d'ubicació, domini, episodi o flux de treball del procés diagnòstic.</description>
                <text>Estat</text>
            </items>
            <items id="at0047">
                <description>El problema o diagnòstic no interfereix amb l'activitat normal ni pot causar danys a la salut si no es tracta.</description>
                <text>Lleu</text>
            </items>
            <items id="at0048">
                <description>El problema o diagnòstic interfereix amb l'activitat normal o pot causar danys a la salut si no es tracta.</description>
                <text>Moderat</text>
            </items>
            <items id="at0049">
                <description>El problema o diagnòstic impedeix l'activitat normal o causarà danys greus a la salut si no es tracta.</description>
                <text>Greu</text>
            </items>
            <items id="at0069">
                <description>Informació descriptiva sobre el problema o diagnòstic no registrada en altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0070">
                <description>La data en què es va actualitzar per última vegada aquest problema o diagnòstic.</description>
                <text>Darrera actualització</text>
            </items>
            <items id="at0071">
                <description>Informació addicional necessària per a recollir el contingut local o per alinear-se amb altres models/formalismes de referència.</description>
                <text>Extensió</text>
            </items>
            <items id="at0072">
                <description>Informació addicional del curs del problema o diagnòstic des de l'inici.</description>
                <text>Descripció del curs</text>
            </items>
            <items id="at0073">
                <description>El nivell de confiança en la identificació del diagnòstic.</description>
                <text>Certesa diagnòstica</text>
            </items>
            <items id="at0074">
                <description>El diagnòstic s'ha identificat amb un nivell baix de certesa.</description>
                <text>Sospita</text>
            </items>
            <items id="at0075">
                <description>El diagnòstic s'ha identificat amb un alt nivell de certesa.</description>
                <text>Probable</text>
            </items>
            <items id="at0076">
                <description>El diagnòstic s'ha confirmat d'acord amb criteris reconeguts.</description>
                <text>Confirmat</text>
            </items>
            <items id="at0077">
                <description>Data/hora estimada o real en què es van observar per primera vegada els signes o símptomes del problema/diagnòstic.</description>
                <text>Data/hora de l’aparició</text>
            </items>
            <items id="at0078">
                <description>Una causa, conjunt de causes o el mecanisme causal del problema o diagnòstic.</description>
                <text>Causa</text>
            </items>
            <items id="at0079">
                <description>Variant o subtipus específic del Diagnòstic, si escau.</description>
                <text>Variant</text>
            </items>
            <items id="at0080">
                <description>Avaluació global de l'impacte o rellevància d'un problema de salut per a un pacient concret.</description>
                <text>Impacte</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-OBSERVATION.exam.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Während der körperlichen Untersuchung eines Patienten beobachtete Befunde.</description>
                <text>Ergebnisse der körperlichen Untersuchung</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Ein Standardwert, ein spezifizierter Zeitpunkt oder ein Intervallereignis, welches explizit in einem Template oder während der Laufzeit definiert werden kann.</description>
                <text>Jedes Ereignis</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Beschreibung der Gesamtbefunde, die bei der körperlichen Untersuchung eines Patienten beobachtet wurden.</description>
                <text>Beschreibung</text>
            </items>
            <items id="at0005">
                <description>Strukturierte Details der körperlichen Untersuchung.</description>
                <text>Untersuchungsdetails</text>
            </items>
            <items id="at0006">
                <description>Einzelnes Wort, Ausdruck oder Kurzbeschreibung der klinischen Bedeutung und Aussagekraft der körperlichen Untersuchungsbefunde.</description>
                <text>Interpretation</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Beschreibung aller zufälligen Faktoren, die zu den Ergebnissen der körperlichen Untersuchung beigetragen haben könnten.</description>
                <text>Störfaktoren</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Details über jedes Gerät, welches bei der körperlichen Untersuchung verwendet wurde.</description>
                <text>Gerätedetails</text>
            </items>
            <items id="at0011">
                <description>Zusätzlicher Freitext über die allgemeinen körperlichen Untersuchungsergebnisse, die in anderen Bereichen nicht erfasst werden konnten.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0012">
                <description>Zusätzliche Information, die für die Erfassung des lokalen Kontexts oder für die Anpassung an andere Referenzmodelle/Formalismen benötigt wird.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0013">
                <description>Die Position der untersuchten Person während der Untersuchung.</description>
                <text>Position</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Observerade fynd under en fysisk undersökning av mottagaren av hälso- och sjukvård.</description>
                <text>Fysiska undersökningsfynd</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Standard, ospecificerad händelse eller intervallhändelse som kan definieras uttryckligen i en mall eller vid körning.</description>
                <text>Ospecificerad händelse</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Detaljerad beskrivning av de övergripande fynden som observerats under en fysisk undersökning av en patient.</description>
                <text>Beskrivning</text>
            </items>
            <items id="at0005">
                <description>Strukturerade detaljer från den fysiska undersökningen.</description>
                <text>Undersökningsdetaljer</text>
            </items>
            <items id="at0006">
                <description>Enkelt ord, fras eller kort beskrivning som representerar den kliniska innebörden och betydelsen av de fysiska undersökningsfynden.</description>
                <text>Tolkning</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Beskrivning av eventuella tillfälliga faktorer som kan ha bidragit till de fysiska undersökningsfynden.</description>
                <text>Möjliga felkällor</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detaljer om utrustning som använts under den fysiska undersökningen.</description>
                <text>Detaljer om utrustning</text>
            </items>
            <items id="at0011">
                <description>Ytterligare beskrivning om de övergripande fysiska undersökningsfynden som inte fångats i andra fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0012">
                <description>Tilläggsinformation som krävs för att fånga lokalt innehåll eller för anpassning till andra referensmodeller/formalismer.</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0013">
                <description>Kroppsställning vid undersökning.</description>
                <text>Kroppsställning</text>
            </items>
        </term_definitions>
        <term_definitions language="es-ar">
            <items id="at0000">
                <description>Hallazgos observados durante el examen fisico de una persona</description>
                <text>Hallazgos del Examen Fisico</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Event Series(en)</text>
            </items>
            <items id="at0002">
                <description>*Unspecified point in time which may be explicitly defined in a template or at run-time.(en)</description>
                <text>*Any event(en)</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
                <description>Descripcion narrativa de los hallazgos generales observados durante un examen fisico de un paciente</description>
                <text>Descripcion</text>
            </items>
            <items id="at0005">
                <description>*Structured details of the physical examination.(en)</description>
                <text>*Examination Detail(en)</text>
            </items>
            <items id="at0006">
                <description>Palabra, frase o descripcion breve que represente el significado clinico e importancia de los hallazgos del examen fisico</description>
                <text>Interpretacion</text>
            </items>
            <items id="at0007">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0008">
                <description>Descripcion de cualquier factor incidental que pueda haber contribuido a los hallazgos del examen físico</description>
                <text>Factores de Confusion</text>
            </items>
            <items id="at0009">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0010">
                <description>Detalles acerca de cualquier dispositivo utilizado durante el examen fisico.</description>
                <text>Detalle del dispositivo</text>
            </items>
            <items id="at0011">
                <description>Cualquier comentario narrativo adicional no incluido por otros elementos</description>
                <text>Comentario</text>
            </items>
            <items id="at0012">
                <description>**(en)</description>
                <text>*Cluster(en)</text>
            </items>
            <items id="at0013">
                <description>*The position of the subject at the time of examination.(en)</description>
                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="nb">
            <items id="at0000">
                <description>Funn ved fysisk undersøkelse av en helsetjenestemottaker.</description>
                <text>Funn ved fysisk undersøkelse</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Standard, uspesifisert tidspunkt eller tidsintervall som kan defineres mer eksplisitt i en template eller i en applikasjon.</description>
                <text>Uspesifisert hendelse</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Fritekstbeskrivelse av funn ved en klinisk undersøkelse av et individ.</description>
                <text>Beskrivelse</text>
            </items>
            <items id="at0005">
                <description>Strukturerte detaljer fra den kliniske undersøkelsen.</description>
                <text>Undersøkelsesdetaljer</text>
            </items>
            <items id="at0006">
                <description>Enkelt ord, setning, frase eller kort beskrivelse som representerer den kliniske betydning og viktigheten av funnene ved den kliniske undersøkelsen.</description>
                <text>Fortolkning</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Kommentar til og registrering av faktorer som kan ha betydning for funn ved den kliniske undersøkelsen.</description>
                <text>Konfunderende faktorer</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detaljer vedrørende medisinsk utstyr benyttet ved den kliniske undersøkelsen.</description>
                <text>Detaljer om medisinsk utstyr</text>
            </items>
            <items id="at0011">
                <description>Tekstlig beskrivelse av de fysiske funn som ikke dekkes av andre felt.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0012">
                <description>Ytterligere informasjon som er nødvendig for å registrere lokalt innhold/kontekst, eller for å sammenstille med andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0013">
                <description>Individets kroppsstilling under undersøkelsen.</description>
                <text>Stilling</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Resultados observados durante o exame físico de um sujeito de atenção.</description>
                <text>Achados de exame físico</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Padrão, ponto indeterminado no tempo ou intervalo de evento que pode ser definido explicitamente em um modelo ou em tempo de execução.</description>
                <text>Qualquer evento</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Descrição narrativa dos achados gerais observados durante o exame físico de um paciente.</description>
                <text>Descrição</text>
            </items>
            <items id="at0005">
                <description>Detalhes estruturados do exame físico</description>
                <text>Detalhes do exame</text>
            </items>
            <items id="at0006">
                <description>Palavra única, frase ou breve descrição que representa o significado clínico e dos achados do exame físico.</description>
                <text>Interpretação</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descrição de fatores incidentais que podem ter contribuído para os achados do exame físico.</description>
                <text>Fatores de confundimento</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalhes sobre qualquer dispositivo utilizado durante o exame físico.</description>
                <text>Detalhes do dispositivo</text>
            </items>
            <items id="at0011">
                <description>Narrativa adicional sobre os achados gerais do exame físico não capturados em outros campos.</description>
                <text>Comentário</text>
            </items>
            <items id="at0012">
                <description>Informações adicionais necessárias para capturar conteúdo local ou alinhar com outros modelos/formalismos de referência.</description>
                <text>Extensão</text>
            </items>
            <items id="at0013">
                <description>A posição do corpo do sujeito durante o exame.</description>
                <text>Posição</text>
            </items>
        </term_definitions>
        <term_definitions language="ar-sy">
            <items id="at0000">
                <description>*Findings observed during the physical examination of a subject.(en)</description>
                <text>*Physical Examination Findings(en)</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Event Series(en)</text>
            </items>
            <items id="at0002">
                <description>*Unspecified point in time which may be explicitly defined in a template or at run-time.(en)</description>
                <text>*Any event(en)</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
