                <archetype_id><value>openEHR-EHR-EVALUATION.sims_classification_nl.v0</value></archetype_id><term_definitions code="at0000"><items id="description">Nederlands risicoclassificatiemodel voor de diabetische voet (categorie 0-3) gebaseerd op PS-verlies, PAV, ulcushistorie en andere risicofactoren.</items><items id="text">Sims-risicoclassificatie</items></term_definitions><term_definitions code="at0001"><items id="description">Boomstructuur.</items><items id="text">Boom</items></term_definitions><term_definitions code="at0002"><items id="description">Risicoclassificatie van de diabetische voet volgens Sims.</items><items id="text">Sims-categorie</items></term_definitions><term_definitions code="at0003"><items id="description">Intacte protectieve sensibiliteit, geen PAV, geen ulcushistorie. Jaarlijkse controle door huisarts.</items><items id="text">Categorie 0 — Geen risicofactoren</items></term_definitions><term_definitions code="at0004"><items id="description">Verlies van protectieve sensibiliteit (PS-verlies), geen PAV, geen ulcushistorie. Halfjaarlijkse controle, podotherapie.</items><items id="text">Categorie 1 — Neuropathie</items></term_definitions><term_definitions code="at0005"><items id="description">PS-verlies + PAV en/of standsafwijkingen. Driemaandelijkse controle, specialistische podotherapie.</items><items id="text">Categorie 2 — Neuropathie + bijkomend risico</items></term_definitions><term_definitions code="at0006"><items id="description">Eerder ulcus, amputatie of Charcot in de voorgeschiedenis. Maandelijkse tot zeswekelijkse controle, specialistische multidisciplinaire zorg.</items><items id="text">Categorie 3 — Ulcus/amputatie in VG</items></term_definitions><term_definitions code="at0007"><items id="description">Protectieve sensibiliteit verloren, vastgesteld met monofilament-test (score ≤5/8).</items><items id="text">Verlies protectieve sensibiliteit</items></term_definitions><term_definitions code="at0008"><items id="description">Aanwezigheid van perifeer arterieel vaatlijden (PAV), vastgesteld via pulsaties en/of EAI.</items><items id="text">Perifeer arterieel vaatlijden</items></term_definitions><term_definitions code="at0009"><items id="description">Aanwezigheid van voet- of teenstandafwijkingen die drukpunten veroorzaken.</items><items id="text">Standsafwijkingen</items></term_definitions><term_definitions code="at0010"><items id="description">Eerder voetulcus in de voorgeschiedenis.</items><items id="text">Historie ulcus</items></term_definitions><term_definitions code="at0011"><items id="description">Eerdere (deel)amputatie van de voet of het been.</items><items id="text">Historie amputatie</items></term_definitions><term_definitions code="at0012"><items id="description">Charcot-osteoarthropathie in de voorgeschiedenis.</items><items id="text">Charcot in voorgeschiedenis</items></term_definitions><term_definitions code="at0013"><items id="description">Aanbevolen frequentie van voetcontrole op basis van de Sims-categorie.</items><items id="text">Aanbevolen controlefrequentie</items></term_definitions><term_definitions code="at0014"><items id="description">Aanvullende opmerkingen bij de Sims-classificatie.</items><items id="text">Opmerking</items></term_definitions><term_definitions code="at0015"><items id="description">Protocol.</items><items id="text">Protocol</items></term_definitions><term_definitions code="at0016"><items id="description">Naam of rol van de beoordelaar.</items><items id="text">Beoordelaar</items></term_definitions><term_definitions code="at0017"><items id="description">Datum en tijd van de beoordeling.</items><items id="text">Datum beoordeling</items></term_definitions></children>
            <children xsi:type="C_ARCHETYPE_ROOT">
