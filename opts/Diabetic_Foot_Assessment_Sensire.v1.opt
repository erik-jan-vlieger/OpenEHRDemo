                <archetype_id><value>openEHR-EHR-OBSERVATION.exam.v1</value></archetype_id><term_definitions code="at0000"><items id="description">Während der körperlichen Untersuchung eines Patienten beobachtete Befunde.</items><items id="text">Ergebnisse der körperlichen Untersuchung</items></term_definitions><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Event Series</items></term_definitions><term_definitions code="at0002"><items id="description">Ein Standardwert, ein spezifizierter Zeitpunkt oder ein Intervallereignis, welches explizit in einem Template oder während der Laufzeit definiert werden kann.</items><items id="text">Jedes Ereignis</items></term_definitions><term_definitions code="at0003"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0004"><items id="description">Beschreibung der Gesamtbefunde, die bei der körperlichen Untersuchung eines Patienten beobachtet wurden.</items><items id="text">Beschreibung</items></term_definitions><term_definitions code="at0005"><items id="description">Strukturierte Details der körperlichen Untersuchung.</items><items id="text">Untersuchungsdetails</items></term_definitions><term_definitions code="at0006"><items id="description">Einzelnes Wort, Ausdruck oder Kurzbeschreibung der klinischen Bedeutung und Aussagekraft der körperlichen Untersuchungsbefunde.</items><items id="text">Interpretation</items></term_definitions><term_definitions code="at0007"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0008"><items id="description">Beschreibung aller zufälligen Faktoren, die zu den Ergebnissen der körperlichen Untersuchung beigetragen haben könnten.</items><items id="text">Störfaktoren</items></term_definitions><term_definitions code="at0009"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0010"><items id="description">Details über jedes Gerät, welches bei der körperlichen Untersuchung verwendet wurde.</items><items id="text">Gerätedetails</items></term_definitions><term_definitions code="at0011"><items id="description">Zusätzlicher Freitext über die allgemeinen körperlichen Untersuchungsergebnisse, die in anderen Bereichen nicht erfasst werden konnten.</items><items id="text">Kommentar</items></term_definitions><term_definitions code="at0012"><items id="description">Zusätzliche Information, die für die Erfassung des lokalen Kontexts oder für die Anpassung an andere Referenzmodelle/Formalismen benötigt wird.</items><items id="text">Erweiterung</items></term_definitions><term_definitions code="at0013"><items id="description">Die Position der untersuchten Person während der Untersuchung.</items><items id="text">Position</items></term_definitions></children>
