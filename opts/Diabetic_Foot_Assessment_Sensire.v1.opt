                <archetype_id><value>openEHR-EHR-OBSERVATION.laboratory_test_result.v1</value></archetype_id><term_definitions code="at0000"><items id="description">*The result, including findings and the laboratory's interpretation, of an investigation performed on specimens collected from an individual or related to that individual.(en)</items><items id="text">*Laboratory test result(en)</items></term_definitions><term_definitions code="at0001"><items id="description">@ internal @</items><items id="text">Event Series</items></term_definitions><term_definitions code="at0002"><items id="description">*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</items><items id="text">*Any event(en)</items></term_definitions><term_definitions code="at0003"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0004"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0005"><items id="description">Naam van het laboratorium onderzoek dat vericht is op het specimen.</items><items id="text">Naam van de Test</items></term_definitions><term_definitions code="at0017"><items id="description">*Details of the laboratory which received the request and has overall responsibility to manage reporting of the test, even if other labs perform specific aspects.(en)</items><items id="text">*Receiving laboratory(en)</items></term_definitions><term_definitions code="at0035"><items id="description">*Details of additional clinicians or organisations who require a copy of the test result.(en)</items><items id="text">*Distribution list(en)</items></term_definitions><term_definitions code="at0037"><items id="description">*This is a partial (e.g. initial, interim or preliminary) Test Result: data in the Test Result may be incomplete or unverified.(en)</items><items id="text">*Partial(en)</items></term_definitions><term_definitions code="at0038"><items id="description">*The Test result is complete and verified by an authorised person.(en)</items><items id="text">*Final(en)</items></term_definitions><term_definitions code="at0040"><items id="description">*The result has been modified subsequent to being Final, and is complete and verified by the responsible pathologist, and result data has been changed.(en)</items><items id="text">*Amended(en)</items></term_definitions><term_definitions code="at0057"><items id="description">*Narrative description of the key findings.(en)</items><items id="text">*Conclusion(en)</items></term_definitions><term_definitions code="at0062"><items id="description">*The local identifier assigned by the requesting clinical system.(en)</items><items id="text">*Requester order identifier(en)</items></term_definitions><term_definitions code="at0063"><items id="description">*The local identifier assigned to the test order by the order filler, usually by the Laboratory Information System (LIS).(en)</items><items id="text">*Receiver order identifier(en)</items></term_definitions><term_definitions code="at0065"><items id="description">*Details about the physical substance that has been analysed.(en)</items><items id="text">*Specimen detail(en)</items></term_definitions><term_definitions code="at0068"><items id="description">*A local identifier assigned by the receiving Laboratory Information System (LIS) to track the test process.(en)</items><items id="text">*Laboratory internal identifier(en)</items></term_definitions><term_definitions code="at0073"><items id="description">*The status of the laboratory test result as a whole.(en)</items><items id="text">*Overall test status(en)</items></term_definitions><term_definitions code="at0074"><items id="description">*The result is unavailable because the test was not started or not completed (also sometimes called 'aborted').(en)</items><items id="text">*Cancelled(en)</items></term_definitions><term_definitions code="at0075"><items id="description">*The date and/or time that ‘Overall test status’ was issued.(en)</items><items id="text">*Overall test status timestamp(en)</items></term_definitions><term_definitions code="at0077"><items id="description">*The diagnostic service or discipline that is responsible for the laboratory test result.(en)</items><items id="text">*Diagnostic service category(en)</items></term_definitions><term_definitions code="at0090"><items id="description">*Details of the clinician or organisation requesting the laboratory test result.(en)</items><items id="text">*Requester(en)</items></term_definitions><term_definitions code="at0094"><items id="description">*Details about the test request.(en)</items><items id="text">*Test request details(en)</items></term_definitions><term_definitions code="at0097"><items id="description">*Results of the test performed on the specimen(s).(en)</items><items id="text">*Test result(en)</items></term_definitions><term_definitions code="at0098"><items id="description">*Single word, phrase or brief description that represents the clinical meaning and significance of the laboratory test result.(en)</items><items id="text">*Test diagnosis(en)</items></term_definitions><term_definitions code="at0100"><items id="description">*Description of clinical information available at the time of interpretation of results.(en)</items><items id="text">*Clinical information provided(en)</items></term_definitions><term_definitions code="at0101"><items id="description">*Additional narrative about the test result not captured in other fields.(en)</items><items id="text">*Comment(en)</items></term_definitions><term_definitions code="at0106"><items id="description">*Name of the original laboratory test requested.(en)</items><items id="text">*Original test requested name(en)</items></term_definitions><term_definitions code="at0107"><items id="description">*The existence of the test is registered in the Laboratory Information System, but there is nothing yet available.(en)</items><items id="text">*Registered(en)</items></term_definitions><term_definitions code="at0110"><items id="description">*Structured details about the method of analysis, device or interpretation used.(en)</items><items id="text">*Testing details(en)</items></term_definitions><term_definitions code="at0111"><items id="description">*This indicates whether the test was performed directly at Point-of-Care (POCT) as opposed to a formal result from a laboratory or other service delivery organisation.(en)</items><items id="text">*Point-of-care test(en)</items></term_definitions><term_definitions code="at0112"><items id="description">@ internal @</items><items id="text">Tree</items></term_definitions><term_definitions code="at0113"><items id="description">*Issues or circumstances that impact on the accurate interpretation of the measurement or test result.(en)</items><items id="text">*Confounding factors(en)</items></term_definitions><term_definitions code="at0114"><items id="description">*Details of issues or circumstances that impact on the accurate interpretation of the measurement or test result.(en)</items><items id="text">*Structured confounding factors(en)</items></term_definitions><term_definitions code="at0115"><items id="description">*The result has been modified subsequent to being Final, and is complete and verified by the responsible pathologist. This is a sub-category of 'Amended'.(en)</items><items id="text">*Corrected(en)</items></term_definitions><term_definitions code="at0116"><items id="description">*The Test Result has been withdrawn following previous Final release.(en)</items><items id="text">*Entered in error(en)</items></term_definitions><term_definitions code="at0117"><items id="description">*Additional information required to capture local content or to align with other reference models/formalisms.(en)</items><items id="text">*Extension(en)</items></term_definitions><term_definitions code="at0118"><items id="description">*Digital image, video or diagram representing the test result.(en)</items><items id="text">*Multimedia representation(en)</items></term_definitions><term_definitions code="at0119"><items id="description">*Subsequent to being final, the report has been modified by adding new content. The existing content is unchanged. This is a sub-category of 'Amended'.(en)</items><items id="text">*Appended(en)</items></term_definitions><term_definitions code="at0120"><items id="description">*Verified early results are available, but not all results are final. This is a sub-category of 'Partial'.(en)</items><items id="text">*Preliminary(en)</items></term_definitions><term_definitions code="at0121"><items id="description">*Description about the method used to perform the test.(en)</items><items id="text">*Test method(en)</items></term_definitions><term_definitions code="at0122"><items id="description">*A structured or complex diagnosis for the laboratory test.(en)</items><items id="text">*Structured test diagnosis(en)</items></term_definitions></children>
