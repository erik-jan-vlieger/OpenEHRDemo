        <term_definitions language="ca">
            <items id="at0000">
                <description>Detalls sobre una única condició de salut, lesió, discapacitat o qualsevol altre problema identificat que afecti el benestar físic, mental o social d’una persona. </description>
                <text>Problema/Diagnòstic</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identificació del problema o diagnòstic pel nom.</description>
                <text>Nom del Problema/Diagnòstic</text>
            </items>
            <items id="at0003">
                <description>Data/hora estimada o real en què un professional sanitari va declarar el diagnòstic o problema.</description>
                <text>Data/hora del diagnòstic clínic</text>
            </items>
            <items id="at0005">
                <description>Una avaluació de la severitat global del problema o diagnòstic.</description>
                <text>Severitat</text>
            </items>
            <items id="at0009">
                <description>Informació addicional del problema o diagnòstic.</description>
                <text>Descripció clínica</text>
            </items>
            <items id="at0012">
                <description>Identificació de la zona del cos per a la localització del problema o diagnòstic.</description>
                <text>Zona del cos</text>
            </items>
            <items id="at0030">
                <description>Data/hora estimada o real de resolució o remissió d'aquest problema o diagnòstic, determinada per un professional sanitari.</description>
                <text>Data/hora de resolució</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Localització anatòmica estructurada per al problema o diagnòstic.</description>
                <text>Zona del cos estructurada</text>
            </items>
            <items id="at0043">
                <description>Detalls que es requereixen addicionalment per a registrar atributs únics d'aquest problema o diagnòstic.</description>
                <text>Detalls específics</text>
            </items>
            <items id="at0046">
                <description>Detalls estructurats per a aspectes específics d'ubicació, domini, episodi o flux de treball del procés diagnòstic.</description>
                <text>Estat</text>
            </items>
            <items id="at0047">
                <description>El problema o diagnòstic no interfereix amb l'activitat normal ni pot causar danys a la salut si no es tracta.</description>
                <text>Lleu</text>
            </items>
            <items id="at0048">
                <description>El problema o diagnòstic interfereix amb l'activitat normal o pot causar danys a la salut si no es tracta.</description>
                <text>Moderat</text>
            </items>
            <items id="at0049">
                <description>El problema o diagnòstic impedeix l'activitat normal o causarà danys greus a la salut si no es tracta.</description>
                <text>Greu</text>
            </items>
            <items id="at0069">
                <description>Informació descriptiva sobre el problema o diagnòstic no registrada en altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0070">
                <description>La data en què es va actualitzar per última vegada aquest problema o diagnòstic.</description>
                <text>Darrera actualització</text>
            </items>
            <items id="at0071">
                <description>Informació addicional necessària per a recollir el contingut local o per alinear-se amb altres models/formalismes de referència.</description>
                <text>Extensió</text>
            </items>
            <items id="at0072">
                <description>Informació addicional del curs del problema o diagnòstic des de l'inici.</description>
                <text>Descripció del curs</text>
            </items>
            <items id="at0073">
                <description>El nivell de confiança en la identificació del diagnòstic.</description>
                <text>Certesa diagnòstica</text>
            </items>
            <items id="at0074">
                <description>El diagnòstic s'ha identificat amb un nivell baix de certesa.</description>
                <text>Sospita</text>
            </items>
            <items id="at0075">
                <description>El diagnòstic s'ha identificat amb un alt nivell de certesa.</description>
                <text>Probable</text>
            </items>
            <items id="at0076">
                <description>El diagnòstic s'ha confirmat d'acord amb criteris reconeguts.</description>
                <text>Confirmat</text>
            </items>
            <items id="at0077">
                <description>Data/hora estimada o real en què es van observar per primera vegada els signes o símptomes del problema/diagnòstic.</description>
                <text>Data/hora de l’aparició</text>
            </items>
            <items id="at0078">
                <description>Una causa, conjunt de causes o el mecanisme causal del problema o diagnòstic.</description>
                <text>Causa</text>
            </items>
            <items id="at0079">
                <description>Variant o subtipus específic del Diagnòstic, si escau.</description>
                <text>Variant</text>
            </items>
            <items id="at0080">
                <description>Avaluació global de l'impacte o rellevància d'un problema de salut per a un pacient concret.</description>
                <text>Impacte</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-ACTION.medication.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Jede Aktivität in Bezug auf die Planung, Vorbereitung, Rezeptverwaltung, Ausgabe, Verabreichung, Einnahme, Absetzung und anderer Verwendung von Arzneimitteln, Impfstoffen, Nahrungsergänzungsmitteln und anderen therapeutischen Mitteln.</description>
                <text>Arzneimittelanwendung</text>
            </items>
            <items id="at0002">
                <description>Für das Arzneimittel wurde ein Rezept ausgestellt.</description>
                <text>Rezept ausgestellt</text>
            </items>
            <items id="at0003">
                <description>Das verordnete Arzneimittel ist an einen Patienten ausgegeben worden, z.B. von einer Apotheke.</description>
                <text>Rezept wurde ausgegeben/eingelöst</text>
            </items>
            <items id="at0004">
                <description>Das Arzneimittel wurde zum ersten Mal von dem Patienten eingenommen oder ihm verabreicht. Obwohl in einigen Situationen das relevante Datum als erste von mehreren Anwendungen errechenbar ist, kann es in der Grundversorgung sein, dass genaue Verabreichungszeit nicht ohne weiteres verfügbar ist.</description>
                <text>Arzneimittelbehandlung hat begonnen</text>
            </items>
            <items id="at0005">
                <description>Das individuelle Arzneimittel wurde neu bewertet, beispielsweise ob das Arzneimittel noch angewendet werden soll. Eine Überprüfung der Arzneimittelliste soll nicht durchgeführt werden.</description>
                <text>Arzneimittel wurde neu bewertet</text>
            </items>
            <items id="at0006">
                <description>Eine einzelne Verabreichung des Arzneimittels ist erfolgt.</description>
                <text>Dosis wurde verabreicht</text>
            </items>
            <items id="at0007">
                <description>Die medikamentöse Behandlung wurde, wie geplant, beendet.</description>
                <text>Arzneimittelbehandlung ist abgeschlossen</text>
            </items>
            <items id="at0008">
                <description>Das Rezept wurde aufgrund einer technischen oder pharmazeutischen Störung nicht ausgegeben.</description>
                <text>Verzögerung der Rezeptabgabe</text>
            </items>
            <items id="at0009">
                <description>Die Verabreichung des Arzneimittels wurde bis zum Erhalt weiterer Informationen ausgesetzt. Es sollten keine weiteren Dosen, bis zur Bekanntgabe des neuen Startdatums oder bis die Bedingungen erfüllt sind, verabreicht werden. Wenn Sie das Datum/ die Voraussetzungen für den Neustart nach dem Aussetzen festlegen, sollte ein Schritt von "Verabreichung wurde ausgesetzt" und zurück zu "Arzneimittel Startdatum/Voraussetzung" ausgeführt werden.</description>
                <text>Verabreichung wurde ausgesetzt</text>
            </items>
            <items id="at0010">
                <description>Ein Rezept wurde für eine vorhandene Arzneimittelverordnung neu ausgestellt.</description>
                <text>Rezept neu ausgestellt</text>
            </items>
            <items id="at0011">
                <description>Die Ausstellung des Rezeptes wartet auf die erneute Autorisierung durch einen Arzt.</description>
                <text>Re-Autorisierug des Rezepts ausstehend</text>
            </items>
            <items id="at0012">
                <description>Die geplante Arzneimittelbehandlung wurde vor der Verabreichung abgesagt.</description>
                <text>Arzneimittelbehandlung wurde abgesagt</text>
            </items>
            <items id="at0013">
                <description>Die geplante Arzneimittelbehandlung wurde vor der Verabreichung verschoben.</description>
                <text>Arzneimittelbehandlung wurde verschoben</text>
            </items>
            <items id="at0015">
                <description>Die Verabreichung des Arzneimittels wurde während der Dauer der geplanten Behandlung eingestellt.</description>
                <text>Arzneimittelbehandlung gestoppt</text>
            </items>
            <items id="at0016">
                <description>Das Startdatum der Arzneimittelanwendung oder andere Startbedingungen wurden festgelegt.</description>
                <text>Arzneimittel Startdatum/Voraussetzung</text>
            </items>
            <items id="at0017">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0018">
                <description>Eine Gabe des Arzneimittels wurde zurückgehalten und nicht gegeben. Es besteht keine Erwartung, dass sie später verabreicht wird, obwohl die nächste Dosis (falls es eine gibt) gemäß der ursprünglichen Verordnung verabreicht werden sollte.</description>
                <text>Verabreichung einer Dosis wurde ausgelassen</text>
            </items>
            <items id="at0020">
                <description>Name des Arzneimittels, eines Impfstoffs oder eines anderen therapeutischen Mittels, welches im Mittelpunkt der Aktivität steht.</description>
                <text>Arzneimittel</text>
            </items>
            <items id="at0021">
                <description>Begründung, warum der Prozessschritt für das identifizierte Arzneimittel durchgeführt wurde.</description>
                <text>Begründung</text>
            </items>
            <items id="at0024">
                <description>Zur Dokumentation von zusätzlichen Schilderungen über die Aktivitäten oder den Prozessschritt, wenn sie noch nicht in anderen Feldern erfasst wurden. Dabei sollen Einzelheiten zu Abweichungen zwischen durchzuführender Aktion und tatsächlich durchgeführter Aktion erfasst werden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0025">
                <description>Die spezifische Sequenznummer des Prozessschritts wird erfasst.</description>
                <text>Sequenznummer</text>
            </items>
            <items id="at0030">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0033">
                <description>Jede Anweisung, Anleitung oder Empfehlung, die dem Patienten oder der Pflegekraft zum Zeitpunkt eines Prozessschrittes übermittelt wird.</description>
                <text>Patientenanweisung</text>
            </items>
            <items id="at0039">
                <description>Eine große Änderung der Verordnung war erforderlich, die dazu führte, dass diese Verordnung gestoppt und eine Ersatzverordnung gestartet wurde.</description>
                <text>Größere Änderung der Verordnung</text>
            </items>
            <items id="at0041">
                <description>Die Arzneimittelverordnung wurde so geändert, dass keine neue Verordnung/neues Rezept nach den lokalen klinischen Regeln ausgestellt werden muss.</description>
                <text>Geringfügige Änderung der Verordnung</text>
            </items>
            <items id="at0043">
                <description>Das Datum/die Uhrzeit, an dem die Aktion mit dem Arzneimittel eingeplant war.</description>
                <text>Ursprünglich geplantes Datum/Uhrzeit</text>
            </items>
            <items id="at0044">
                <description>Die Verabreichung einer Dosis hat sich verzögert, wird aber so schnell wie möglich erfolgen.</description>
                <text>Verabreichung einer Dosis wurde verschoben</text>
            </items>
            <items id="at0053">
                <description>Weitere strukturierte Details zu der Aktivität, möglicherweise speziell zu einem Prozessschritt.</description>
                <text>Zusätzliche Details</text>
            </items>
            <items id="at0085">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0103">
                <description>Eindeutige ID der Arzneimittelverordnung.</description>
                <text>ID der Verordnung</text>
            </items>
            <items id="at0104">
                <description>Strukturierte Informationen über das Arzneimittel inklusive Stärke, Form und Inhaltsstoffe.</description>
                <text>Arzneimitteldetails</text>
            </items>
            <items id="at0106">
                <description>Die ursprüngliche Verordnung des Arzneimittels wurde erneut genehmigt, um eine wiederholte Verschreibung oder Abgabe zu ermöglichen. In einigen Ländern, wie z.B. Deutschland, muss unter diesen Umständen ein völlig neues Rezept ausgestellt werden.</description>
                <text>Rezept ist re-autorisiert</text>
            </items>
            <items id="at0109">
                <description>Das Arzneimittel wurde empfohlen, aber es wurden keine Schritte unternommen, um die Verschreibung/Verordnung einzuleiten.</description>
                <text>Arzneimittel empfohlen</text>
            </items>
            <items id="at0131">
                <description>Spezifische Angaben zur Dosis des Arzneimittels.</description>
                <text>Dosis</text>
            </items>
            <items id="at0132">
                <description>Substitutionsmaßnahmen, die von der Person ergriffen werden, die das Medikament verabreicht oder ausgibt.</description>
                <text>Substitution</text>
            </items>
            <items id="at0133">
                <description>Die Ursache oder die Begründung für die durchgeführte Substitution.</description>
                <text>Grund für die Substitution</text>
            </items>
            <items id="at0138">
                <description>Ein Arzneimittel wurde substituiert, welches bioäquivalent zu dem Angeforderten ist.</description>
                <text>Substitution wurde durchgeführt</text>
            </items>
            <items id="at0139">
                <description>Obwohl es nach der Arzneimittelverordnung erlaubt gewesen wäre, wurde nicht mit einem bioäquivalenten Arzneimittel substituiert.</description>
                <text>Substitution wurde nicht durchgeführt</text>
            </items>
            <items id="at0140">
                <description>Details über die Körperstelle und über die Verabreichung des Arzneimittels.</description>
                <text>Details zur Verabreichung</text>
            </items>
            <items id="at0141">
                <description>Strukturierte Beschreibung der Körperstelle, an der das Arzneimittel angewendet wird.</description>
                <text>Körperstelle</text>
            </items>
            <items id="at0142">
                <description>Genaue Beschreibung der Körperstelle, an der das Arzneimittel, der Impfstoff oder ein therapeutisches Produkt angewendet wird.</description>
                <text>Lokalisation</text>
            </items>
            <items id="at0143">
                <description>Die Technik oder das Gerät mit dem das verschriebene Arzneimittel verabreicht wird oder werden soll.</description>
                <text>Methode der Verabreichung</text>
            </items>
            <items id="at0144">
                <description>Details zu der Vorrichtung mit dem das Arzneimittel verabreicht wird.</description>
                <text>Verabreichungsmittel</text>
            </items>
            <items id="at0145">
                <description>Der Rezeptentwurf wurde erstellt und wartet auf die Bestätigung durch einen autorisierten Arzt. Kann auch verwendet werden, wenn die Re-autorisierung gebündelt erfolgt. Dieser "careflow_step" hat den Status "geplant" oder "aktiv", was die Notwendigkeit widerspiegelt, sowohl Neuaufträge als auch erneut autorisierte Aufträge zu bearbeiten.</description>
                <text>Rezept wartet auf Genehmigung</text>
            </items>
            <items id="at0147">
                <description>Die Angabe darüber, auf welche Art das verordnete Arzneimittel am Körper des Patienten angewendet wird.</description>
                <text>Verabreichungsweg</text>
            </items>
            <items id="at0148">
                <description>*The medication has been physically prepared. (en)</description>
                <text>Arzneimittel wurde vorbereitet</text>
            </items>
            <items id="at0149">
                <description>Der Prozessschritt wurde durch eine unabhängige Person überprüft.</description>
                <text>Nachkontrolliert?</text>
            </items>
            <items id="at0150">
                <description>Das Rezept wurde vor der Ausstellung widerrufen.</description>
                <text>Rezept wurde widerrufen</text>
            </items>
            <items id="at0151">
                <description>Das Rezept ist ungültig geworden oder ist abgelaufen, ohne das es eingelöst wurde.</description>
                <text>Rezept ist ungültig oder abgelaufen</text>
            </items>
            <items id="at0152">
                <description>Das Rezept wurde erfolgreich ausgeführt/eingehalten.</description>
                <text>Rezept wurde ausgeführt</text>
            </items>
            <items id="at0153">
                <description>Das Arzneimittel ist offiziell zur Anwendung genehmigt.</description>
                <text>Arzneimittel wurde genehmigt</text>
            </items>
            <items id="at0154">
                <description>Das Datum/die Uhrzeit an dem die Arzneimittelbehandlung wieder begonnen wird, gemäß dem "Verabreichung wurde ausgesetzt"- Schritt.</description>
                <text>Datum/Uhrzeit des Neustarts</text>
            </items>
            <items id="at0155">
                <description>Das Kriterium, das den Neustart der Arzneimittelbehandlung auslöst, gemäß dem Schritt "Verabreichung wurde ausgesetzt".</description>
                <text>Kriterium des Neustarts</text>
            </items>
            <items id="at0156">
                <description>Der klinische Grund für die Aktivität mit dem Arzneimittel.</description>
                <text>Klinische Indikation</text>
            </items>
            <items id="at0157">
                <description>*The prepared medication has been double checked. (en)</description>
                <text>*Medication double checked (en)</text>
            </items>
            <items id="at0158">
                <description>*An administration of a dose of the medication was started but was subsequently aborted. (en)</description>
                <text>*Dose administration aborted (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="ru">
            <items id="at0000">
                <description>*Any activity related to the planning, scheduling, prescription management, dispensing, administration, cessation and other use of a medication, vaccine, nutritional product or other therapeutic item.(en)</description>
                <text>*Medication management(en)</text>
            </items>
            <items id="at0002">
                <description>*A prescription has been issued for the medication.(en)</description>
                <text>*Prescription issued(en)</text>
            </items>
            <items id="at0003">
                <description>*The ordered medication has been dispensed, for example from a pharmacy to the patient.(en)</description>
                <text>*Prescription dispensed(en)</text>
            </items>
            <items id="at0004">
                <description>*The medication has been taken by, or administered to, the patient for the first time. Although in some settings this significant date may be computable as the first of several administrations, in other settings, such as primary care, specific administration dates are not readily available.(en)</description>
                <text>*Medication course commenced(en)</text>
            </items>
            <items id="at0005">
                <description>*The specific medication item has been reviewed, as planned. This is not intended to capture review of the whole medication list.(en)</description>
                <text>*Medication course reviewed(en)</text>
            </items>
            <items id="at0006">
                <description>*A single administration of the medication has taken place.(en)</description>
                <text>*Dose administered(en)</text>
            </items>
            <items id="at0007">
                <description>*The medication course has been completed as planned.(en)</description>
                <text>*Medication course completed(en)</text>
            </items>
            <items id="at0008">
                <description>*The prescription has not been dispensed due to a technical or pharamaceutical supply issue.(en)</description>
                <text>*Prescription supply delayed(en)</text>
            </items>
            <items id="at0009">
                <description>*The administration of the medication has been suspended until further notice. No further doses should be given until the restart date or conditions have been met. When setting the date/conditions for restart after suspending, a step from ‘Administrations suspended’ and back to 'Medication start date/condition set' should be performed.(en)</description>
                <text>*Administrations suspended(en)</text>
            </items>
            <items id="at0010">
                <description>*A prescription token has been re-issued for an existing medication order.(en)</description>
                <text>*Prescription re-issued(en)</text>
            </items>
            <items id="at0011">
                <description>*Reissuing of this prescription is not available without some intervention.(en)</description>
                <text>*Prescription re-issue suspended(en)</text>
            </items>
            <items id="at0012">
                <description>*The planned course of medication has been cancelled prior to any administration.(en)</description>
                <text>*Medication course cancelled(en)</text>
            </items>
            <items id="at0013">
                <description>*The scheduled medication course has been postponed prior to any administration.(en)</description>
                <text>*Medication course postponed(en)</text>
            </items>
            <items id="at0015">
                <description>*The administration of this medication has been ceased after the first dose has been administered, but before intended completion of the course.  (en)</description>
                <text>*Medication course stopped(en)</text>
            </items>
            <items id="at0016">
                <description>*The time to start this medication, or other starting condition, has been set.(en)</description>
                <text>*Medication start date/condition set(en)</text>
            </items>
            <items id="at0017">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0018">
                <description>*The administration of a medication has been withheld and not given. There is no expectation that it will be given later, though the next dose (if any) should be administered according to the original order.(en)</description>
                <text>*Dose administration omitted(en)</text>
            </items>
            <items id="at0020">
                <description>*Name of the medication, vaccine or other therapeutic/prescribable item which was the focus of the activity.(en)</description>
                <text>*Medication item(en)</text>
            </items>
            <items id="at0021">
                <description>*Reason that the pathway step for the identified medication was carried out.(en)</description>
                <text>*Reason(en)</text>
            </items>
            <items id="at0024">
                <description>*Additional narrative about the activity or care pathway step not captured in other fields, including details of any variance between the intended action and the action actually performed.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0025">
                <description>*The sequence number specific to the activity being recorded.(en)</description>
                <text>*Sequence number(en)</text>
            </items>
            <items id="at0030">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0033">
                <description>*Any guidance, instructions or advice given to the subject of care or personal carer at the time of the pathway step.(en)</description>
                <text>*Patient guidance(en)</text>
            </items>
            <items id="at0039">
                <description>*A major change to the order was required, resulting in this order being stopped and a replacement order being started.(en)</description>
                <text>*Major change to order.(en)</text>
            </items>
            <items id="at0041">
                <description>*The medication order has been changed in a manner which does not require a new instruction/order to be issued, according to local clinical rules.(en)</description>
                <text>*Minor change to order(en)</text>
            </items>
            <items id="at0043">
                <description>*The datetime at which the medication action was scheduled to occur.(en)</description>
                <text>*Original scheduled date/time(en)</text>
            </items>
            <items id="at0044">
                <description>*Administration of a dose of mediciation has been delayed but is expected to be given as soon as possible.(en)</description>
                <text>*Dose administration deferred(en)</text>
            </items>
            <items id="at0053">
                <description>*Further structured details of the action, possibly specific to a pathway step.(en)</description>
                <text>*Additional details(en)</text>
            </items>
            <items id="at0085">
                <description>**(en)</description>
                <text>*Cluster(en)</text>
            </items>
            <items id="at0103">
                <description>*Unique identifier for the medication order.(en)</description>
                <text>*Order ID(en)</text>
            </items>
            <items id="at0104">
                <description>*Structured details about the medication including strength, form and constituent substances.(en)</description>
                <text>*Medication details(en)</text>
            </items>
            <items id="at0106">
                <description>*The original medication order has been re-authorised to allow repeat prescription or dispensing. In some jurisdictions an entirely new order must be issued in these circumstances.(en)</description>
                <text>*Prescription re-authorised(en)</text>
            </items>
            <items id="at0109">
                <description>*The medication has been recommended but no steps have been taken to initiate prescribing.(en)</description>
                <text>*Medication recommended(en)</text>
            </items>
            <items id="at0131">
                <description>*Specific details about the amount of the medication item.(en)</description>
                <text>*Amount(en)</text>
            </items>
            <items id="at0132">
                <description>*Subsitution action taken by the person administering or dispensing the drug.(en)</description>
                <text>*Substitution(en)</text>
            </items>
            <items id="at0133">
                <description>*The reason or justification for the substitution action taken.(en)</description>
                <text>*Substitution reason(en)</text>
            </items>
            <items id="at0138">
                <description>*A medication was substituted which is bioequivalent to that ordered.(en)</description>
                <text>*Substitution performed(en)</text>
            </items>
            <items id="at0139">
                <description>*Although allowed by the medication order a bioequvalent medication was not substituted.(en)</description>
                <text>*Substitution not performed(en)</text>
            </items>
            <items id="at0140">
                <description>*Details of body site and administration of the medication.(en)</description>
                <text>*Administration details(en)</text>
            </items>
            <items id="at0141">
                <description>*Structured description of the site of administration of the ordered item.(en)</description>
                <text>*Body site(en)</text>
            </items>
            <items id="at0142">
                <description>*Structured description of the site of administration of the medication, vaccine or therapeutic good.(en)</description>
                <text>*Structured body site(en)</text>
            </items>
            <items id="at0143">
                <description>*The technique or device by which the ordered item was, or is to be, administered.(en)</description>
                <text>*Administration method(en)</text>
            </items>
            <items id="at0144">
                <description>*Details of the medical device used to assist administration of the medication.(en)</description>
                <text>*Administration device(en)</text>
            </items>
            <items id="at0145">
                <description>*Draft prescription has been prepared and is awaiting confirmation from an authorised clinician. May be used where reauthorisations are performed as a batch. This careflow_step may have a status of 'planned' or 'active', reflecting the need to to handle new orders as well as re-authorised orders.(en)</description>
                <text>*Prescription awaiting authorisation(en)</text>
            </items>
            <items id="at0147">
                <description>*The route by which the ordered item was, or is to be, administered into the subject's body.(en)</description>
                <text>*Route(en)</text>
            </items>
            <items id="at0148">
                <description>*The medication has been physically prepared. (en)</description>
                <text>*Medication prepared(en)</text>
            </items>
            <items id="at0149">
                <description>*The action step has been checked by a separate individual.(en)</description>
                <text>*Double-checked?(en)</text>
            </items>
            <items id="at0150">
                <description>*The prescription was cancelled prior to being issued.(en)</description>
                <text>*Prescription cancelled(en)</text>
            </items>
            <items id="at0151">
                <description>*Prescription has been invalidated or has expired without being fulfilled.(en)</description>
                <text>*Prescription invalid or expired(en)</text>
            </items>
            <items id="at0152">
                <description>*The prescription has been fulfilled successfully.(en)</description>
                <text>*Prescription fulfilled(en)</text>
            </items>
            <items id="at0153">
                <description>*The medication has been formally authorised for use.(en)</description>
                <text>*Medication authorised(en)</text>
            </items>
            <items id="at0154">
                <description>*The date/time on which the medication course is set to restart, as per the "Medication restart date/condition set" pathway step.(en)</description>
                <text>*Restart date/time(en)</text>
            </items>
            <items id="at0155">
                <description>*The criterion which triggers the medication course to restart, as per the "Medication restart date/condition set" pathway step.(en)</description>
                <text>*Restart criterion(en)</text>
            </items>
            <items id="at0156">
                <description>*The clinical reason for the medication activity. (en)</description>
                <text>*Clinical indication (en)</text>
            </items>
            <items id="at0157">
                <description>*The prepared medication has been double checked. (en)</description>
                <text>*Medication double checked (en)</text>
            </items>
            <items id="at0158">
                <description>*An administration of a dose of the medication was started but was subsequently aborted. (en)</description>
                <text>*Dose administration aborted (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Aktiviteter relaterade till planering, schemaläggning, recepthantering, dosering, administrering, avbrott från eller användning av läkemedel, vaccinering, näringspreparat eller annan terapeutisk produkt.</description>
                <text>Hantering av läkemedelsregim</text>
            </items>
            <items id="at0002">
                <description>En ordination av läkemedlet har utfärdats.</description>
                <text>Utfärdad ordination</text>
            </items>
            <items id="at0003">
                <description>Det ordinerade läkemedlet har dispenserats, exempelvis från ett apotek till patienten.</description>
                <text>Utdelad ordination</text>
            </items>
            <items id="at0004">
                <description>Läkemedlet har tagits av eller administrerats till patienten för första gången. I vissa fall kan startdatum för varje administrationstillfälle finnas tillgängligt, medan det i andra fall (såsom i primärvården) inte gör det.</description>
                <text>Påbörjad läkemedelsbehandling</text>
            </items>
            <items id="at0005">
                <description>Omprövning av det enskilda läkemedlet, exempelvis huruvida medicineringen ska fortskrida. Syftet är inte att skapa en översyn av läkemedelslistan.</description>
                <text>Omprövning av läkemedel</text>
            </items>
            <items id="at0006">
                <description>Engångsadministrering av läkemedlet.</description>
                <text>Administrerad dos</text>
            </items>
            <items id="at0007">
                <description>Läkemedelsbehandlingen har slutförts som planerat.</description>
                <text>Fullföljd läkemedelsbehandling</text>
            </items>
            <items id="at0008">
                <description>Ordinationen har inte delats ut på grund av ett teknisk eller faramaceutiskt leveransproblem.</description>
                <text>Försenad receptleverans</text>
            </items>
            <items id="at0009">
                <description>Administreringen av läkemedlet har avbrutits tills vidare. Inga ytterligare doser ska ges förrän ett nytt startdatum har angivits eller villkoren har uppfyllts. Vid inställning av in datum/villkor för omstart, ska stegen från "Läkemedlets startdatum/fastställda villkor" till "Indragen administrering" utföras på nytt.</description>
                <text>Indragen administrering</text>
            </items>
            <items id="at0010">
                <description>En ordination har utfärdats på nytt för en befintlig läkemedelsorder.</description>
                <text>Förnyelse av ordination</text>
            </items>
            <items id="at0011">
                <description>Inväntar återauktorisering för ordination av en läkare.</description>
                <text>Återauktorisering av recept inväntas</text>
            </items>
            <items id="at0012">
                <description>Schemalagd läkemedelsbehandling som har avbrutits före administrering.</description>
                <text>Avbruten läkemedelsbehandling</text>
            </items>
            <items id="at0013">
                <description>Schemalagd läkemedelsbehandling som har blivit uppskjuten före administrering.</description>
                <text>Uppskjuten läkemedelsbehandling</text>
            </items>
            <items id="at0015">
                <description>Administreringen av läkemedlet har avbrutits under det planerade förloppet.</description>
                <text>Avbruten läkemedelsbehandling</text>
            </items>
            <items id="at0016">
                <description>Tid då medicinering startar, eller vid annat startvillkor.</description>
                <text>Läkemedlets startdatum/fastställda villkor</text>
            </items>
            <items id="at0017">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0018">
                <description>Nekad administrering av läkemedlet. Denna dos förväntas inte att ges vid senare tillfälle, även om en eventuellt nästa dos ska administreras enligt planerat.</description>
                <text>Utelämnad dos</text>
            </items>
            <items id="at0020">
                <description>Benämning på läkemedlet, vaccinet eller annan terapeutisk/ordinationsbar artikel som aktiviteten gäller.</description>
                <text>Läkemedelsartikel</text>
            </items>
            <items id="at0021">
                <description>Anledningen till att steget för det aktuella läkemedlet utfördes.</description>
                <text>Orsak</text>
            </items>
            <items id="at0024">
                <description>Kommentarer avseende den aktivitet eller det vårdsteg som inte beskrivs i övriga fält, inklusive detaljer om eventuell avvikelse mellan den avsedda åtgärden och den faktiska utförda åtgärden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0025">
                <description>Det specifika sekvensnumret för det aktuella vårdsteget.</description>
                <text>Sekvensnummer</text>
            </items>
            <items id="at0030">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0033">
                <description>Vägledning, instruktioner eller råd som ges till patienten eller dennes personliga vårdgivare vid tidpunkten för vårdsteget.</description>
                <text>Patientvägledning</text>
            </items>
            <items id="at0039">
                <description>Då en större ändring av ordern krävdes, resulterade detta i att denna order stoppades och en ersättningsorder påbörjades.</description>
                <text>Större orderändring</text>
            </items>
            <items id="at0041">
                <description>Läkemedelsordern har ändrats på ett sätt som inte kräver att en ny order ska utfärdas, enligt lokala kliniska regler.</description>
                <text>Mindre orderändring</text>
            </items>
            <items id="at0043">
                <description>Tidpunkt då hantering av läkemedelsregim var schemalagd.</description>
                <text>Ursprungligt datum/tid</text>
            </items>
            <items id="at0044">
                <description>En dos av läkemedlet har försenats men förväntas administreras så snart som möjligt.</description>
                <text>Uppskjuten dos</text>
            </items>
            <items id="at0053">
                <description>Ytterligare information om åtgärden, eventuellt specifikt för ett särskilt vårdsteg.</description>
                <text>Övrig information</text>
            </items>
            <items id="at0085">
                <description>Plats för att infoga tilläggsinformation som krävs för lokala anpassningar eller anpassning till andra referensmodeller eller formella krav.</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0103">
                <description>Unik identifikator för läkemedelsbeställningen.</description>
                <text>Beställnings-ID</text>
            </items>
            <items id="at0104">
                <description>Information om läkemedlet inklusive dess styrka, form och beståndsdelar.</description>
                <text>Läkemedelsinformation</text>
            </items>
            <items id="at0106">
                <description>Den ursprungliga läkemedelsorden har godkänts på nytt för att möjliggöra fortsatt dosering. I vissa jurisdiktioner måste en helt ny order utfärdas.</description>
                <text>Förnyelse av receptbeläggning</text>
            </items>
            <items id="at0109">
                <description>Rekommenderat läkemedel, ej påbörjad ordination.</description>
                <text>Rekommenderat läkemedel</text>
            </items>
            <items id="at0131">
                <description>Kvantitet av läkemedelsartikeln.</description>
                <text>Kvantitet</text>
            </items>
            <items id="at0132">
                <description>Substitutionsåtgärder vidtagna av den person som administrerar eller dispenserar läkemedlet.</description>
                <text>Substitution</text>
            </items>
            <items id="at0133">
                <description>Anledning eller motivering till den vidtagna substitutionsåtgärden.</description>
                <text>Orsak för substitution</text>
            </items>
            <items id="at0138">
                <description>Ersättning av läkemedel som är bioekvivalent med det som beställts.</description>
                <text>Utförd substitution</text>
            </items>
            <items id="at0139">
                <description>Trots tillåtelse av läkemedelsordern, ersattes inte ett bioekvivalent läkemedel.</description>
                <text>Ej utförd substitution</text>
            </items>
            <items id="at0140">
                <description>Information om atomisk lokalisering och administrering av läkemedlet.</description>
                <text>Administreringsinformation</text>
            </items>
            <items id="at0141">
                <description>Beskrivning av administrationsstället för den beställda artikeln.</description>
                <text>Anatomisk lokalisering</text>
            </items>
            <items id="at0142">
                <description>Närmare beskrivning av administrationsstället för läkemedlet, vaccinet eller annan terapeutisk produkt.</description>
                <text>Exakt anatomisk lokalisering</text>
            </items>
            <items id="at0143">
                <description>Den teknik eller utrustning med vilken den beställda artikeln administrerades eller ska administreras.</description>
                <text>Administreringsmetod</text>
            </items>
            <items id="at0144">
                <description>Information om den medicinska utrustning som används vid administrering av läkemedlet.</description>
                <text>Utrustning för administrering</text>
            </items>
            <items id="at0145">
                <description>Förslag på ordination har utarbetats och inväntar bekräftelse från en auktoriserad läkare. Kan användas där återauktorisering utförs som en batch. Detta flödessteg kan ha statusen "planerad" eller "aktiv", vilket återspeglar behovet av att hantera nya beställningar såväl som återauktoriserade ordrar.</description>
                <text>Ordination som inväntar tillstånd</text>
            </items>
            <items id="at0147">
                <description>Sättet genom vilken den beställda artikeln administrerades eller ska administreras i patientens kropp.</description>
                <text>Administreringsväg</text>
            </items>
            <items id="at0148">
                <description>*The medication has been physically prepared. (en)</description>
                <text>Förberedelse av läkemedel</text>
            </items>
            <items id="at0149">
                <description>Vårdsteget har dubbelkontrollerats av annan individ.</description>
                <text>Dubbelkontrollerat?</text>
            </items>
            <items id="at0150">
                <description>Ordinationen avbröts innan det utfärdades.</description>
                <text>Avbruten ordination</text>
            </items>
            <items id="at0151">
                <description>Receptet har ogiltigförklarats eller upphört att gälla.</description>
                <text>Ogiltigt eller utgånget recept</text>
            </items>
            <items id="at0152">
                <description>Receptet har framgångsrikt uppfyllts.</description>
                <text>Uppfyllt recept</text>
            </items>
            <items id="at0153">
                <description>Läkemedlet har formellt godkänts för användning.</description>
                <text>Godkännande av läkemedel</text>
            </items>
            <items id="at0154">
                <description>Datum/tid för omstart av läkemedelsbehandling, enligt "Indragen administrering".</description>
                <text>Datum/tid för omstart</text>
            </items>
            <items id="at0155">
                <description>Kriteriet för omstart av läkemedelsbehandling, enligt "Indragen administrering".</description>
                <text>Omstartskriterium</text>
            </items>
            <items id="at0156">
                <description>Klinisk orsak till läkemedelsbehandling.</description>
                <text>Klinisk indikation</text>
            </items>
            <items id="at0157">
                <description>*The prepared medication has been double checked. (en)</description>
                <text>*Medication double checked (en)</text>
            </items>
            <items id="at0158">
                <description>*An administration of a dose of the medication was started but was subsequently aborted. (en)</description>
                <text>*Dose administration aborted (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Qualquer atividade relacionada ao planejamento, agendamento, gestão da prescrição, dispensação, administração, término e outro uso de um medicamento, vacina, produto nutricional ou outro item terapêutico.</description>
                <text>Gestão de medicação</text>
            </items>
            <items id="at0002">
                <description>Uma prescrição foi emitida para a medicação.</description>
                <text>Prescrição emitida</text>
            </items>
            <items id="at0003">
                <description>Uma prescrição de medicação foi aviada, por exemplo de uma farmácia ao paciente.</description>
                <text>Prescrição aviada</text>
            </items>
            <items id="at0004">
                <description>A medicação foi adquirida, ou administrada, ao paciente pela primeira vez. Embora em algumas situações esta data significativa pode ser computada como a primeira de muitas administrações, em outras, como na atenção primária, datas de administração específicas não estão prontamente disponíveis. &#13;
</description>
                <text>Curso da medicação iniciado</text>
            </items>
            <items id="at0005">
                <description>O item de medicação específico foi revisado, conforme planejado. Este não pretende capturar uma revisão da lista completa de medicação.</description>
                <text>Curso da medicação revisado</text>
            </items>
            <items id="at0006">
                <description>Dose do medicamento foi administrada.</description>
                <text>Dose administrada</text>
            </items>
            <items id="at0007">
                <description>O tratamento medicamentoso foi finalizado conforme previsto.</description>
                <text>Final do tratamento medicamentoso</text>
            </items>
            <items id="at0008">
                <description>A prescrição não foi aviada devido a um problema técnico ou de suprimento farmacêutico.</description>
                <text>Suprimento da prescrição atrasado</text>
            </items>
            <items id="at0009">
                <description>A administração do medicamento foi suspensa até nova ordem. Doses adicionais não devem ser administradas até que a data de reinício ou condições forem alcançadas. Na configuração de nova data/condições para reinício após a suspensão, deve-se realizar a etapa de suspensão de Administrações suspensas e voltar a Data do início/ Condição de início.</description>
                <text>Administração suspensa</text>
            </items>
            <items id="at0010">
                <description>Nova liberação de prescrição já existente.</description>
                <text>Nova liberação de prescrição</text>
            </items>
            <items id="at0011">
                <description>Reemissão da prescrição não está disponível sem alguma intervenção.</description>
                <text>Reemissão da prescrição suspensa</text>
            </items>
            <items id="at0012">
                <description>O curso planejado da medicação foi cancelado antes de qualquer administração.</description>
                <text>Curso da medicação cancelado</text>
            </items>
            <items id="at0013">
                <description>O curso planejado da medicação foi adiado antes de qualquer administração.</description>
                <text>Curso da medicação adiado</text>
            </items>
            <items id="at0015">
                <description>A administração desta medicação foi interrompida após administração da primeira dose, mas antes de completar o curso pretendido.</description>
                <text>Curso da medicação interrompido</text>
            </items>
            <items id="at0016">
                <description>A hora de começar a medicação, ou outra condição para iniciar o tratamento foi estabelecida.</description>
                <text>Data do início/ Condição de início</text>
            </items>
            <items id="at0017">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0018">
                <description>A administração de um medicamento foi suspensa e não realizada. Não há expectativa de que será dada mais tarde, embora a próxima dose (se houver) deva ser administrada conforme a prescrição original.</description>
                <text>Omissão da administração da dose</text>
            </items>
            <items id="at0020">
                <description>Nome do medicamento, vacina ou outro item terapêutico que foi o foco da atividade.</description>
                <text>Item de medicação</text>
            </items>
            <items id="at0021">
                <description>Motivo pelo qual a etapa para determinada medicação foi realizada.</description>
                <text>Motivo</text>
            </items>
            <items id="at0024">
                <description>Narrativa adicional sobre a atividade ou etapa do fluxo de cuidado não capturada em outros campos, incluindo detalhes de quaisquer variáveis entre a ação pretendida e a ação realmente realizada.</description>
                <text>Comentário</text>
            </items>
            <items id="at0025">
                <description>O número sequencial específico da atividade registrada.</description>
                <text>Número sequencial</text>
            </items>
            <items id="at0030">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0033">
                <description>Quaisquer orientações, instruções ou conselhos dados ao sujeito do cuidado ou cuidador no momento</description>
                <text>Orientação ao paciente</text>
            </items>
            <items id="at0039">
                <description>Foi necessário realizar uma alteração significativa na prescrição, resultando no cancelamento da atual e a substituição por uma nova prescrição.</description>
                <text>Alteração significativa na prescrição</text>
            </items>
            <items id="at0041">
                <description>A prescrição foi alterada de uma forma que não exige uma nova liberação da prescrição, de acordo com as regras clínicas locais.</description>
                <text>Prescrição com mínimas mudanças</text>
            </items>
            <items id="at0043">
                <description>Data/hora na qual a foi agendada ação da medicação.</description>
                <text>Data/hora original do agendamento</text>
            </items>
            <items id="at0044">
                <description>A administração de uma dose de medicamento foi adiada, mas espera-se que seja administrada o mais rápido possível.</description>
                <text>Administração da dose adiada</text>
            </items>
            <items id="at0053">
                <description>Demais detalhes estruturados da ação, possivelmente específicos à etapa do processo.</description>
                <text>Detalhes adicionais</text>
            </items>
            <items id="at0085">
                <description>Informações adicionais necessárias para capturar o conteúdo local ou para se alinhar com outros modelos de referência / formalismos.</description>
                <text>Extensão</text>
            </items>
            <items id="at0103">
                <description>Identificador único para a solicitação de medicação.</description>
                <text>Identificação da solicitação</text>
            </items>
            <items id="at0104">
                <description>Detalhes estruturados sobre a medicação incluindo concentração, forma e componentes.</description>
                <text>Detalhes da medicação</text>
            </items>
            <items id="at0106">
                <description>A solicitação original da medicação foi reautorização para permitir prescrição ou dispensação repetida. Em algumas jurisdições uma nova solicitação deve ser emitida nestas circunstâncias.</description>
                <text>Prescrição reautorizada</text>
            </items>
            <items id="at0109">
                <description>Medicamento foi recomendado mas nenhuma ação foi realizada para iniciar a prescrição.</description>
                <text>Medicamento recomendado</text>
            </items>
            <items id="at0131">
                <description>Detalhes específicos sobre a quantidade do item de medicação.</description>
                <text>Quantidade</text>
            </items>
            <items id="at0132">
                <description>Ação de substituição realizada pela pessoa que administrou ou dispensou o medicamento.</description>
                <text>Substituição</text>
            </items>
            <items id="at0133">
                <description>O motivo ou justificativa para a ação de substituição realizada.</description>
                <text>Motivo da substituição</text>
            </items>
            <items id="at0138">
                <description>A medicação substituída é bioequivalente àquela prescrita.</description>
                <text>Substituição realizada</text>
            </items>
            <items id="at0139">
                <description>Embora permitido pela prescrição da medicação a substituição por um medicamento bioequivalente não foi realizada.</description>
                <text>Substituição não realizada</text>
            </items>
            <items id="at0140">
                <description>Detalhes do local do corpo e administração da medicação.</description>
                <text>Detalhes da administração</text>
            </items>
            <items id="at0141">
                <description>Descrição estruturada do local de administração do item prescrito.</description>
                <text>Local do corpo</text>
            </items>
            <items id="at0142">
                <description>Descrição estruturada do local de administração do medicamento, vacina ou insumo terapêutico.</description>
                <text>Local do corpo estruturado</text>
            </items>
            <items id="at0143">
                <description>A técnica ou dispositivo pelo qual o item foi, ou deve ser, administrado.</description>
                <text>Método de administração</text>
            </items>
            <items id="at0144">
                <description>Detalhes do dispositivo médico usado para auxiliar a administração do medicamento.</description>
                <text>Dispositivo de administração</text>
            </items>
            <items id="at0145">
                <description>Rascunho da prescrição foi preparado e está aguardando confirmação de um clínico autorizado. Pode ser usado quando reautorizações são realizadas em lote. Esta etapa do processo de cuidado pode ter um estado de "planejado" ou "ativo", refletindo a necessidade de gerir novas solicitações assim como solicitações reautorizadas.</description>
                <text>Prescrição no aguardo de autorização</text>
            </items>
            <items id="at0147">
                <description>A via pela qual o item prescrito foi, ou deve ser, administrado no corpo do indivíduo.</description>
                <text>Via</text>
            </items>
            <items id="at0148">
                <description>*The medication has been physically prepared. (en)</description>
                <text>Medicamento preparado</text>
            </items>
            <items id="at0149">
                <description>Uma ação que foi checada por outro indivíduo.</description>
                <text>Dupla checagem?</text>
            </items>
            <items id="at0150">
                <description>A prescrição foi cancelada antes de ser emitida.</description>
                <text>Prescrição cancelada</text>
            </items>
            <items id="at0151">
                <description>A prescrição foi invalidada ou expirou sem ser aviada.</description>
                <text>Prescrição inválida ou cancelada</text>
            </items>
            <items id="at0152">
                <description>A prescrição foi aviada com sucesso.</description>
                <text>Prescrição aviada</text>
            </items>
            <items id="at0153">
                <description>A medicação foi formalmente autorizada para uso.</description>
                <text>Medicação autorizada</text>
            </items>
            <items id="at0154">
                <description>A data/hora na qual o curso da medicação está configurado para reiniciar, como a etapa "Conjunto de condições para reinício da medicação" do processo.</description>
                <text>Data/hora do reinício</text>
            </items>
            <items id="at0155">
                <description>O critério que desencadeia o reinício do curso da medicação, como uma etapa "Conjunto de condições para reinício da medicação" do processo.</description>
                <text>Critério do reinício</text>
            </items>
            <items id="at0156">
                <description>*The clinical reason for the medication activity. (en)</description>
                <text>*Clinical indication (en)</text>
            </items>
            <items id="at0157">
                <description>*The prepared medication has been double checked. (en)</description>
                <text>*Medication double checked (en)</text>
            </items>
            <items id="at0158">
                <description>*An administration of a dose of the medication was started but was subsequently aborted. (en)</description>
                <text>*Dose administration aborted (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Any activity related to the planning, scheduling, prescription management, dispensing, administration, cessation and other use of a medication, vaccine, nutritional product or other therapeutic item.</description>
                <text>Medication management</text>
            </items>
            <items id="at0002">
                <description>A prescription has been issued for the medication.</description>
                <text>Prescription issued</text>
            </items>
            <items id="at0003">
                <description>The ordered medication has been dispensed, for example from a pharmacy to the patient.</description>
                <text>Prescription dispensed</text>
            </items>
            <items id="at0004">
                <description>The medication has been taken by, or administered to, the patient for the first time. Although in some settings this significant date may be computable as the first of several administrations, in other settings, such as primary care, specific administration dates are not readily available.</description>
                <text>Medication course commenced</text>
            </items>
            <items id="at0005">
                <description>The individual medication has been reassessed, for example whether the medication should still be taken. This is not intended to capture review of the medication list.</description>
                <text>Medication reassessed</text>
            </items>
            <items id="at0006">
                <description>A single administration of the medication has taken place.</description>
                <text>Dose administered</text>
            </items>
            <items id="at0007">
                <description>The medication course has been completed as planned.</description>
                <text>Medication course completed</text>
            </items>
            <items id="at0008">
                <description>The prescription has not been dispensed due to a technical or pharamaceutical supply issue.</description>
                <text>Prescription supply delayed</text>
            </items>
            <items id="at0009">
                <description>The administration of the medication has been suspended until further notice. No further doses should be given until the restart date or conditions have been met. When setting the date/conditions for restart after suspending, a step from ‘Administrations suspended’ and back to 'Medication start date/condition set' should be performed.</description>
                <text>Administrations suspended</text>
            </items>
            <items id="at0010">
                <description>A prescription has been re-issued for an existing medication order.</description>
                <text>Prescription re-issued</text>
            </items>
            <items id="at0011">
                <description>Issue of the prescription is awaiting re-authorisation by a clinician.</description>
                <text>Prescription re-authorisation pending</text>
            </items>
            <items id="at0012">
                <description>The planned course of medication has been cancelled prior to any administration.</description>
                <text>Medication course cancelled</text>
            </items>
            <items id="at0013">
                <description>The scheduled medication course has been postponed prior to any administration.</description>
                <text>Medication course postponed</text>
            </items>
            <items id="at0015">
                <description>Administration of the medication has been ceased during the period of the intended course.</description>
                <text>Medication course stopped</text>
            </items>
            <items id="at0016">
                <description>The time to start the medication, or other starting condition, has been set.</description>
                <text>Medication start date/condition set</text>
            </items>
            <items id="at0017">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0018">
                <description>An administration of the medication has been withheld and not given. There is no expectation that it will be given later, though the next dose (if any) should be administered according to the original order.</description>
                <text>Dose administration omitted</text>
            </items>
            <items id="at0020">
                <description>Name of the medication, vaccine or other therapeutic/prescribable item which was the focus of the activity.</description>
                <text>Medication item</text>
            </items>
            <items id="at0021">
                <description>Reason that the pathway step for the identified medication was carried out.</description>
                <text>Reason</text>
            </items>
            <items id="at0024">
                <description>Additional narrative about the activity or pathway step not captured in other fields, including details of any variance between the intended action and the action actually performed.</description>
                <text>Comment</text>
            </items>
            <items id="at0025">
                <description>The sequence number specific to the pathway step being recorded.</description>
                <text>Sequence number</text>
            </items>
            <items id="at0030">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0033">
                <description>Any guidance, instructions or advice given to the subject of care or personal carer at the time of the pathway step.</description>
                <text>Patient guidance</text>
            </items>
            <items id="at0039">
                <description>A major change to the order was required, resulting in this order being stopped and a replacement order being started.</description>
                <text>Major change to order</text>
            </items>
            <items id="at0041">
                <description>The medication order has been changed in a manner which does not require a new instruction/order to be issued, according to local clinical rules.</description>
                <text>Minor change to order</text>
            </items>
            <items id="at0043">
                <description>The datetime at which the medication action was scheduled to occur.</description>
                <text>Original scheduled date/time</text>
            </items>
            <items id="at0044">
                <description>An administration of a dose of the medication has been delayed but is expected to be given as soon as possible.</description>
                <text>Dose administration deferred</text>
            </items>
            <items id="at0053">
                <description>Further structured details of the action, possibly specific to a pathway step.</description>
                <text>Additional details</text>
            </items>
            <items id="at0085">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0103">
                <description>Unique identifier for the medication order.</description>
                <text>Order ID</text>
            </items>
            <items id="at0104">
                <description>Structured details about the medication including strength, form and constituent substances.</description>
                <text>Medication details</text>
            </items>
            <items id="at0106">
                <description>The original medication order has been re-authorised to allow repeat prescription or dispensing. In some jurisdictions an entirely new order must be issued in these circumstances.</description>
                <text>Prescription re-authorised</text>
            </items>
            <items id="at0109">
                <description>The medication has been recommended but no steps have been taken to initiate prescribing.</description>
                <text>Medication recommended</text>
            </items>
            <items id="at0131">
                <description>Specific details about the amount of the medication item.</description>
                <text>Amount</text>
            </items>
            <items id="at0132">
                <description>Subsitution action taken by the person administering or dispensing the drug.</description>
                <text>Substitution</text>
            </items>
            <items id="at0133">
                <description>The reason or justification for the substitution action taken.</description>
                <text>Substitution reason</text>
            </items>
            <items id="at0138">
                <description>A medication was substituted which is bioequivalent to that ordered.</description>
                <text>Substitution performed</text>
            </items>
            <items id="at0139">
                <description>Although allowed by the medication order a bioequvalent medication was not substituted.</description>
                <text>Substitution not performed</text>
            </items>
            <items id="at0140">
                <description>Details of body site and administration of the medication.</description>
                <text>Administration details</text>
            </items>
            <items id="at0141">
                <description>Structured description of the site of administration of the ordered item.</description>
                <text>Body site</text>
            </items>
            <items id="at0142">
                <description>Structured description of the site of administration of the medication, vaccine or therapeutic good.</description>
                <text>Structured body site</text>
            </items>
            <items id="at0143">
                <description>The technique or device by which the ordered item was, or is to be, administered.</description>
                <text>Administration method</text>
            </items>
            <items id="at0144">
                <description>Details of the medical device used to assist administration of the medication.</description>
                <text>Administration device</text>
            </items>
            <items id="at0145">
                <description>Draft prescription has been prepared and is awaiting confirmation from an authorised clinician. May be used where reauthorisations are performed as a batch. This careflow_step may have a status of 'planned' or 'active', reflecting the need to to handle new orders as well as re-authorised orders.</description>
                <text>Prescription awaiting authorisation</text>
            </items>
            <items id="at0147">
                <description>The route by which the ordered item was, or is to be, administered into the subject's body.</description>
                <text>Route</text>
            </items>
            <items id="at0148">
                <description>The medication has been physically prepared.</description>
                <text>Medication prepared</text>
            </items>
            <items id="at0149">
                <description>The pathway step has been checked by a separate individual.</description>
                <text>Double-checked?</text>
            </items>
            <items id="at0150">
                <description>The prescription was cancelled prior to being issued.</description>
                <text>Prescription cancelled</text>
            </items>
            <items id="at0151">
                <description>Prescription has been invalidated or has expired without being fulfilled.</description>
                <text>Prescription invalid or expired</text>
            </items>
            <items id="at0152">
                <description>The prescription has been fulfilled successfully.</description>
                <text>Prescription fulfilled</text>
            </items>
            <items id="at0153">
                <description>The medication has been formally authorised for use.</description>
                <text>Medication authorised</text>
            </items>
            <items id="at0154">
                <description>The date/time on which the medication course is set to restart, as per the "Administrations suspended" pathway step.</description>
                <text>Restart date/time</text>
            </items>
            <items id="at0155">
                <description>The criterion which triggers the medication course to restart, as per the "Administrations suspended" pathway step.</description>
                <text>Restart criterion</text>
            </items>
            <items id="at0156">
                <description>The clinical reason for the medication activity.</description>
                <text>Clinical indication</text>
            </items>
            <items id="at0157">
                <description>The prepared medication has been double checked.</description>
                <text>Medication double checked</text>
            </items>
            <items id="at0158">
                <description>An administration of a dose of the medication was started but was subsequently aborted.</description>
                <text>Dose administration aborted</text>
            </items>
        </term_definitions>
        <term_definitions language="ar-sy">
            <items id="at0000">
                <description>*Any activity related to the planning, scheduling, prescription management, dispensing, administration, cessation and other use of a medication, vaccine, nutritional product or other therapeutic item.(en)</description>
                <text>*Medication management(en)</text>
            </items>
            <items id="at0002">
                <description>*A prescription has been issued for the medication.(en)</description>
                <text>*Prescription issued(en)</text>
            </items>
            <items id="at0003">
                <description>*The ordered medication has been dispensed, for example from a pharmacy to the patient.(en)</description>
                <text>*Prescription dispensed(en)</text>
            </items>
            <items id="at0004">
                <description>*The medication has been taken by, or administered to, the patient for the first time. Although in some settings this significant date may be computable as the first of several administrations, in other settings, such as primary care, specific administration dates are not readily available.(en)</description>
                <text>*Medication course commenced(en)</text>
            </items>
            <items id="at0005">
                <description>*The specific medication item has been reviewed, as planned. This is not intended to capture review of the whole medication list.(en)</description>
                <text>*Medication course reviewed(en)</text>
            </items>
            <items id="at0006">
                <description>*A single administration of the medication has taken place.(en)</description>
                <text>*Dose administered(en)</text>
            </items>
            <items id="at0007">
                <description>*The medication course has been completed as planned.(en)</description>
                <text>*Medication course completed(en)</text>
            </items>
            <items id="at0008">
                <description>*The prescription has not been dispensed due to a technical or pharamaceutical supply issue.(en)</description>
                <text>*Prescription supply delayed(en)</text>
            </items>
            <items id="at0009">
                <description>*The administration of the medication has been suspended until further notice. No further doses should be given until the restart date or conditions have been met. When setting the date/conditions for restart after suspending, a step from ‘Administrations suspended’ and back to 'Medication start date/condition set' should be performed.(en)</description>
                <text>*Administrations suspended(en)</text>
            </items>
            <items id="at0010">
                <description>*A prescription token has been re-issued for an existing medication order.(en)</description>
                <text>*Prescription re-issued(en)</text>
            </items>
            <items id="at0011">
                <description>*Reissuing of this prescription is not available without some intervention.(en)</description>
                <text>*Prescription re-issue suspended(en)</text>
            </items>
            <items id="at0012">
                <description>*The planned course of medication has been cancelled prior to any administration.(en)</description>
                <text>*Medication course cancelled(en)</text>
            </items>
            <items id="at0013">
                <description>*The scheduled medication course has been postponed prior to any administration.(en)</description>
                <text>*Medication course postponed(en)</text>
            </items>
            <items id="at0015">
                <description>*The administration of this medication has been ceased after the first dose has been administered, but before intended completion of the course.  (en)</description>
                <text>*Medication course stopped(en)</text>
            </items>
            <items id="at0016">
                <description>*The time to start this medication, or other starting condition, has been set.(en)</description>
                <text>*Medication start date/condition set(en)</text>
            </items>
            <items id="at0017">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0018">
                <description>*The administration of a medication has been withheld and not given. There is no expectation that it will be given later, though the next dose (if any) should be administered according to the original order.(en)</description>
                <text>*Dose administration omitted(en)</text>
            </items>
            <items id="at0020">
                <description>*Name of the medication, vaccine or other therapeutic/prescribable item which was the focus of the activity.(en)</description>
                <text>*Medication item(en)</text>
            </items>
            <items id="at0021">
                <description>*Reason that the pathway step for the identified medication was carried out.(en)</description>
                <text>*Reason(en)</text>
            </items>
            <items id="at0024">
                <description>*Additional narrative about the activity or care pathway step not captured in other fields, including details of any variance between the intended action and the action actually performed.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0025">
                <description>*The sequence number specific to the activity being recorded.(en)</description>
                <text>*Sequence number(en)</text>
            </items>
            <items id="at0030">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0033">
                <description>*Any guidance, instructions or advice given to the subject of care or personal carer at the time of the pathway step.(en)</description>
                <text>*Patient guidance(en)</text>
            </items>
            <items id="at0039">
                <description>*A major change to the order was required, resulting in this order being stopped and a replacement order being started.(en)</description>
                <text>*Major change to order.(en)</text>
            </items>
            <items id="at0041">
                <description>*The medication order has been changed in a manner which does not require a new instruction/order to be issued, according to local clinical rules.(en)</description>
                <text>*Minor change to order(en)</text>
            </items>
            <items id="at0043">
                <description>*The datetime at which the medication action was scheduled to occur.(en)</description>
                <text>*Original scheduled date/time(en)</text>
            </items>
            <items id="at0044">
                <description>*Administration of a dose of mediciation has been delayed but is expected to be given as soon as possible.(en)</description>
                <text>*Dose administration deferred(en)</text>
            </items>
            <items id="at0053">
                <description>*Further structured details of the action, possibly specific to a pathway step.(en)</description>
                <text>*Additional details(en)</text>
            </items>
