                <text>Detalls de l'examen</text>
            </items>
            <items id="at0006">
                <description>Una sola paraula, frase o descripció breu que englobi el significat clínic i la importància de les troballes de l'examen físic.</description>
                <text>Interpretació</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descripció dels factors que puguin haver obstruït o dificultat les troballes de l'examen físic.</description>
                <text>Factors de confusió</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalls sobre qualsevol dispositiu utilitzat durant l'examen físic.</description>
                <text>Detalls del dispositiu</text>
            </items>
            <items id="at0011">
                <description>Informació narrativa addicional sobre les troballes durant l'examen físic no registrats a altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0012">
                <description>Informació addicional requerida per registrar contingut local o alinear amb altres models o formalismes.</description>
                <text>Ampliació</text>
            </items>
            <items id="at0013">
                <description>Posició del pacient durant l'examen.</description>
                <text>Posició</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-INSTRUCTION.care_plan_request.v0" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Ordem ou instrução para a criação e série de atividades para alcançar uma meta específica de gestão ou resultado do tratamento, realizado por profissionais de saúde e / ou do assunto.</description>
                <text>Plano de cuidados</text>
            </items>
            <items id="at0001">
                <description>Atividade atual.</description>
                <text>Atividade</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0007">
                <description>Descrição do escopo do plano de cuidados, intenção e propostas de atividades.</description>
                <text>Descrição</text>
            </items>
            <items id="at0011">
                <description>Indicação para o plano de cuidados.</description>
                <text>Indicação</text>
            </items>
            <items id="at0017">
                <description>Identificação do plano de cuidados.</description>
                <text>Nome do plano de cuidados</text>
            </items>
            <items id="at0018">
                <description>Data do início do plano de cuidados.</description>
                <text>Data do início</text>
            </items>
            <items id="at0019">
                <description>Narrativa adicional sobre a ordem de plano de cuidados não capturados em outros campos.</description>
                <text>Comentário</text>
            </items>
            <items id="at0020">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0021">
                <description>**(en)</description>
                <text>*Cluster(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Order or instruction for the creation and sequence of activities to achieve a specified management goal or treatment outcome, carried out by health professionals and/or the subject.</description>
                <text>Care plan request</text>
            </items>
            <items id="at0001">
                <description>Current Activity.</description>
                <text>Activity</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0007">
                <description>Description of the care plan scope, intent and proposed activities.</description>
