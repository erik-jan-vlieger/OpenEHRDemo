                <text>دمای بدن</text>
            </items>
            <items id="at0001">
                <description>*</description>
                <text>منفرد</text>
            </items>
            <items id="at0002">
                <description>*@ internal @(en)</description>
                <text>*History(en)</text>
            </items>
