                <text>Service type</text>
            </items>
            <items id="at0149">
                <description>Digital document, image, video or diagram supplied as additional information to support or inform the request.</description>
                <text>Supporting information</text>
            </items>
            <items id="at0150">
                <description>Additional narrative about the service request not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0151">
                <description>Details about a complex service request requiring a sequence of timings.</description>
                <text>Complex timing</text>
            </items>
            <items id="at0152">
                <description>The symptom, sign or diagnosis that necessitates the requested service.</description>
                <text>Clinical indication</text>
            </items>
            <items id="at0153">
                <description>Additional details and instructions about how the services are to be delivered.</description>
                <text>Order detail</text>
            </items>
            <items id="at0154">
                <description>Narrative information about the individual and their situation, providing relevant context for the request.</description>
                <text>Clinical context</text>
            </items>
            <items id="at0155">
                <description>Details about the designated contact person or organisation and preferred mode of contact for urgent or emergency notifications related to this request.</description>
                <text>Urgent contact</text>
            </items>
            <items id="at0156">
                <description>A recommendation from the requester to the receiver about the method of payment for the service.</description>
                <text>Billing guidance</text>
            </items>
            <items id="at0157">
                <description>Details about the individual or organisation who will assume responsibility for payment of the service.</description>
                <text>Responsible payer</text>
            </items>
            <items id="at0158">
                <description>Advice from the requester to the receiver about the individual's eligibility for the requested service.</description>
                <text>Eligibility guidance</text>
            </items>
        </term_definitions>
        <term_definitions language="it">
            <items id="at0000">
                <description>Richiesta di un servizio o di un'attività sanitaria da parte di un clinico, di un'organizzazione o di un'agenzia.</description>
                <text>Richiesta di un servizio.</text>
            </items>
            <items id="at0001">
                <description>Attività corrente.</description>
                <text>Attività corrente</text>
            </items>
            <items id="at0008">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>L'identificativo locale assegnato dal sistema clinico richiedente.</description>
                <text>Identificativo dell'ordine per il richiedente</text>
            </items>
            <items id="at0011">
                <description>L'identificativo locale assegnato alla richiesta dal clinico o dall'organizzazione che riceve la richiesta per il servizio.</description>
                <text>Identificativo dell'ordine per il ricevente</text>
            </items>
            <items id="at0040">
                <description>*The date/time or description about timing for provision of the requested service/s. (en)</description>
                <text>*Service due (en)</text>
            </items>
            <items id="at0062">
                <description>*The specific problem needing attention or the clinical question that requires investigation. (en)</description>
                <text>Motivo della richiesta</text>
            </items>
            <items id="at0064">
                <description>*Narrative description about the issue or clinical query that needs resolution.  (en)</description>
                <text>Descrizione del motivo</text>
            </items>
            <items id="at0065">
                <description>*Description of the intended outcome of the request. (en)</description>
                <text>Intento</text>
            </items>
            <items id="at0068">
                <description>Urgenza per la richiesta di servizio</description>
                <text>Urgenza</text>
            </items>
            <items id="at0076">
                <description>Indicazione sul fatto che informazioni supplementari saranno fornite su richiesta.</description>
                <text>Informazioni supplementari</text>
            </items>
            <items id="at0078">
                <description>Descrizione delle informazioni supplementari.</description>
                <text>Descrizione delle informazioni</text>
            </items>
            <items id="at0112">
                <description>*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</description>
                <text>Estensione</text>
            </items>
            <items id="at0116">
                <description>Lingua, trasporto o altre esigenze personali per sostenere la presenza o la partecipazione del paziente alla fornitura del servizio.</description>
                <text>Requisiti per il paziente</text>
            </items>
            <items id="at0121">
                <description>*The name of the service/s requested. (en)</description>
                <text>Nome del servizio</text>
            </items>
            <items id="at0127">
                <description>Lo stato della richiesta di servizio come indicato dal richiedente.</description>
                <text>Stato della richiesta</text>
            </items>
            <items id="at0128">
                <description>Dettagli di altri medici, organizzazioni o agenzie che richiedono copie di qualsiasi comunicazione.</description>
                <text>Lista di distribuzione</text>
            </items>
            <items id="at0132">
                <description>Ulteriori dettagli sul servizio richiesto.</description>
                <text>Dettagli specifici</text>
            </items>
            <items id="at0135">
                <description>Descrizione narrativa del servizio richiesto.</description>
                <text>Descrizione</text>
            </items>
            <items id="at0136">
                <description>La richiesta richiede un'attenzione immediata.</description>
                <text>Emergenza</text>
            </items>
            <items id="at0137">
                <description>La richiesta richiede un'attenzione prioritaria. </description>
                <text>Urgente</text>
            </items>
            <items id="at0138">
                <description>La richiesta non richiede una programmazione con priorità.</description>
                <text>Routine</text>
            </items>
            <items id="at0141">
                <description>Dettagli sul clinico o sull'organizzazione che richiede il servizio.</description>
                <text>Richiedente</text>
            </items>
            <items id="at0142">
                <description>Dettagli sul clinico o sull'organizzazione che riceve la richiesta di servizio.</description>
                <text>Ricevente</text>
            </items>
            <items id="at0148">
                <description>Categoria di servizio richiesto.</description>
                <text>*Service type (en)</text>
            </items>
            <items id="at0149">
                <description>Documento digitale, immagine, video o diagramma forniti come informazioni aggiuntive per supportare o motivare la richiesta.</description>
                <text>Informazione di supporto</text>
            </items>
            <items id="at0150">
                <description>Narrativa aggiuntiva sulla richiesta di servizio non acquisita in altri campi.</description>
                <text>Commento</text>
            </items>
            <items id="at0151">
                <description>Dettagli su una richiesta di servizio complessa che richiede una sequenza di temporizzazioni.</description>
                <text>Tempistica complessa</text>
            </items>
            <items id="at0152">
                <description>*The symptom, sign or diagnosis that necessitates the requested service. (en)</description>
                <text>Indicazione clinica</text>
            </items>
            <items id="at0153">
                <description>*Additional details and instructions about how the services are to be delivered. (en)</description>
                <text>*Order detail (en)</text>
            </items>
            <items id="at0154">
                <description>*Narrative information about the individual and their situation, providing relevant context for the request. (en)</description>
                <text>*Clinical context (en)</text>
            </items>
            <items id="at0155">
                <description>*Details about the designated contact person or organisation and preferred mode of contact for urgent or emergency notifications related to this request. (en)</description>
                <text>*Urgent contact (en)</text>
            </items>
            <items id="at0156">
                <description>*A recommendation from the requester to the receiver about the method of payment for the service. (en)</description>
                <text>*Billing guidance (en)</text>
            </items>
            <items id="at0157">
                <description>*Details about the individual or organisation who will assume responsibility for payment of the service. (en)</description>
                <text>*Responsible payer (en)</text>
            </items>
            <items id="at0158">
                <description>*Advice from the requester to the receiver about the individual's eligibility for the requested service. (en)</description>
                <text>*Eligibility guidance (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="nl">
            <items id="at0000">
                <description>Verzoek om een gezondheidsgerelateerde dienst of activiteit te leveren door een arts, organisatie of instantie.</description>
                <text>Serviceverzoek</text>
            </items>
            <items id="at0001">
                <description>Huidige Activity</description>
                <text>Huidige Activity</text>
            </items>
            <items id="at0008">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>De lokale identificatie die is toegewezen door het aanvragende klinische systeem.</description>
                <text>Identificatie verzoeksaanvrager</text>
            </items>
            <items id="at0011">
                <description>De lokale identificatie die aan het verzoek is toegewezen door de zorgverlener of organisatie die het verzoek voor service ontvangt.</description>
                <text>Identificatie verzoek ontvanger</text>
            </items>
            <items id="at0040">
                <description>*The date/time or description about timing for provision of the requested service/s. (en)</description>
                <text>*Service due (en)</text>
            </items>
            <items id="at0062">
                <description>*The specific problem needing attention or the clinical question that requires investigation. (en)</description>
                <text>Reden voor aanvraag</text>
            </items>
            <items id="at0064">
                <description>*Narrative description about the issue or clinical query that needs resolution.  (en)</description>
                <text>Omschrijving van de reden</text>
            </items>
            <items id="at0065">
                <description>*Description of the intended outcome of the request. (en)</description>
                <text>Bedoeling</text>
            </items>
            <items id="at0068">
                <description>Urgentie van het verzoek om service.</description>
                <text>Urgentie</text>
            </items>
            <items id="at0076">
                <description>Aanvullende informatie volgt op dit verzoek.</description>
                <text>Aanvullende informatie</text>
            </items>
            <items id="at0078">
                <description>Beschrijving van de aanvullende informatie.</description>
                <text>Informatiebeschrijving</text>
            </items>
            <items id="at0112">
                <description>*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</description>
                <text>Uitbreiding</text>
            </items>
            <items id="at0116">
                <description>Taal, vervoer of andere persoonlijke vereisten ter ondersteuning van de aanwezigheid of deelname van de patiënt aan de dienstverlening.</description>
                <text>Vereisten voor patiënt</text>
            </items>
            <items id="at0121">
                <description>*The name of the service/s requested. (en)</description>
                <text>Servicenaam</text>
            </items>
            <items id="at0127">
                <description>De status van het serviceverzoek zoals aangegeven door de aanvrager.</description>
                <text>Status van verzoek</text>
            </items>
            <items id="at0128">
                <description>Details van aanvullende clinici, organisaties of instanties die kopieën van communicatie nodig hebben.</description>
                <text>Distributielijst</text>
            </items>
            <items id="at0132">
                <description>Aanvullende details over de gevraagde service.</description>
                <text>Specifieke details</text>
            </items>
            <items id="at0135">
                <description>Narratieve beschrijving van de gevraagde dienst.</description>
                <text>Omschrijving</text>
            </items>
            <items id="at0136">
                <description>Het verzoek vereist onmiddellijke aandacht.</description>
                <text>Acuut</text>
            </items>
            <items id="at0137">
                <description>Het verzoek vereist geprioriteerde aandacht.</description>
                <text>Urgent</text>
            </items>
            <items id="at0138">
                <description>Het verzoek vereist geen planning met prioriteit.</description>
                <text>Routine</text>
            </items>
            <items id="at0141">
                <description>Details over de zorgverlener of organisatie die de service aanvraagt.</description>
                <text>Aanvrager</text>
            </items>
            <items id="at0142">
                <description>Details over de arts of organisatie die het serviceverzoek ontvangt.</description>
                <text>Ontvanger</text>
            </items>
            <items id="at0148">
                <description>Categorie van de gevraagde service.</description>
                <text>*Service type (en)</text>
            </items>
            <items id="at0149">
                <description>Digital document, image, video or diagram supplied as additional information to support or inform the request.</description>
                <text>Ondersteunende informatie</text>
            </items>
            <items id="at0150">
                <description>Aanvullende opmerking over het serviceverzoek dat niet in andere velden is vastgelegd.</description>
                <text>Opmerking</text>
            </items>
            <items id="at0151">
                <description>Details over een complexe serviceaanvraag die een reeks timings vereist.</description>
                <text>Complexe timing</text>
            </items>
            <items id="at0152">
                <description>*The symptom, sign or diagnosis that necessitates the requested service. (en)</description>
                <text>Klinische indicatie</text>
            </items>
            <items id="at0153">
                <description>*Additional details and instructions about how the services are to be delivered. (en)</description>
                <text>*Order detail (en)</text>
            </items>
            <items id="at0154">
                <description>*Narrative information about the individual and their situation, providing relevant context for the request. (en)</description>
                <text>*Clinical context (en)</text>
            </items>
            <items id="at0155">
                <description>*Details about the designated contact person or organisation and preferred mode of contact for urgent or emergency notifications related to this request. (en)</description>
                <text>*Urgent contact (en)</text>
            </items>
            <items id="at0156">
                <description>*A recommendation from the requester to the receiver about the method of payment for the service. (en)</description>
                <text>*Billing guidance (en)</text>
            </items>
            <items id="at0157">
                <description>*Details about the individual or organisation who will assume responsibility for payment of the service. (en)</description>
                <text>*Responsible payer (en)</text>
            </items>
            <items id="at0158">
                <description>*Advice from the requester to the receiver about the individual's eligibility for the requested service. (en)</description>
                <text>*Eligibility guidance (en)</text>
            </items>
