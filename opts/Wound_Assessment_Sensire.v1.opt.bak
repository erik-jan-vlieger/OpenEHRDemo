            </items>
        </term_definitions>
        <term_definitions language="nb">
            <items id="at0000">
                <description>Detaljer om én identifisert helsetilstand, skade, funksjonshemming eller annet forhold som påvirker et individs fysiske, mentale og/eller sosiale velvære.</description>
                <text>Problem/diagnose</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identifisering av problemet eller diagnosen ved hjelp av navn.</description>
                <text>Problem/diagnosenavn</text>
            </items>
            <items id="at0003">
                <description>Anslått eller faktisk dato/tid da diagnosen eller problemet ble bekreftet av helsepersonell.</description>
                <text>Dato/tid for klinisk bekreftelse</text>
            </items>
            <items id="at0005">
                <description>En vurdering av problemet eller diagnosens overordnede alvorlighetsgrad.</description>
                <text>Alvorlighetsgrad</text>
            </items>
            <items id="at0009">
                <description>Fritekstbeskrivelse av problemet eller diagnosen.</description>
                <text>Klinisk beskrivelse</text>
            </items>
            <items id="at0012">
                <description>Registrering av et enkelt og usammensatt anatomisk sted der problemet eller diagnosen er lokalisert.</description>
                <text>Anatomisk lokalisering</text>
            </items>
            <items id="at0030">
                <description>Estimert eller faktisk dato/tid for bedring eller remisjon av det aktuelle problemet eller diagnosen, fastslått av helsepersonell.</description>
                <text>Dato/tid for bedring/remisjon</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>SLOT som kan inneholde en eller flere detaljerte og strukturerte anatomiske lokaliseringer.</description>
                <text>Strukturert anatomisk lokalisering</text>
            </items>
            <items id="at0043">
                <description>Detaljer som er nødvendige for å registrere det aktuelle problemet eller diagnosens unike egenskaper.</description>
                <text>Spesifikke detaljer</text>
            </items>
            <items id="at0046">
                <description>Strukturerte detaljer for lokalisering-, fagområde-, episode- eller arbeidsflytsspesifikke aspekter av den diagnostiske prosessen.</description>
                <text>Status</text>
            </items>
            <items id="at0047">
                <description>Problemet eller diagnosen forstyrrer ikke normal aktivitet.</description>
                <text>Mild</text>
            </items>
            <items id="at0048">
                <description>Problemet eller diagnosen forstyrrer normal aktivitet.</description>
                <text>Moderat</text>
            </items>
            <items id="at0049">
                <description>Problemet eller diagnosen forhindrer normal aktivitet.</description>
                <text>Alvorlig</text>
            </items>
            <items id="at0069">
                <description>Utdypende fritekst om problemet eller diagnosen, som ikke passer i andre felt.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0070">
                <description>Datoen da problemet eller diagnosen sist ble oppdatert.</description>
                <text>Sist oppdatert</text>
            </items>
            <items id="at0071">
                <description>Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0072">
                <description>Fritekstbeskrivelse av forløpet av problemet eller diagnosen siden debut.</description>
                <text>Forløpsbeskrivelse</text>
            </items>
            <items id="at0073">
                <description>Grad av sikkerhet i identifikasjonen av diagnosen.</description>
                <text>Diagnostisk sikkerhet</text>
            </items>
            <items id="at0074">
                <description>Diagnoses er identifisert med en lav grad av sikkerhet.</description>
                <text>Mistenkt</text>
            </items>
            <items id="at0075">
                <description>Diagnosen er identifisert med en stor grad av sikkerhet.</description>
                <text>Sannsynlig</text>
            </items>
            <items id="at0076">
                <description>Diagnosen er bekreftet opp mot anerkjente kriterier.</description>
                <text>Bekreftet</text>
            </items>
            <items id="at0077">
                <description>Antatt eller faktisk dato/tid da tegn eller symptomer på problemet eller diagnosen først ble observert.</description>
                <text>Dato/ tid for debut</text>
            </items>
            <items id="at0078">
                <description>En årsak, kjede av årsaker til, eller hendelsesforløp forut for problemet eller diagnosen.</description>
                <text>Årsak</text>
            </items>
            <items id="at0079">
                <description>Spesifikk variant eller subtype av diagnose, hvis det er relevant.</description>
                <text>Variant</text>
            </items>
            <items id="at0080">
                <description>Overordnet vurdering av innvirkningen et helseproblem har for individet.</description>
                <text>Innvirkning</text>
            </items>
        </term_definitions>
        <term_definitions language="es-ar">
            <items id="at0000">
                <description>Detalles acerca de una condición de salud, lesión, incapacidad o cualquier otra cuerstión, univocamente identificadas, que impacta sobre el bienestar físico, mental y/o social de un individuo</description>
                <text>Problema/Diagnóstico</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*structure(en)</text>
            </items>
            <items id="at0002">
                <description>Identificación del problema o diagnóstico, por nombre.</description>
                <text>Nombre del problema/diagnóstico</text>
            </items>
            <items id="at0003">
                <description>Fecha y hora estimadas o confirmadas en las cuales el diagnóstico o problema fue reconocido por el profesional de la salud.</description>
                <text>Fecha y hora del reconocimiento clínico</text>
            </items>
            <items id="at0005">
                <description>Una evaluación de la severidad general del problema o diagnóstico.</description>
                <text>Severidad</text>
            </items>
            <items id="at0009">
                <description>Descripción narrativa del problema o diagnóstico.</description>
                <text>Descripción clínica</text>
            </items>
            <items id="at0012">
                <description>Identificación de un sitio corporal simple para la localización o el problema.</description>
                <text>Sitio corporal</text>
            </items>
            <items id="at0030">
                <description>Fecha y hora estimadas o confirmadas en las cuales este problema o diagnóstico remitió o se resolvió, determinadas de un profesional de la salud.</description>
                <text>Fecha/hora de resolución</text>
            </items>
            <items id="at0032">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0039">
                <description>una localización anatómica estructurada para el problema o diagnóstico.</description>
                <text>Sitio corporal estructurado</text>
            </items>
            <items id="at0043">
                <description>Detalles adicionales requeridos para registrar como atributos unívocos del este problema o diagnóstico.</description>
                <text>Detalles específicos</text>
            </items>
            <items id="at0046">
                <description>Detalles estructurados para los aspectos específicos de localización, dominio, episodio o decurso del proceso diagnóstico.</description>
                <text>Estado</text>
            </items>
            <items id="at0047">
                <description>El problema o diagnóstico no interfiere con la actividad normal o puede causar daños a la salud si no es tratado.</description>
                <text>Leve</text>
            </items>
            <items id="at0048">
                <description>El problema o diagnóstico interfiere con la actividad normal o puede dañar la salud si no es tratado.</description>
                <text>Moderado</text>
            </items>
            <items id="at0049">
                <description>El problema o diagnóstico impide la actividad normal o pude dañar seriamente la salud si no es tratado.</description>
                <text>Severo</text>
            </items>
            <items id="at0069">
                <description>Narrativa adicional acerca del problema o diagnóstico que no ha sido consignada en otros campos.</description>
                <text>Comentario</text>
            </items>
            <items id="at0070">
                <description>La fecha de la última actualización de este problema o diagnóstico.</description>
                <text>Última actualización.</text>
            </items>
            <items id="at0071">
                <description>Información adicional requerida para consignar contenidos locales o alinear con otros modelos de referencia o formalismos.</description>
                <text>Extensión</text>
            </items>
            <items id="at0072">
                <description>Descripción narrativa del curso del problema o diagnóstico desde su aparición.</description>
                <text>Descripción del curso</text>
            </items>
            <items id="at0073">
                <description>El nivel de certeza de la identificación del diagnóstico.</description>
                <text>Certeza diagnóstica</text>
            </items>
            <items id="at0074">
                <description>El diagnóstico ha sido identificado con un bajo nivel de certeza.</description>
                <text>Sospechado</text>
            </items>
            <items id="at0075">
                <description>El diagnóstico ha sido identificado con un alto nivel de certeza.</description>
                <text>Probable</text>
            </items>
            <items id="at0076">
                <description>El diagnóstico ha sido confirmado en base a criterios reconocidos.</description>
                <text>Confirmado</text>
            </items>
            <items id="at0077">
                <description>Fecha y hora estimadas o confirmadas en las cuales los signos o síntomas del problema fueron observados por primera vez.</description>
                <text>Fecha/hora de aparición</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
                <text>*Variant (en)</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
