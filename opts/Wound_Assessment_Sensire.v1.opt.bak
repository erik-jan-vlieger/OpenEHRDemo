        <term_definitions language="ca">
            <items id="at0000">
                <description>Informe o resum narratiu sobre un pacient, específicament des de la perspectiva d'un professional d’atenció sanitària, i amb o sense interpretacions associades.</description>
                <text>Sinopsi clínica</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>List</text>
            </items>
            <items id="at0002">
