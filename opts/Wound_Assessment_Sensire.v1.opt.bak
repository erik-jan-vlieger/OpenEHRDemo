            </items>
            <items id="at0057">
                <description>تفاصيل حول مقدم الخدمة الصحية أو المؤسسة التي تستقبل طلب الخدمة.</description>
                <text>المستقبِل</text>
            </items>
            <items id="at0058">
                <description>*Urgency of the procedure.(en)</description>
                <text>*Urgency(en)</text>
            </items>
            <items id="at0060">
                <description>*The date and/or time when the entire procedure, or the last component of a multicomponent procedure,  was finished.(en)</description>
                <text>*Final end date/time(en)</text>
            </items>
            <items id="at0061">
                <description>*The total amount of time taken to complete the procedure, which may include time spent during the active phase of the procedure plus time during which the procedure was suspended.(en)</description>
                <text>*Total duration(en)</text>
            </items>
            <items id="at0062">
                <description>*Mulitimedia representation of a performed procedure.(en)</description>
                <text>*Multimedia(en)</text>
            </items>
            <items id="at0063">
                <description>*Identification of the body site for the procedure.(en)</description>
                <text>*Body site(en)</text>
            </items>
            <items id="at0064">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
            <items id="at0065">
                <description>*Identification of specific method or technique for the procedure.(en)</description>
                <text>*Method(en)</text>
            </items>
            <items id="at0066">
                <description>*The date and/or time on which the procedure is intended to be performed.(en)</description>
                <text>*Scheduled date/time(en)</text>
            </items>
            <items id="at0067">
                <description>*The type of procedure.(en)</description>
                <text>*Procedure type(en)</text>
            </items>
            <items id="at0068">
                <description>*The procedure, or subprocedure in a multicomponent procedure, has been commenced.(en)</description>
                <text>*Procedure commenced(en)</text>
            </items>
            <items id="at0069">
                <description>*Difficulties or issues encountered during the procedure.(en)</description>
                <text>*Procedural difficulty(en)</text>
            </items>
            <items id="at0070">
                <description>*The clinical or process-related reason for the procedure. (en)</description>
                <text>*Indication (en)</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>A clinical activity carried out for screening, investigative, diagnostic, curative, therapeutic, evaluative or palliative purposes.</description>
                <text>Procedure</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identification of the procedure by name.</description>
                <text>Procedure name</text>
            </items>
            <items id="at0003">
                <description>Structured information about the procedure.</description>
                <text>Procedure detail</text>
            </items>
            <items id="at0004">
                <description>The procedure to be undertaken is planned.</description>
                <text>Procedure planned</text>
            </items>
            <items id="at0005">
                <description>Additional narrative about the activity or care pathway step not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0006">
                <description>Details about any complication arising from the procedure.</description>
                <text>Complication</text>
            </items>
            <items id="at0007">
                <description>Request for procedure sent.</description>
                <text>Procedure request sent</text>
            </items>
            <items id="at0014">
                <description>Reason that the activity or care pathway step for the identified procedure was carried out.</description>
                <text>Reason</text>
            </items>
            <items id="at0034">
                <description>This pathway step has been deprecated as it was incorrectly associated with 'initial' status - use the new 'Procedure planned' (at0004) pathway step  which is correctly associated with 'planned' status.</description>
                <text>X - Procedure planned</text>
            </items>
            <items id="at0035">
                <description>This pathway step has been deprecated as it was incorrectly associated with 'initial' status - use the new 'Procedure request sent' (at0007) pathway step  which is correctly associated with 'planned' status.</description>
                <text>X - Procedure request sent</text>
            </items>
            <items id="at0036">
                <description>The procedure has been scheduled.</description>
                <text>Procedure scheduled</text>
            </items>
            <items id="at0038">
                <description>The procedure has been postponed.</description>
                <text>Procedure postponed</text>
            </items>
            <items id="at0039">
                <description>The planned procedure has been cancelled prior to commencement.</description>
                <text>Procedure cancelled</text>
            </items>
            <items id="at0040">
                <description>The procedure has been suspended.</description>
                <text>Procedure suspended</text>
            </items>
            <items id="at0041">
                <description>The procedure has been aborted.</description>
                <text>Procedure aborted</text>
            </items>
            <items id="at0043">
                <description>The procedure has been performed and all associated clinical activities completed.</description>
                <text>Procedure completed</text>
            </items>
            <items id="at0047">
                <description>The procedure, or subprocedure in a multicomponent procedure, has been performed.</description>
                <text>Procedure performed</text>
            </items>
            <items id="at0048">
                <description>Outcome of procedure performed.</description>
                <text>Outcome</text>
            </items>
            <items id="at0049">
                <description>Narrative description about the procedure, as appropriate for the pathway step.</description>
                <text>Description</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>The local ID assigned to the order by the healthcare provider or organisation requesting the service.</description>
                <text>Requestor order identifier</text>
            </items>
            <items id="at0055">
                <description>Details about the healthcare provider or organisation requesting the service.</description>
                <text>Requestor</text>
            </items>
            <items id="at0056">
                <description>The ID assigned to the order by the healthcare provider or organisation receiving the request for service. This is also referred to as Filler Order Identifier.</description>
                <text>Receiver order identifier</text>
            </items>
            <items id="at0057">
                <description>Details about the healthcare provider or organisation receiving the request for service.</description>
                <text>Receiver</text>
            </items>
            <items id="at0058">
                <description>Urgency of the procedure.</description>
                <text>Urgency</text>
            </items>
            <items id="at0060">
                <description>The date and/or time when the entire procedure, or the last component of a multicomponent procedure, was finished.</description>
                <text>Final end date/time</text>
            </items>
            <items id="at0061">
                <description>The total amount of time taken to complete the procedure, which may include time spent during the active phase of the procedure plus time during which the procedure was suspended.</description>
                <text>Total duration</text>
            </items>
            <items id="at0062">
                <description>Mulitimedia representation of a performed procedure.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0063">
                <description>Identification of the body site for the procedure.</description>
                <text>Body site</text>
            </items>
            <items id="at0064">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0065">
                <description>Identification of specific method or technique for the procedure.</description>
                <text>Method</text>
            </items>
            <items id="at0066">
                <description>The date and/or time on which the procedure is intended to be performed.</description>
                <text>Scheduled date/time</text>
            </items>
            <items id="at0067">
                <description>The type of procedure.</description>
                <text>Procedure type</text>
            </items>
            <items id="at0068">
                <description>The procedure, or subprocedure in a multicomponent procedure, has been commenced.</description>
                <text>Procedure commenced</text>
            </items>
            <items id="at0069">
                <description>Difficulties or issues encountered during performance of the procedure.</description>
                <text>Procedural difficulty</text>
            </items>
            <items id="at0070">
                <description>The clinical or process-related reason for the procedure.</description>
                <text>Indication</text>
            </items>
            <items id="at0071">
                <description>Assessment of the impact of a procedure or its outcome for a specific patient.</description>
                <text>Impact</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>为了实现评估类、探查类、筛查类、诊断类、治愈类、疗法类或姑息治疗类等目的而开展的临床活动。</description>
                <text>操作</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>利用名称对于此项操作进行的标识。</description>
                <text>操作名称</text>
            </items>
            <items id="at0003">
                <description>关于此项操作的结构化信息。</description>
                <text>操作详情</text>
            </items>
            <items id="at0004">
                <description>计划有待开展/执行/实施的操作。</description>
                <text>操作已编制计划</text>
            </items>
            <items id="at0005">
                <description>关于其他字段之中并未采集/记录的，关于此项活动或照护服务路径步骤的其他文字叙述型内容。</description>
                <text>注释</text>
            </items>
            <items id="at0006">
                <description>关于此项操作所引发的任何并发症的详情。</description>
                <text>并发症</text>
            </items>
            <items id="at0007">
                <description>已发送关于当前操作的请求。</description>
                <text>操作请求已发送</text>
            </items>
            <items id="at0014">
                <description>关于针对当前操作实际开展/执行此项活动或照护服务路径步骤的原因。</description>
                <text>原因</text>
            </items>
            <items id="at0034">
                <description>目前已弃用此路径步骤，因其错误地关联了“初始”（initial）状态 —— 请采用新的“操作已编制计划”（Procedure planned，编码：at0004）路径步骤，该步骤正确地关联了“已计划”（planned）状态。</description>
                <text>X - 操作已编制计划</text>
            </items>
            <items id="at0035">
                <description>目前已弃用此路径步骤，因其错误地关联了“初始”（initial）状态 —— 请采用新的“操作请求已发送”（Procedure request sent，编码：at0007）路径步骤，该步骤正确地关联了“已计划”（planned）状态。</description>
                <text>X - 操作请求已发送</text>
            </items>
            <items id="at0036">
                <description>目前已对此项操作进行了排程。</description>
                <text>操作已排程</text>
            </items>
            <items id="at0038">
                <description>目前已延期此项操作。</description>
                <text>操作已延期</text>
            </items>
            <items id="at0039">
                <description>已计划的操作在开始之前已被取消。</description>
                <text>操作已取消</text>
            </items>
            <items id="at0040">
                <description>目前已暂停此项操作。</description>
                <text>操作已暂停</text>
            </items>
            <items id="at0041">
                <description>目前已中止此项操作。</description>
                <text>操作已中止</text>
            </items>
            <items id="at0043">
                <description>目前已执行此项操作，且所有相关的临床活动均已完成。</description>
                <text>操作已完成</text>
            </items>
            <items id="at0047">
                <description>目前已执行此项操作（或多组成部分操作之中的此项子操作）。</description>
                <text>操作已执行</text>
            </items>
            <items id="at0048">
                <description>已执行操作的结局。</description>
                <text>结局</text>
            </items>
            <items id="at0049">
                <description>对于此项操作进行的，适合于当前路径步骤的叙述性描述。</description>
                <text>描述</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>申请此项服务的健康医疗服务提供方或机构为此项医嘱所分配的本地标识符。</description>
                <text>申请方医嘱标识符</text>
            </items>
            <items id="at0055">
                <description>关于申请此项服务的健康医疗服务提供方或机构的相关详情。</description>
                <text>申请方</text>
            </items>
            <items id="at0056">
                <description>由接收服务请求的健康医疗服务提供方或机构为此项医嘱所分配的标识符，也称为“执行方医嘱标识符”（Filler Order Identifier）。</description>
                <text>接收方医嘱标识符</text>
            </items>
            <items id="at0057">
                <description>关于接收服务请求的健康医疗服务提供方或机构的相关详情。</description>
                <text>接收方</text>
            </items>
            <items id="at0058">
                <description>此项操作的紧急程度。</description>
                <text>紧急程度</text>
            </items>
            <items id="at0060">
                <description>整个操作（或多组成部分操作之中的最后一个组成部分）完成时的日期和/或时间。</description>
                <text>最终结束日期/时间</text>
            </items>
            <items id="at0061">
                <description>完成此项操作所实际花费的总时间，可能包括操作执行阶段所花费的时间以及操作暂停期间所流逝的时间。</description>
                <text>总时长</text>
            </items>
            <items id="at0062">
                <description>关于所执行的操作的多媒体呈现资料。</description>
                <text>多媒体</text>
            </items>
            <items id="at0063">
                <description>对于此项操作所针对的身体部位的标识。</description>
                <text>身体部位</text>
            </items>
            <items id="at0064">
                <description>采集本地内容或者实现与其他参考模型/形式化体系之间进行协调统一所额外需的其他信息。</description>
                <text>扩展</text>
            </items>
            <items id="at0065">
                <description>对于此项操作所采用的特定方法或技术方法的标识。</description>
                <text>方法</text>
            </items>
            <items id="at0066">
                <description>预定执行此项操作的日期和/或时间。</description>
                <text>所排程的日期/时间</text>
            </items>
            <items id="at0067">
                <description>此项操作的类型。</description>
                <text>操作类型</text>
            </items>
            <items id="at0068">
                <description>此项操作（或多组成部分操作之中的此项子操作）目前已开始。</description>
                <text>操作已开始</text>
            </items>
            <items id="at0069">
                <description>执行此项操作过程中所遇到的困难或问题。</description>
                <text>操作难度</text>
            </items>
            <items id="at0070">
                <description>此项操作的临床原因/理由或流程相关原因/理由。</description>
                <text>适应证</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Actividad clínica llevada a cabo con fines de cribado, investigación, diagnóstico, curativos, terapéuticos, de evaluación o paliativos.</description>
                <text>Procedimiento</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identificación del procedimiento por su nombre.</description>
                <text>Nombre del procedimiento</text>
            </items>
            <items id="at0003">
                <description>Información estructurada sobre el procedimiento.</description>
                <text>Detalles del procedimiento</text>
            </items>
            <items id="at0004">
                <description>Se planifica el procedimiento a llevar a cabo.</description>
                <text>Procedimiento planificado</text>
            </items>
            <items id="at0005">
                <description>Información adicional sobre la actividad o etapa asistencial no recogida en otros campos.</description>
                <text>Comentarios</text>
            </items>
            <items id="at0006">
                <description>Detalles sobre cualquier complicación derivada del procedimiento.</description>
                <text>Complicación</text>
            </items>
            <items id="at0007">
                <description>Solicitud de procedimiento enviada.</description>
                <text>Solicitud de procedimiento enviada</text>
            </items>
            <items id="at0014">
                <description>Motivo por el que se llevó a cabo la actividad o etapa asistencial para el procedimiento identificado.</description>
                <text>Motivo</text>
            </items>
            <items id="at0034">
                <description>Este apartado ha quedado obsoleto, ya que se asociaba incorrectamente con el estado "inicial". Utilice el nuevo apartado "Procedimiento planificado" (at0004), asociado correctamente con el estado "planificado".</description>
                <text>X - Procedimiento planificado</text>
            </items>
            <items id="at0035">
                <description>Este apartado ha quedado obsoleto, ya que se asociaba incorrectamente con el estado "inicial". Utilice el nuevo apartado "Solicitud de procedimiento enviada" (at0004), asociado correctamente con el estado "planificado".</description>
                <text>X - Solicitud de procedimiento enviada</text>
            </items>
            <items id="at0036">
                <description>Se ha programado el procedimiento.</description>
                <text>Procedimiento programado</text>
            </items>
            <items id="at0038">
                <description>El procedimiento se ha pospuesto.</description>
                <text>Procedimiento pospuesto</text>
            </items>
            <items id="at0039">
                <description>El procedimiento previsto se ha cancelado antes de comenzar.</description>
                <text>Procedimiento cancelado</text>
            </items>
            <items id="at0040">
                <description>Se ha suspendido el procedimiento.</description>
                <text>Procedimiento suspendido</text>
            </items>
            <items id="at0041">
                <description>Se ha interrumpido el procedimiento.</description>
                <text>Procedimiento interrumpido</text>
            </items>
            <items id="at0043">
                <description>Se ha realizado el procedimiento y se han completado todas las actividades clínicas asociadas.</description>
                <text>Procedimiento completado</text>
            </items>
            <items id="at0047">
                <description>El procedimiento, o subprocedimiento en un procedimiento multicomponente, se ha realizado.</description>
                <text>Procedimiento realizado</text>
            </items>
            <items id="at0048">
                <description>Resultado del procedimiento realizado.</description>
                <text>Resultado</text>
            </items>
            <items id="at0049">
                <description>Descripción narrativa sobre el procedimiento, según corresponda a la fase del proceso.</description>
                <text>Descripción</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>El ID local asignado a la orden por el proveedor sanitario o la organización que solicita el servicio.</description>
                <text>Identificador de orden del solicitante</text>
            </items>
            <items id="at0055">
                <description>Datos del profesional sanitario u organización que solicita el servicio.</description>
                <text>Solicitante</text>
            </items>
            <items id="at0056">
                <description>El identificador asignado a la orden por el proveedor sanitario o la organización que recibe la solicitud de servicio. También se denomina Identificador de Orden de Cumplimentación.</description>
                <text>Identificador de orden del receptor</text>
            </items>
            <items id="at0057">
                <description>Datos sobre el proveedor u organización sanitaria que recibe la solicitud de servicio.</description>
                <text>Receptor</text>
            </items>
            <items id="at0058">
                <description>Urgencia del procedimiento.</description>
                <text>Urgencia</text>
            </items>
            <items id="at0060">
                <description>La fecha y/o la hora en que finalizó todo el procedimiento, o el último componente de un procedimiento multicomponente.</description>
                <text>Fecha/hora de finalización</text>
            </items>
            <items id="at0061">
                <description>Cantidad total de tiempo empleado en completar el procedimiento, que puede incluir el tiempo empleado durante la fase activa del procedimiento más el tiempo durante el cual el procedimiento estuvo suspendido.</description>
                <text>Duración</text>
            </items>
            <items id="at0062">
                <description>Representación multimedia del procedimiento realizado.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0063">
                <description>Identificación de la zona del cuerpo para el procedimiento.</description>
                <text>Zona corporal</text>
            </items>
            <items id="at0064">
                <description>Información adicional necesaria para registrar contenido local o para alinearse con otros modelos/formalismos de referencia.</description>
                <text>Ampliación</text>
            </items>
            <items id="at0065">
                <description>Identificación del método o técnica específicos para el procedimiento.</description>
                <text>Método</text>
            </items>
            <items id="at0066">
                <description>Fecha y/u hora en que está previsto realizar el procedimiento.</description>
                <text>Fecha/hora programada</text>
            </items>
            <items id="at0067">
                <description>Tipo de procedimiento.</description>
                <text>Tipo de procedimiento</text>
            </items>
            <items id="at0068">
                <description>El procedimiento, o subprocedimiento en un procedimiento multicomponente, se ha iniciado.</description>
                <text>Procedimiento iniciado</text>
            </items>
            <items id="at0069">
                <description>Dificultades o problemas encontrados durante la realización del procedimiento.</description>
                <text>Dificultades del procedimiento</text>
            </items>
            <items id="at0070">
                <description>El motivo, clínico o relacionado con el proceso, del procedimiento.</description>
                <text>Indicación</text>
            </items>
            <items id="at0071">
                <description>Evaluación global del impacto o relevancia de un procedimiento o su resultado para un paciente concreto.</description>
                <text>Impacto</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-pt">
            <items id="at0000">
                <description>Atividade clínica realizada para fins de rastreio, investigação, diagnóstico, cura, tratamento, avaliação ou cuidados paliativos.</description>
                <text>Procedimento</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identificação do procedimento pelo nome.</description>
                <text>Nome do procedimento</text>
            </items>
            <items id="at0003">
                <description>Informação estruturada sobre o procedimento.</description>
                <text>Detalhe do procedimento</text>
            </items>
            <items id="at0004">
                <description>O procedimento a ser realizado está planeado.</description>
                <text>Procedimento Planeado</text>
            </items>
            <items id="at0005">
                <description>Narrativa adicional sobre a atividade ou etapa do caminho do cuidado não capturada noutros campos.</description>
                <text>Comentário</text>
            </items>
            <items id="at0006">
                <description>Detalhes sobre qualquer complicação decorrente do procedimento.</description>
                <text>Complicação</text>
            </items>
            <items id="at0007">
                <description>Pedido para o procedimento enviado.</description>
                <text>Pedido de procedimento enviado</text>
            </items>
            <items id="at0014">
                <description>Motivo pelo qual foi realizada a etapa da atividade ou da via de cuidado para o procedimento identificado.</description>
                <text>Motivo</text>
            </items>
            <items id="at0034">
                <description>Esta etapa de caminho foi preterida, pois foi incorretamente associada ao estado 'inicial' - use a nova etapa de caminho 'Procedimento planeado' (at0004) que está corretamente associada ao estado 'planeado'.</description>
                <text>X - Procedimento planeado</text>
            </items>
            <items id="at0035">
                <description>Esta etapa de caminho foi preterida, pois foi incorretamente associada ao estado 'inicial' - use a nova etapa de caminho 'Pedido de procedimento enviado' (at0007) que está corretamente associada ao estado 'planeado'.</description>
                <text>X - Solicitação de procedimento enviada</text>
            </items>
            <items id="at0036">
                <description>O procedimento foi agendado.</description>
                <text>Procedimento programado</text>
            </items>
            <items id="at0038">
                <description>O procedimento foi adiado.</description>
                <text>Procedimento Adiado</text>
            </items>
            <items id="at0039">
                <description>O procedimento previsto foi cancelado antes do início.</description>
                <text>Procedimento Cancelado</text>
            </items>
            <items id="at0040">
                <description>O procedimento foi suspenso.</description>
                <text>Procedimento suspenso</text>
            </items>
            <items id="at0041">
                <description>O procedimento foi abortado.</description>
                <text>Procedimento abortado</text>
            </items>
            <items id="at0043">
                <description>O procedimento foi realizado e todas as atividades clínicas associadas foram concluídas.</description>
                <text>Procedimento concluído</text>
            </items>
            <items id="at0047">
                <description>O procedimento, ou subprocedimento num procedimento com vários componentes, foi realizado.</description>
                <text>Procedimento realizado</text>
            </items>
            <items id="at0048">
                <description>Resultado do procedimento realizado.</description>
                <text>Resultado</text>
            </items>
            <items id="at0049">
                <description>Descrição narrativa sobre o procedimento, conforme apropriado para a etapa do caminho.</description>
                <text>Descrição</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>O documento de identificação local atribuído ao pedido pelo prestador de cuidados de saúde ou organização que solicita o serviço.</description>
                <text>Identificador do requerente do pedido</text>
            </items>
            <items id="at0055">
                <description>Detalhes sobre o prestador de cuidados de saúde ou a organização que solicita o serviço.</description>
                <text>Requerente</text>
            </items>
            <items id="at0056">
                <description>O ID atribuído à encomenda pelo prestador de cuidados de saúde ou organização que recebe o pedido de serviço. Isto também é referido como Filler Order Identifier.</description>
                <text>Identificador do destinatário do pedido</text>
            </items>
            <items id="at0057">
                <description>Informações sobre o prestador de cuidados de saúde ou a organização que recebe o pedido de assistência.</description>
                <text>Recetor</text>
            </items>
            <items id="at0058">
                <description>Urgência do procedimento.</description>
                <text>Urgência</text>
            </items>
            <items id="at0060">
                <description>A data e/ou hora em que todo o procedimento, ou o último componente de um procedimento com vários componentes, foi concluído.</description>
                <text>Data/hora final</text>
            </items>
            <items id="at0061">
                <description>O tempo total necessário para concluir o procedimento, que pode incluir o tempo gasto durante a fase ativa do procedimento e o tempo durante o qual o procedimento foi suspenso.</description>
                <text>Duração total</text>
            </items>
            <items id="at0062">
                <description>Representação multimédia de um procedimento realizado.</description>
                <text>Multimédia</text>
            </items>
            <items id="at0063">
                <description>Identificação do local do corpo para o procedimento.</description>
                <text>Local do corpo</text>
            </items>
            <items id="at0064">
                <description>Informações adicionais necessárias para capturar conteúdo local ou para alinhar com outros modelos/formalismos de referência.</description>
                <text>Extensão</text>
            </items>
            <items id="at0065">
                <description>Identificação do método ou técnica específica para o procedimento.</description>
                <text>Método</text>
            </items>
            <items id="at0066">
                <description>A data e/ou hora em que o procedimento se destina a ser realizado.</description>
                <text>Data/hora agendada</text>
            </items>
            <items id="at0067">
                <description>O tipo de procedimento.</description>
                <text>Tipo de procedimento</text>
            </items>
            <items id="at0068">
                <description>O procedimento, ou subprocedimento num procedimento com vários componentes, foi iniciado.</description>
                <text>Procedimento iniciado</text>
            </items>
            <items id="at0069">
                <description>Dificuldades ou problemas encontrados durante a execução do procedimento.</description>
                <text>Dificuldade processual</text>
            </items>
            <items id="at0070">
                <description>A razão clínica ou relacionada ao processo para o procedimento.</description>
                <text>indicação</text>
            </items>
            <items id="at0071">
                <description>Overall assessment of the impact of a health problem for the specific patient. </description>
                <text>Impact</text>
            </items>
        </term_definitions>
        <term_definitions language="nb">
            <items id="at0000">
                <description>En klinisk aktivitet som er utført i undersøkende, diagnostisk, kurativ, terapeutisk, evaluerende, prognostisk eller palliativ hensikt.</description>
                <text>Prosedyre</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Navnet på prosedyren.</description>
                <text>Prosedyrenavn</text>
            </items>
            <items id="at0003">
                <description>Strukturert informasjon om prosedyren.</description>
                <text>Prosedyredetaljer</text>
            </items>
            <items id="at0004">
                <description>Prosedyren er planlagt.</description>
                <text>Prosedyre planlagt</text>
            </items>
            <items id="at0005">
                <description>Ytterligere fritekstbeskrivelse av aktivitet eller prosesstrinn som ikke er registrert i andre felt.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0006">
                <description>Detaljer om komplikasjoner oppstått under gjennomføring av prosedyren.</description>
                <text>Komplikasjon</text>
            </items>
            <items id="at0007">
                <description>Det er sendt rekvisisjon for prosedyren.</description>
                <text>Prosedyrerekvisisjon sendt</text>
            </items>
            <items id="at0014">
                <description>Begrunnelse for at aktiviteten eller prosesstrinnet for den aktuelle prosedyren ble utført.</description>
                <text>Begrunnelse</text>
            </items>
            <items id="at0034">
                <description>Dette prosesstrinnet er satt ut av bruk, siden det ved en feil hadde statusen "initial". Bruk det nye prosesstrinnet "Prosedyre planlagt" (at0004) som har den korrekte statusen "planned".</description>
                <text>X - Prosedyre planlagt</text>
            </items>
            <items id="at0035">
                <description>Dette prosesstrinnet er satt ut av bruk, siden det ved en feil hadde statusen "initial". Bruk det nye prosesstrinnet "Prosedyre planlagt" (at0007) som har den korrekte statusen "planned".</description>
                <text>X - Prosedyrerekvisisjon sendt</text>
            </items>
            <items id="at0036">
                <description>Tidspunkt for prosedyre er fastsatt.</description>
                <text>Fastsatt tidspunkt for prosedyre</text>
            </items>
            <items id="at0038">
                <description>Prosedyren er utsatt.</description>
                <text>Prosedyre utsatt</text>
            </items>
            <items id="at0039">
                <description>Den planlagte prosedyren har blitt avlyst før den ble igangsatt.</description>
                <text>Prosedyre avlyst</text>
            </items>
            <items id="at0040">
                <description>Prosedyren er suspendert/ midlertidig stanset.</description>
                <text>Prosedyre midlertidig stanset</text>
            </items>
            <items id="at0041">
                <description>Prosedyren har blitt avbrutt.</description>
                <text>Prosedyre avbrutt</text>
            </items>
            <items id="at0043">
                <description>Prosedyren er utført og alle tilknyttede kliniske handlinger er fullførte.</description>
                <text>Prosedyre fullført</text>
            </items>
            <items id="at0047">
                <description>Prosedyren eller en del av en prosedyre som består av flere delprosedyrer er utført.</description>
                <text>Prosedyre utført</text>
            </items>
            <items id="at0048">
                <description>Resultatet av den utførte prosedyren.</description>
                <text>Resultat</text>
            </items>
            <items id="at0049">
                <description>Fritekstbeskrivelse av prosedyren, tilpasset det aktuelle prosesstrinnet.</description>
                <text>Beskrivelse</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>Den lokale IDen tilordnet rekvisisjonen av helsepersonellet eller organisasjonen som rekvirerer prosedyren.</description>
                <text>Rekvisisjonsidentifikator</text>
            </items>
            <items id="at0055">
                <description>Detaljer om helsepersonellet eller organisasjonen som har rekvirert prosedyren.</description>
                <text>Rekvirent</text>
            </items>
            <items id="at0056">
                <description>IDen tilordnet rekvisisjonen av helsepersonellet eller organisasjonen som mottar rekvisisjonen.</description>
                <text>Mottakers rekvisisjonsidentifikator</text>
            </items>
            <items id="at0057">
                <description>Detaljer om helsepersonellet eller organisasjonen som mottar prosedyrerekvisisjonen.</description>
                <text>Mottaker</text>
            </items>
            <items id="at0058">
                <description>Prosedyrens hastegrad.</description>
                <text>Hastegrad</text>
            </items>
            <items id="at0060">
                <description>Datoen og/eller tiden da hele eller den siste av komponentene i en kompleks prosedyre ble avsluttet.</description>
                <text>Dato/tid for avslutning av prosedyren</text>
            </items>
            <items id="at0061">
                <description>Den totale tiden som ble brukt til å fullføre prosedyren. Dette kan omfatte tidsbruk under den aktive fasen av prosedyren, og i tillegg tid da prosedyren var midlertidig stanset.</description>
                <text>Total varighet</text>
            </items>
            <items id="at0062">
                <description>Multimediarepresentasjon av en utført prosedyre.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0063">
                <description>Stedet på kroppen der prosedyren er utført.</description>
                <text>Kroppssted</text>
            </items>
            <items id="at0064">
                <description>Ytterligere informasjon som er nødvendig for å sammenstille med andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0065">
                <description>Den spesifikke metoden eller teknikken for prosedyren.</description>
                <text>Metode</text>
            </items>
            <items id="at0066">
                <description>Dato/tid når prosedyren er planlagt utført.</description>
                <text>Planlagt dato/tid</text>
            </items>
            <items id="at0067">
                <description>Typen prosedyre.</description>
                <text>Prosedyretype</text>
            </items>
            <items id="at0068">
                <description>Prosedyren eller en del av en prosedyre som består av flere delprosedyrer er påbegynt.</description>
                <text>Prosedyre påbegynt</text>
            </items>
            <items id="at0069">
                <description>Vanskeligheter eller problemer som det ble støtt på under prosedyren.</description>
                <text>Problem ved prosedyre</text>
            </items>
            <items id="at0070">
                <description>Den kliniske eller prosessrelaterte årsaken til prosedyren.</description>
                <text>Indikasjon</text>
            </items>
            <items id="at0071">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="sl">
            <items id="at0000">
                <description>*A clinical activity carried out for screening, investigative, diagnostic, curative, therapeutic, evaluative or palliative purposes.(en)</description>
                <text>*Procedure(en)</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0002">
                <description>*Identification of the procedure by name.(en)</description>
                <text>*Procedure name(en)</text>
            </items>
            <items id="at0003">
                <description>*Structured information about the procedure. Use to capture detailed, structured information about anatomical location, method &amp; technique, equipment used, devices implanted, results, findings etc.(en)</description>
                <text>*Procedure detail(en)</text>
            </items>
            <items id="at0004">
                <description>*</description>
                <text>*Procedure planned (en)</text>
            </items>
            <items id="at0005">
                <description>*Additional narrative about the activity or care pathway step not captured in other fields.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0006">
                <description>*Details about any complication arising from the procedure.(en)</description>
                <text>*Complication(en)</text>
            </items>
            <items id="at0007">
                <description>*</description>
                <text>*Procedure request sent (en)</text>
            </items>
            <items id="at0014">
                <description>*Reason that the activity or care pathway step for the identified procedure was carried out.(en)</description>
                <text>*Reason(en)</text>
            </items>
            <items id="at0034">
                <description>*The procedure to be undertaken is planned.(en)</description>
                <text>*Procedure planned(en)</text>
            </items>
            <items id="at0035">
                <description>*Request for procedure sent.(en)</description>
                <text>*Procedure request sent(en)</text>
            </items>
            <items id="at0036">
                <description>*The procedure has been scheduled.(en)</description>
                <text>*Procedure scheduled(en)</text>
            </items>
            <items id="at0038">
                <description>*The procedure has been postponed.(en)</description>
                <text>*Procedure postponed(en)</text>
            </items>
            <items id="at0039">
                <description>*The planned procedure has been cancelled prior to commencement.(en)</description>
                <text>*Procedure cancelled(en)</text>
            </items>
            <items id="at0040">
                <description>*The procedure has been suspended.(en)</description>
                <text>*Procedure suspended(en)</text>
            </items>
            <items id="at0041">
                <description>*The procedure has been aborted.(en)</description>
                <text>*Procedure aborted(en)</text>
            </items>
            <items id="at0043">
                <description>*The procedure has been performed and all associated clinical activities completed.(en)</description>
                <text>*Procedure completed(en)</text>
            </items>
            <items id="at0047">
                <description>*The procedure, or subprocedure in a multicomponent procedure, has been performed.(en)</description>
                <text>*Procedure performed(en)</text>
            </items>
            <items id="at0048">
                <description>*Outcome of procedure performed.(en)</description>
                <text>*Outcome(en)</text>
            </items>
            <items id="at0049">
                <description>*Narrative description about the procedure, as appropriate for the pathway step.(en)</description>
                <text>*Description(en)</text>
            </items>
            <items id="at0053">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0054">
                <description>*The local ID assigned to the order by the healthcare provider or organisation requesting the service.(en)</description>
                <text>*Requestor order identifier(en)</text>
            </items>
            <items id="at0055">
                <description>Kdo je naročil aktivnost, posameznik ali organizacija</description>
                <text>Naročnik</text>
            </items>
            <items id="at0056">
                <description>*The ID assigned to the order by the healthcare provider or organisation receiving the request for service. This is also referred to as Filler Order Identifier.(en)</description>
                <text>*Receiver order identifier(en)</text>
            </items>
            <items id="at0057">
                <description>Prejemnik naročila za izvedbo aktivnosti</description>
                <text>Prejemnik</text>
            </items>
            <items id="at0058">
                <description>*Urgency of the procedure.(en)</description>
                <text>*Urgency(en)</text>
            </items>
            <items id="at0060">
                <description>*The date and/or time when the entire procedure, or the last component of a multicomponent procedure,  was finished.(en)</description>
                <text>*Final end date/time(en)</text>
            </items>
            <items id="at0061">
                <description>*The total amount of time taken to complete the procedure, which may include time spent during the active phase of the procedure plus time during which the procedure was suspended.(en)</description>
                <text>*Total duration(en)</text>
            </items>
            <items id="at0062">
                <description>*Mulitimedia representation of a performed procedure.(en)</description>
                <text>*Multimedia(en)</text>
            </items>
            <items id="at0063">
                <description>*Identification of the body site for the procedure.(en)</description>
                <text>*Body site(en)</text>
            </items>
            <items id="at0064">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
            <items id="at0065">
                <description>*Identification of specific method or technique for the procedure.(en)</description>
                <text>*Method(en)</text>
            </items>
            <items id="at0066">
                <description>*The date and/or time on which the procedure is intended to be performed.(en)</description>
                <text>*Scheduled date/time(en)</text>
            </items>
            <items id="at0067">
                <description>*The type of procedure.(en)</description>
                <text>*Procedure type(en)</text>
            </items>
            <items id="at0068">
                <description>*The procedure, or subprocedure in a multicomponent procedure, has been commenced.(en)</description>
                <text>*Procedure commenced(en)</text>
            </items>
            <items id="at0069">
                <description>*Difficulties or issues encountered during the procedure.(en)</description>
                <text>*Procedural difficulty(en)</text>
            </items>
            <items id="at0070">
                <description>*The clinical or process-related reason for the procedure. (en)</description>
                <text>*Indication (en)</text>
            </items>
            <items id="at0071">
                <description>Overall assessment of the impact of a health problem for the specific patient. </description>
                <text>Impact</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Activitat clínica duta a terme amb fins de cribratge, investigació, diagnòstic, curatius, terapèutics, d'avaluació o pal·liatius.</description>
                <text>Procediment</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identificació del procediment pel nom.</description>
                <text>Nom del procediment</text>
            </items>
            <items id="at0003">
                <description>Informació estructurada sobre el procediment.</description>
                <text>Detalls del procediment</text>
            </items>
            <items id="at0004">
                <description>Es planifica el procediment que cal dur a terme.</description>
                <text>Procediment planificat</text>
            </items>
            <items id="at0005">
                <description>Informació addicional sobre l'activitat o l'etapa assistencial no recollida en altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0006">
                <description>Detalls sobre qualsevol complicació derivada del procediment.</description>
                <text>Complicació</text>
            </items>
            <items id="at0007">
                <description>Sol·licitud de procediment enviada.</description>
                <text>Sol·licitud de procediment enviada</text>
            </items>
            <items id="at0014">
                <description>Motiu pel qual es va dur a terme l'activitat o etapa assistencial per al procediment identificat.</description>
                <text>Motiu</text>
            </items>
            <items id="at0034">
                <description>Aquest apartat ha quedat obsolet, ja que s'associava incorrectament amb l'estat inicial. Utilitzeu el nou apartat "Procediment planificat" (at0004), associat correctament amb l'estat "planificat".</description>
                <text>X - Procediment planificat</text>
            </items>
            <items id="at0035">
                <description>Aquest apartat ha quedat obsolet, ja que s'associava incorrectament amb l'estat inicial. Utilitzeu el nou apartat "Sol·licitud de procediment enviada" (at0004), associat correctament amb l'estat "planificat".</description>
                <text>X - Sol·licitud de procediment enviada</text>
            </items>
            <items id="at0036">
                <description>El procediment s'ha programat.</description>
                <text>Procediment programat</text>
            </items>
            <items id="at0038">
                <description>El procediment s'ha posposat.</description>
                <text>Procediment posposat</text>
            </items>
            <items id="at0039">
                <description>S'ha cancel·lat el procediment previst abans de començar.</description>
                <text>Procediment cancel·lat</text>
            </items>
            <items id="at0040">
                <description>El procediment s'ha suspès.</description>
                <text>Procediment suspès</text>
            </items>
            <items id="at0041">
                <description>El procediment s'ha interromput.</description>
                <text>Procediment interromput</text>
            </items>
            <items id="at0043">
                <description>S'ha fet el procediment i s'han completat totes les activitats clíniques associades.</description>
                <text>Procediment completat</text>
            </items>
            <items id="at0047">
                <description>El procediment o subprocediment en un procediment multicomponent s'ha realitzat.</description>
                <text>Procediment realitzat</text>
            </items>
            <items id="at0048">
                <description>Resultat del procediment realitzat.</description>
                <text>Resultat</text>
            </items>
            <items id="at0049">
                <description>Descripció narrativa del procediment, segons correspongui a la fase del procés.</description>
                <text>Descripció</text>
            </items>
            <items id="at0053">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0054">
                <description>L'ID local assignat a l'ordre pel proveïdor sanitari o l'organització que sol·licita el servei.</description>
                <text>Identificador d'ordre del sol·licitant</text>
            </items>
            <items id="at0055">
                <description>Dades del professional sanitari o organització que sol·licita el servei.</description>
                <text>Sol·licitant</text>
            </items>
            <items id="at0056">
                <description>L'identificador assignat a l'ordre pel proveïdor sanitari o organització que rep la sol·licitud de servei. També s'anomena identificador d'ordre d'emplenament.</description>
                <text>Identificador d'ordre del receptor</text>
            </items>
            <items id="at0057">
                <description>Dades sobre el proveïdor o organització sanitària que rep la sol·licitud de servei.</description>
                <text>Receptor</text>
            </items>
            <items id="at0058">
                <description>Urgència del procediment.</description>
                <text>Urgència</text>
            </items>
            <items id="at0060">
                <description>Data i/o hora en què va finalitzar tot el procediment, o l'últim component d'un procediment multicomponent.</description>
                <text>Data/hora de finalització</text>
            </items>
            <items id="at0061">
                <description>Quantitat total de temps emprat a completar el procediment, que pot incloure el temps emprat durant la fase activa del procediment més el temps durant el qual el procediment va estar suspès.</description>
                <text>Durada</text>
            </items>
            <items id="at0062">
                <description>Representació multimèdia del procediment realitzat.</description>
                <text>Multimèdia</text>
            </items>
            <items id="at0063">
                <description>Identificació de la zona del cos per al procediment.</description>
                <text>Zona corporal</text>
            </items>
            <items id="at0064">
                <description>Informació addicional necessària per registrar contingut local o per alinear-se amb altres models/formalismes de referència.</description>
                <text>Ampliació</text>
            </items>
            <items id="at0065">
                <description>Identificació del mètode o tècnica específics per al procediment.</description>
                <text>Mètode</text>
            </items>
            <items id="at0066">
                <description>Data i/o hora en què està previst fer el procediment.</description>
                <text>Data/hora programada</text>
            </items>
            <items id="at0067">
                <description>Tipus de procediment.</description>
                <text>Tipus de procediment</text>
            </items>
            <items id="at0068">
                <description>El procediment o subprocediment en un procediment multicomponent s'ha iniciat.</description>
                <text>Procediment iniciat</text>
            </items>
            <items id="at0069">
                <description>Dificultats o problemes trobats durant la realització del procediment.</description>
                <text>Dificultats del procediment</text>
            </items>
            <items id="at0070">
                <description>El motiu, clínic o relacionat amb el procés, del procediment.</description>
                <text>Indicació</text>
            </items>
            <items id="at0071">
                <description>Avaluació de l'impacte o la rellevància d'un procediment o del seu resultat per a un pacient concret.</description>
                <text>Impacte</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-ACTION.health_education.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Kommunikation zur Verbesserung der Gesundheitskompetenz und der Lebenskompetenzen.</description>
                <text>Gesundheitsberatung</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identifizierung des Themas der Gesundheitsberatung mit Namen.</description>
                <text>Thema</text>
            </items>
            <items id="at0003">
                <description>Beschreibung der Gesundheitsberatung.</description>
                <text>Beschreibung</text>
            </items>
            <items id="at0004">
                <description>Methode, mit der die Gesundheitsberatung der Person erteilt wurde.</description>
                <text>Methode</text>
            </items>
            <items id="at0006">
                <description>Beratung ist geplant, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</description>
                <text>Beratung geplant</text>
            </items>
            <items id="at0007">
                <description>Termin für die Beratung festgelegt.</description>
                <text>Beratung terminiert</text>
            </items>
            <items id="at0008">
                <description>Beratungssitzung oder Material angeboten.</description>
                <text>Beratung angeboten</text>
            </items>
            <items id="at0010">
                <description>Grund, warum der Pathway-Schritt für die identifizierte Gesundheitsberatung durchgeführt wurde.</description>
                <text>Grund</text>
            </items>
            <items id="at0013">
                <description>Alle geplanten Beratungsaktivitäten wurden erfolgreich abgeschlossen.</description>
                <text>Beratung abgeschlossen</text>
            </items>
            <items id="at0014">
                <description>Die Beratung wurde noch vor Beginn verschoben.</description>
                <text>Beratung verschoben</text>
            </items>
            <items id="at0015">
                <description>Die Beratung wurde noch vor Beginn abgesagt.</description>
                <text>Beratung abgesagt</text>
            </items>
            <items id="at0016">
                <description>Die Beratungssitzungen wurde vor Abschluss abgebrochen.</description>
                <text>Beratung nicht abgeschlossen</text>
            </items>
            <items id="at0017">
                <description>Geplante Beratungssitzungen wurden nach Beginn ausgesetzt.</description>
                <text>Beratung unterbrochen</text>
            </items>
            <items id="at0018">
                <description>Beratung wurde empfohlen, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</description>
                <text>Beratung empfohlen</text>
            </items>
            <items id="at0019">
                <description>Beschreibung des Ergebnisses der Gesundheitsberatung.</description>
                <text>Ergebnis</text>
            </items>
            <items id="at0020">
                <description>Nummer der Beratungssitzung in einem Kurs mit mehreren Sitzungen.</description>
                <text>Sitzungsnummer</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0025">
                <description>Strukturierte Angaben zum Beratungsmaterial, das der Person zur Verfügung gestellt wird.</description>
                <text>Material</text>
            </items>
            <items id="at0026">
                <description>Datum und / oder Uhrzeit der Durchführung der Beratungsaktivität.</description>
                <text>Termin Datum/Uhrzeit</text>
            </items>
            <items id="at0027">
                <description>Zusätzliche Beschreibung über den Aktivitäts- oder Pflegeschritt, der in anderen Feldern nicht erfasst wurde.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0028">
                <description>Angaben über den Gesundheitsdienstleister oder die Organisation, die die Beratung anfordert.</description>
                <text>Anforderer</text>
            </items>
            <items id="at0029">
                <description>Angaben zu dem Gesundheitsdienstleister oder der Organisation, die die Anforderung zur Beratung erhalten hat.</description>
                <text>Empfänger</text>
            </items>
            <items id="at0030">
                <description>Die lokale ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Beratung anfordert, zugewiesen wurde.</description>
                <text>Anforderer ID</text>
            </items>
            <items id="at0031">
                <description>Die ID, die dem Antrag von dem Gesundheitsdienstleister oder der Organisation zugewiesen wurde, die den Antrag auf Beratung erhalten hat. Dies wird auch als Filler Order Identifier bezeichnet.</description>
                <text>Empfänger ID</text>
            </items>
            <items id="at0032">
                <description>Empfänger der Gesundheitsberatung.</description>
                <text>Beratungsempfänger</text>
            </items>
            <items id="at0033">
                <description>Zusätzliche strukturierte Angaben zur Gesundheitsberatung.</description>
                <text>Zusätzliche Angaben</text>
            </items>
            <items id="at0034">
                <description>Angaben zum Dolmetscher.</description>
                <text>Dolmetscher</text>
            </items>
            <items id="at0035">
                <description>Der klinische Grund für die Beratungsaktivität.</description>
                <text>Klinische Indikation</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Kommunikation avsedd att öka hälsokunskap och praktiska färdigheter (ofta relaterade till hälsotillstånd)</description>
                <text>Hälsorådgivning/information/undervisning</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Namn/benämning för rådgivningen/undervisningen</description>
                <text>Ämne</text>
            </items>
            <items id="at0003">
                <description>Beskrivande text om rådgivningen/utbildningen</description>
                <text>Beskrivning</text>
            </items>
            <items id="at0004">
                <description>Metod genom vilken rådgivningen/hälsoutbildningen genomförs.</description>
                <text>Metod</text>
            </items>
            <items id="at0006">
                <description>Rådgivning/utbildning är planerad men inga övriga åtgärder har gjorts för att påbörja den.</description>
                <text>Rådgivning/utbildning planerad</text>
            </items>
            <items id="at0007">
                <description>Rådgivning/utbildning har bokats eller schemalagts.</description>
                <text>Rådgivning/utbildning inbokad</text>
            </items>
            <items id="at0008">
                <description>Rådginings-/utbildningstillfälle har genomförts eller råd/undervisningsmaterial har delats ut.</description>
                <text>Rådgivning/utbildning genomförd</text>
            </items>
            <items id="at0010">
                <description>Orsak till att detta processteg nåddes</description>
                <text>Orsak</text>
            </items>
            <items id="at0013">
                <description>All planerad rådgivning/utbildning har genomförts.</description>
                <text>Rådgivning/utbildning fullbordad</text>
            </items>
            <items id="at0014">
                <description>Rådgivning/utbildning sköts upp innan den hade påbörjats.</description>
                <text>Rådgivning/utbildning uppskjuten</text>
            </items>
            <items id="at0015">
                <description>Rådgivning/utbildning ställdes in innan den hade påbörjats.</description>
                <text>Rådgivning/utbildning inställd</text>
            </items>
            <items id="at0016">
                <description>Rådgivning/utbildning avbröts innan den var fullbordad.</description>
                <text>Rådgivning/utbildning ej fullbordad</text>
            </items>
            <items id="at0017">
                <description>Planerad rådgivning/utbildning har pausats (efter att ha påbörjats).</description>
                <text>Rådgivning/utbildning pausad</text>
            </items>
            <items id="at0018">
                <description>Rådgivning/utbildning har rekommenderats men inga åtgärder har gjorts för att påbörja den.</description>
                <text>Rådgivning/utbildning rekommenderas</text>
            </items>
            <items id="at0019">
                <description>Beskrivning av rådgivningens/undervisningens resultat</description>
                <text>Resultat</text>
            </items>
            <items id="at0020">
                <description>Numret i ordningen av antal tillfällen i en kurs med flera tillfällen.</description>
                <text>Undervisningstillfälle</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>Plats för att infoga ytterligare information som krävs för att fånga upp lokalt innehåll eller för att anpassa sig till andra referensmodeller/format.</description>
                <text>Utökning</text>
            </items>
            <items id="at0025">
                <description>Beskivning av materialet som individen fick. (kan exempelvis vara bild/kopia)</description>
                <text>Detaljer om materialet</text>
            </items>
            <items id="at0026">
                <description>Datumet och/eller tiden då rådgivnings/undervisningsaktiviteten ska genomföras.</description>
                <text>Bokad/schemalagd tidpunkt</text>
            </items>
            <items id="at0027">
                <description>Ytterligare beskrivning av aktiviteten eller processteget som inte redan fångats i övriga fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0028">
                <description>Detaljer om den som beställt rådgivningen/undervisningen</description>
                <text>Beställare/Remittent</text>
            </items>
            <items id="at0029">
                <description>Detaljer om den som genomför utbildningen/rådgivningen &#13;
</description>
                <text>Remissmottagare/utförare</text>
            </items>
            <items id="at0030">
                <description>Lokalt beställnings/remiss-ID tilldelat av beställande/remitterande vårdgivare eller organisation som efterfrågar utbildningen/rådgivningen</description>
                <text>Beställarens ID för beställningen/remissen</text>
            </items>
            <items id="at0031">
                <description>Lokalt beställnings/remiss-ID tilldelat av mottagande vårdgivare eller organisation som genomför utbildningen/rådgivningen &#13;
</description>
                <text>Remissmottagarens ID för beställningen/remissen</text>
            </items>
            <items id="at0032">
                <description>Den som tar emot råden/undervisningen.</description>
                <text>Informationsmottagare/Kursdeltagare</text>
            </items>
            <items id="at0033">
                <description>Plats för att infoga ytterligare strukturerade detaljer om rådgivningen/undervisningen</description>
                <text>Ytterligare detaljer</text>
            </items>
            <items id="at0034">
                <description>Detaljer om tolkhjälp.</description>
                <text>Information om tolk</text>
            </items>
            <items id="at0035">
                <description>*The clinical reason for the education activity.(en)</description>
                <text>*Clinical indication(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="nb">
            <items id="at0000">
                <description>Detaljer om kommunikasjon som har til hensikt å øke evne til å forstå og anvende helseinformasjon, og å mestre praktiske ferdigheter eller livet relatert til helsetilstanden.</description>
                <text>Helseinformasjon/undervisning</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Navn på tema for helseinformasjonen/undervisningen.</description>
                <text>Emne</text>
            </items>
            <items id="at0003">
                <description>Beskrivelse i fritekst om helseinformasjonen/undervisningen.</description>
                <text>Beskrivelse</text>
            </items>
            <items id="at0004">
                <description>Hvilken metode som ble brukt da helseinformasjon/undervisning ble kommunisert.</description>
                <text>Metode</text>
            </items>
            <items id="at0006">
                <description>Helseinformasjon/undervisning er planlagt, men ingen aktivitet er gjort for å initiere den.</description>
                <text>Helseinformasjon/undervisning planlagt</text>
            </items>
            <items id="at0007">
                <description>Det er gjort en avtale for når helseinformasjonen/undervisningen skal gjennomføres.</description>
                <text>Helseinformasjon/undervisning tidsfestet</text>
            </items>
            <items id="at0008">
                <description>Helseinformasjon/undervisning er utført eller informasjonsmateriellet er overlevert. Dette kan være når en av flere økter er gjennomført, eller et emne er informert om eller undervist i, uten at man har nådd målet for informasjonen/undervisningen og status kan settes til "Helseinformasjon/undervisning fullført".</description>
                <text>Helseinformasjon/undervisning gjennomført</text>
            </items>
            <items id="at0010">
                <description>Årsak til at det aktuelle prosesstrinnet ble utført.</description>
                <text>Årsak</text>
            </items>
            <items id="at0013">
                <description>Alle planlagte aktiviteter for helseinformasjon/undervisning er gjennomført.</description>
                <text>Helseinformasjon/undervisning fullført</text>
            </items>
            <items id="at0014">
                <description>Helseinformasjon/undervisning er utsatt før den er påbegynt.</description>
                <text>Helseinformasjon/undervisning utsatt</text>
            </items>
            <items id="at0015">
                <description>Helseinformasjon/undervisning er kansellert før den er påbegynt.</description>
                <text>Helseinformasjon/undervisning er kansellert</text>
            </items>
            <items id="at0016">
                <description>Helseinformasjon/undervisning ble avbrutt før den ble fullført.</description>
                <text>Helseinformasjon/undervisning ikke fullført</text>
            </items>
            <items id="at0017">
                <description>Helseinformasjon/undervisning, eller serien av økter er midlertidig stanset etter at den/de ble påbegynt.</description>
                <text>Helseinformasjon/undervisning midlertidig stanset</text>
            </items>
            <items id="at0018">
                <description>Helseinformasjon/undervisning er anbefalt, men ingen aktivitet er gjort for å initiere den.</description>
                <text>Helseinformasjon/undervisning anbefalt</text>
            </items>
            <items id="at0019">
                <description>Beskrivelse av resultatet av helseinformasjonen/undervisningen.</description>
                <text>Resultat</text>
            </items>
            <items id="at0020">
                <description>Nummeret på sesjonen dersom det er en serie på et antall økter.</description>
                <text>Sesjonsnummer</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0025">
                <description>Strukturerte detaljer om opplæringsmateriellet som er gitt til individet.</description>
                <text>Detaljer om materiell</text>
            </items>
            <items id="at0026">
                <description>Dato eller dato/tid når undervisningsaktiviteten er planlagt utført.</description>
                <text>Planlagt dato/tid</text>
            </items>
            <items id="at0027">
                <description>Ytterligere fritekst om aktiviteten eller prosesstrinnet som ikke representeres i andre elementer.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0028">
                <description>Detaljer om helsepersonellet eller organisasjonen som har rekvirert helseinformasjonen/undervisningen.</description>
                <text>Rekvirent</text>
            </items>
            <items id="at0029">
                <description>Detaljer om helsepersonellet eller organisasjonen som mottar forespørselen om helseinformasjon/undervisning.</description>
                <text>Mottaker</text>
            </items>
            <items id="at0030">
                <description>Den lokale IDen tilordnet rekvisisjonen av helsepersonellet eller organisasjonen som har rekvirert helseinformasjonen/undervisningen.</description>
                <text>RekvisisjonsID</text>
            </items>
            <items id="at0031">
                <description>IDen tilordnet rekvisisjonen av helsepersonellet eller organisasjonen som mottar forespørselen.</description>
                <text>Mottakers rekvisisjonsID</text>
            </items>
            <items id="at0032">
                <description>Mottakeren av helseinformasjon/undervisning.</description>
                <text>Subjektet</text>
            </items>
            <items id="at0033">
                <description>Ytterligere strukturerte detaljer om helseinformasjonen/undervisningen.</description>
                <text>Ytterligere detaljer</text>
            </items>
            <items id="at0034">
                <description>Detaljer om tolking som ble utført.</description>
                <text>Detaljer om tolking</text>
            </items>
            <items id="at0035">
                <description>Den kliniske årsaken for den forespurte helseinformasjon/undervisningsaktiviteten.</description>
                <text>Klinisk indikasjon</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Communication to improve health literacy and life skills.</description>
                <text>Health education</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identification of the topic of health education, by name.</description>
                <text>Topic name</text>
            </items>
            <items id="at0003">
                <description>Narrative description about the health education.</description>
                <text>Description</text>
            </items>
            <items id="at0004">
                <description>Method by which the health education was communicated to the individual.</description>
                <text>Method</text>
            </items>
            <items id="at0006">
                <description>Education has been planned but no steps have been taken to initiate education.</description>
                <text>Education planned</text>
            </items>
            <items id="at0007">
                <description>Appointment for education scheduled.</description>
                <text>Education scheduled</text>
            </items>
            <items id="at0008">
                <description>Education session or material provided.</description>
                <text>Education provided</text>
            </items>
            <items id="at0010">
                <description>Reason that the pathway step for the identified health education was carried out.</description>
                <text>Reason</text>
            </items>
            <items id="at0013">
                <description>All planned activities for education have been successfully completed.</description>
                <text>Education completed</text>
            </items>
            <items id="at0014">
                <description>Education has been postponed prior to commencement.</description>
                <text>Education postponed</text>
            </items>
            <items id="at0015">
                <description>Education has been cancelled prior to commencement.</description>
                <text>Education cancelled</text>
            </items>
            <items id="at0016">
                <description>Education session was abandoned before complete.</description>
                <text>Education not completed</text>
            </items>
            <items id="at0017">
                <description>Planned education sessions were suspended after commencement.</description>
                <text>Education suspended</text>
            </items>
            <items id="at0018">
                <description>Education has been recommended but no steps have been taken to initiate education.</description>
                <text>Education recommended</text>
            </items>
            <items id="at0019">
                <description>Description of the outcome of health education.</description>
                <text>Outcome</text>
            </items>
            <items id="at0020">
                <description>Number of the education session in an multi-session course.</description>
                <text>Session Number</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>Additional information required to capture local context or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0025">
                <description>Structured details about the education material provided to the individual.</description>
                <text>Material details</text>
            </items>
            <items id="at0026">
                <description>The date and/or time on which the education activity is intended to be performed.</description>
                <text>Scheduled date/ time</text>
            </items>
            <items id="at0027">
                <description>Additional narrative about the activity or care pathway step not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0028">
                <description>Details about the healthcare provider or organisation requesting the education.</description>
                <text>Requestor</text>
            </items>
            <items id="at0029">
                <description>Details about the healthcare provider or organisation who received the request for education.</description>
                <text>Receiver</text>
            </items>
            <items id="at0030">
                <description>The local ID assigned to the order by the healthcare provider or organisation requesting the education.</description>
                <text>Requestor order identifier</text>
            </items>
            <items id="at0031">
                <description>The ID assigned to the order by the healthcare provider or organisation receiving the request for education. This is also referred to as Filler Order Identifier.</description>
                <text>Receiver order identifier</text>
            </items>
            <items id="at0032">
                <description>Recipient of the health education.</description>
                <text>Recipient</text>
            </items>
            <items id="at0033">
                <description>Additional structured details about the health education.</description>
                <text>Additional details</text>
            </items>
            <items id="at0034">
                <description>Details about the interpretation.</description>
                <text>Interpreter details</text>
            </items>
            <items id="at0035">
                <description>The clinical reason for the education activity.</description>
                <text>Clinical indication</text>
            </items>
        </term_definitions>
        <term_definitions language="id">
            <items id="at0000">
                <description>Komunikasi untuk meningkatkan literasi kesehatan dan kecakapan hidup.</description>
                <text>Edukasi kesehatan</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identifikasi topik edukasi kesehatan, berdasarkan nama.</description>
                <text>Nama topik</text>
            </items>
            <items id="at0003">
                <description>Deksripsi naratif tentang edukasi kesehatan.</description>
                <text>Deskripsi</text>
            </items>
            <items id="at0004">
                <description>Metode komunikasi edukasi kesehatan kepada individu.</description>
                <text>Metode</text>
            </items>
            <items id="at0006">
                <description>Edukasi telah direncanakan tetapi tidak ada langkah yang diambil untuk memulai edukasi.</description>
                <text>Edukasi direncanakan</text>
            </items>
            <items id="at0007">
                <description>Penjadwalan untuk janji temu edukasi.</description>
                <text>Edukasi dijadwalkan</text>
            </items>
            <items id="at0008">
                <description>Sesi edukasi atau materi yang diberikan.</description>
                <text>Edukasi diberikan</text>
            </items>
            <items id="at0010">
                <description>Alasan dilakukannya jalur edukasi kesehatan yang dimaksud.</description>
                <text>Alasan</text>
            </items>
            <items id="at0013">
                <description>Semua kegiatan yang direncanakan untuk edukasi telah berhasil diselesaikan.</description>
                <text>Edukasi selesai</text>
            </items>
            <items id="at0014">
                <description>Edukasi telah ditunda sebelum dimulai.</description>
                <text>Edukasi ditunda</text>
            </items>
            <items id="at0015">
                <description>Edukasi telah dibatalkan sebelum dimulai.</description>
                <text>Edukasi dibatalkan</text>
            </items>
            <items id="at0016">
                <description>Sesi edukasi ditinggalkan sebelum selesai.</description>
                <text>Edukasi tidak selesai</text>
            </items>
            <items id="at0017">
                <description>Sesi edukasi yang direncanakan ditangguhkan setelah dimulai.</description>
                <text>Edukasi ditangguhkan</text>
            </items>
            <items id="at0018">
                <description>Edukasi telah direkomendasikan tetapi tidak ada langkah yang diambil untuk memulai edukasi.</description>
                <text>Edukasi direkomendasikan</text>
            </items>
            <items id="at0019">
                <description>Deskripsi hasil edukasi kesehatan.</description>
                <text>Hasil</text>
            </items>
            <items id="at0020">
                <description>Jumlah sesi pendidikan dalam kursus multi-sesi.</description>
                <text>Jumlah sesi</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>Informasi tambahan diperlukan untuk menangkap konteks lokal atau menyelaraskan dengan model referensi/formalisme lainnya.</description>
                <text>Ekstensi</text>
            </items>
            <items id="at0025">
                <description>Rincian terstruktur tentang materi edukasi yang diberikan kepada individu.</description>
                <text>Detail materi</text>
            </items>
            <items id="at0026">
                <description>Tanggal dan/atau waktu di mana kegiatan edukasi yang dimaksud dilaksanakan.</description>
                <text>Tanggal/waktu terjadwal</text>
            </items>
            <items id="at0027">
                <description>Narasi tambahan tentang aktivitas atau jalur perawatan yang tidak terekam di bidang lain.</description>
                <text>Komentar</text>
            </items>
            <items id="at0028">
                <description>Detail tentang penyedia layanan kesehatan atau organisasi yang meminta edukasi.</description>
                <text>Pemohon</text>
            </items>
            <items id="at0029">
                <description>Detail tentang penyedia layanan kesehatan atau organisasi yang menerima permintaan edukasi.</description>
                <text>Penerima (institusi)</text>
            </items>
            <items id="at0030">
                <description>ID lokal yang ditetapkan untuk pesanan oleh penyedia layanan kesehatan atau organisasi yang meminta edukasi.</description>
                <text>Pengidentifikasi pesanan pemohon</text>
            </items>
            <items id="at0031">
                <description>ID yang ditetapkan untuk pesanan oleh penyedia layanan kesehatan atau organisasi yang menerima permintaan edukasi. Ini juga disebut sebagai Filler Order Identifier.</description>
                <text>Pengidentifikasi pesanan penerima</text>
            </items>
            <items id="at0032">
                <description>Penerima edukasi kesehatan</description>
                <text>Penerima</text>
            </items>
            <items id="at0033">
                <description>Rincian terstruktur tambahan tentang edukasi kesehatan.</description>
                <text>Detail tambahan</text>
            </items>
            <items id="at0034">
                <description>Detail tentang interpretasi</description>
                <text>Detail penerjemah</text>
            </items>
            <items id="at0035">
                <description>Alasan klinis dilakukannya edukasi.</description>
                <text>Indikasi klinis</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>旨在提升健康素养和生活技能的沟通交流。</description>
                <text>健康教育</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>采用名称对于健康教育主题的明确/标识。</description>
                <text>主题名称</text>
            </items>
            <items id="at0003">
                <description>关于健康教育的文本叙述型说明。</description>
                <text>描述</text>
            </items>
            <items id="at0004">
                <description>对当前人员开展健康教育或者说向其传达健康教育信息时所采用的方法。</description>
                <text>方法</text>
            </items>
            <items id="at0006">
                <description>已经对教育活动进行了计划，但尚未采取启动教育的步骤/措施。</description>
                <text>已计划的教育</text>
            </items>
            <items id="at0007">
                <description>已经安排了旨在教育的预约。</description>
                <text>已排程的教育</text>
            </items>
            <items id="at0008">
                <description>所提供的教育服务时段（一节课程/讲座）或材料。</description>
                <text>所提供的教育</text>
            </items>
            <items id="at0010">
                <description>关于当时开展所标识的健康教育的这一路径步骤的原因。</description>
                <text>原因</text>
            </items>
            <items id="at0013">
                <description>已经成功地完成了所有已计划的教育活动。</description>
                <text>所完成的教育</text>
            </items>
            <items id="at0014">
                <description>教育已经在开始之前遭到推迟。</description>
                <text>已推迟的教育</text>
            </items>
            <items id="at0015">
                <description>教育已经在开始之前遭到取消。</description>
                <text>已取消的教育</text>
            </items>
            <items id="at0016">
                <description>教育服务时段（一节课程/讲座）在完成之前遭到放弃。</description>
                <text>未完成的教育</text>
            </items>
            <items id="at0017">
                <description>已计划的教育服务时段（一节课程/讲座）在开始之后遭到了暂停/中止。</description>
                <text>已暂停的教育</text>
            </items>
            <items id="at0018">
                <description>已经推荐/建议开展教育，但尚未采取启动教育的步骤/措施。</description>
                <text>已推荐的教育</text>
            </items>
            <items id="at0019">
                <description>关于健康教育的效果/结果/结局。</description>
                <text>效果</text>
            </items>
            <items id="at0020">
                <description>多节课程/讲座之中当前服务时段（一节）的编号。</description>
                <text>服务时段编号</text>
            </items>
            <items id="at0021">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0023">
                <description>采集本地语境/上下文背景或者是与其他的参考模型/形式化体系进行协调统一时所需的其他信息。</description>
                <text>扩展</text>
            </items>
            <items id="at0025">
                <description>关于提供给当前人员的教育资料/材料的结构化详情。</description>
                <text>资料详情</text>
            </items>
            <items id="at0026">
                <description>计划安排开展教育活动的日期和/或时间。</description>
                <text>所安排的日期/时间</text>
            </items>
            <items id="at0027">
                <description>关于其他字段之中所未采集的活动或照护服务路径的文本叙述型注释。</description>
                <text>备注</text>
            </items>
            <items id="at0028">
                <description>关于申请当前教育/宣教[服务]的健康医疗服务人员或组织机构的详情。</description>
                <text>申请方</text>
            </items>
            <items id="at0029">
                <description>关于接收/收到当前教育/宣教[服务]申请的健康医疗服务人员或组织机构的详情。</description>
                <text>接收方</text>
            </items>
            <items id="at0030">
                <description>申请当前教育/宣教[服务]的健康医疗服务人员或组织机构为当前医嘱/申请所指定的本地标识符。</description>
                <text>申请方医嘱标识符</text>
            </items>
            <items id="at0031">
                <description>接收/收到关于当前教育/宣教[服务]的申请的健康医疗服务人员或组织机构为当前医嘱/申请所指定的本地标识符。该标识符又称为执行方医嘱标识符（Filler Order Identifier）。</description>
                <text>接收方医嘱标识符</text>
            </items>
            <items id="at0032">
                <description>当前健康教育的接受者。</description>
                <text>接受者</text>
            </items>
            <items id="at0033">
                <description>更多其他关于当前健康教育的结构化详情。</description>
                <text>其他详情</text>
            </items>
            <items id="at0034">
                <description>关于口译人员的详情。</description>
                <text>口译人员详情</text>
            </items>
            <items id="at0035">
                <description>教育活动的临床原因。</description>
                <text>临床适应证</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-INSTRUCTION.therapeutic_item_order.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="nb">
            <items id="at0000">
                <description>En ordinasjon av medisinsk utstyr for et spesifikt individ.</description>
                <text>Ordinering av medisinsk utstyr</text>
            </items>
            <items id="at0001">
                <description>Detaljer knyttet til ordineringen.</description>
                <text>Ordinering</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Unik identifikator for ordineringen.</description>
                <text>Ordineringsidentifikator</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Ytterligere informasjon som er nødvendig for å registrere lokalt innhold/kontekst, eller for å sammenstille med andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0009">
                <description>Fritekstbeskrivelse av hvordan utstyret skal brukes.</description>
                <text>Anvisningsbeskrivelse</text>
            </items>
            <items id="at0011">
                <description>Et vilkår for at utstyret kan tas i bruk.</description>
                <text>Startkriterium</text>
            </items>
            <items id="at0012">
                <description>Dato og eventuell tidsangivelse for oppstart av utstyret.</description>
                <text>Startdato/tid</text>
            </items>
            <items id="at0013">
                <description>Dato og eventuell tidsangivelse for seponering av utstyret.</description>
                <text>Stoppdatotid</text>
            </items>
            <items id="at0016">
                <description>Et vilkår for at utstyret skal seponeres.</description>
                <text>Stoppkriterium</text>
            </items>
            <items id="at0018">
                <description>Den kliniske begrunnelsen for bruk av utstyret.</description>
                <text>Klinisk indikasjon</text>
            </items>
            <items id="at0070">
                <description>Navn på utstyret som er ordinert.</description>
                <text>Utstyrsnavn</text>
            </items>
            <items id="at0092">
                <description>Navn på kroppstedet hvor utstyret skal brukes.</description>
                <text>Anatomisk lokalisering</text>
            </items>
            <items id="at0093">
                <description>Strukturert beskrivelse av kroppstedet hvor utstyret skal brukes.</description>
                <text>Strukturert anatomisk lokalisering</text>
            </items>
            <items id="at0107">
                <description>Beskrivelse av monitorering ved bruk av utstyret.</description>
                <text>Overvåkningsinstruksjon</text>
            </items>
            <items id="at0143">
                <description>Strukturerte detaljer om utstyret.</description>
                <text>Utstyrsdetaljer</text>
            </items>
            <items id="at0148">
                <description>Den terapeutiske hensikten med bruk av utstyret.</description>
                <text>Terapeutisk hensikt</text>
            </items>
            <items id="at0166">
                <description>Ytterligere detaljer om utstyret som ikke er fanget i andre felt.</description>
                <text>Ytterligere detaljer</text>
            </items>
            <items id="at0167">
                <description>Ytterligere fritekst om ordinering av utstyret som ikke er fanget i andre felt.</description>
                <text>Kommentar</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>An order for a therapeutic item, including a medical device, used by the individual or a carer as part of direct provision of healthcare or to mitigate a healthcare risk.</description>
                <text>Therapeutic item order</text>
            </items>
            <items id="at0001">
                <description>Details of the requested order.</description>
                <text>Order</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Unique identifier for the order.</description>
                <text>Order identifier</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0009">
                <description>Narrative description about the intended use of the item.</description>
                <text>Directions</text>
            </items>
            <items id="at0011">
                <description>Criteria which triggers commencement of use.</description>
                <text>Start criterion</text>
            </items>
            <items id="at0012">
                <description>Date/time when use of the item should commence.</description>
                <text>Start date/time</text>
            </items>
            <items id="at0013">
                <description>Date/time when use of the item should stop.</description>
                <text>Stop date/time</text>
            </items>
            <items id="at0016">
                <description>Criteria which triggers cessation of use.</description>
                <text>Stop criterion</text>
            </items>
            <items id="at0018">
                <description>The clinical reason for use of the ordered item.</description>
                <text>Clinical indication</text>
            </items>
            <items id="at0070">
                <description>Name of the item ordered.</description>
                <text>Item name</text>
            </items>
            <items id="at0092">
                <description>Name of the body site where the item is intended to be used.</description>
                <text>Body site</text>
            </items>
            <items id="at0093">
                <description>Structured description of the body site where the item is intended to be used.</description>
                <text>Structured body site</text>
            </items>
            <items id="at0107">
                <description>Description about monitoring required for use of the item.</description>
                <text>Monitoring instruction</text>
            </items>
            <items id="at0143">
                <description>Structured details about the item.</description>
                <text>Item details</text>
            </items>
            <items id="at0148">
                <description>The therapeutic intent of the item.</description>
                <text>Therapeutic intent</text>
            </items>
            <items id="at0166">
                <description>Additional structured details about the order not captured in other fields.</description>
                <text>Additional details</text>
            </items>
            <items id="at0167">
                <description>Additional narrative about the order not captured in other fields.</description>
                <text>Comment</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-INSTRUCTION.service_request.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Antrag auf eine gesundheitsbezogene Dienstleistung oder Aktivität, die von einem Kliniker, einer Klinik oder einer Einrichtung erbracht werden soll.</description>
                <text>Dienstleistung</text>
            </items>
            <items id="at0001">
                <description>Aktuelle Aktivität</description>
                <text>Aktuelle Aktivität</text>
            </items>
            <items id="at0008">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Lokale Auftrags-ID des anfordernden/einsendenden Systems.</description>
                <text>Auftrags-ID des anfordernden/einsendenden Systems</text>
            </items>
            <items id="at0011">
                <description>Lokale Auftrags-ID, die der Anforderung durch den Kliniker oder die Organisation, die die Leistungsanforderung erhält, zugewiesen wurde.</description>
                <text>Auftrags-ID (Empfänger)</text>
            </items>
            <items id="at0040">
                <description>Datum/Uhrzeit oder Beschreibung des Zeitplans für die Erbringung der angeforderten Dienstleistung(en).</description>
                <text>Anstehende Dienstleistung</text>
            </items>
            <items id="at0062">
                <description>Das spezifische Problem, das Aufmerksamkeit erfordert, oder die klinische Frage, die untersucht werden muss.</description>
                <text>Grund für die Anforderung</text>
            </items>
            <items id="at0064">
                <description>Narrative Beschreibung des Problems oder der klinischen Frage, die gelöst werden muss.</description>
                <text>Beschreibung des Grundes</text>
            </items>
            <items id="at0065">
                <description>Beschreibung des beabsichtigten Ergebnisses der Anfrage.</description>
                <text>Intention</text>
            </items>
            <items id="at0068">
                <description>Dringlichkeit der Anforderung der Dienstleistung.</description>
                <text>Dringlichkeit</text>
            </items>
            <items id="at0076">
                <description>Ergänzende Informationen werden auf Anfrage zur Verfügung gestellt.</description>
                <text>Ergänzende Informationen</text>
            </items>
            <items id="at0078">
                <description>Beschreibung der Zusatzinformationen.</description>
                <text>Beschreibung der Informationen</text>
            </items>
            <items id="at0112">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle / Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0116">
                <description>Sprach-, Transport- oder andere persönliche Anforderungen, um die Beteiligung oder Teilnahme des Patienten an der Erbringung der Dienstleistung zu unterstützen.</description>
                <text>Anforderungen an Patienten</text>
            </items>
            <items id="at0121">
                <description>Der Name der angeforderten Dienstleistung(en).</description>
                <text>Name der Dienstleistung</text>
            </items>
            <items id="at0127">
                <description>Der Status des Zustellungsantrags, wie vom Antragsteller angegeben.</description>
                <text>Status der Anfrage</text>
            </items>
            <items id="at0128">
                <description>Details über weitere Kliniker, Organisationen oder Einrichtungen, die Kopien aller Mitteilungen benötigen.</description>
                <text>Verteilerliste</text>
            </items>
            <items id="at0132">
                <description>Zusätzliche Details über die angeforderte Dienstleistung.</description>
                <text>Spezifische Details</text>
            </items>
            <items id="at0135">
                <description>Narrative Beschreibung der gewünschten Dienstleistung.</description>
                <text>Beschreibung</text>
            </items>
            <items id="at0136">
                <description>Die Anforderung erfordert sofortige Behandlung.</description>
                <text>Notfall</text>
            </items>
            <items id="at0137">
                <description>Die Anforderung erfordert eine prioritäre Behandlung.</description>
                <text>Dringend</text>
            </items>
            <items id="at0138">
                <description>Die Anforderung erfordert keine priorisierte Planung.</description>
                <text>Routine</text>
            </items>
            <items id="at0141">
                <description>Details über den Kliniker oder die Abteilung, die die Dienstleistung anfordert.</description>
                <text>Einsender</text>
            </items>
            <items id="at0142">
                <description>Details über den Kliniker oder die Abteilung, die die Dienstleistung erhält.</description>
                <text>Empfänger</text>
            </items>
            <items id="at0148">
                <description>Kategorie der beantragten Dienstleistung.</description>
                <text>Art der Dienstleistung</text>
            </items>
            <items id="at0149">
                <description>Digitales Dokument, Bild, Video oder Diagramm als zusätzliche Information zur Unterstützung oder Information der Anforderung.</description>
                <text>Unterstützende Informationen</text>
            </items>
            <items id="at0150">
                <description>Weitere Informationen über die Dienstanforderung, welche bisher nicht in den anderen Feldern erfasst wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0151">
                <description>Einzelheiten über eine komplexe Dienstanforderung, die eine Abfolge von Zeitangaben erfordert.</description>
                <text>Komplexe Zeitplanung</text>
            </items>
            <items id="at0152">
                <description>Das Symptom, das Zeichen oder die Diagnose, die die angeforderte Leistung erforderlich macht.</description>
                <text>Klinische Indikation</text>
            </items>
            <items id="at0153">
                <description>Zusätzliche Details und Anweisungen darüber, wie die Dienstleistungen zu erbringen sind.</description>
                <text>Auftragsdetail</text>
            </items>
            <items id="at0154">
                <description>Beschreibende Information über die Person und ihre Situation, die einen relevanten Kontext für den Antrag liefern.</description>
