                <text>Synopsis</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
        </term_definitions>
        <term_definitions language="ar-sy">
            <items id="at0000">
                <description>ملخص بالرواية أو نظرة عامة عن المريض, خاصة من وجهة نظر مقدم الخدمة الصحية, مع إرفاق أو عدم إرفاق تفسيرات </description>
