        <term_definitions language="nl">
            <items id="at0000">
                <description>Een meting van de lichaamstemperatuur, wat een surrogaat is van de kerntemperatuur van het lichaam van een individu.</description>
                <text>Lichaamstemperatuur</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0002">
                <description>*@ internal @(en)</description>
                <text>*History(en)</text>
            </items>
            <items id="at0003">
                <description>Standaard, ongespecificeerd punt in de tijd, of een interval gebeurtenis, die expliciet gedefinieerd kan worden in een template, of terwijl de applicatie loopt.</description>
                <text>Elke gebeurtenis</text>
            </items>
            <items id="at0004">
                <description>De gemeten lichaamstemperatuur (als surrogaat van de kerntemperatuur van het lichaam).</description>
                <text>Temperatuur</text>
            </items>
            <items id="at0020">
                <description>*@ internal @(en)</description>
                <text>*Protocol(en)</text>
            </items>
            <items id="at0021">
                <description>Eenvoudige beschrijving van de locatie van de meting.</description>
                <text>Locatie van de meting</text>
            </items>
            <items id="at0022">
                <description>Temperatuur is gemeten in de mond.</description>
                <text>Mond</text>
            </items>
            <items id="at0023">
                <description>Temperatuur is gemeten in de externe gehoorgang.</description>
                <text>Gehoorgang</text>
            </items>
            <items id="at0024">
                <description>Temperatuur is gemeten op de huid van de axilla met de arm langs het lichaam naar beneden.</description>
                <text>Axilla</text>
            </items>
            <items id="at0025">
                <description>Temperatuur gemeten in het rectum.</description>
                <text>Rectum</text>
            </items>
            <items id="at0026">
                <description>De temperatuur is gemeten in de nasopharynx.</description>
                <text>Nasopharynx</text>
            </items>
            <items id="at0027">
                <description>De temperatuur is gemeten in de urineblaas.</description>
                <text>Urineblaas</text>
            </items>
            <items id="at0028">
                <description>Temperatuur is gemeten in het vaatstelsel.</description>
                <text>Intravasculair</text>
            </items>
            <items id="at0029">
                <description>Informatie over de toestand van de patiënt.</description>
                <text>Toestand</text>
            </items>
            <items id="at0030">
                <description>In hoeverre het individu ontbloot is op het moment van meten.</description>
                <text>Ontbloting</text>
            </items>
            <items id="at0031">
                <description>Geen kleding, onderkleding of bedekking.</description>
                <text>Naakt</text>
            </items>
            <items id="at0032">
                <description>De persoon is bedekt door minder kleding dan gepast zou zijn voor de omgevings omstandigheden.</description>
                <text>Beperkte kleding.</text>
            </items>
            <items id="at0033">
                <description>De persoon is bedekt door een hoeveelheid kleding die gepast is voor de omgevingsomstandigheden.</description>
                <text>Gepaste kleding</text>
            </items>
            <items id="at0034">
                <description>De persoon is bedekt door meer kleding vergeleken dan passend is voor de omgevingsomstandigheden.</description>
                <text>Extra kleding</text>
            </items>
            <items id="at0041">
                <description>Verhalende beschrijving van de omstandigheden waaronder het individu geplaatst is die invloed hebben op de lichaamstemperatuur.</description>
                <text>Beschrijving van de temperatuur stress</text>
            </items>
            <items id="at0043">
                <description>De temperatuur is gemeten op de ontblote huid.</description>
                <text>Huid</text>
            </items>
            <items id="at0051">
                <description>Temperatuur is gemeten in de de vagina.</description>
                <text>Vagina</text>
            </items>
            <items id="at0054">
                <description>Temperatuur is gemeten in de oesophagus.</description>
                <text>Oesophagus</text>
            </items>
            <items id="at0055">
                <description>Temperatuur is gemeten in de liesplooi tussen het been en de buikwand.</description>
                <text>Liesplooi</text>
            </items>
            <items id="at0056">
                <description>Gegevens over de omgevingsfactoren op het moment van de meten van de temperatuur.</description>
                <text>Omgevingsfactoren</text>
            </items>
            <items id="at0057">
                <description>Gegevens over de inspanning van de persoon op het moment van de meting van de temperatuur.</description>
                <text>Inspannign</text>
            </items>
            <items id="at0059">
                <description>Gegevens van het apparaat dat gebruikt is voor het meten van de lichaamstemperatuur.</description>
                <text>Apparaat</text>
            </items>
            <items id="at0060">
                <description>Temperatuur is gemeten op de slaap, boven de arteria temporalis superficialis.</description>
                <text>Slaap</text>
            </items>
            <items id="at0061">
                <description>De temperatuur is gemeten op het voorhoofd.</description>
                <text>Voorhoofd</text>
            </items>
            <items id="at0062">
                <description>Aanvullende informatie benodigd voor het ondervangen van lokale eisen of om te verbinden met andere referentiemodellen/formalismen.</description>
                <text>Uitbreiding</text>
            </items>
            <items id="at0063">
                <description>Extra opmerking over de lichaamstemperatuurmeting die niet gedekt wordt door andere velden.</description>
                <text>Opmerking</text>
            </items>
            <items id="at0064">
                <description>Gestructureerde gegevens over de locatie van meting.</description>
                <text>Gestructureerde meetlocatie</text>
            </items>
            <items id="at0065">
                <description>Huidige dag van de menstruele cyclus.</description>
                <text>Dag van de menstruele cyclus</text>
            </items>
            <items id="at0066">
                <description>Additionele problemen of factoren die invloed kunnen hebben op de meting van de lichaamstemperatuur, niet gedekt door andere velden.</description>
                <text>Beïnvloedende factoren</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Mesura de la temperatura corporal, que és un substitut de la temperatura central del pacient.</description>
                <text>Temperatura corporal</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>History</text>
            </items>
            <items id="at0003">
                <description>Esdeveniment en un interval o moment no especificat, que es pot definir de manera explícita en una plantilla o en temps d'execució.</description>
                <text>Qualsevol esdeveniment</text>
            </items>
            <items id="at0004">
                <description>La temperatura mesurada.</description>
                <text>Temperatura</text>
            </items>
            <items id="at0020">
                <description>@ internal @</description>
                <text>Protocol</text>
            </items>
            <items id="at0021">
                <description>Descripció senzilla sobre el lloc de mesura de la temperatura.</description>
                <text>Lloc del mesurament</text>
            </items>
            <items id="at0022">
                <description>La temperatura es mesura dins de la cavitat bucal.</description>
                <text>Boca</text>
            </items>
            <items id="at0023">
                <description>La temperatura es mesura des de l'interior del canal auditiu extern.</description>
                <text>Canal auditiu</text>
            </items>
            <items id="at0024">
                <description>La temperatura es mesura al buit axil·lar amb el braç posicionat al costat del cos.</description>
                <text>Axil·la</text>
            </items>
            <items id="at0025">
                <description>Mesurament de la temperatura pel recte.</description>
                <text>Recte</text>
            </items>
            <items id="at0026">
                <description>La temperatura es mesura dins de la nasofaringe.</description>
                <text>Nasofaringe</text>
            </items>
            <items id="at0027">
                <description>La temperatura es mesura en la bufeta urinària.</description>
                <text>Bufeta urinària</text>
            </items>
            <items id="at0028">
                <description>La temperatura es mesura dins del sistema vascular.</description>
                <text>Intravascular</text>
            </items>
            <items id="at0029">
                <description>Informació sobre el pacient.</description>
                <text>Estat</text>
            </items>
            <items id="at0030">
                <description>El grau d'exposició del pacient en el moment del mesurament.</description>
                <text>Exposició corporal</text>
            </items>
            <items id="at0031">
                <description>Sense roba, llençols ni cobertures.</description>
                <text>Nu/a</text>
            </items>
            <items id="at0032">
                <description>La persona es troba coberta per una quantitat d'indumentària o roba de llit inferior a la que es considera adequada per a les circumstàncies ambientals.</description>
                <text>Indumentària/roba de llit reduïda</text>
            </items>
            <items id="at0033">
                <description>La persona es troba coberta amb una quantitat dʻindumentària o roba de llit que es considera adequada per a les circumstàncies ambientals.</description>
                <text>Indumentària/roba de llit adequada</text>
            </items>
            <items id="at0034">
                <description>La persona es troba coberta per una quantitat d'indumentària o roba de llit superior a la que es considera adequada per a les circumstàncies ambientals.</description>
                <text>Indumentària/roba de llit incrementada</text>
            </items>
            <items id="at0041">
                <description>Descripció narrativa de les condicions aplicades al pacient que podrien influir en el mesurament de la temperatura corporal.</description>
                <text>Descripció d'estrès tèrmic</text>
            </items>
            <items id="at0043">
                <description>La temperatura es mesura sobre la pell exposada.</description>
                <text>Pell</text>
            </items>
            <items id="at0051">
                <description>La temperatura es mesura dins de la vagina.</description>
                <text>Vagina</text>
            </items>
            <items id="at0054">
                <description>La temperatura es mesura dins de l'esòfag.</description>
                <text>Esòfag</text>
            </items>
            <items id="at0055">
                <description>La temperatura es mesura al plec inguinal entre la cuixa i la paret abdominal.</description>
                <text>Plec inguinal</text>
            </items>
            <items id="at0056">
                <description>Detalls sobre les condicions ambientals al moment del mesurament de la temperatura.</description>
                <text>Condicions ambientals</text>
            </items>
            <items id="at0057">
                <description>Detalls sobre l'activitat física del pacient al moment del mesurament de la temperatura.</description>
                <text>Activitat física</text>
            </items>
            <items id="at0059">
                <description>Detalls sobre el dispositiu utilitzat per mesurar la temperatura corporal.</description>
                <text>Dispositiu</text>
            </items>
            <items id="at0060">
                <description>La temperatura es mesura a la templa, sobre l'artèria temporal superficial.</description>
                <text>Templa</text>
            </items>
            <items id="at0061">
                <description>La temperatura es mesura en el front.</description>
                <text>Front</text>
            </items>
            <items id="at0062">
                <description>Informació addicional requerida per a capturar el contingut local o per alinear-se amb altres models/formalismes de referència.</description>
                <text>Extensió</text>
            </items>
            <items id="at0063">
                <description>Comentaris addicionals sobre el mesurament de la temperatura corporal no recollits en altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0064">
                <description>Detalls estructurats sobre la part de mesura.</description>
                <text>Part de mesurament detallada</text>
