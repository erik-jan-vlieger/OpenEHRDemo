            <items id="at0002">
                <description>*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</description>
                <text>Extensió</text>
            </items>
        </term_definitions>
    </terminology>
    <component_terminologies archetype_id="openEHR-EHR-EVALUATION.contraindication.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="nb">
            <items id="at0000">
                <description>Et klinisk tiltak (for eksempel - men ikke begrenset til, en behandling, en prøve eller prosedyre) som ikke må utføres på pasienten på grunn av sannsynlighet eller mulighet for at individet kan påføres skade.</description>
                <text>Kontraindikasjon</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Navnet på den kliniske intervensjonen eller type tiltak som ikke bør utføres. For eksempel - men ikke begrenset til, en behandling, en prøve eller prosedyre.</description>
                <text>Kontraindisert intervensjon</text>
            </items>
            <items id="at0003">
                <description>Fritekstbeskrivelse som forklarer forholdet mellom "Klinisk indikasjon" og "Kontraindisert intervensjon".</description>
                <text>Rasjonale</text>
            </items>
            <items id="at0004">
                <description>Dato da kontraindikasjonen sist ble oppdatert.</description>
                <text>Sist oppdatert</text>
            </items>
            <items id="at0006">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0007">
                <description>En indikasjon av potensiale for kritisk organskade eller livstruende konsekvenser.</description>
                <text>Kritikalitet</text>
            </items>
            <items id="at0008">
                <description>Ytterligere informasjon om kontraindikasjonen, som ikke er fanget i andre felt.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0009">
                <description>Dato for neste kliniske evaluering.</description>
                <text>Dato for evaluering</text>
            </items>
            <items id="at0010">
                <description>Utførelse av "Kontraindisert intervensjon" vil sannsynligvis ikke resultere i kritisk organskade eller livstruende konsekvenser for individet eller familiemedlemmet. Fremtidig eksponering for den identifiserte intervensjonen bør regnes som en relativ kontraindikasjon under ordinære kliniske omstendigheter.</description>
                <text>Lav</text>
            </items>
            <items id="at0011">
                <description>Utførelse av "Kontraindisert intervensjon" kan resultere i kritisk organskade eller livstruende konsekvenser. Fremtidig eksponering for den identifiserte intervensjonen bør regnes som en absolutt kontraindikasjon under ordinære kliniske omstendigheter.</description>
                <text>Høy</text>
            </items>
            <items id="at0012">
                <description>Umulig å vurdere med tilgjengelig informasjon.</description>
                <text>Ubestemt</text>
            </items>
            <items id="at0013">
                <description>Kategorisering av "Kontraindisert intervensjon".</description>
                <text>Kategori</text>
            </items>
            <items id="at0014">
                <description>Påstand om hvor sikkert det er at individet har en fremtidig skaderisiko på grunn "Kontraindisert intervensjon".</description>
                <text>Status</text>
            </items>
            <items id="at0015">
                <description>En lav grad av klinisk sikkerhet om utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</description>
                <text>Mistenkt</text>
            </items>
            <items id="at0016">
                <description>En rimelig grad av klinisk sikkerhet at utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</description>
                <text>Sannsynlig</text>
            </items>
            <items id="at0017">
                <description>En stor grad av klinisk sikkerhet at utførelse av "Kontraindisert intervensjon" vil påføre individet eller familiemedlemmet skade.</description>
                <text>Bekreftet</text>
            </items>
            <items id="at0018">
                <description>Den tidligere påstanden om at individet ikke bør eksponeres for "Kontraindisert intervensjon" er klinisk revurdert og er ikke lenger vurdert som en aktiv risiko.</description>
                <text>Opphørt</text>
            </items>
            <items id="at0019">
                <description>Den tidligere påstanden om at individet ikke bør eksponeres for "Kontraindisert intervensjon" er avvist med høy grad av klinisk sikkerhet ved testing.</description>
                <text>Avkreftet</text>
            </items>
            <items id="at0020">
                <description>Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0021">
                <description>Den kliniske årsaken til at den identifiserte "Kontraindisert intervensjon" ikke skal benyttes eller utføres.</description>
                <text>Klinisk indikasjon</text>
            </items>
            <items id="at0022">
                <description>Dato/Tid når kontraindikasjonen blir aktiv.</description>
                <text>Gyldighetsperiode start</text>
            </items>
            <items id="at0023">
                <description>Dato/Tid når kontraindikasjonen blir inaktiv.</description>
                <text>Gyldighetsperiode slutt</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>A clinical intervention (including, but not limited to, use of a treatment or performance of a test or procedure) that should not be carried out due to the likelihood, or possibility, of harm being caused to an individual.</description>
                <text>Contraindication</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Identification, by name, of a clinical intervention or class of intervention including, but not limited to, a treatment, test or procedure that should not be performed.</description>
                <text>Contraindicated intervention</text>
            </items>
            <items id="at0003">
                <description>Narrative description explaining the relationship between the 'Indication' and the 'Contraindicated intervention'.</description>
                <text>Rationale</text>
            </items>
            <items id="at0004">
                <description>Date when the contraindication information was last updated.</description>
                <text>Last updated</text>
            </items>
            <items id="at0006">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0007">
                <description>An indication of the potential for critical system organ damage or life threatening consequence.</description>
                <text>Criticality</text>
            </items>
            <items id="at0008">
                <description>Additional narrative about the contraindication, not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0009">
                <description>Date when next due for review by a clinician.</description>
                <text>Review date</text>
            </items>
            <items id="at0010">
                <description>Carrying out of the 'Contraindicated intervention' is unlikely to result in critical system organ damage or life threatening consequences for the individual or family member. Future exposure to the identified intervention should be considered a relative contraindication in normal clinical circumstances.</description>
                <text>Low</text>
            </items>
            <items id="at0011">
                <description>Carrying out of the 'Contraindicated intervention' may result in critical organ system damage or life threatening consequences for the individual or family member. Future exposure to the identified intervention should be considered an absolute contraindication in normal clinical circumstances.</description>
                <text>High</text>
            </items>
            <items id="at0012">
                <description>Unable to assess with information available.</description>
                <text>Indeterminate</text>
            </items>
            <items id="at0013">
                <description>Category of the identified 'Contraindicated intervention'.</description>
                <text>Category</text>
            </items>
            <items id="at0014">
                <description>Assertion about the certainty or potential future risk, of the identified 'Contraindicated intervention'.</description>
                <text>Status</text>
            </items>
            <items id="at0015">
                <description>A low level of clinical certainty that carrying out the 'Contraindicated intervention' will cause harm to the individual or family member.</description>
                <text>Suspected</text>
            </items>
            <items id="at0016">
                <description>A reasonable level of clinical certainty that carrying out the 'Contraindicated intervention' will cause harm to the individual or family member.</description>
                <text>Likely</text>
            </items>
            <items id="at0017">
                <description>A high level of clinical certainty that carrying out the 'Contraindicated intervention' will cause harm to the individual or family member.</description>
                <text>Confirmed</text>
            </items>
            <items id="at0018">
                <description>The previous assertion that the subject should not be exposed to the 'Contraindicated intervention' has been clinically reassessed and considered no longer to be an active risk.</description>
                <text>Resolved</text>
            </items>
            <items id="at0019">
                <description>The previous assertion that the subject should not be exposed to the 'Contraindicated intervention' has been clinically reassessed or has been disproved with a high level of clinical certainty by testing.</description>
                <text>Refuted</text>
            </items>
            <items id="at0020">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0021">
                <description>Identification of the clinical reason why the identified 'Contraindicated intervention' should not be used or performed.</description>
                <text>Clinical indication</text>
            </items>
            <items id="at0022">
                <description>Date/time when the contraindication becomes active.</description>
                <text>Valid period start</text>
            </items>
            <items id="at0023">
                <description>Date/time when the contraindication becomes inactive.</description>
                <text>Valid period end</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-EVALUATION.problem_diagnosis.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Angaben über einen einzelnen identifizierten Gesundheitszustand, eine Verletzung, eine Behinderung oder ein Problem, welches das körperliche, geistige und/oder soziale Wohlergehen einer Einzelperson beeinträchtigt.</description>
                <text>Diagnose/Symptom</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Structure</text>
            </items>
            <items id="at0002">
                <description>Namentliche Bezeichnung des Symptoms ("medical Problem") oder der Diagnose.</description>
                <text>Diagnose-/Symptombezeichnung</text>
            </items>
            <items id="at0003">
                <description>Geschätzte oder exakte Zeit (bzw. Datum), zu der die Diagnose oder das Problem von einer medizinischen Fachkraft festgestellt wurde.</description>
                <text>Datum/Zeitpunkt der klinischen Feststellung</text>
            </items>
            <items id="at0005">
                <description>Eine Gesamtbeurteilung des Schweregrades des Problems oder der Diagnose.</description>
                <text>Schweregrad</text>
            </items>
            <items id="at0009">
                <description>Beschreibung des Problems oder der Diagnose.</description>
                <text>Klinische Beschreibung</text>
            </items>
            <items id="at0012">
                <description>Identifikation einer einfachen Körperstelle zur Lokalisierung des Problems oder der Diagnose.</description>
                <text>Körperstelle</text>
            </items>
            <items id="at0030">
                <description>Geschätzte oder exakte Zeit (bzw. Datum), zu der von einer medizinischen Fachkraft die Genesung oder die Remission des Problems oder der Diagnose festgestellt wurde.</description>
                <text>Datum/Zeitpunkt der Genesung</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Eine strukturierte anatomische Beschreibung der Körperstelle, an der das Problem oder die Diagnose auftreten.</description>
                <text>Strukturierte Körperstelle</text>
            </items>
            <items id="at0043">
                <description>Zusätzlich benötigte Angaben, welche als eindeutige Merkmale des Problem/der Diagnose erfasst werden sollten.</description>
                <text>Spezifische Angaben</text>
            </items>
            <items id="at0046">
                <description>Strukturierte Angaben zu standort-, domänen-, episoden- oder workflow-spezifischen Aspekten des diagnostischen Prozesses.</description>
                <text>Status</text>
            </items>
            <items id="at0047">
                <description>Das Problem oder die Diagnose beeinträchtigt die normale Aktivität nicht, bzw. verursacht nicht bleibende gesundheitliche Schäden, falls es nicht behandelt wird.</description>
                <text>Leicht</text>
            </items>
            <items id="at0048">
                <description>Das Problem oder die Diagnose beeinträchtigt die normale Aktivität oder verursacht bleibende gesundheitliche Schäden, falls es nicht behandelt wird.</description>
                <text>Mäßig</text>
            </items>
            <items id="at0049">
                <description>Das Problem oder die Diagnose verhindert die normale Aktivität oder verursacht schwerwiegende gesundheitliche Schäden, falls es nicht behandelt wird.</description>
                <text>Schwer</text>
            </items>
            <items id="at0069">
                <description>Ergänzende Beschreibung des Problems oder der Diagnose, die nicht anderweitig erfasst wurde.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0070">
                <description>Datum der letzten Aktualisierung der Diagnose bzw. des Problems.</description>
                <text>Zuletzt aktualisiert</text>
            </items>
            <items id="at0071">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0072">
                <description>Beschreibung des Problem-/ Diagnoseverlaufs seit Beginn.</description>
                <text>Beschreibung des Verlaufs</text>
            </items>
            <items id="at0073">
                <description>Grad der Sicherheit, mit der die Diagnose festgestellt wurde.</description>
                <text>Diagnostische Sicherheit</text>
            </items>
            <items id="at0074">
                <description>Die Diagnose wurde mit einem niedrigen Grad an Sicherheit gestellt.</description>
                <text>Vermutet</text>
            </items>
            <items id="at0075">
                <description>Die Diagnose wurde mit einem hohen Maß an Sicherheit gestellt.</description>
                <text>Wahrscheinlich</text>
            </items>
            <items id="at0076">
                <description>Die Diagnose wurde anhand anerkannter Kriterien bestätigt.</description>
                <text>Bestätigt</text>
            </items>
            <items id="at0077">
                <description>Geschätzte oder exakte Zeit (bzw. Datum), zu der die Krankheitsanzeichen oder Symptome zum ersten mal beobachtet wurden.</description>
                <text>Datum des erstmaligen Auftretens</text>
            </items>
            <items id="at0078">
                <description>Die Ursache, eine Reihe von Ursachen oder eine Art und Weise der Verursachung des Problems oder der Diagnose.</description>
                <text>Ätiologie</text>
            </items>
            <items id="at0079">
                <description>Spezifische Variante oder Subtyp der Diagnose, falls relevant.</description>
                <text>Subtyp</text>
            </items>
            <items id="at0080">
                <description>Gesamtbeurteilung der Auswirkungen der Diagnose/des Symptoms auf den Patienten.</description>
                <text>Auswirkungen</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Detaljer om enskilt identifierat hälsotillstånd, skada, funktionshinder eller något annat problem som påverkar individens fysiska, psykiska och eller sociala välbefinnande.</description>
                <text>Problem/Diagnos</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Problemets eller diagnosens benämning.</description>
                <text>Benämning på problem/diagnos</text>
            </items>
            <items id="at0003">
                <description>Uppskattat eller reellt datum och tid när problemets eller diagnosens tecken eller symtom först bekräftades av sjukvårdspersonal.</description>
                <text>Datum och tid för klinisk bekräftelse</text>
            </items>
            <items id="at0005">
                <description>En bedömning av problemets eller diagnosens totala svårighetsgrad.</description>
                <text>Svårighetsgrad</text>
            </items>
            <items id="at0009">
                <description>Beskrivning av problemet eller diagnosen.</description>
                <text>Klinisk beskrivning</text>
            </items>
            <items id="at0012">
                <description>Identifiering av problemets eller diagnosens anatomiska plats.</description>
                <text>Anatomisk position</text>
            </items>
            <items id="at0030">
                <description>Av sjukvårdspersonal uppskattat eller faktiskt datum och tid för tillfrisknande eller remission.</description>
                <text>Datum och tid för tillfrisknande</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>En strukturerad anatomisk plats för problemet eller diagnosen.</description>
                <text>Strukturerad anatomisk position</text>
            </items>
            <items id="at0043">
                <description>Ytterligare detaljer som krävs för att dokumentera de egenskaper som är unika för problemet eller diagnosen.</description>
                <text>Specifika detaljer</text>
            </items>
            <items id="at0046">
                <description>Strukturerade specifika detaljer om den diagnostiska processen såsom plats, område, episod eller arbetsflöde.</description>
                <text>Status</text>
            </items>
            <items id="at0047">
                <description>Problemet eller diagnosen påverkar inte normal aktivitet och kan inte orsaka skador på hälsan utan behandling.</description>
                <text>Lindrig</text>
            </items>
            <items id="at0048">
                <description>Problemet eller diagnosen stör normal aktivitet och kan skada hälsan utan behandling.</description>
                <text>Måttlig</text>
            </items>
            <items id="at0049">
                <description>Problemet eller diagnosen förhindrar normal aktivitet och kan allvarligt skada hälsan utan behandling.</description>
                <text>Svår</text>
            </items>
            <items id="at0069">
                <description>Ytterligare beskrivning av problemet eller diagnosen som inte dokumenterats i andra fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0070">
                <description>Datum då dokumentation om problemet eller diagnosen senast uppdaterades.</description>
                <text>Senast uppdaterad</text>
            </items>
            <items id="at0071">
                <description>Plats för tilläggsinformation som krävs för lokala anpassningar eller anpassning till andra referensmodeller eller formella krav.</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0072">
                <description>Beskrivning av problemets eller diagnosens förlopp sedan debuten.</description>
                <text>Förlopp</text>
            </items>
            <items id="at0073">
                <description>Graden av säkerhet vid fastställande av diagnosen.</description>
                <text>Diagnostisk säkerhet</text>
            </items>
            <items id="at0074">
                <description>Diagnosen har bekräftats med en låg grad av säkerhet.</description>
                <text>Misstänkt</text>
            </items>
            <items id="at0075">
                <description>Diagnosen har bekräftats med en hög grad av säkerhet.</description>
                <text>Sannolik</text>
            </items>
            <items id="at0076">
                <description>Diagnosen har bekräftats mot kända kriterier.</description>
                <text>Bekräftad</text>
            </items>
            <items id="at0077">
                <description>Uppskattat eller reellt datum och tid när problemets eller diagnosens tecken eller symtom först observerades.</description>
                <text>Datum och tid för debut</text>
            </items>
            <items id="at0078">
                <description>En eller flera orsaker till problemet eller diagnosen, eller dess uppkomstsätt</description>
                <text>Orsak</text>
            </items>
            <items id="at0079">
                <description>Specificering av diagnosen, där det är relevant.</description>
                <text>Specificering</text>
            </items>
            <items id="at0080">
                <description>*Overall assessment of the impact of a health problem for the specific patient. (en)</description>
                <text>*Impact(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="fi">
            <items id="at0000">
                <description>Yksityiskohdat yksittäisestä tunnistetusta terveystilasta, vammasta, vammasta tai muusta aiheesta, joka vaikuttaa yksilön fyysiseen, henkiseen ja / tai sosiaaliseen hyvinvointiin.</description>
                <text>Ongelma/Diagnoosi</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Ongelman tai diagnoosin tunnistaminen nimellä.</description>
                <text>Ongelman/Diagnoosin nimi</text>
            </items>
            <items id="at0003">
                <description>Arvioitu tai tarkka ajankohta ongelman tai diagnoosin toteamiselle terv.huollon ammattilaisen tekemänä</description>
                <text>Toteamispäivämäärä</text>
            </items>
            <items id="at0005">
                <description>Arvioitu vakavuus oireen tai diagnoosin kohdalla</description>
                <text>Vakavuus</text>
            </items>
            <items id="at0009">
                <description>Ongelman tai diagnoosin vapaamuotoinen selitys</description>
                <text>Kliininen kuvaus</text>
            </items>
            <items id="at0012">
                <description>Yksinkertaisen vartalokohdan tunnistaminen ongelman tai diagnoosin sijaintia varten.</description>
                <text>Kehonosa</text>
            </items>
            <items id="at0030">
                <description>ongelman tai diagnoosin arvioitu tai todellinen ratkaisemis- tai loppumispäivämäärä / -aika, jonka on määrittänyt terveydenhuollon ammattilainen.</description>
                <text>Toteamise pvm</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Ongelman tai diagnoosin anatominen alue</description>
                <text>Anatominen alue</text>
            </items>
            <items id="at0043">
                <description>Tiedot, joita tarvitaan lisäksi tämän ongelman tai diagnoosin yksilöivinä ominaisuuksina tallentamiseksi.</description>
                <text>Tarkennettu tieto</text>
            </items>
            <items id="at0046">
                <description>Jäsennellyt yksityiskohdat diagnosointiprosessin sijainti-, alue-, jakso- tai työnkulkukohtaisista näkökohdista.</description>
                <text>Status</text>
            </items>
            <items id="at0047">
                <description>Ongelma tai diagnoosi ei häiritse normaalia toimintaa tai voi aiheuttaa terveysvaurioita, jos sitä ei hoideta.</description>
                <text>Vähäinen</text>
            </items>
            <items id="at0048">
                <description>Ongelma tai diagnoosi häiritsee normaalia toimintaa tai vahingoittaa terveyttä, jos sitä jätetään hoitamatta.</description>
                <text>Kohtalainen</text>
            </items>
            <items id="at0049">
                <description>Ongelma tai diagnoosi estää normaalia toimintaa tai vahingoittaa vakavasti terveyttä, jos sitä jätetään hoitamatta.</description>
                <text>Vakava</text>
            </items>
            <items id="at0069">
                <description>Lisätietoa ongelmasta tai diagnoosista, jota ei voi asettaa edeltäville tietokentille.</description>
                <text>Kommentti</text>
            </items>
            <items id="at0070">
                <description>Ongelman tai diagnoosin viimeisin päivityspäivämäärä</description>
                <text>Viimeksi päivitetty</text>
            </items>
            <items id="at0071">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Laajennus</text>
            </items>
            <items id="at0072">
                <description>Kuvaus ongelman tai diagnoosin etenemisestä alusta.</description>
                <text>Ongelman kulku</text>
            </items>
            <items id="at0073">
                <description>Diagnoosin tunnistamisen luotettavuus</description>
                <text>Diagnoosin varmuus</text>
            </items>
            <items id="at0074">
                <description>Diagnoosi on tunnistettu alhaisella varmuustasolla.</description>
                <text>Epäilty</text>
            </items>
            <items id="at0075">
                <description>Diagnoosi on tunnistettu erittäin varmuudella.</description>
                <text>Mahdollinen</text>
            </items>
            <items id="at0076">
                <description>Diagnoosi on vahvistettu tunnustettujen kriteerien perusteella.</description>
                <text>Varmistettu</text>
            </items>
            <items id="at0077">
                <description>Arvioitu tai todellinen päivämäärä / aika, jolloin ongelman / diagnoosin merkkejä tai oireita havaittiin ensimmäisen kerran.</description>
                <text>Alkamis pvm</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
                <text>*Variant (en)</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="ko">
            <items id="at0000">
                <description>한 개인의 신체, 정신 그리고/또는 사회적 웰빙에 영향을 주는 단일한 확인된 건강 성태, 상해, 장애 또는 다른 이슈에 대한 상세내용.</description>
                <text>문제/진단</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>명칭으로 문제 또는 진단의 식별.</description>
                <text>문제/진단명</text>
            </items>
            <items id="at0003">
                <description>진단 또는 문가가 헬스케어 전문가에게 인지된 추정 또는 실제 날짜/시간.</description>
                <text>임상적으로 인지된 날짜/시간</text>
            </items>
            <items id="at0005">
                <description>문제 또는 진단의 전반적인 중증도 평가.</description>
                <text>중증도</text>
            </items>
            <items id="at0009">
                <description>문제 또는 진단에 대한 서술 기록.</description>
                <text>임상적 서술</text>
            </items>
            <items id="at0012">
                <description>문제 또는 진단의 위치를 위해 간단한 신체 위치 확인</description>
                <text>신체 위치</text>
            </items>
            <items id="at0030">
                <description>헬스케어 전문가에 의해 결정된 이 문제나 진단의 추정 또는 실제 완치 또는 관해 날짜시간.</description>
                <text>완치 날짜/시간</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>문제 또는 진단을 위한 구조화된 해부학적 위치</description>
                <text>구조화된 신체 위치</text>
            </items>
            <items id="at0043">
                <description>이 문제 또는 진단의 유일한 속성으로 기록하는데 필요한 상세내용.</description>
                <text>특정 상세내용</text>
            </items>
            <items id="at0046">
                <description>진단 과정의 위치-, 도메인-, 에피소드- 또는 워크플로우-특징적인 측면에 대한 구조화된 상세내용.</description>
                <text>상태</text>
            </items>
            <items id="at0047">
                <description>문제나 진단이 정상 활동을 방해하지 않거나 치료하지 않으면 건강에 해를 일으킬 수 있음.</description>
                <text>경도</text>
            </items>
            <items id="at0048">
                <description>문제나 진단이 정상 활동에 방해가 되거나 치료하지 않으면 건강에 해가 됨.</description>
                <text>중등도</text>
            </items>
            <items id="at0049">
                <description>문제나 진단이 정상 활동을 할 수 없게 하거나 치료하지 않으면 건강에 심각한 해가 됨.</description>
                <text>증증도</text>
            </items>
            <items id="at0069">
                <description>다른 필드에서 획득되지 않은 문제 또는 진단에 대한 추가적인 서술내용</description>
                <text>코멘트</text>
            </items>
            <items id="at0070">
                <description>문제 또는 진단이 최종 업데이트된 날짜.</description>
                <text>최종 업데이트 날짜</text>
            </items>
            <items id="at0071">
                <description>로컬 컨텐트를 획득하거나 다른 참조모델/표기형식과 조율하기 위해 필요한 추가적인 정보.</description>
                <text>확장</text>
            </items>
            <items id="at0072">
                <description>발병이후 문제 또는 진단의 결과에 대한 서술.</description>
                <text>경과 서술</text>
            </items>
            <items id="at0073">
                <description>진단을 확인하는 신뢰의 수준.</description>
                <text>진단적 확실성</text>
            </items>
            <items id="at0074">
                <description>진단이 낮은 확신 수준으로 식별됨.</description>
                <text>의심</text>
            </items>
            <items id="at0075">
                <description>진단이 높은 확신 수준으로 식별됨.</description>
                <text>추정</text>
            </items>
            <items id="at0076">
                <description>진단이 인정된 기준에 대해 확진됨.</description>
                <text>확진</text>
            </items>
            <items id="at0077">
                <description>문제/진단의 증상 또는 징후가 처음 관찰된 추정 또는 실제 날짜/시간.</description>
                <text>발병 날짜/시간</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
                <text>*Variant (en)</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Detalhes sobre uma única condição de saúde identificada, lesões, deficiência ou qualquer outra questão que tenha impacto sobre o bem-estar físico, mental e / ou social de um indivíduo.</description>
                <text>Problema /Diagnóstico</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identificação do problema ou diagnóstico, por nome.</description>
                <text>Nome do Problema / Diagnóstico</text>
            </items>
            <items id="at0003">
                <description>Data / hora, estimada ou real, que o diagnóstico ou o problema foi reconhecido por um profissional de saúde.</description>
                <text>Data / hora da reconhecimento clínico</text>
            </items>
            <items id="at0005">
                <description>Uma avaliação global da severidade do problema ou diagnóstico.</description>
                <text>Severidade</text>
            </items>
            <items id="at0009">
                <description>Descrição narrativa sobre o problema ou diagnóstico.</description>
                <text>Descrição clínica</text>
            </items>
            <items id="at0012">
                <description>Simples identificação de um local do corpo para a localização do problema ou diagnóstico.</description>
                <text>Local do corpo</text>
            </items>
            <items id="at0030">
                <description>Data / tempo, estimado ou atual, de resolução ou de dispensa desse problema ou diagnóstico, como determinado por um profissional de saúde.</description>
                <text>Data /tempo de resolução</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree(en)</text>
            </items>
            <items id="at0039">
                <description>A localização anatômica estruturada para o problema ou diagnóstico.</description>
                <text>Local estruturado do corpo</text>
            </items>
            <items id="at0043">
                <description>Detalhes que são adicionalmente necessários para gravar atributos como únicos deste problema ou diagnóstico.</description>
                <text>Detalhes específicos</text>
            </items>
            <items id="at0046">
                <description>Detalhes estruturados para localização, domínio, episódio ou aspectos específicos do fluxo de trabalho do processo de diagnóstico.</description>
                <text>Estado</text>
            </items>
            <items id="at0047">
                <description>O problema ou o diagnóstico não interfere na atividade normal ou causa danos à saúde, se não for tratado.</description>
                <text>Suave</text>
            </items>
            <items id="at0048">
                <description>O problema ou o diagnóstico interfere na atividade normal ou prejudicará a saúde, se não for tratado.</description>
                <text>Moderado</text>
            </items>
            <items id="at0049">
                <description>O problema ou diagnóstico impede a atividade normal ou causará sérios danos à saúde se não tratado.</description>
                <text>Severo</text>
            </items>
            <items id="at0069">
                <description>Narrativa adicional sobre o problema ou diagnóstico, não capturados em outros campos.</description>
                <text>Comentário</text>
            </items>
            <items id="at0070">
                <description>A data este problema ou diagnóstico foi atualizado pela última vez.</description>
                <text>Ultima atualização</text>
            </items>
            <items id="at0071">
                <description>Informações adicionais necessárias para capturar o conteúdo local ou para alinhar com outros modelos de referência / formalismos.</description>
                <text>Extensão</text>
            </items>
            <items id="at0072">
                <description>Descrição narrativa sobre o curso do problema ou diagnóstico, desde o início.</description>
                <text>Descrição do curso</text>
            </items>
            <items id="at0073">
                <description>O nível de confiança da identificação do diagnóstico.</description>
                <text>Certeza do diagnóstico</text>
            </items>
            <items id="at0074">
                <description>O diagnóstico foi identificado com um nível baixo de convicção.</description>
                <text>Suspeito</text>
            </items>
            <items id="at0075">
                <description>O diagnóstico foi identificado com um elevado grau de certeza.</description>
                <text>Provável</text>
            </items>
            <items id="at0076">
                <description>O diagnóstico foi confirmado com base em critérios reconhecidos.</description>
                <text>confirmado</text>
            </items>
            <items id="at0077">
                <description>Data / tempo, estimada ou real, que os sinais ou sintomas do problema / diagnóstico foram observados pela primeira vez.</description>
                <text>Data / tempo de início</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
                <text>*Variant (en)</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Details about a single identified health condition, injury, disability or any other issue which impacts on the physical, mental and/or social well-being of an individual.</description>
                <text>Problem/Diagnosis</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identification of the problem or diagnosis, by name.</description>
                <text>Problem/Diagnosis name</text>
            </items>
            <items id="at0003">
                <description>Estimated or actual date/time the diagnosis or problem was recognised by a healthcare professional.</description>
                <text>Date/time clinically recognised</text>
            </items>
            <items id="at0005">
                <description>An assessment of the overall severity of the problem or diagnosis.</description>
                <text>Severity</text>
            </items>
            <items id="at0009">
                <description>Narrative description about the problem or diagnosis.</description>
                <text>Clinical description</text>
            </items>
            <items id="at0012">
                <description>Identification of a simple body site for the location of the problem or diagnosis.</description>
                <text>Body site</text>
            </items>
            <items id="at0030">
                <description>Estimated or actual date/time of resolution or remission for this problem or diagnosis, as determined by a healthcare professional.</description>
                <text>Date/time of resolution</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>A structured anatomical location for the problem or diagnosis.</description>
                <text>Structured body site</text>
            </items>
            <items id="at0043">
                <description>Details that are additionally required to record as unique attributes of this problem or diagnosis.</description>
                <text>Specific details</text>
            </items>
            <items id="at0046">
                <description>Structured details for location-, domain-, episode- or workflow-specific aspects of the diagnostic process.</description>
                <text>Status</text>
            </items>
            <items id="at0047">
                <description>The problem or diagnosis does not interfere with normal activity or may cause damage to health if left untreated.</description>
                <text>Mild</text>
            </items>
            <items id="at0048">
                <description>The problem or diagnosis causes interference with normal activity or will damage health if left untreated.</description>
                <text>Moderate</text>
            </items>
            <items id="at0049">
                <description>The problem or diagnosis prevents normal activity or will seriously damage health if left untreated.</description>
                <text>Severe</text>
            </items>
            <items id="at0069">
                <description>Additional narrative about the problem or diagnosis not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0070">
                <description>The date this problem or diagnosis was last updated.</description>
                <text>Last updated</text>
            </items>
            <items id="at0071">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0072">
                <description>Narrative description about the course of the problem or diagnosis since onset.</description>
                <text>Course description</text>
            </items>
            <items id="at0073">
                <description>The level of confidence in the identification of the diagnosis.</description>
                <text>Diagnostic certainty</text>
            </items>
            <items id="at0074">
                <description>The diagnosis has been identified with a low level of certainty.</description>
                <text>Suspected</text>
            </items>
            <items id="at0075">
                <description>The diagnosis has been identified with a high level of certainty.</description>
                <text>Probable</text>
            </items>
            <items id="at0076">
                <description>The diagnosis has been confirmed against recognised criteria.</description>
                <text>Confirmed</text>
            </items>
            <items id="at0077">
                <description>Estimated or actual date/time that signs or symptoms of the problem/diagnosis were first observed.</description>
                <text>Date/time of onset</text>
            </items>
            <items id="at0078">
                <description>A cause, set of causes, or manner of causation of the problem or diagnosis.</description>
                <text>Cause</text>
            </items>
            <items id="at0079">
                <description>Specific variant or subtype of the Diagnosis, if relevant.</description>
                <text>Variant</text>
            </items>
            <items id="at0080">
                <description>Overall assessment of the impact of a health problem for the specific patient.</description>
                <text>Impact</text>
            </items>
        </term_definitions>
        <term_definitions language="ar-sy">
            <items id="at0000">
                <description>*Details about a single identified health condition, injury, disability or any other issue which impacts on the physical, mental and/or social well-being of an individual.(en)</description>
                <text>*Problem/Diagnosis(en)</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*structure(en)</text>
            </items>
            <items id="at0002">
                <description>*Identification of the problem or diagnosis, by name.(en)</description>
                <text>*Problem/Diagnosis name(en)</text>
            </items>
            <items id="at0003">
                <description>*Estimated or actual date/time the diagnosis or problem was recognised by a healthcare professional.(en)</description>
                <text>*Date/time clinically recognised(en)</text>
            </items>
