                <description>دما از طریق بینی حلقی اندازه گیری می شود</description>
                <text>بینی حلقی</text>
            </items>
            <items id="at0027">
                <description>دما از طریق مثانه اندازه گیری می شود</description>
                <text>مثانه</text>
            </items>
