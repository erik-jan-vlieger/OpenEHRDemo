        <term_definitions language="nb">
            <items id="at0000">
                <description>Interaksjon, kontakt eller omsorgshendelse mellom et individ og helsepersonell.</description>
                <text>Klinisk kontakt</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.</description>
                <text>Utvidelse</text>
            </items>
        </term_definitions>
        <term_definitions language="nl">
            <items id="at0000">
                <description>Interactie, contact of zorggebeurtenis tussen een onderwerp van zorg en zorgverlener(s).</description>
                <text>Contact</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0002">
                <description>*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</description>
                <text>Extensie</text>
            </items>
            <items id="id1">
                <description>Contactmoment voor wondzorg volgens het Algemeen Wondprotocol Sensire.</description>
                <text>Wondconsult Sensire</text>
            </items>
            <items id="id2">
                <description>Diagnose en classificatie van de wond.</description>
                <text>Wonddiagnose</text>
            </items>
            <items id="id3">
                <description>Lichamelijk onderzoek van de wond volgens TIME-framework.</description>
                <text>Wondinspectie (TIME)</text>
            </items>
            <items id="id4">
                <description>Temperatuurmeting bij infectieverdenking.</description>
                <text>Lichaamstemperatuur</text>
            </items>
            <items id="id5">
                <description>Reiniging, debridement of verband aanleggen.</description>
                <text>Procedure</text>
            </items>
            <items id="id6">
                <description>Toediening van pijnmedicatie.</description>
                <text>Pijnmedicatie</text>
            </items>
            <items id="id7">
                <description>Gezondheidsvoorlichting specifiek voor DM-patiënten.</description>
                <text>DM-voorlichting</text>
            </items>
            <items id="id8">
                <description>Order voor lokaal of systemisch antibacterieel middel.</description>
                <text>Antibacterieel beleid</text>
            </items>
            <items id="id9">
                <description>Order voor verbandmateriaal.</description>
                <text>Verbandorder</text>
            </items>
            <items id="id10">
                <description>Verwijzing naar de vakgroep wondzorg bij stagnatie.</description>
                <text>Verwijzing vakgroep</text>
            </items>
            <items id="id11">
                <description>Zorgplan voor wondbehandeling.</description>
                <text>Wondplan</text>
            </items>
            <items id="id12">
                <description>Klinische samenvatting.</description>
                <text>Samenvatting</text>
            </items>
            <items id="id13">
                <description>Contra-indicaties voor debridement.</description>
                <text>Contra-indicatie debridement</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Interacció, contacte o esdeveniment d’atenció entre un pacient i un o més professionals d'atenció sanitària.</description>
                <text>Encontre</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Tree</text>
