            </items>
            <items id="at0004">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Resumen narrativo o visión general sobre un paciente, específicamente desde la perspectiva de un profesional sanitario, y con o sin interpretaciones asociadas.</description>
                <text>Sinopsis clínica</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>List</text>
            </items>
            <items id="at0002">
