    <component_terminologies archetype_id="openEHR-EHR-INSTRUCTION.medication_order.v3" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Verschreibung eines Medikaments, Impfstoffs, Ernährungsprodukts oder anderen therapeutischen Mittels für eine bestimmte Person.</description>
                <text>Verordnung von Arzneimittel</text>
            </items>
            <items id="at0001">
                <description>Angaben zur Verordnung.</description>
                <text>Verordnung</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Eindeutige Kennung der Medikamentenverordnung / des Rezeptes.</description>
                <text>ID der Verordnung</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0009">
                <description>Gesamtbeschreibung, wie das verordneten Medikament zu verwenden ist.</description>
                <text>Allgemeine Beschreibung der Anweisungen</text>
            </items>
            <items id="at0011">
                <description>Eine Bedingung für den Beginn der Verwendung des verordneten Arzneimittels.</description>
                <text>Startkriterium für die Verordnung</text>
            </items>
            <items id="at0012">
                <description>Datum und optionale Uhrzeit für den Beginn der Verwendung des verordneten Arzneimittels.</description>
                <text>Beginn der Verordnung</text>
            </items>
            <items id="at0013">
                <description>Datum und optionale Uhrzeit, wann die Verwendung des verordneten Arzneimittels eingestelt werden soll.</description>
                <text>Ende der Verordnung</text>
            </items>
            <items id="at0016">
                <description>Eine Bedingung für das Einstellen der Verwendung des verordneten Arzneimittels.</description>
                <text>Stopkriterium für die Verordnung</text>
            </items>
            <items id="at0018">
                <description>Der klinische Grund für die Verwendung des verordneten Arzneimittels.</description>
                <text>Klinische Indikation</text>
            </items>
            <items id="at0044">
                <description>Ein zusätzlicher Hinweis zur Verwendung oder Lagerung des verordneten Arzneimittels.</description>
                <text>Zusätzliche Anweisung</text>
            </items>
            <items id="at0047">
                <description>Eine maschinenlesbare, berechenbare Textdarstellung der Anweisung.</description>
                <text>Maschinenlesbare Anweisungen</text>
            </items>
            <items id="at0050">
                <description>Der Zeitraum, in dem die Person / der Patient das verordnete Arzneimittel noch vor der Ausstellung dieser Verordnung bereits angewendet hat.</description>
                <text>Dauer der durchgeführten Verordnung</text>
            </items>
            <items id="at0051">
                <description>Details zur maximal zulässigen kumulativen Dosis über einen definierten Zeitraum für das verordnete Arzneimittel.</description>
                <text>Maximale Dosis</text>
            </items>
            <items id="at0053">
                <description>Der Zeitraum, für den die maximale Dosis berechnet wird.</description>
                <text>Zulässige Dauer</text>
            </items>
            <items id="at0060">
                <description>Die Anzahl der Verabreichungen des verordneten Arzneimittels, die im Rahmen der geplanten Gesamtverordnung, bereits vor dieser Ausgabe, durchgeführt wurden.</description>
                <text>Anwendungen durchgeführt</text>
            </items>
            <items id="at0062">
                <description>Angaben über die Arzneimittelsicherheit des verordneten Medikaments.</description>
                <text>Arzneimittelsicherheit</text>
            </items>
            <items id="at0064">
                <description>Bestätigung durch den verschreibenden Arzt, ob die normale Dosis oder andere Sicherheitsgrenzen aufgrund besonderer Umstände überschritten wurden.</description>
                <text>Beabsichtigte Sicherheitsüberschreitung?</text>
            </items>
            <items id="at0065">
                <description>Detaillierte Angaben zur Menge des verordneten Arzneimittels, das abgegeben werden soll.</description>
                <text>Abgabemenge</text>
            </items>
            <items id="at0069">
                <description>Details der Autorisierung für das verordnete Arzneimittel, einschließlich Unterstützung der lokalen Richtlinien zur Selbstverwaltung, Ausgabe und Bestätigung.</description>
                <text>Anweisungen zur Genehmigung</text>
            </items>
            <items id="at0070">
                <description>Name des verordneten Medikaments, Impfstoffs oder anderen therapeutischen / verschreibungsfähigen Mittels.</description>
                <text>Arzneimittel</text>
            </items>
            <items id="at0091">
                <description>Die Angabe darüber, auf welche Art das verordnete Arzneimittel am Körper des Patienten angewendet wird.</description>
                <text>Verabreichungsweg</text>
            </items>
            <items id="at0092">
                <description>Name der Körperstelle, an der das Arzneimittel verabreicht wird.</description>
                <text>Körperstelle</text>
            </items>
            <items id="at0093">
                <description>Strukturierte Beschreibung der Körperstelle, an der das Arzneimittel verabreicht wird.</description>
                <text>Lokalisation</text>
            </items>
            <items id="at0094">
                <description>Die Technik oder das Gerät mit dem das versordnete Arzneimittel verabreicht werden soll.</description>
                <text>Methode der Verabreichung</text>
            </items>
            <items id="at0095">
                <description>Details zu der Vorrichtung mit der das verordnete Arzneimittel verabreicht wird.</description>
                <text>Verabreichungsmittel</text>
            </items>
            <items id="at0105">
                <description>Ein zusätzlicher Hinweis, der sich in erster Linie an die Person/ den Patienten oder Angehörige richtet.</description>
                <text>Patienteninformation</text>
            </items>
            <items id="at0106">
                <description>Ein zusätzlicher Hinweis richtet sich in erster Linie an die Person, die das verordnete Arzneimittel verteilt.</description>
                <text>Abgabehinweis</text>
            </items>
            <items id="at0107">
                <description>Eine zusätzliche Anweisung mit Hinweisen auf die empfohlene oder erforderliche Überwachung bei Verwendung des verordneten Arzneimittels.</description>
                <text>Überwachungshinweis</text>
            </items>
            <items id="at0112">
                <description>Zusammenfassende Informationen zur Verwendung des verordneten Arzneimittels, z. B. aktueller Status oder Schlüsseldaten, die normalerweise in anderen Kontexten außer Verordnung verwendet werden.</description>
                <text>Zusammenfassung der Verordnung</text>
            </items>
            <items id="at0113">
                <description>Detaillierte Angaben zu der gesamten Medikamentenverordnung.</description>
                <text>Detaillierte Angaben zu der Verordnung</text>
            </items>
            <items id="at0129">
                <description>Anweisungen zur Abgabe des verordneten Arzneimittels.</description>
                <text>Anweisungen zur Abgabe</text>
            </items>
            <items id="at0130">
                <description>Die maximale, kumulative Menge an Medikamenten, die innerhalb des zulässigen Zeitraums verabreicht werden sollte.</description>
                <text>Höchstmenge</text>
            </items>
            <items id="at0132">
                <description>Erlaubnis zum Ersatz durch ein bioäquivalentes Arzneimittel.</description>
                <text>Substitutionsanweisung</text>
            </items>
            <items id="at0139">
                <description>Ein Indikator wie dringlich das verordnete Arzneimittel abgegeben werden soll.</description>
                <text>Priorität</text>
            </items>
            <items id="at0143">
                <description>Strukturierte Angaben über das gesamte Medikament, einschließlich Stärke, Form und Inhaltsstoffe.</description>
                <text>Angaben zur Medikation</text>
            </items>
            <items id="at0148">
                <description>Gesamttherapeutischer Zweck des verordneten Arzneimittels.</description>
                <text>Therapiezweck</text>
            </items>
            <items id="at0150">
                <description>Angaben zur täglichen Gesamtmenge des verordneten Arzneimittels, das verabreicht werden soll.</description>
                <text>Tägliche effektive Gesamtdosis</text>
            </items>
            <items id="at0151">
                <description>Die Gesamtmenge des Arzneimittels, die bei bestimmungsgemäßer Verabreichung täglich angewendet wird.</description>
                <text>Tägliche Gesamtdosis</text>
            </items>
            <items id="at0154">
                <description>Der Grund warum eine Substitution des verordneten Arzneimittels nicht zulässig ist.</description>
                <text>Ablehnungsgrund der Substitution</text>
            </items>
            <items id="at0155">
                <description>Das Datum, ab dem das verordnete Arzneimittel zum ersten Mal abgegeben werden darf.</description>
                <text>Beginn der Abgabe</text>
            </items>
            <items id="at0161">
                <description>Das Datum, ab dem das Rezept für die legale Abgabe des Arzneimittels nicht mehr gültig ist.</description>
                <text>Ablaufdatum der Abgabe</text>
            </items>
            <items id="at0162">
                <description>Der Grund für eine Überschreitung der klinischen Sicherheit oder maximalen Dosis.</description>
                <text>Grund der Überschreitung</text>
            </items>
            <items id="at0165">
                <description>Beschreibung des Grundes für die Erfassung einer täglichen effektiven Gesamtdosis.</description>
                <text>Zweck</text>
            </items>
            <items id="at0166">
                <description>Zusätzliche strukturierte Angaben über verordnetes Arzneimittel, die nicht in anderen Feldern erfasst wurden.</description>
                <text>Zusätzliche Information</text>
            </items>
            <items id="at0167">
                <description>Zusätzliche Kommentare über die Medikamentenverordnung, die nicht in anderen Feldern erfasst wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0168">
                <description>Die Substitution des Arzneimittels mit einem bioequivalenten Arzneimittel ist erlaubt.</description>
                <text>Erlaubt</text>
            </items>
            <items id="at0169">
                <description>Die Substitution des Arzneimittels mit einem bioequivalenten Arzneimittel ist nicht erlaubt.</description>
                <text>Nicht erlaubt</text>
            </items>
            <items id="at0170">
                <description>Weitere detaillierte Angaben zu den Anweisungen zur Abgabe.</description>
                <text>Details der Abgabe</text>
            </items>
            <items id="at0171">
                <description>Ein bekanntes oder anerkanntes Sicherheitsproblem, das für dieses Medikament gilt, wie z. B. eine Allergie, ein Warnhinweis zur Vervielfältigung von Arzneimitteln oder eine Kontraindikation. Dieses Element wird normalerweise nur aufgezeichnet, wenn dieser Sicherheitshinweis außer Kraft gesetzt wird.</description>
                <text>Hinweis zur überschrittenen Sicherheitsgrenze</text>
            </items>
            <items id="at0173">
                <description>Freitextbeschreibung eines bestimmten Teils der Gesamtanweisung.</description>
                <text>Beschreibung der spezifischen Anweisungen</text>
            </items>
            <items id="at0174">
                <description>Eine Beschreibung der Begründung für die Berechnung einer Dosismenge oder Verabreichungsrate, wenn dies von einem anderen Faktor abhängt.</description>
                <text>Begründung der Dosis</text>
            </items>
            <items id="at0177">
                <description>Details zu strukturierten Dosis- und Zeitangaben</description>
                <text>Strukturierte Dosis- und Zeitangaben</text>
            </items>
            <items id="at0178">
                <description>Überschreiten eines bekannten oder anerkannten Sicherheitshinweis des Medikaments, wie z. B. eine Allergie, eine Warnung vor Drogenmissbrauch oder eine Kontraindikation.</description>
                <text>Sicherheitsgrenze überschritten</text>
            </items>
            <items id="at0179">
                <description>Empfehlung an die zukünftigen Verordner/Abgeber über die fortlaufende, langjährige Verordnung.</description>
                <text>Klinische Leitlinie</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>En beställning av ett läkemedel, vaccin, näringspreparat eller annat terapeutiskt produkt för en identifierad individ.</description>
                <text>Läkemedelsbeställning</text>
            </items>
            <items id="at0001">
                <description>Information om den begärda ordern.</description>
                <text>Order</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Unik identifikator för läkemedelsbeställningen.</description>
                <text>Beställnings-ID</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Plats för att infoga tilläggsinformation som krävs för lokala anpassningar eller anpassning till andra referensmodeller eller formella krav.</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0009">
                <description>Komplett beskrivning om hur den beställda artikeln ska användas.</description>
                <text>Fullständig beskrivning av anvisningar</text>
            </items>
            <items id="at0011">
                <description>Det villkor som måste vara uppfyllt innan administrering eller användning påbörjas.</description>
                <text>Startkriterium för order</text>
            </items>
            <items id="at0012">
                <description>Datum och tid (valfritt) då användning av den beställda artikeln planeras påbörja.</description>
                <text>Datum/tid för påbörjad order</text>
            </items>
            <items id="at0013">
                <description>Datum och tid (valfritt) då användning av den beställda artikeln planeras upphöra.</description>
                <text>Datum/tid för avslutad order</text>
            </items>
            <items id="at0016">
                <description>Det villkor som måste vara uppfyllt innan administrering eller användning upphör.</description>
                <text>Stoppkriterium för order</text>
            </items>
            <items id="at0018">
                <description>Klinisk orsak till användning av den beställda artikeln.</description>
                <text>Klinisk indikation</text>
            </items>
            <items id="at0044">
                <description>Ytterligare instruktioner för hur beställd produkt ska brukas.</description>
                <text>Ytterligare instruktioner</text>
            </items>
            <items id="at0047">
                <description>En tolkbar, computable textrepresentation av anvisningarna.</description>
                <text>Tolkningsanvisningar</text>
            </items>
            <items id="at0050">
                <description>Den tidsperiod under vilken individen/patienten redan har använt den beställda artikeln. Detta är en del av den avsedda totala beställningen, men före utfärdandet av denna beställning.</description>
                <text>Varaktighet för slutförd order</text>
            </items>
            <items id="at0051">
                <description>Detaljer om den maximala, kumulativa dosen av den beställda artikeln som tillåts under en definierad period.</description>
                <text>Maximal dos</text>
            </items>
            <items id="at0053">
                <description>Tidsperioden under vilken den maximala dosen är beräknad.</description>
                <text>Tillåten period</text>
            </items>
            <items id="at0060">
                <description>Antalet slutförda administrationer av den beställda artikeln. Detta är en del av den avsedda totala beställningen, men före utfärdandet av denna beställning.</description>
                <text>Slutförda administrationer</text>
            </items>
            <items id="at0062">
                <description>Detaljer om medicinsk säkerhet för den beställda artikeln.</description>
                <text>Läkemedelssäkerhet</text>
            </items>
            <items id="at0064">
                <description>Bekräftelse från ordineraren att normal dos eller annan säkerhetsgräns har åsidosatts på grund av exceptionella omständigheter.</description>
                <text>Säkerhet åsidosatt?</text>
            </items>
            <items id="at0065">
                <description>Detaljer om den mängden av beställd artikel som ska dispenseras.</description>
                <text>Dispenseringsmängd</text>
            </items>
            <items id="at0069">
                <description>Detaljer om auktorisering av den beställda artikeln, inklusive stöd för lokal självadministrering, utförda och godkännandepolicyer.</description>
                <text>Anvisningar om auktorisering</text>
            </items>
            <items id="at0070">
                <description>Benämning på det läkemedel, vaccin eller annan terapeutisk/ordinerbar artikel som beställs.&#13;
</description>
                <text>Läkemedelsartikel</text>
            </items>
            <items id="at0091">
                <description>Sättet genom vilken den beställda artikeln ska administreras i patientens kropp.</description>
                <text>Administreringsväg</text>
            </items>
            <items id="at0092">
                <description>Beskrivning av administrationsstället för den beställda artikeln.</description>
                <text>Kroppsområde</text>
            </items>
            <items id="at0093">
                <description>Strukturerad beskrivning av administrationsstället för den beställda produkten.</description>
                <text>Strukturerat kroppsområde</text>
            </items>
            <items id="at0094">
                <description>Den teknik eller utrustning med vilken den beställda artikeln ska administreras.</description>
                <text>Administreringsmetod</text>
            </items>
            <items id="at0095">
                <description>Information om den medicinska utrustning som används vid administrering av läkemedlet.</description>
                <text>Administreringsutrustning</text>
            </items>
            <items id="at0105">
                <description>Ytterligare instruktion främst riktad till vårdtagaren eller vårdgivaren.</description>
                <text>Patientinformation</text>
            </items>
            <items id="at0106">
                <description>Ytterligare instruktion riktad främst till den individ som ska dispensera den beställda artikeln.</description>
                <text>Instruktion för dispensering</text>
            </items>
            <items id="at0107">
                <description>Ytterligare instruktion om rekommenderad eller begärd övervakning av den beställda artikeln.</description>
                <text>Övervakningsinstruktioner</text>
            </items>
            <items id="at0112">
                <description>Sammanfattad information om användning av den beställda artikeln, såsom aktuell status eller nyckeldatum som vanligtvis används i receptfria sammanhang.</description>
                <text>Ordersammanfattning</text>
            </items>
            <items id="at0113">
                <description>Detaljer om läkemedelsbeställningen.</description>
                <text>Orderdetaljer</text>
            </items>
            <items id="at0129">
                <description>Anvisningar för dispensering av den beställda artikeln.</description>
                <text>Anvisningar för dispensering</text>
            </items>
            <items id="at0130">
                <description>*The maximum, cumulative amount of medication which should be administered within the allowed period.(en)</description>
                <text>Maximal dosmängd</text>
            </items>
            <items id="at0132">
                <description>Tillstånd för att ersätta en bioekvivalent artikel.</description>
                <text>Anvisningar för substitution</text>
            </items>
            <items id="at0139">
                <description>Indikation på hur brådskande den beställda artikeln ska dispenseras.</description>
                <text>Prioritet</text>
            </items>
            <items id="at0143">
                <description>Strukturerade detaljer på övergripande nivå inklusive styrka, beredningsform och beståndsdelar.</description>
                <text>Läkemedelsdetaljer</text>
            </items>
            <items id="at0148">
                <description>Den övergripande behandlingsavsikten med den beställda artikeln.</description>
                <text>Behandlingsavsikt</text>
            </items>
            <items id="at0150">
                <description>Detaljer om den totala mängden per dag för den beställda artikeln som förväntas administreras.</description>
                <text>Total daglig effektiv dos</text>
            </items>
            <items id="at0151">
                <description>Mängd av beställd produkt som kommer att tas varje dag om avsedda administreringsanvisningar följs.</description>
                <text>Total daglig dos</text>
            </items>
            <items id="at0154">
                <description>Anledningen till att en beställd artikel inte ska ersättas vid dispensering.</description>
                <text>Skäl till ej tillåten substitution</text>
            </items>
            <items id="at0155">
                <description>Det datum från vilket den beställda artikeln får dispenseras för första gången.</description>
                <text>Startdatum för dispensering</text>
            </items>
            <items id="at0161">
                <description>Datumet efter det att den beställda artikeln inte längre är giltig för laglig dispensering</description>
                <text>Utgångsdatum för dispensering</text>
            </items>
            <items id="at0162">
                <description>Anledningen till åsidosättning av en klinisk säkerhet eller överskridande av maximal dos.</description>
                <text>Anledning för åsidosättning</text>
            </items>
            <items id="at0165">
                <description>Beskrivning av anledningen till registrering av en total daglig effektiv dos.</description>
                <text>Syfte</text>
            </items>
            <items id="at0166">
                <description>Ytterligare strukturerad information om den beställda artikeln som inte fångats i andra fält.</description>
                <text>Ytterligare information</text>
            </items>
            <items id="at0167">
                <description>Kommentarer avseende läkemedelsbeställningen som inte beskrivs i övriga fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0168">
                <description>Ersättning av läkemedlet med ett bioekvivalent alternativ är tillåtet.</description>
                <text>Tillåtet</text>
            </items>
            <items id="at0169">
                <description>Ersättning av läkemedlet med ett bioekvivalent alternativ är inte tillåtet.</description>
                <text>Ej tillåtet</text>
            </items>
            <items id="at0170">
                <description>Ytterligare information om dispenseringsanvisningar.</description>
                <text>Detaljer om dispensering</text>
            </items>
            <items id="at0171">
                <description>En känd säkerhetsfråga som gäller för vårdtagaren och den beställda artikeln, såsom en allergi, varning om läkemedel eller kontraindikation. Detta element registreras normalt bara när säkerhetsanvisningarna åsidosätts.</description>
                <text>Åsidosatta säkerhetsanvisningar</text>
            </items>
            <items id="at0173">
                <description>Beskrivning av en specifik del av de övergripande anvisningarna.</description>
                <text>Specifika anvisningar</text>
            </items>
            <items id="at0174">
                <description>Motivering till beräkning av dosmängd eller administreringshastighet där detta är beroende av utomstående faktor.</description>
                <text>Motivering till dos</text>
            </items>
            <items id="at0177">
                <description>Detaljer om strukturerad dos och tidsanvisningar.</description>
                <text>Strukturerad dos och tidsanvisningar</text>
            </items>
            <items id="at0178">
                <description>Åsidosättande av en känd säkerhetsfråga som gäller för vårdtagaren och den beställda artikeln, såsom en allergi, varning om läkemedelsdubblering eller kontraindikation.</description>
                <text>Åsidosättande av säkerhet</text>
            </items>
            <items id="at0179">
                <description>*Advice to future prescribers/dispensers about the ongoing, long term order.(en)</description>
                <text>*Clinician guidance(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="nb">
            <items id="at0000">
                <description>Ordinering av et legemiddel, en vaksine, parenteral væske, ernæringsprodukt eller medisinsk forbruksmateriell, for et spesifikt individ.</description>
                <text>Legemiddelordinering</text>
            </items>
            <items id="at0001">
                <description>Detaljer knyttet til ordineringen.</description>
                <text>Ordinering</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Unik identifikator for ordineringen.</description>
                <text>Ordineringsidentifikator</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Ytterligere informasjon som er nødvendig for å registrere lokalt innhold/kontekst, eller for å sammenstille med andre referansemodeller/formalismer.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0009">
                <description>En komplett fritekstbeskrivelse av hvordan den ordinerte varen skal brukes.</description>
                <text>Overordnet anvisningsbeskrivelse</text>
            </items>
            <items id="at0011">
                <description>Et vilkår for at den ordinerte varen kan tas i bruk.</description>
                <text>Startkriterium</text>
            </items>
            <items id="at0012">
                <description>Dato og valgfri tid for oppstart av den ordinerte varen.</description>
                <text>Startdato/tid for ordineringen</text>
            </items>
            <items id="at0013">
                <description>Dato og valgfri tid når det er planlagt å seponere den ordinerte varen.</description>
                <text>Dato/tid for seponering</text>
            </items>
            <items id="at0016">
                <description>Et vilkår for at den ordinerte varen skal seponeres.</description>
                <text>Seponeringskriterium</text>
            </items>
            <items id="at0018">
                <description>Den kliniske begrunnelsen for bruk av den ordinerte varen.</description>
                <text>Klinisk indikasjon</text>
            </items>
            <items id="at0044">
                <description>Tilleggsinstruksjon for hvordan bruke eller lagre den ordinerte varen.</description>
                <text>Tilleggsinstruksjon</text>
            </items>
            <items id="at0047">
                <description>En maskinlesbar tekstfremstilling av anvisningene.</description>
                <text>Maskinlesbare anvisninger</text>
            </items>
            <items id="at0050">
                <description>Tidsperioden individet/pasienten har brukt den ordinerte varen i forkant av denne instruksjonen.</description>
                <text>Del av ordinering allerede administrert</text>
            </items>
            <items id="at0051">
                <description>Detaljer om den maksimale kumulative dosen av den ordinerte varen som er tillatt i en definert tidsperiode.</description>
                <text>Maksimumsdose</text>
            </items>
            <items id="at0053">
                <description>Tidsperioden maksimumsdosen er kalkulert for.</description>
                <text>Tidsperiode</text>
            </items>
            <items id="at0060">
                <description>Antall administreringer av den ordinerte varen som er utført som del av den planlagte ordineringen, men i forkant av denne instruksjonen.</description>
                <text>Antall administreringer utført</text>
            </items>
            <items id="at0062">
                <description>Detaljer knyttet til sikkerhet rundt den ordinerte varen.</description>
                <text>Legemiddelsikkerhet</text>
            </items>
            <items id="at0064">
                <description>Bekreftelse fra forskriveren om at den maksimale dosen eller andre sikkerhetsgrenser er overstyrt på grunn av spesielle omstendigheter.</description>
                <text>Overstyring av sikkerhetsgrenser?</text>
            </items>
            <items id="at0065">
                <description>Detaljer om mengden av den ordinerte varen som skal utdeles.</description>
                <text>Utdelingsmengde</text>
            </items>
            <items id="at0069">
                <description>Detaljer om autoriseringen for den ordinerte varen, støtter også selvadministrering, utlevering og retningslinjer for godkjenning.</description>
                <text>Autoriseringsveiledning</text>
            </items>
            <items id="at0070">
                <description>Navnet på legemiddelet, vaksinen eller det medisinske forbruksmateriellet som ordineres.</description>
                <text>Legemiddel</text>
            </items>
            <items id="at0091">
                <description>Administreringsveien for den ordinerte varen.</description>
                <text>Administreringsvei</text>
            </items>
            <items id="at0092">
                <description>Navn på kroppsstedet der den ordinerte varen skal administreres.</description>
                <text>Anatomisk lokalisering</text>
            </items>
            <items id="at0093">
                <description>Strukturert beskrivelse av administreringsstedet for den ordinerte varen.</description>
                <text>Strukturert anatomisk lokalisering</text>
            </items>
            <items id="at0094">
                <description>Teknikken eller utstyret som brukes for å administrere den ordinerte varen.</description>
                <text>Administreringsmetode</text>
            </items>
            <items id="at0095">
                <description>Detaljer om det medisinske utstyret som brukes til å administrere den ordinerte varen.</description>
                <text>Administreringsutstyr</text>
            </items>
            <items id="at0105">
                <description>Tilleggsinstruksjon primært rettet mot pasient og pårørende.</description>
                <text>Bruksområde</text>
            </items>
            <items id="at0106">
                <description>Tilleggsinstruksjon primært rettet mot personen som deler ut den ordinerte varen.</description>
                <text>Utdelingsinstruksjon</text>
            </items>
            <items id="at0107">
                <description>Tilleggsinstruksjon som gir råd om anbefalt eller nødvendig overvåkning ved bruk av den ordinerte varen.</description>
                <text>Overvåkningsinstruksjon</text>
            </items>
            <items id="at0112">
                <description>Oppsummerende informasjon om bruk av den ordinerte varen, f.eks. nåværende status eller nøkkeldatoer, som regel brukt i andre sammenhenger enn resepter.</description>
                <text>Sammendrag av ordineringen</text>
            </items>
            <items id="at0113">
                <description>Detaljer om hele legemiddelordineringen.</description>
                <text>Ordineringsdetaljer</text>
            </items>
            <items id="at0129">
                <description>Veiledning for utdeling av den ordinerte varen.</description>
                <text>Utdelingsanvisning</text>
            </items>
            <items id="at0130">
                <description>Den maksimale kumulative legemiddelmengden som bør administreres i perioden.</description>
                <text>Maksimum legemiddelmengde</text>
            </items>
            <items id="at0132">
                <description>Indikerer om generisk bytte med en bioekvivalent vare er tillatt.</description>
                <text>Generisk bytte</text>
            </items>
            <items id="at0139">
                <description>En indikator for hastegraden den ordinerte varen bør utdeles under.</description>
                <text>Prioritet</text>
            </items>
            <items id="at0143">
                <description>Strukturerte detaljer om det overordnede legemiddelet, blant annet styrke, form og substansene det består av.</description>
                <text>Legemiddeldetaljer</text>
            </items>
            <items id="at0148">
                <description>Overordnet terapeutisk hensikt med den ordinerte varen.</description>
                <text>Terapeutisk hensikt</text>
            </items>
            <items id="at0150">
                <description>Detaljer om den totale daglige mengden av den ordinerte varen som skal administreres.</description>
                <text>Total daglig effektiv dose</text>
            </items>
            <items id="at0151">
                <description>Mengden ordinert vare som skal tas per dag dersom det administreres som ordinert.</description>
                <text>Total daglig dosemengde</text>
            </items>
            <items id="at0154">
                <description>Begrunnelsen for beslutningen om at generisk bytte av den ordinerte varen ikke tillates.</description>
                <text>Begrunnelse for byttereservasjon</text>
            </items>
            <items id="at0155">
                <description>Datoen den ordinerte varen kan utdeles for første gang.</description>
                <text>Startdato utlevering</text>
            </items>
            <items id="at0161">
                <description>Dato da ordineringen ikke lenger er gyldig for utdeling.</description>
                <text>Utløpsdato utdeling</text>
            </items>
            <items id="at0162">
                <description>Begrunnelsen for hvorfor sikkerhetsgrensen eller maksimumsdosen er overstyrt.</description>
                <text>Årsak til overstyring</text>
            </items>
            <items id="at0165">
                <description>Begrunnelsen for at det registreres en total daglig effektiv dose.</description>
                <text>Formål</text>
            </items>
            <items id="at0166">
                <description>Ytterligere strukturerte detaljer om den ordinerte varen som ikke omfattes av andre felt.</description>
                <text>Tilleggsinformasjon</text>
            </items>
            <items id="at0167">
                <description>Ytterligere fritekst om legemiddelordineringen som ikke er fanget i andre felt.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0168">
                <description>Generisk bytte med bioekvivalent legemiddel er tillatt.</description>
                <text>Tillatt</text>
            </items>
            <items id="at0169">
                <description>Generisk bytte med bioekvivalent legemiddel er ikke tillatt.</description>
                <text>Ikke tillatt</text>
            </items>
            <items id="at0170">
                <description>Ytterligere detaljer relatert til utdelingsanvisningene.</description>
                <text>Utdelingsdetaljer</text>
            </items>
            <items id="at0171">
                <description>Et kjent problem relatert til legemiddelsikkerhet for dette individet og den ordinerte varen, f.eks. allergi, advarsel om legemiddelduplisering, eller kontraindikasjon. Registreres ordinært bare dersom anbefalingen overstyres.</description>
                <text>Overstyrt sikkerhetsanbefaling</text>
            </items>
            <items id="at0173">
                <description>Fritekstbeskrivelse av en spesifikk del av den overordnede anvisningen.</description>
                <text>Spesifikk anvisningsbeskrivelse</text>
            </items>
            <items id="at0174">
                <description>Begrunnelsen for hvorfor en spesifikk dose er valgt, der dette er avhengig av en ytre faktor.</description>
                <text>Begrunnelse for dose</text>
            </items>
            <items id="at0177">
                <description>Detaljerte og strukturerte anvisninger om dose og timing.</description>
                <text>Strukturerte anvisninger om dose og timing</text>
            </items>
            <items id="at0178">
                <description>Overstyring av et kjent problem relatert til legemiddelsikkerhet for dette individet og den ordinerte varen, f.eks. allergi, advarsel om legemiddelduplisering, eller kontraindikasjon.</description>
                <text>Sikkerhetsoverstyring</text>
            </items>
            <items id="at0179">
                <description>Råd til personer som i fremtiden ordinerer eller deler ut legemiddelet, om den langvarige ordineringen.</description>
                <text>Klinikerveiledning</text>
            </items>
        </term_definitions>
        <term_definitions language="es-ar">
            <items id="at0000">
                <description>Una orden para un medicamento, vacuna, producto nutricional u otro ítem terapéutico para un individuo identificado.</description>
                <text>Orden de medicamento</text>
            </items>
            <items id="at0001">
                <description>Detalles de la orden requerida.</description>
                <text>Orden</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Identificador unívoco de la orden de medicamento.</description>
                <text>Identificador de la orden</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Información adicional requerida para representar contenidos locales o para compatibilizar con otros modelos o formalismos de referencia.</description>
                <text>Extensión</text>
            </items>
            <items id="at0009">
                <description>Descripción narrativa completa del modo en que el ítem ordenado debe ser utilizado.</description>
                <text>Descripción de las directivas generales</text>
            </items>
            <items id="at0011">
                <description>La condición frente a la cual se debe comenzar la administración o uso.</description>
                <text>Criterio de comienzo de la orden</text>
            </items>
            <items id="at0012">
                <description>La fecha y hora (esta última opcional) de comienzo del uso del ítem ordenado.</description>
                <text>Fecha y hora de comienzo de la orden</text>
            </items>
            <items id="at0013">
                <description>La fecha y hora (esta última opcional) para la cual se planea discontinuar el uso del ítem ordenado.</description>
                <text>Fecha y hora de finalización de la orden</text>
            </items>
            <items id="at0016">
                <description>La condición frente a la cual se debe discontinuar la administración o uso.</description>
                <text>Criterio de finalización de la orden</text>
            </items>
            <items id="at0018">
                <description>La razón clínica para el uso del ítem ordenado.</description>
                <text>Indicación clínica</text>
            </items>
            <items id="at0044">
                <description>Instrucciones adicionales acerca de como utilizar o almacenar el ítem ordenado.</description>
                <text>Instrucciones adicionales</text>
            </items>
            <items id="at0047">
                <description>La de las directivas en forma de texto parseable y computable.</description>
                <text>Directivas parseables</text>
            </items>
            <items id="at0050">
                <description>El período de tiempo durante el cual el individuo/paciente ha estado recibiendo el item ordenado como parte de la orden completa panificaa pero previo a la emisión de esta orden.</description>
                <text>Duración de la orden completada</text>
            </items>
            <items id="at0051">
                <description>Detalles acerca de la dosis máxima acumulativa permitida para un lapso definido para el ítem ordenado.</description>
                <text>Dosis máxima</text>
            </items>
            <items id="at0053">
                <description>El período de tiempo permitido para la dosis máxima calculada.</description>
                <text>Período permitido</text>
            </items>
            <items id="at0060">
                <description>La cantidad de administraciones del ítem ordenado que ya han sido completadas como parte de la orden completa pero previo a la emisión de esta orden.</description>
                <text>Administraciones realizadas</text>
            </items>
            <items id="at0062">
                <description>Detalles acerca de la seguridad del ítem ordenado.</description>
                <text>Seguridad del medicamento</text>
            </items>
            <items id="at0064">
                <description>Confirmación por parte del prescriptor de que la dosis normal o un límite de seguridad han sido ignorados por circunstancias excepcionales.</description>
                <text>¿Problema de seguridad ignorado por excepción?</text>
            </items>
            <items id="at0065">
                <description>Detalles acerca de la cantidad del ítem ordenado a dispensar.</description>
                <text>Cantidad a dispensar</text>
            </items>
            <items id="at0069">
                <description>Detalles sobre la autorización del ítem ordenado, incluyendo ayuda para autoadministración local, y politicas frente a problemas y ratificaciones.</description>
                <text>Directivas de autorización</text>
            </items>
            <items id="at0070">
                <description>Nombre del medicamento, vacuna, u otro ítem terapéutico o prescribible que es ordenado</description>
                <text>Ítem medicamentoso</text>
            </items>
            <items id="at0091">
                <description>La ruta o vía de administración a través de la cual el ítem ordenado debe ser administrado en el cuerpo del sujeto.</description>
                <text>Ruta</text>
            </items>
            <items id="at0092">
                <description>Nombre del sitio de administración del ítem ordenado.</description>
                <text>Sitio corporal</text>
            </items>
            <items id="at0093">
                <description>Descripción estructurada del sitio de administración del ítem ordenado.</description>
                <text>Sitio corporal estructurado</text>
            </items>
            <items id="at0094">
                <description>La técnica o dispositivo mediante el cual el ítem ordenado será administrado.</description>
                <text>Método de administración</text>
            </items>
            <items id="at0095">
                <description>Detalles del dispositivo médico utilizado para asistir en la administración del ítem ordenado.</description>
                <text>Detalles del dispositivo de administración</text>
            </items>
            <items id="at0105">
                <description>Instrucciones adicionales dirigidas al individuo/paciente o a sus tutores.</description>
                <text>Información para el paciente</text>
            </items>
            <items id="at0106">
                <description>Instrucción adicional dirigida principalmente a la persona que dispensa el ítem ordenado.</description>
                <text>Instrucciones de dispensación</text>
            </items>
            <items id="at0107">
                <description>Instrucciones adicionales que brindan recomendaciones o monitoreos requeridos para el ítem ordenado.</description>
                <text>Instrucciones de monitoreo</text>
            </items>
            <items id="at0112">
                <description>Información resumida acerca del uso del ítem ordenado, tal como el estado actual o ciertas fechas clave, generalmente utilizado en contexto no vinculados a una prescripción.</description>
                <text>Resumen de orden</text>
            </items>
            <items id="at0113">
                <description>Detalles aplicados a la orden en su totalidad.</description>
                <text>Detalle de la orden</text>
            </items>
            <items id="at0129">
                <description>Directivas relativas a la dispensación del ítem ordenado.</description>
                <text>Directivas para dispensación</text>
            </items>
            <items id="at0130">
                <description>*The maximum, cumulative amount of medication which should be administered within the allowed period. (en)</description>
                <text>Cantidad máxima</text>
            </items>
            <items id="at0132">
                <description>Permisos para la sustitución por un ítem bioequivalente.</description>
                <text>Directiva de sustitución</text>
            </items>
            <items id="at0139">
                <description>Un indicador de la urgencia con la cual el ítem ordenado debe ser dispensado.</description>
                <text>Prioridad</text>
            </items>
            <items id="at0143">
                <description>*Structured details about the overall medication including strength, form and constituent substances. (en)</description>
                <text>*Medication details (en)</text>
            </items>
            <items id="at0148">
                <description>El propósito terapéutico general del ítem ordenado.</description>
                <text>Propósito terapéutico</text>
            </items>
            <items id="at0150">
                <description>Detalles de la dosis diaria total efectiva el ítem ordenado y que se espera administrar.</description>
                <text>Dosis diaria total efectiva</text>
            </items>
            <items id="at0151">
                <description>La cantidad del ítem ordenado que puede ser consumida diariamente si se la administra como se ha planificado.</description>
                <text>Cantidad diaria total</text>
            </items>
            <items id="at0154">
                <description>La razón por la cual un ítem ordenado no debe ser sustituido al momento de la dispensa.</description>
                <text>Razón de la no sustitución</text>
            </items>
            <items id="at0155">
                <description>La fecha a partir de la cual se permite la dispensa del ítem ordenado por primera vez.</description>
                <text>Fecha de inicio de la dispensa</text>
            </items>
            <items id="at0161">
                <description>La fecha posterior a la cual el ítem ordenado o puede ser legalmente dispensado.</description>
                <text>Fecha de expiración de la dispensa</text>
            </items>
            <items id="at0162">
                <description>La razón por la cual se ignoró un problema de seguridad clínica o una dosis máxima.</description>
                <text>Razón para ignorar la seguridad</text>
            </items>
            <items id="at0165">
                <description>Descripción de la razón por la cual se registró una dosis diaria total efectiva.</description>
                <text>Propósito</text>
            </items>
            <items id="at0166">
                <description>Dealles adicionales estructurados acerca del ítem ordenado que pueden no haber sido representados en otros campos.</description>
                <text>Detalles adicionales</text>
            </items>
            <items id="at0167">
                <description>Narrativa adicional relativa a datos del medicamento que pueden no haber sido representados en otros campos.</description>
                <text>Comentario</text>
            </items>
            <items id="at0168">
                <description>La sustitución del medicamento por un bioequivalente es permitida.</description>
                <text>Permitida</text>
            </items>
            <items id="at0169">
                <description>La sustitución del medicamento por un bioequivalente no es permitida.</description>
                <text>No permitida</text>
            </items>
            <items id="at0170">
                <description>Mayores detalles relativos a las diectivas de dispensación.</description>
                <text>Detalles para la dispensa</text>
            </items>
            <items id="at0171">
                <description>Un problema de seguridad reconocido para el sujeto y el ítem ordenado, tal como una alergia, la duplicación de una droga o una contraindicación, normalmente registrada solo cuando el mismo es deliberadamente ignorado.</description>
                <text>Alerta de seguridad omitida</text>
            </items>
            <items id="at0173">
                <description>La descripción narrativa de una parte específica de las directivas generales.</description>
                <text>Descripción de las directivas específicas</text>
            </items>
            <items id="at0174">
                <description>La descripción de la justificación utilizada para calcular la cantidad o frecuencia de administración de una dosis cuando este depende de otro factor.</description>
                <text>Justificación de la dosis</text>
            </items>
            <items id="at0177">
                <description>Detalles de las directivas estructuradas de dosis y frecuencia.</description>
                <text>Directivas estructuradas de dosis y frecuencia</text>
            </items>
            <items id="at0178">
                <description>La omisión de una cuestión de seguridad conocida o detectada que aplica al sujeto y al ítem de la orden, tal como una alergia, la duplicación de droga o una contraindicación.</description>
                <text>Omisión asunto de seguridad</text>
            </items>
            <items id="at0179">
                <description>*Advice to future prescribers/dispensers about the ongoing, long term order. (en)</description>
                <text>*Clinician guidance (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Prescrição de medicamentos, vacina, produtos nutricionais ou outro item de tratamento para um indivíduo identificado.</description>
                <text>Prescrição de Medicamentos</text>
            </items>
            <items id="at0001">
                <description>Detalhes da prescrição solicitada.</description>
                <text>Prescrição</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Identificador unívoco do ítem prescrito.</description>
                <text>Outros identificadores</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Informações adicionais necessárias para capturar o conteúdo local ou para se alinhar com outros modelos de referência / formalismos.</description>
                <text>Extensão</text>
            </items>
            <items id="at0009">
                <description>Narrativa completa da descrição de como o item deve ser utilizado.</description>
                <text>Instruções Gerais da Prescrição</text>
            </items>
            <items id="at0011">
                <description>Uma condição que, quando encontrada, exige o início da administração ou uso.</description>
                <text>Critério para o início da prescrição</text>
            </items>
            <items id="at0012">
                <description>A data e hora opcional para iniciar o uso do medicamento prescrito.</description>
                <text>Data/Hora do início prescrição</text>
            </items>
            <items id="at0013">
                <description>A data e hora opcional quando está planejado finalizar a utilização do ítem prescrito</description>
                <text>Data/hora do final da prescrição</text>
            </items>
            <items id="at0016">
                <description>Uma condição que se existente, exige a interrupção da administração ou uso.</description>
                <text>Critérios para interromper a prescrição</text>
            </items>
            <items id="at0018">
                <description>A indicação clínica para o uso do item prescrito.</description>
                <text>Indicação Clínica</text>
            </items>
            <items id="at0044">
                <description>Instruções adicionais sobre como usar ou armazenar o ítem prescrito.</description>
                <text>Instruções adicionais</text>
            </items>
            <items id="at0047">
                <description>Uma representação em texto parseável das orientações.</description>
                <text>Orientação para parsear texto</text>
            </items>
            <items id="at0050">
                <description>O período de tempo em que o indíviduo/paciente vem fazendo uso do item prescrito com parte da duração total do tratamento, antes da execução da prescrição atual.</description>
                <text>Duração do uso do ítem da prescrição</text>
            </items>
            <items id="at0051">
                <description>Detalhes sobre a dose máxima cumulativa permitida durante um período definido para o item prescrito.</description>
                <text>Dose máxima</text>
            </items>
            <items id="at0053">
                <description>O período do tempo durante o qual a dose máxima é calculada.</description>
                <text>Periodo de tempo permitido</text>
            </items>
            <items id="at0060">
                <description>O número de administrações realizadas do item prescrito, como parte da prescrição total, antes da execução da prescrição atual.</description>
                <text>Administrações finalizadas</text>
            </items>
            <items id="at0062">
                <description>Detalhes sobre a segurança de medicamentos prescritos.</description>
                <text>Segurança de medicamentos</text>
            </items>
            <items id="at0064">
                <description>Confirmação pelo prescritor de que a dose normal ou outro limite de segurança foi ultrapassado, por circunstâncias excepcionais.</description>
                <text>Cancelamento excepcional do alerta?</text>
            </items>
            <items id="at0065">
                <description>Detalhes sobre a quantidade do item prescrito a ser dispensada.</description>
                <text>Quantidade a ser dispensada</text>
            </items>
            <items id="at0069">
                <description>Detalhes da autorização do ítem prescrito, incluindo o local de administração e políticas de reembolso.</description>
                <text>Informações da autorização</text>
            </items>
            <items id="at0070">
                <description>Nome do medicamento, vacina ou outro item terapêutico/prescritível a ser solicitado.</description>
                <text>Item da prescrição de medicamentos</text>
            </items>
            <items id="at0091">
                <description>A via de administração pela qual o item prescrito deve ser administrada à pessoa.</description>
                <text>Via de Administração</text>
            </items>
            <items id="at0092">
                <description>Nome do local de administração do item prescrito.</description>
                <text>Local do corpo</text>
            </items>
            <items id="at0093">
                <description>Descrição estruturada do local da administração do item prescrito.</description>
                <text>Local do corpo estruturado</text>
            </items>
            <items id="at0094">
                <description>*The technique or device by which the ordered item is to be administered.(en)</description>
                <text>*Administration method(en)</text>
            </items>
            <items id="at0095">
                <description>*Details of the medical device used to assist administration of the ordered item.(en)</description>
                <text>*Administration device(en)</text>
            </items>
            <items id="at0105">
                <description>Informações adicionais direcionadas principalmente para o indivíduo/paciente ou cuidador.</description>
                <text>Informações do paciente</text>
            </items>
            <items id="at0106">
                <description>Instruções adicionais direcionadas primariamente para a pessoa responsável pela dispensação do ítem prescrito.</description>
                <text>Instruções para a dispensação</text>
            </items>
            <items id="at0107">
                <description>Instruções adicionais que advertem sobre o monitoramento dos itens prescritos.</description>
                <text>Monitoramento da instrução</text>
            </items>
            <items id="at0112">
                <description>Informações sumarizadas sobre o uso do item prescrito, tais como: status atual, datas chave, geralmente utilizado fora do contexto da prescrição.</description>
                <text>Sumário da prescrição</text>
            </items>
            <items id="at0113">
                <description>Detalhes sobre a prescrição como um todo.</description>
                <text>Prescrição detalhada</text>
            </items>
            <items id="at0129">
                <description>Orientações sobre a dispensação do ítem prescrito.</description>
                <text>Orientações para a dispensação</text>
            </items>
            <items id="at0130">
                <description>*The maximum, cumulative amount of medication which should be administered within the allowed period. (en)</description>
                <text>Quantidade máxima</text>
            </items>
            <items id="at0132">
                <description>Permissão para substituir item prescrito por outro bioequivalente.</description>
                <text>Orientações para substituição</text>
            </items>
            <items id="at0139">
                <description>Indicador da urgência de dispensação do ítem prescrito.</description>
                <text>Prioridade</text>
            </items>
            <items id="at0143">
                <description>*Structured details about the overall medication including strength, form and constituent substances. (en)</description>
                <text>*Medication details (en)</text>
            </items>
            <items id="at0148">
                <description>A intenção terapêutica sobre o item prescrito.</description>
                <text>Intenção terapêutica</text>
            </items>
            <items id="at0150">
                <description>Detalhes sobre a quantidade total diária do item prescrito a ser administrado.</description>
                <text>Dose efetiva total diária</text>
            </items>
            <items id="at0151">
                <description>A quantidade do item prescrito que será ingerida diariamente se administrada conforme pretendido.</description>
                <text>Quantidade diária total</text>
            </items>
            <items id="at0154">
                <description>Motivo pelo qual o ítem prescrito não deve ser substituído no momento da dispensação.</description>
                <text>Justificativa para a não substituição</text>
            </items>
            <items id="at0155">
                <description>Data inicial permitida para a primeira dispensação do ítem prescrito.</description>
                <text>Data do início da dispensação</text>
            </items>
            <items id="at0161">
                <description>Data a partir da qual a dispensação não é mais válida.</description>
                <text>Data de validade da dispensação</text>
            </items>
            <items id="at0162">
                <description>O motivo pelo qual um item de segurança clínica ou de uma dose máxima não foi cumprido.</description>
                <text>Justificativa do cancelamento do alerta</text>
            </items>
            <items id="at0165">
                <description>Descrição do motivo para registrar a dose efetiva diária total.</description>
                <text>Propósito</text>
            </items>
            <items id="at0166">
                <description>Detalhes adicionais estruturados sobre o ítem prescrito, não capturados em outros campos.</description>
                <text>Detalhes adicionais</text>
            </items>
            <items id="at0167">
                <description>Comentários adicionais sobre o ítem prescrito em texto livre, não capturados em outros campos.</description>
                <text>Comentários</text>
            </items>
            <items id="at0168">
                <description>Permitir a subsituição do medicamento por medicamento bioequivalente.</description>
                <text>Perimitido</text>
            </items>
            <items id="at0169">
                <description>Não é permitido subsituir medicamento por medicamento bioequivalente.</description>
                <text>Não permitidio</text>
            </items>
            <items id="at0170">
                <description>Detalhes adicionais das instruções de dispensação.</description>
                <text>Detalhes da dispensação</text>
            </items>
            <items id="at0171">
                <description>Uma questão de segurança conhecida ou reconhecida de uma pessoa ecom relação ao item prescrito, tais como, alergia, aviso de duplicidade de drogas ou contra-indicação. Este elemento normalmente é registrado apenas quando este aviso de segurança é cancelado.</description>
                <text>Aviso de segurança cancelado</text>
            </items>
            <items id="at0173">
                <description>Descrição em texto de uma parte das orientações globais.</description>
                <text>Orientações específicas</text>
            </items>
            <items id="at0174">
                <description>A descrição da justificativa utilizada para calcular a dose total ou taxa da administração quando esta é dependente de algum outro fator.</description>
                <text>Justificativa da dosagem</text>
            </items>
            <items id="at0177">
                <description>Detalhes das orientações estuturadas de dose e duração.</description>
                <text>Orientações estuturadas de dose e duração</text>
            </items>
            <items id="at0178">
                <description>*Overriding of a known or recognised safety issue which applies to this subject and the ordered item, such as an allergy, drug duplication warning or contraindication.(en)</description>
                <text>*Safety override(en)</text>
            </items>
            <items id="at0179">
                <description>*Advice to future prescribers/dispensers about the ongoing, long term order. (en)</description>
                <text>*Clinician guidance (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="sk">
            <items id="at0000">
                <description>Preskripcia lieku, vakcíny, dietetickej potraviny alebo iného terapeutického produktu pre identifikovaného pacienta.</description>
                <text>Preskripcia</text>
            </items>
            <items id="at0001">
                <description>Detaily preskripcie</description>
                <text>Preskripcia</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>*Unique identifier for the medication order.(en)</description>
                <text>*Order identifier(en)</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
            <items id="at0009">
                <description>Kompletný popis k podávaniu preskribovanej položky</description>
                <text>Kompletný popis pokynov k podávaniu</text>
            </items>
            <items id="at0011">
                <description>*A condition which, when met, requires the commencement of administration or use.(en)</description>
                <text>*Order start criterion(en)</text>
            </items>
            <items id="at0012">
                <description>*The date and optional time to commence use of the ordered item.(en)</description>
                <text>*Order start date/time(en)</text>
            </items>
            <items id="at0013">
                <description>*The date and optional time when it is planned to cease use of the ordered item.(en)</description>
                <text>*Order stop date/time(en)</text>
            </items>
            <items id="at0016">
                <description>*A condition which, when met, requires the cessation of administration or use.(en)</description>
                <text>*Order stop criterion(en)</text>
            </items>
            <items id="at0018">
                <description>*The clinical reason for use of the ordered item.(en)</description>
                <text>*Clinical indication(en)</text>
            </items>
            <items id="at0044">
                <description>*An additional instruction on how to use or store the ordered item.(en)</description>
                <text>*Additional instruction(en)</text>
            </items>
            <items id="at0047">
                <description>Pokyny zadané vo forme parsovateľného , vypočítateľného textu</description>
                <text>Parsovateľné pokyny</text>
            </items>
            <items id="at0050">
                <description>*The time period during which the individual/patient has already been using the ordered item as a part of the intended whole order but prior to the issuance of this order.(en)</description>
                <text>*Duration of order completed(en)</text>
            </items>
            <items id="at0051">
                <description>Detaily ohľadom maximálnej kumulatívnej dávky počas definovaného časového intervalu</description>
                <text>Maximálna dávka</text>
            </items>
            <items id="at0053">
                <description>Časový interval pre výpočet maximálnej dávky</description>
                <text>Počas intervalu</text>
            </items>
            <items id="at0060">
                <description>*The number of administrations of the ordered item that have been completed, as part of the intended whole order but prior to the issuance of this order.(en)</description>
                <text>*Administrations completed(en)</text>
            </items>
            <items id="at0062">
                <description>Detaily k bezpečnosti medikácie pre preskribovanú položku</description>
                <text>Bezpečnosť</text>
            </items>
            <items id="at0064">
                <description>Potvrdenie , že preskribujúci predpísal vyššiu dávku ako je norma, prípadne , že boli prekročené iné bezpečnostné limity kvôli výnimočným okolnostiam</description>
                <text>Výnimočné prekročenie bezpečnej dávky?</text>
            </items>
            <items id="at0065">
                <description>*Details about the amount of the ordered item to be dispensed.(en)</description>
                <text>*Dispense amount(en)</text>
            </items>
            <items id="at0069">
                <description>*Details of authorisation of the ordered item, including supporting local self-administration, issue and endorsement policies.(en)</description>
                <text>*Authorisation directions(en)</text>
            </items>
            <items id="at0070">
                <description>Názov lieku /liečiva, vakcíny alebo inej preskribovanej položky</description>
                <text>Preskribovaná položka</text>
            </items>
            <items id="at0091">
                <description>Cesta podania predpísaná pre danú preskribovanú položku</description>
                <text>Cesta podania</text>
            </items>
            <items id="at0092">
                <description>Názov časti tela, kde má byť podaná preskribovaná položka</description>
                <text>Časť tela</text>
            </items>
            <items id="at0093">
                <description>Štrukturovaný popis časti tela , do ktorej má byť podaná preskribovaná položka</description>
                <text>Štrukturovaná časť tela</text>
            </items>
            <items id="at0094">
                <description>Technika alebo zariadenie, ktorým má byť podaná preskribovaná položka</description>
                <text>Metóda podania</text>
            </items>
            <items id="at0095">
                <description>Detaily zariadenia, ktoré má byť použité na podanie preskribovanej položky.</description>
                <text>Zariadenie pre podávanie</text>
            </items>
            <items id="at0105">
                <description>*An additional instruction directed primarily at the individual/patient or carers.(en)</description>
                <text>*Patient information(en)</text>
            </items>
            <items id="at0106">
                <description>*An additional instruction directed primarily at the person dispensing the ordered item.(en)</description>
                <text>*Dispense instruction(en)</text>
            </items>
            <items id="at0107">
                <description>*An additional instruction which gives advice on recommended or required monitoring of the ordered item.(en)</description>
                <text>*Monitoring instruction(en)</text>
            </items>
            <items id="at0112">
                <description>*Summary information about use of the ordered item, such as current status or key dates, generally used in non-prescription contexts.(en)</description>
                <text>*Order summary(en)</text>
            </items>
            <items id="at0113">
                <description>*Details about the whole medication order.(en)</description>
                <text>*Order details(en)</text>
            </items>
            <items id="at0129">
                <description>*Directions about the dispensing of the ordered item.(en)</description>
                <text>*Dispense directions(en)</text>
            </items>
            <items id="at0130">
                <description>Maximálna kumulatívna dávka počas definovaného časového intervalu</description>
                <text>Maximálne množstvo</text>
            </items>
            <items id="at0132">
                <description>*Permission for substitution with a bioequivalent item.(en)</description>
                <text>*Substitution direction(en)</text>
            </items>
            <items id="at0139">
                <description>*An indicator of the urgency with which the ordered item should be dispensed.(en)</description>
                <text>*Priority(en)</text>
            </items>
            <items id="at0143">
                <description>Štrukturované detaily predpísanej položky, vrátane sily, formy a jednotlivé ingrediencie v zmesi</description>
                <text>Detaily predpísanej položky</text>
            </items>
            <items id="at0148">
                <description>*The overall therapeutic intent of the ordered item.(en)</description>
                <text>*Therapeutic intent(en)</text>
            </items>
            <items id="at0150">
                <description>Detaily ohľadom celkovej dennej dávky preskribovanej položky</description>
                <text>Celková denná dávka</text>
            </items>
            <items id="at0151">
                <description>*The amount of ordered item which will be taken each day if administered as intended.(en)</description>
                <text>*Total daily amount(en)</text>
            </items>
            <items id="at0154">
                <description>*The reason why an ordered item should not be substituted at dispense.(en)</description>
                <text>*Non-substitution reason(en)</text>
            </items>
            <items id="at0155">
                <description>*The date from which the ordered item is permitted to be dispensed for the first time.(en)</description>
                <text>*Dispensing start date(en)</text>
            </items>
            <items id="at0161">
                <description>*The date after which the ordered item is no longer valid to be legally dispensed.(en)</description>
                <text>*Dispensing expiry date(en)</text>
            </items>
            <items id="at0162">
                <description>Dôvod pre prekročenie bezpečnej dávky alebo klinickej bezpečnosti</description>
                <text>Dôvod pre prekročenie</text>
            </items>
            <items id="at0165">
                <description>Popis k dôvodu pre záznam k celkovej dennej efektívnej dávke</description>
                <text>Dôvod</text>
            </items>
            <items id="at0166">
                <description>*Additional structured details about the ordered item not captured in other fields.(en)</description>
                <text>*Additional details(en)</text>
            </items>
            <items id="at0167">
                <description>*Additional narrative about the medication order not captured in other fields.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0168">
                <description>*Substitution of the medication with a bioequivalent medication is allowed.(en)</description>
                <text>*Permitted(en)</text>
            </items>
            <items id="at0169">
                <description>*Substitution of the medication with a bioequivalent medication is not allowed.(en)</description>
                <text>*Not permitted(en)</text>
            </items>
            <items id="at0170">
                <description>*Further details related to dispense directions.(en)</description>
                <text>*Dispense details(en)</text>
            </items>
            <items id="at0171">
                <description>Prekročenie známej alebo rozpoznanej bezpečnosti pri preskribovaní položky danému pacientovi , ako napr. alergia, opakované podanie alebo kontraindikácia. Tento element bude vyplnený iba v prípade, že je prekročená bezpečnosť</description>
                <text>Odporúčanie pre prekročenie</text>
            </items>
            <items id="at0173">
                <description>Popis špecifickej časti pokynov voľným textom</description>
                <text>Popis všeobecných pokynov k podávaniu</text>
            </items>
            <items id="at0174">
                <description>Popis oddôvodnenia pre výočet veľkosti dávky alebo rýchlosti podania , v prípade, že to závisí od nejakých iných faktorov</description>
                <text>Oddôvodnenie dávkovania</text>
            </items>
            <items id="at0177">
                <description>Detaily pre štrukturované dávkovanie a časy podania</description>
                <text>Štrukturované dávkovanie a časy podania</text>
            </items>
            <items id="at0178">
                <description>Prekročenie známej alebo rozpoznanej bezpečnosti pri preskribovaní položky danému pacientovi , ako napr. alergia, opakované podanie alebo kontraindikácia</description>
                <text>Prekročenie bezpečnej dávky</text>
            </items>
            <items id="at0179">
                <description>*Advice to future prescribers/dispensers about the ongoing, long term order.(en)</description>
                <text>*Clinician guidance(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>An order for a medication, vaccine, nutritional product or other therapeutic item for an identified individual.</description>
                <text>Medication order</text>
            </items>
            <items id="at0001">
                <description>Details of the requested order.</description>
                <text>Order</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Unique identifier for the medication order.</description>
                <text>Order identifier</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0009">
                <description>Complete narrative description about how the ordered item is to be used.</description>
                <text>Overall directions description</text>
            </items>
            <items id="at0011">
                <description>A condition which, when met, requires the commencement of administration or use.</description>
                <text>Order start criterion</text>
            </items>
            <items id="at0012">
                <description>The date and optional time to commence use of the ordered item.</description>
                <text>Order start date/time</text>
            </items>
            <items id="at0013">
                <description>The date and optional time when it is planned to cease use of the ordered item.</description>
                <text>Order stop date/time</text>
            </items>
            <items id="at0016">
                <description>A condition which, when met, requires the cessation of administration or use.</description>
                <text>Order stop criterion</text>
            </items>
            <items id="at0018">
                <description>The clinical reason for use of the ordered item.</description>
                <text>Clinical indication</text>
            </items>
            <items id="at0044">
                <description>An additional instruction on how to use or store the ordered item.</description>
                <text>Additional instruction</text>
            </items>
            <items id="at0047">
                <description>A parsable, computable text representation of the directions.</description>
                <text>Parsable directions</text>
            </items>
            <items id="at0050">
                <description>The time period during which the individual/patient has already been using the ordered item as a part of the intended whole order but prior to the issuance of this order.</description>
                <text>Duration of order completed</text>
            </items>
            <items id="at0051">
                <description>Details about the maximum, cumulative dose allowed over a defined period for the ordered item.</description>
                <text>Maximum dose</text>
            </items>
            <items id="at0053">
                <description>The period of time during which the maximum dose is calculated.</description>
                <text>Allowed period</text>
            </items>
            <items id="at0060">
                <description>The number of administrations of the ordered item that have been completed, as part of the intended whole order but prior to the issuance of this order.</description>
                <text>Administrations completed</text>
            </items>
            <items id="at0062">
                <description>Details about medication safety for the ordered item.</description>
                <text>Medication safety</text>
            </items>
            <items id="at0064">
                <description>Confirmation by the prescriber that the normal dose or other safety limit has been overridden due to exceptional circumstances.</description>
                <text>Exceptional safety override?</text>
            </items>
            <items id="at0065">
                <description>Details about the amount of the ordered item to be dispensed.</description>
                <text>Dispense amount</text>
            </items>
            <items id="at0069">
                <description>Details of authorisation of the ordered item, including supporting local self-administration, issue and endorsement policies.</description>
                <text>Authorisation directions</text>
            </items>
            <items id="at0070">
                <description>Name of the medication, vaccine or other therapeutic/prescribable item being ordered.</description>
                <text>Medication item</text>
            </items>
            <items id="at0091">
                <description>The route by which the ordered item is to be administered into the subject's body.</description>
                <text>Route</text>
            </items>
            <items id="at0092">
                <description>Name of the site of administration of the ordered item.</description>
                <text>Body site</text>
            </items>
            <items id="at0093">
                <description>Structured description of the site of administration of the ordered item.</description>
                <text>Structured body site</text>
            </items>
            <items id="at0094">
                <description>The technique or device by which the ordered item is to be administered.</description>
                <text>Administration method</text>
            </items>
            <items id="at0095">
                <description>Details of the medical device used to assist administration of the ordered item.</description>
                <text>Administration device</text>
            </items>
            <items id="at0105">
                <description>An additional instruction directed primarily at the individual/patient or carers.</description>
                <text>Patient information</text>
            </items>
            <items id="at0106">
                <description>An additional instruction directed primarily at the person dispensing the ordered item.</description>
                <text>Dispense instruction</text>
            </items>
            <items id="at0107">
                <description>An additional instruction which gives advice on recommended or required monitoring of the ordered item.</description>
                <text>Monitoring instruction</text>
            </items>
            <items id="at0112">
                <description>Summary information about use of the ordered item, such as current status or key dates, generally used in non-prescription contexts.</description>
                <text>Order summary</text>
            </items>
            <items id="at0113">
                <description>Details about the whole medication order.</description>
                <text>Order details</text>
            </items>
            <items id="at0129">
                <description>Directions about the dispensing of the ordered item.</description>
                <text>Dispense directions</text>
            </items>
            <items id="at0130">
                <description>The maximum, cumulative amount of medication which should be administered within the allowed period.</description>
                <text>Maximum amount</text>
            </items>
            <items id="at0132">
                <description>Permission for substitution with a bioequivalent item.</description>
                <text>Substitution direction</text>
            </items>
            <items id="at0139">
                <description>An indicator of the urgency with which the ordered item should be dispensed.</description>
                <text>Priority</text>
            </items>
            <items id="at0143">
                <description>Structured details about the overall medication including strength, form and constituent substances.</description>
                <text>Medication details</text>
            </items>
            <items id="at0148">
                <description>The overall therapeutic intent of the ordered item.</description>
                <text>Therapeutic intent</text>
            </items>
            <items id="at0150">
                <description>Details about the total daily amount of the ordered item expected to be administered.</description>
                <text>Total daily effective dose</text>
            </items>
            <items id="at0151">
                <description>The amount of ordered item which will be taken each day if administered as intended.</description>
                <text>Total daily amount</text>
            </items>
            <items id="at0154">
                <description>The reason why an ordered item should not be substituted at dispense.</description>
                <text>Non-substitution reason</text>
            </items>
            <items id="at0155">
                <description>The date from which the ordered item is permitted to be dispensed for the first time.</description>
                <text>Dispensing start date</text>
            </items>
            <items id="at0161">
                <description>The date after which the ordered item is no longer valid to be legally dispensed.</description>
                <text>Dispensing expiry date</text>
            </items>
            <items id="at0162">
                <description>The reason for a clinical safety or maximum dose override.</description>
                <text>Override reason</text>
            </items>
            <items id="at0165">
                <description>Description of the reason for recording a total daily effective dose.</description>
                <text>Purpose</text>
            </items>
            <items id="at0166">
                <description>Additional structured details about the ordered item not captured in other fields.</description>
                <text>Additional details</text>
            </items>
            <items id="at0167">
                <description>Additional narrative about the medication order not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0168">
                <description>Substitution of the medication with a bioequivalent medication is allowed.</description>
                <text>Permitted</text>
            </items>
            <items id="at0169">
                <description>Substitution of the medication with a bioequivalent medication is not allowed.</description>
                <text>Not permitted</text>
            </items>
            <items id="at0170">
                <description>Further details related to dispense directions.</description>
                <text>Dispense details</text>
            </items>
            <items id="at0171">
                <description>A known or recognised safety issue which applies to this subject and the ordered item, such as an allergy, drug duplication warning or contraindication. This element is normally only recorded when this safety advice is overridden.</description>
                <text>Overriden safety advice</text>
            </items>
            <items id="at0173">
                <description>A narrative description of a specific part of overall directions.</description>
                <text>Specific directions description</text>
            </items>
            <items id="at0174">
                <description>A description of the justification used to calculate a dose amount or administration rate where this is dependent on some other factor.</description>
                <text>Dosage justification</text>
            </items>
            <items id="at0177">
                <description>Details of structured dose and timing directions.</description>
                <text>Structured dose and timing directions</text>
            </items>
            <items id="at0178">
                <description>Overriding of a known or recognised safety issue which applies to this subject and the ordered item, such as an allergy, drug duplication warning or contraindication.</description>
                <text>Safety override</text>
            </items>
            <items id="at0179">
                <description>Advice to future prescribers/dispensers about the ongoing, long term order.</description>
                <text>Clinician guidance</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Una ordre per una medicació, vacuna, producte nutricional o altre element terapèutic per a un individu identificat.</description>
                <text>Ordre mèdica</text>
            </items>
            <items id="at0001">
                <description>Detalls de la ordre sol·licitada.</description>
                <text>Ordre</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Identificador únic per a l'ordre dels medicaments.</description>
                <text>Identificador de la ordre</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Informació addicional requerida per capturar contingut local o per alinear-se amb altres models/formalismes de referència.</description>
                <text>Extensió</text>
            </items>
            <items id="at0009">
                <description>Descripció narrativa completa sobre com s'ha d'utilitzar l'element ordenat.</description>
                <text>Descripció de les instruccions generals</text>
            </items>
            <items id="at0011">
                <description>Una condició que, una vegada completa, requereix el començament de l'administració o ús.</description>
                <text>Criteri d'inici de la ordre</text>
            </items>
            <items id="at0012">
                <description>La data i l'hora opcional per a començar a utilitzar l'element ordenat.</description>
                <text>Data/hora d'inici de la ordre</text>
            </items>
            <items id="at0013">
                <description>La data i l'hora opcional en què està previst cessar l'ús de l'element ordenat.</description>
                <text>Criteri d'inici de la ordre</text>
            </items>
            <items id="at0016">
                <description>Una condició que, quan es compleix, requereix el cessament de l'administració o l'ús.</description>
                <text>Criteri d'aturada de la ordre.</text>
            </items>
            <items id="at0018">
                <description>El motiu clínic de l'ús de l'article ordenat.</description>
                <text>Indicació clínica</text>
            </items>
            <items id="at0044">
                <description>Una instrucció addicional sobre com utilitzar o emmagatzemar l'element ordenat.</description>
                <text>Instrccions adicionals</text>
            </items>
            <items id="at0047">
                <description>Una representació de text, analitzable i calculable, de les instruccions.</description>
                <text>Instruccions analitzables</text>
            </items>
            <items id="at0050">
                <description>El període de temps durant el qual l'individu/pacient ja ha estat utilitzant l'element ordenat com a part de l'ordre complet previst, però abans de l'emissió d'aquesta ordre.</description>
                <text>Durada de la ordre completada</text>
            </items>
            <items id="at0051">
                <description>Detalls sobre la dosi màxima acumulada permesa durant un període definit per a l'element ordenat.</description>
                <text>Dosi màxima</text>
            </items>
            <items id="at0053">
                <description>Període de temps durant el qual es calcula la dosi màxima.</description>
                <text>Període permès</text>
            </items>
            <items id="at0060">
                <description>El nombre d'administracions de l'article ordenat que s'han completat, com a part de l'ordre complet previst, però abans de l'emissió d'aquesta ordre.</description>
                <text>Administracions completades</text>
            </items>
            <items id="at0062">
                <description>Detalls sobre la seguretat de la medicació del producte ordenat.</description>
                <text>Seguretat de la medicació</text>
            </items>
            <items id="at0064">
                <description>Confirmació per part del prescriptor que la dosi normal o un altre límit de seguretat s'ha anul·lat a causa de circumstàncies excepcionals.</description>
                <text>Anul·lació per seguretat excepcional?</text>
            </items>
            <items id="at0065">
                <description>Detalls sobre la quantitat de l'article ordenat a dispensació.</description>
                <text>Quantitat de dispensació</text>
            </items>
            <items id="at0069">
                <description>Detalls de l'autorització de l'element ordenat, inclòs el suport a les polítiques locals d'autoadministració, emissió i aprovació.</description>
                <text>Instruccions d'autorització</text>
            </items>
            <items id="at0070">
                <description>Nom del medicament, vacuna, o altre producte terapèutic/prescriptible que s'ha ordenat.</description>
                <text>Producte de medicació</text>
            </items>
            <items id="at0091">
                <description>La ruta per la qual l'article ordenat ha de ser administrat al cos del subjecte.</description>
                <text>Ruta</text>
            </items>
            <items id="at0092">
                <description>Nom del lloc d'administració del producte ordenat.</description>
                <text>Localització corporal</text>
            </items>
            <items id="at0093">
                <description>Descripció estructurada del lloc d'administració de l'element ordenat.</description>
                <text>Localització corporal estructurada</text>
            </items>
            <items id="at0094">
                <description>Tècnica o dispositiu pel qual s'administrarà la medicació ordenada.</description>
                <text>Mètode d'administració</text>
            </items>
            <items id="at0095">
                <description>Detalls del dispositiu mèdic utilitzat per assistir a l'administració de la medicació ordenada</description>
                <text>Aparell d'administració</text>
            </items>
            <items id="at0105">
                <description>Una instrucció addicional dirigida principalment a l'individu/pacient o cuidadors.</description>
                <text>Informació del pacient</text>
            </items>
            <items id="at0106">
                <description>Una instrucció addicional dirigida principalment a la persona que dispensa l'element ordenat.</description>
                <text>Instrucció de distribució</text>
            </items>
            <items id="at0107">
                <description>Una instrucció addicional que dona consells sobre el seguiment recomanat o requerit de l'element ordenat.</description>
                <text>Instruccions de monitoratge</text>
            </items>
            <items id="at0112">
                <description>Informació resumida sobre l'ús de l'element ordenat, com ara l'estat actual o les dates clau, generalment s'utilitzen en contextos de no prescripció.</description>
                <text>Resum de la comanda</text>
            </items>
            <items id="at0113">
                <description>Detalls sobre tota la ordre de medicaments.</description>
                <text>Detalls de la ordre</text>
            </items>
            <items id="at0129">
                <description>Instruccions sobre la dispensació de l'element ordenat.</description>
                <text>Instruccions de dispensació</text>
            </items>
            <items id="at0130">
                <description>La quantitat màxima i acumulativa de medicació que s'hauria d'administrar en el termini permès.</description>
                <text>Quantitat màxima</text>
            </items>
            <items id="at0132">
                <description>Permís de substitució amb un article bioequivalent.</description>
                <text>Instrucció de la substitució</text>
            </items>
            <items id="at0139">
                <description>Indicador de la urgència amb què s'ha de dispensar l'element ordenat.</description>
                <text>Prioritat</text>
            </items>
            <items id="at0143">
                <description>Detalls estructurats sobre la medicació en general, incloent-hi la concentració, forma i substàncies constituents.</description>
                <text>Detalls de la medicació</text>
            </items>
            <items id="at0148">
                <description>La intenció terapèutica general de l'element ordenat.</description>
                <text>Intenció terapèutica</text>
            </items>
            <items id="at0150">
                <description>Detalls sobre la quantitat diària total de l'article ordenat que s'espera serà administrat.</description>
                <text>Dosi efectiva diària total</text>
            </items>
            <items id="at0151">
                <description>La quantitat d'articles ordenats que es prendran cada dia si s'administren segons el que es preveu.</description>
                <text>Quantitat diària total</text>
            </items>
            <items id="at0154">
                <description>La raó per la qual un objecte ordenat no hauria de ser substituït a la dispensació.</description>
                <text>Motiu de no-substitució</text>
            </items>
            <items id="at0155">
                <description>La data a partir de la qual la dispensació de l'element ordenat es permesa per primera vegada.</description>
                <text>Data d'inici de la dispensació</text>
            </items>
            <items id="at0161">
                <description>La data després de la qual l'element ordenat ja no és vàlid per ser dispensat legalment.</description>
                <text>Data de venciment de la dispensació</text>
            </items>
            <items id="at0162">
                <description>Motiu per l'anul·lació d'una dosi màxima o seguretat clínica.</description>
                <text>Motiu anul·lat</text>
            </items>
            <items id="at0165">
                <description>Descripció del motiu per al registre d'una dosi efectiva diària total.</description>
                <text>Objectiu</text>
            </items>
            <items id="at0166">
                <description>Detalls estructurats addicionals sobre l'element ordenat no capturat en altres camps.</description>
                <text>Detalls addicionals</text>
            </items>
            <items id="at0167">
                <description>Narrativa addicional sobre l'ordre de medicació no capturada en altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0168">
                <description>Es permet la substitució de la medicació amb una medicació bioequivalent.</description>
                <text>Permès</text>
            </items>
            <items id="at0169">
                <description>No es permet la substitució de la medicació amb una medicació bioequivalent.</description>
                <text>No permès</text>
            </items>
            <items id="at0170">
                <description>Més detalls relacionats amb les direccions de dispensació.</description>
                <text>Detalls de dispensació</text>
            </items>
            <items id="at0171">
                <description>Un problema de seguretat conegut o reconegut que s'aplica a aquest tema i a l'objecte ordenat, com ara una al·lèrgia, advertència per duplicació de fàrmacs o contraindicació. Normalment, aquest element només es registra quan aquest consell de seguretat és anul·lat.</description>
                <text>Consell de seguretat anul·lat</text>
            </items>
            <items id="at0173">
                <description>Descripció narrativa d'una part específica de les instruccions generals.</description>
                <text>Descripció d'instruccions específiques</text>
            </items>
            <items id="at0174">
                <description>Descripció de la justificació emprada per a calcular la quantitat d'una dosi o velocitat d'administració quan això depèn d'un altre factor.</description>
                <text>Justificació de la dosificació</text>
            </items>
            <items id="at0177">
                <description>Detalls de la dosi estructurada i indicacions de temps d'administració.</description>
                <text>Dosi estructurada i indicacions de temps</text>
            </items>
            <items id="at0178">
                <description>Anul·lació d'un problema de seguretat conegut o reconegut que s'aplica a aquest tema i a l'element ordenat, com ara una al·lèrgia, avís de duplicació de fàrmacs o contraindicació.</description>
                <text>Anul·lació de seguretat</text>
            </items>
            <items id="at0179">
                <description>Consells a futurs prescriptors/dispensadors sobre l'ordre en curs a llarg termini.</description>
                <text>Orientació clínica</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Una prescripción para un medicamento, vacuna, producto nutricional o otro producto terapéutico para un individuo específico</description>
                <text>Prescripción médica</text>
            </items>
            <items id="at0001">
                <description>Detalles de la prescripción solicitada</description>
                <text>Prescripción</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>*Unique identifier for the medication order.(en)</description>
                <text>*Order identifier(en)</text>
            </items>
            <items id="at0005">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
            <items id="at0009">
                <description>*Complete narrative description about how the ordered item is to be used.(en)</description>
                <text>*Overall directions description(en)</text>
            </items>
            <items id="at0011">
                <description>*A condition which, when met, requires the commencement of administration or use.(en)</description>
                <text>*Order start criterion(en)</text>
            </items>
            <items id="at0012">
                <description>*The date and optional time to commence use of the ordered item.(en)</description>
                <text>*Order start date/time(en)</text>
            </items>
            <items id="at0013">
                <description>*The date and optional time when it is planned to cease use of the ordered item.(en)</description>
                <text>*Order stop date/time(en)</text>
            </items>
            <items id="at0016">
                <description>*A condition which, when met, requires the cessation of administration or use.(en)</description>
                <text>*Order stop criterion(en)</text>
            </items>
            <items id="at0018">
                <description>*The clinical reason for use of the ordered item.(en)</description>
                <text>*Clinical indication(en)</text>
            </items>
            <items id="at0044">
                <description>*An additional instruction on how to use or store the ordered item.(en)</description>
                <text>*Additional instruction(en)</text>
            </items>
            <items id="at0047">
                <description>*A parsable, computable text representation of the directions.(en)</description>
                <text>*Parsable directions(en)</text>
            </items>
            <items id="at0050">
                <description>*The time period during which the individual/patient has already been using the ordered item as a part of the intended whole order but prior to the issuance of this order.(en)</description>
                <text>*Duration of order completed(en)</text>
            </items>
            <items id="at0051">
                <description>*Details about the maximum, cumulative dose allowed over a defined period for the ordered item.(en)</description>
                <text>*Maximum dose(en)</text>
            </items>
            <items id="at0053">
                <description>*The period of time during which the maximum dose is calculated.(en)</description>
                <text>*Allowed period(en)</text>
            </items>
            <items id="at0060">
                <description>*The number of administrations of the ordered item that have been completed, as part of the intended whole order but prior to the issuance of this order.(en)</description>
                <text>*Administrations completed(en)</text>
            </items>
            <items id="at0062">
                <description>*Details about medication safety for the ordered item.(en)</description>
                <text>*Medication safety(en)</text>
            </items>
            <items id="at0064">
                <description>*Confirmation by the prescriber that the normal dose or other safety limit has been overridden due to exceptional circumstances.(en)</description>
                <text>*Exceptional safety override?(en)</text>
            </items>
            <items id="at0065">
                <description>*Details about the amount of the ordered item to be dispensed.(en)</description>
                <text>*Dispense amount(en)</text>
            </items>
            <items id="at0069">
                <description>*Details of authorisation of the ordered item, including supporting local self-administration, issue and endorsement policies.(en)</description>
                <text>*Authorisation directions(en)</text>
            </items>
            <items id="at0070">
                <description>*Name of the medication, vaccine or other therapeutic/prescribable item being ordered.(en)</description>
                <text>*Medication item(en)</text>
            </items>
            <items id="at0091">
                <description>*The route by which the ordered item is to be administered into the subject's body.(en)</description>
                <text>*Route(en)</text>
            </items>
            <items id="at0092">
                <description>*Name of the site of administration of the ordered item.(en)</description>
                <text>*Body site(en)</text>
            </items>
            <items id="at0093">
                <description>*Structured description of the site of administration of the ordered item.(en)</description>
                <text>*Structured body site(en)</text>
            </items>
            <items id="at0094">
                <description>*The technique or device by which the ordered item is to be administered.(en)</description>
                <text>*Administration method(en)</text>
            </items>
            <items id="at0095">
                <description>*Details of the medical device used to assist administration of the ordered item.(en)</description>
                <text>*Administration device(en)</text>
            </items>
            <items id="at0105">
                <description>*An additional instruction directed primarily at the individual/patient or carers.(en)</description>
                <text>*Patient information(en)</text>
            </items>
            <items id="at0106">
                <description>*An additional instruction directed primarily at the person dispensing the ordered item.(en)</description>
                <text>*Dispense instruction(en)</text>
            </items>
            <items id="at0107">
                <description>*An additional instruction which gives advice on recommended or required monitoring of the ordered item.(en)</description>
                <text>*Monitoring instruction(en)</text>
            </items>
            <items id="at0112">
                <description>*Summary information about use of the ordered item, such as current status or key dates, generally used in non-prescription contexts.(en)</description>
                <text>*Order summary(en)</text>
            </items>
            <items id="at0113">
                <description>*Details about the whole medication order.(en)</description>
                <text>*Order details(en)</text>
            </items>
            <items id="at0129">
                <description>*Directions about the dispensing of the ordered item.(en)</description>
                <text>*Dispense directions(en)</text>
            </items>
            <items id="at0130">
                <description>*The maximum, cumulative amount of medication which should be administered within the allowed period.(en)</description>
                <text>*Maximum amount(en)</text>
            </items>
            <items id="at0132">
                <description>*Permission for substitution with a bioequivalent item.(en)</description>
                <text>*Substitution direction(en)</text>
            </items>
            <items id="at0139">
                <description>*An indicator of the urgency with which the ordered item should be dispensed.(en)</description>
                <text>*Priority(en)</text>
            </items>
            <items id="at0143">
                <description>*Structured details about the overall medication including strength, form and constituent substances.(en)</description>
                <text>*Medication details(en)</text>
            </items>
            <items id="at0148">
                <description>*The overall therapeutic intent of the ordered item.(en)</description>
                <text>*Therapeutic intent(en)</text>
            </items>
            <items id="at0150">
                <description>*Details about the total daily amount of the ordered item expected to be administered.(en)</description>
                <text>*Total daily effective dose(en)</text>
            </items>
            <items id="at0151">
                <description>*The amount of ordered item which will be taken each day if administered as intended.(en)</description>
                <text>*Total daily amount(en)</text>
            </items>
            <items id="at0154">
                <description>*The reason why an ordered item should not be substituted at dispense.(en)</description>
                <text>*Non-substitution reason(en)</text>
            </items>
            <items id="at0155">
                <description>*The date from which the ordered item is permitted to be dispensed for the first time.(en)</description>
                <text>*Dispensing start date(en)</text>
            </items>
            <items id="at0161">
                <description>*The date after which the ordered item is no longer valid to be legally dispensed.(en)</description>
                <text>*Dispensing expiry date(en)</text>
            </items>
            <items id="at0162">
                <description>*The reason for a clinical safety or maximum dose override.(en)</description>
                <text>*Override reason(en)</text>
            </items>
            <items id="at0165">
                <description>*Description of the reason for recording a total daily effective dose.(en)</description>
                <text>*Purpose(en)</text>
            </items>
            <items id="at0166">
                <description>*Additional structured details about the ordered item not captured in other fields.(en)</description>
                <text>*Additional details(en)</text>
            </items>
            <items id="at0167">
                <description>*Additional narrative about the medication order not captured in other fields.(en)</description>
                <text>*Comment(en)</text>
            </items>
            <items id="at0168">
                <description>*Substitution of the medication with a bioequivalent medication is allowed.(en)</description>
                <text>*Permitted(en)</text>
            </items>
            <items id="at0169">
                <description>*Substitution of the medication with a bioequivalent medication is not allowed.(en)</description>
                <text>*Not permitted(en)</text>
            </items>
            <items id="at0170">
                <description>*Further details related to dispense directions.(en)</description>
                <text>*Dispense details(en)</text>
            </items>
            <items id="at0171">
                <description>*A known or recognised safety issue which applies to this subject and the ordered item, such as an allergy, drug duplication warning or contraindication. This element is normally only recorded when this safety advice is overridden.(en)</description>
                <text>*Overriden safety advice(en)</text>
            </items>
            <items id="at0173">
                <description>*A narrative description of a specific part of overall directions.(en)</description>
                <text>*Specific directions description(en)</text>
            </items>
            <items id="at0174">
                <description>*A description of the justification used to calculate a dose amount or administration rate where this is dependent on some other factor.(en)</description>
                <text>*Dosage justification(en)</text>
            </items>
            <items id="at0177">
                <description>*Details of structured dose and timing directions.(en)</description>
                <text>*Structured dose and timing directions(en)</text>
            </items>
            <items id="at0178">
                <description>*Overriding of a known or recognised safety issue which applies to this subject and the ordered item, such as an allergy, drug duplication warning or contraindication.(en)</description>
                <text>*Safety override(en)</text>
            </items>
            <items id="at0179">
                <description>*Advice to future prescribers/dispensers about the ongoing, long term order.(en)</description>
                <text>*Clinician guidance(en)</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-OBSERVATION.body_temperature.v2" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Eine Messung der Körpertemperatur, als Surrogat für die Temperatur des gesamten Körper der Person.</description>
                <text>Körpertemperatur</text>
            </items>
            <items id="at0001">
                <description>*</description>
                <text>Single</text>
            </items>
            <items id="at0002">
                <description>@ internal @</description>
                <text>History</text>
            </items>
            <items id="at0003">
                <description>Standardwert, ein undefinierter/s Zeitpunkt oder Intervallereignis, das explizit im Template oder zur Laufzeit der Anwendung definiert werden kann.</description>
                <text>Beliebiges Ereignis</text>
            </items>
            <items id="at0004">
                <description>Die gemessene Körpertemperatur.</description>
                <text>Temperatur</text>
            </items>
            <items id="at0020">
                <description>@ internal @</description>
                <text>Protocol</text>
            </items>
            <items id="at0021">
                <description>Einfache Beschreibung der Stelle der Messung.</description>
                <text>Lokalisation der Messung</text>
            </items>
            <items id="at0022">
                <description>Messung der Temperatur im Mund.</description>
                <text>Mund</text>
            </items>
            <items id="at0023">
                <description>Messung der Temperatur innerhalb des äußeren Gehörgangs.</description>
                <text>Ohrkanal</text>
            </items>
            <items id="at0024">
                <description>Messung der Temperatur an der Haut der Achselhöhle mit seitlich angelegtem Arm.</description>
                <text>Achselhöhle</text>
            </items>
            <items id="at0025">
                <description>Messung der Temperatur innerhalb des Rektums.</description>
                <text>Rektum</text>
            </items>
            <items id="at0026">
                <description>Messung der Temperatur innerhalb des Nasopharynxs (Nasenrachens).</description>
                <text>Nasopharynx</text>
            </items>
            <items id="at0027">
                <description>Messung der Temperatur in der Harnblase.</description>
                <text>Harnblase</text>
            </items>
            <items id="at0028">
                <description>Messung der Temperatur innerhalb des vaskulären Systems.</description>
                <text>Intravaskulär</text>
            </items>
            <items id="at0029">
                <description>Statusinformationen über den Patienten.</description>
                <text>Status</text>
            </items>
            <items id="at0030">
                <description>Der Expositionsgrad der Person, deren Temperatur gemessen wird.</description>
                <text>Körperexposition</text>
            </items>
            <items id="at0031">
                <description>Keine Kleidung, Bettzeug oder andere Bedeckung.</description>
                <text>Nackt</text>
            </items>
            <items id="at0032">
                <description>Die Person wird bedeckt von einer geringeren Menge an Kleidung oder Bettzeug als für die Umgebungsbedingungen angemessen erscheint.</description>
                <text>Reduzierte Kleidung/Bettzeug</text>
            </items>
            <items id="at0033">
                <description>Die Person wird bedeckt von einer Menge an Kleidung oder Bettzeug, die den Umgebungsbedingungen angemessen erscheint.</description>
                <text>Angemessene Kleidung/Bettzeug</text>
            </items>
            <items id="at0034">
                <description>Die Person wird bedeckt von einer größeren Menge an Kleidung oder Bettzeug als für die Umgebungsbedingungen angemessen erscheint.</description>
                <text>Erhöhte Kleidung/Bettzeug</text>
            </items>
            <items id="at0041">
                <description>Beschreibung von Bedingungen, denen die Person ausgesetzt ist, welche die gemessene Körpertemperatur beeinflussen könnten.</description>
                <text>Beschreibung der Wärmebelastung</text>
            </items>
            <items id="at0043">
                <description>Messung der Temperatur an freiliegender Haut.</description>
                <text>Haut</text>
            </items>
            <items id="at0051">
                <description>Messung der Temperatur innerhalb der Vagina.</description>
                <text>Vagina</text>
            </items>
            <items id="at0054">
                <description>Messung der Temperatur innerhalb des Oesophagus.</description>
                <text>Oesophagus</text>
            </items>
            <items id="at0055">
                <description>Messung der Temperatur in der inguinalen Hautfalte zwischen Bein und Abdominalwand.</description>
                <text>Inguinale Hautfalte</text>
            </items>
            <items id="at0056">
                <description>Details über die Umgebungsbedingungen zum Zeitpunkt der Temperaturmessung</description>
                <text>Umgebungsbedingungen</text>
            </items>
            <items id="at0057">
                <description>Details über die Betätigung der Person zum Zeitpunkt der Messung der Temperatur.</description>
                <text>Betätigung</text>
            </items>
            <items id="at0059">
                <description>Details über das Gerät, das zur Temperaturmessung benutzt wurde.</description>
                <text>Gerät</text>
            </items>
            <items id="at0060">
                <description>Messung der Temperatur an der Schläfe, über der oberflächlichen Schläfenarterie.</description>
                <text>Schläfe</text>
            </items>
            <items id="at0061">
                <description>Messung der Temperatur auf der Stirn.</description>
                <text>Stirn</text>
            </items>
            <items id="at0062">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0063">
                <description>Zusätzliche Informationen über die Körpertemperatur, die nicht in anderen Bereichen dargestellt wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0064">
                <description>Strukturierte anatomische Lokalisation, an dem die Messung vorgenommen wurde.</description>
                <text>Strukturierte Lokalisation der Messung</text>
            </items>
            <items id="at0065">
                <description>Aktueller Tag des Menstruationszyklus.</description>
                <text>Tag des Menstruationszyklus</text>
            </items>
            <items id="at0066">
                <description>Zusätzliche Probleme oder Faktoren, die sich auf die Messung der Körpertemperatur auswirken können und in anderen Bereichen nicht dargestellt werden.</description>
                <text>Störfaktoren</text>
            </items>
        </term_definitions>
        <term_definitions language="ru">
            <items id="at0000">
                <description>Измерение температуры тела, которая является суррогатом температуры тела человека в целом.</description>
                <text>Температура тела</text>
            </items>
            <items id="at0001">
                <description>**(en)</description>
                <text>*Single(en)</text>
            </items>
            <items id="at0002">
                <description>*@ internal @(en)</description>
                <text>*History(en)</text>
            </items>
            <items id="at0003">
                <description>*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</description>
                <text>*Any event(en)</text>
            </items>
            <items id="at0004">
                <description>*The measured temperature. (en)</description>
                <text>Температура(ru)</text>
            </items>
            <items id="at0020">
                <description>*@ internal @(en)</description>
                <text>*Protocol(en)</text>
            </items>
            <items id="at0021">
