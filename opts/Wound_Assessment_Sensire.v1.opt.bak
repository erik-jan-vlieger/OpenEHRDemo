                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="it">
            <items id="at0000">
                <description>Dettagli su una specifica condizione di salute, una lesione, una disabilità o un qualsiasi altro problema individuato su un individuo che abbia un impatto sul benessere fisico, mentale e/o sociale.</description>
                <text>Problema/Diagnosi</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Nome/identificativo del problema o della diagnosi.</description>
                <text>Nome del problema/diagnosi</text>
            </items>
            <items id="at0003">
                <description>Data/ora, stimate o effettive, in cui la diagnosi o il problema sono stati riconosciuti da un operatore sanitario.</description>
                <text>Data/ora di riconoscimento clinico</text>
            </items>
            <items id="at0005">
                <description>Una valutazione generale della severità del problema o della diagnosi.</description>
                <text>Severità</text>
            </items>
            <items id="at0009">
                <description>Descrizione narrativa del problema o della diagnosi.</description>
                <text>Descrizione clinica</text>
            </items>
            <items id="at0012">
                <description>Identificativo di un semplice sito corporeo per per la localizzazione del problema o della diagnosi.</description>
                <text>Sito corporeo</text>
            </items>
            <items id="at0030">
                <description>Data/ora, stimate o effettive, della risoluzione o remissione del problema o della diagnosi come determinato da un operatore sanitario.</description>
                <text>Data/ora di risoluzione</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Una descrizione strutturata della localizzazione anatomica a cui il problema o la diagnosi si riferiscono.</description>
                <text>Dettagli strutturati del sito corporeo</text>
            </items>
            <items id="at0043">
                <description>Ulteriori dettagli richiesti per memorizzare attributi specifici del problema o della diagnosi.</description>
                <text>Ulteriori dettagli</text>
            </items>
            <items id="at0046">
                <description>Dettagli strutturati per descrivere aspetti del processo diagnostico specifici in relazione alla localizzazione, dominio, episodio o workflow.</description>
                <text>Stato</text>
            </items>
            <items id="at0047">
                <description>Il problema o la diagnosi non interferiscono con la normale attività o potrebbero causare problemi di salute salute se non trattati.</description>
                <text>Lieve</text>
            </items>
            <items id="at0048">
                <description>Il problema o la diagnosi interferiscono con la normale attività o causerebbero problemi di salute se non trattati.</description>
                <text>Moderato</text>
            </items>
            <items id="at0049">
                <description>Il problema o la diagnosi impediscono la normale attività o causerebbero problemi di salute importanti se non trattati.</description>
                <text>Severo</text>
            </items>
            <items id="at0069">
                <description>Informazioni aggiuntive sul problema o diagnosi non catturate in altri campi.</description>
                <text>Commento</text>
            </items>
            <items id="at0070">
                <description>La data in cui questo record di Problema/Diagnosi è stato aggiornato l'ultima volta.</description>
                <text>Ultimo aggiornamento</text>
            </items>
            <items id="at0071">
                <description>Informazioni aggiuntive necessarie per registrare specifici contenuti locali o per allinearsi con altri modelli/formalismi di riferimento.</description>
                <text>Estensione</text>
            </items>
            <items id="at0072">
                <description>Descrizione testuale del decorso del problema o della diagnosi a partire dall'insorgenza.</description>
                <text>Decorso</text>
            </items>
            <items id="at0073">
                <description>Grado di certezza nell'identificazione della diagnosi.</description>
                <text>Certezza diagnostica</text>
            </items>
            <items id="at0074">
                <description>La diagnosi è identificata con un basso livello di certezza.</description>
                <text>Sospetto</text>
            </items>
            <items id="at0075">
                <description>La diagnosi è identificata con un alto livello di certezza.</description>
                <text>Probabile</text>
            </items>
            <items id="at0076">
                <description>La diagnosi è stata confermata in base a criteri riconosciuti.</description>
                <text>Confermato</text>
            </items>
            <items id="at0077">
                <description>Data/ora, stimate o effettive, in cui sono stati per la prima volta osservati i sintomi del problema/diagnosi.</description>
                <text>Data/ora di insorgenza</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
                <text>*Variant (en)</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>关于单个已明确的健康状况、损伤、残疾或任何其他影响个人身体健康、心理健康和/或社会福祉的问题/事项的详情。</description>
                <text>问题/诊断</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>利用名称对问题或诊断的标识。</description>
                <text>问题/诊断名称</text>
            </items>
            <items id="at0003">
                <description>医疗保健专业人员认定当前诊断或问题的估计或实际日期/时间。</description>
                <text>临床认定日期/时间</text>
            </items>
            <items id="at0005">
                <description>对于当前问题或诊断的总体严重程度的评估[结果]。</description>
                <text>严重程度</text>
            </items>
            <items id="at0009">
                <description>关于当前问题或诊断的叙述性描述。</description>
                <text>临床描述</text>
            </items>
            <items id="at0012">
                <description>明确的是代表当前问题或诊断所处解剖位置的简单的身体部位。</description>
                <text>身体部位</text>
            </items>
            <items id="at0030">
                <description>医疗保健专业人员所确定的，当前问题或诊断的估计或实际的解决或缓解日期/时间。</description>
                <text>解决日期/时间</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>当前问题或诊断的结构化解剖位置。</description>
                <text>结构化身体部位</text>
            </items>
            <items id="at0043">
                <description>记录当前问题或诊断特有的特征属性时所额外需要的详细信息。</description>
                <text>特有详情</text>
            </items>
            <items id="at0046">
                <description>关于诊断过程的位置/场所、领域、服务节段/片段（episode）或工作流的特有方面的结构化详细信息。</description>
                <text>状态</text>
            </items>
            <items id="at0047">
                <description>如果不加治疗/处理，当前的问题或诊断并不会干扰患者的正常活动或者可能会对其健康造成损害。</description>
                <text>轻度</text>
            </items>
            <items id="at0048">
                <description>如果不加治疗/处理，当前的问题或诊断会干扰患者的正常活动或者会对其健康造成损害。</description>
                <text>中度</text>
            </items>
            <items id="at0049">
                <description>如果不加治疗/处理，当前的问题或诊断会妨碍患者的正常活动或者会对其健康造成严重的损害。</description>
                <text>重度</text>
            </items>
            <items id="at0069">
                <description>其他字段之中并未采集的，关于当前问题或诊断的其他叙述。</description>
                <text>备注</text>
            </items>
            <items id="at0070">
                <description>最后更新当前问题或诊断时的日期。</description>
                <text>最后更新日期</text>
            </items>
            <items id="at0071">
                <description>采集本地内容或与其他参考模型/形式化体系保持一致时所需的其他信息。</description>
                <text>扩展</text>
            </items>
            <items id="at0072">
                <description>关于起始/发病以来当前问题或诊断的过程/进程/病程（course）的叙述性描述。</description>
                <text>进程描述</text>
            </items>
            <items id="at0073">
                <description>关于确定当前诊断的置信度水平。</description>
                <text>诊断确定性</text>
            </items>
            <items id="at0074">
                <description>确定当前诊断时的确定性较低。</description>
                <text>疑似</text>
            </items>
            <items id="at0075">
                <description>确定当前诊断时的确定性较高。</description>
                <text>很可能</text>
            </items>
            <items id="at0076">
                <description>确定当前诊断时依据的是公认的[诊断]标准/评判准则。</description>
                <text>确诊/确认</text>
            </items>
            <items id="at0077">
                <description>首次观察到/发现当前问题/诊断的症状或体征的估计或实际日期/时间。</description>
                <text>起始日期/时间</text>
            </items>
            <items id="at0078">
                <description>问题或诊断的原因、原因集合（成套/成组的原因）或因果作用方式（manner of causation）。</description>
                <text>原因</text>
            </items>
            <items id="at0079">
                <description>当前诊断的特定变体/变异类型或亚型/子类型（如果相关/合适）。</description>
                <text>变体/亚型</text>
            </items>
            <items id="at0080">
                <description></description>
                <text>*DV_TEXT (en)</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Detalles sobre una única condición de salud, lesión, discapacidad o cualquier otro problema identificado que afecte al bienestar físico, mental y/o social de un individuo.</description>
                <text>Problema/Diagnóstico</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identificación del problema o diagnóstico, por nombre.</description>
                <text>Nombre del problema/diagnóstico</text>
            </items>
            <items id="at0003">
                <description>Fecha/hora estimada o real en que un profesional sanitario reconoció el diagnóstico o el problema.</description>
                <text>Fecha/Hora de reconocimiento del problema</text>
            </items>
            <items id="at0005">
                <description>Evaluación de la gravedad global del problema o diagnóstico.</description>
                <text>Severidad</text>
            </items>
            <items id="at0009">
                <description>Descripción narrativa del problema o diagnóstico.</description>
                <text>Descripción clínica</text>
            </items>
            <items id="at0012">
                <description>Identificación de una zona corporal sencilla para la localización del problema o diagnóstico.</description>
                <text>Zona corporal</text>
            </items>
            <items id="at0030">
                <description>Fecha/hora estimada o real de resolución o remisión de este problema o diagnóstico, determinada por un profesional sanitario.</description>
                <text>Fecha/hora de resolución</text>
            </items>
            <items id="at0032">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0039">
                <description>Ubicación anatómica estructurada del problema o diagnóstico.</description>
                <text>Zona corporal estructurada</text>
            </items>
            <items id="at0043">
                <description>Detalles que es necesario registrar adicionalmente como atributos únicos de este problema o diagnóstico.</description>
                <text>Detalles específicos</text>
            </items>
            <items id="at0046">
                <description>Detalles estructurados para aspectos específicos del proceso de diagnóstico de ubicación, dominio, episodio o flujo de trabajo.</description>
                <text>Estado</text>
            </items>
            <items id="at0047">
                <description>El problema o diagnóstico no interfiere con la actividad normal ni puede causar daños a la salud si no se trata.</description>
                <text>Leve</text>
            </items>
            <items id="at0048">
                <description>El problema o diagnóstico interfiere en la actividad normal o perjudica la salud si no se trata.</description>
                <text>Moderado</text>
            </items>
            <items id="at0049">
                <description>El problema o diagnóstico impide la actividad normal o perjudica gravemente la salud si no se trata.</description>
                <text>Severo</text>
            </items>
            <items id="at0069">
                <description>Información adicional sobre el problema o el diagnóstico no recogida en otros campos.</description>
                <text>Comentarios</text>
            </items>
            <items id="at0070">
                <description>Fecha de la última actualización de este problema o diagnóstico.</description>
                <text>Última actualización</text>
            </items>
            <items id="at0071">
                <description>Información adicional necesaria para registrar el contenido local o para alinearse con otros modelos/formalismos de referencia.</description>
                <text>Ampliación</text>
            </items>
            <items id="at0072">
                <description>Descripción narrativa sobre la evolución del problema o diagnóstico desde su aparición.</description>
                <text>Progreso</text>
            </items>
            <items id="at0073">
                <description>Nivel de confianza en la identificación del diagnóstico.</description>
                <text>Certeza diagnóstica</text>
            </items>
            <items id="at0074">
                <description>El diagnóstico se ha identificado con un bajo nivel de certeza.</description>
                <text>Dudoso</text>
            </items>
            <items id="at0075">
                <description>El diagnóstico se ha identificado con un alto nivel de certeza.</description>
                <text>Probable</text>
            </items>
            <items id="at0076">
                <description>El diagnóstico se ha confirmado con criterios reconocidos.</description>
                <text>Confirmado</text>
            </items>
            <items id="at0077">
                <description>Fecha/hora estimada o real en que se observaron por primera vez los signos o síntomas del problema/diagnóstico.</description>
                <text>Fecha/hora de inicio</text>
            </items>
            <items id="at0078">
                <description>Causa, conjunto de causas o manera de causar el problema o diagnóstico.</description>
                <text>Causa</text>
            </items>
            <items id="at0079">
                <description>Variante o subtipo específico del Diagnóstico, si procede.</description>
                <text>Variante</text>
            </items>
            <items id="at0080">
                <description>Evaluación global del impacto o relevancia de un problema de salud para un paciente concreto.</description>
                <text>Impacto</text>
            </items>
        </term_definitions>
        <term_definitions language="zh">
            <items id="at0000">
                <description>*Details about a single identified health condition, injury, disability or any other issue which impacts  the physical, mental and/or social wellbeing of an individual.(en)</description>
                <text>问题/诊断</text>
            </items>
            <items id="at0001">
                <description>@ internal @ (en)</description>
                <text>structure (en)</text>
            </items>
            <items id="at0002">
                <description>*Identification of the problem or diagnosis, by name.(en)</description>
                <text>问题/诊断名字</text>
            </items>
            <items id="at0003">
                <description>*Estimated or actual date/time the diagnosis or problem was recognised by a healthcare professional.(en)</description>
                <text>临床认可的日期/时间</text>
            </items>
            <items id="at0005">
                <description>*An assessment of the overall severity of the problem or diagnosis.(en)</description>
                <text>严重性</text>
            </items>
            <items id="at0009">
                <description>*Narrative description about the problem or diagnosis.(en)</description>
                <text>临床描述</text>
            </items>
            <items id="at0012">
                <description>*Identification of a simple body site for the location of the problem or diagnosis.(en)</description>
                <text>身体位置</text>
            </items>
            <items id="at0030">
                <description>*Estimated or actual date/time of resolution or remission for this problem or diagnosis, as determined by a healthcare professional.(en)</description>
                <text>解决的日期/时间</text>
            </items>
            <items id="at0032">
                <description>@ internal @ (en)</description>
                <text>Tree (en)</text>
            </items>
            <items id="at0039">
                <description>*A structured anatomical location for the problem or diagnosis.(en)</description>
                <text>结构化身体位置</text>
            </items>
            <items id="at0043">
                <description>*Details that are additionally required to record as unique attributes of this problem or diagnosis.(en)</description>
                <text>详情</text>
            </items>
            <items id="at0046">
                <description>描述与位置，域，发作或者工作流程等诊断过程中特定方面相关的结构化细节。</description>
                <text>状态</text>
            </items>
            <items id="at0047">
                <description>*The problem or diagnosis does not interfere with normal activity or may cause damage to health if left untreated.(en)</description>
                <text>Mild (en)</text>
            </items>
            <items id="at0048">
                <description>*The problem or diagnosis causes interference with normal activity or will damage health if left untreated.(en)</description>
                <text>Moderate (en)</text>
            </items>
            <items id="at0049">
                <description>*The problem or diagnosis prevents normal activity or will seriously damage health if left untreated.(en)</description>
                <text>Severe (en)</text>
            </items>
            <items id="at0069">
                <description>*Additional narrative about the problem or diagnosis not captured in other fields.(en)</description>
                <text>备注</text>
            </items>
            <items id="at0070">
                <description>*The date this problem or diagnosis was last updated.(en)</description>
                <text>最近更新</text>
            </items>
            <items id="at0071">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>其他</text>
            </items>
            <items id="at0072">
                <description>*Narrative description about the course of the problem or diagnosis since onset.(en)</description>
                <text>过程描述</text>
            </items>
            <items id="at0073">
                <description>*The level of confidence in the identification of the diagnosis.(en)</description>
                <text>诊断确定性</text>
            </items>
            <items id="at0074">
                <description>*The diagnosis has been identified with a low level of certainty.(en)</description>
                <text>*Suspected (en)</text>
            </items>
            <items id="at0075">
                <description>*The diagnosis has been identified with a high level of certainty.(en)</description>
                <text>*Probable (en)</text>
            </items>
            <items id="at0076">
                <description>*The diagnosis has been confirmed against recognised criteria.(en)</description>
                <text>*Confirmed (en)</text>
            </items>
            <items id="at0077">
                <description>*Estimated or actual date/time that signs or symptoms of the problem/diagnosis were first observed.(en)</description>
                <text>开始日期/时间</text>
            </items>
            <items id="at0078">
                <description>*A cause, set of causes, or manner of causation of the problem or diagnosis.(en)</description>
                <text>*Cause (en)</text>
            </items>
            <items id="at0079">
                <description>*Specific variant or subtype of the Diagnosis, if relevant. (en)</description>
