            </items>
            <items id="at0011">
                <description>Indication for the care plan.</description>
                <text>Indication</text>
            </items>
            <items id="at0017">
                <description>Identification of the care plan.</description>
                <text>Plan name</text>
            </items>
            <items id="at0018">
                <description>Date of onset for the care plan.</description>
                <text>Date of onset</text>
            </items>
            <items id="at0019">
                <description>Additional narrative about the care plan request, not captured in other fields.</description>
