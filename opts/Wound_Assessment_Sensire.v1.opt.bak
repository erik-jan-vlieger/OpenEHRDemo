            <items id="at0065">
                <description>Dia actual del cicle menstrual.</description>
                <text>Dia del cicle menstrual</text>
            </items>
            <items id="at0066">
                <description>Qüestions o factors addicionals que poden influir en el mesurament de la temperatura corporal, no recollits en altres camps.</description>
