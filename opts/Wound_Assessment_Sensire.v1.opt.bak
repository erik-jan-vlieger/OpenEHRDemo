    <component_terminologies archetype_id="openEHR-EHR-EVALUATION.clinical_synopsis.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Zusammenfassung oder Übersicht einer Patientengeschichte, speziell aus der Sicht eines Gesundheitsdienstleisters, evtl. mit dazugehörigen Interpretationen.</description>
                <text>Klinische Synopsis</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*List(en)</text>
            </items>
            <items id="at0002">
                <description>Die Zusammenfassung, Beurteilung, Aussagen or Auswertung des klinischen Befunds.</description>
                <text>Synopsis</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle / Formalismen.&#13;
</description>
                <text>Erweiterung</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Beskrivande sammanfattning eller överblick av en patient, särskilt ur vårdgivarens perspektiv, med eller utan associerade tolkningar.</description>
                <text>Klinisk synopsis</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>List</text>
            </items>
            <items id="at0002">
                <description>Sammanfattning, bedömning, slutsatser eller utvärderingar av de kliniska fynden.</description>
                <text>Synopsis</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="pt-br">
            <items id="at0000">
                <description>Resumo narrativo ou visão geral sobre um paciente, especificamente a partir da perspectiva de um profissional de saúde, e com ou sem interpretações associadas.</description>
                <text>Sinopse Clínica</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*List(en)</text>
            </items>
            <items id="at0002">
                <description>O sumário, a avaliação, conclusões ou avaliação dos achados clínicos.</description>
                <text>Sinopse</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
                <description>*Additional information required to capture local content or to align with other reference models/formalisms.(en)</description>
                <text>*Extension(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="el">
            <items id="at0000">
                <description>Αφηγηματική περίληψη ή επισκόπηση σχετικά με έναν ασθενή, ειδικά από την οπτική γωνία ενός παρόχου υγειονομικής περίθαλψης και με ή χωρίς σχετικές ερμηνείες.</description>
                <text>Κλινική σύνοψη</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>List</text>
            </items>
            <items id="at0002">
                <description>Η περίληψη, η αξιολόγηση, τα συμπεράσματα ή η αξιολόγηση των κλινικών ευρημάτων.</description>
                <text>Σύνοψη</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Πρόσθετες πληροφορίες που απαιτούνται για την καταγραφή τοπικού περιεχομένου ή για την ευθυγράμμιση με άλλα μοντέλα αναφοράς/φορμαλισμούς.</description>
                <text>*Extension(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Narrative summary or overview about a patient, specifically from the perspective of a healthcare provider, and with or without associated interpretations.</description>
                <text>Clinical synopsis</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>List</text>
            </items>
            <items id="at0002">
