                <ns0:archetype_id><ns0:value>openEHR-EHR-EVALUATION.sims_classification_nl.v0</ns0:value></ns0:archetype_id><ns0:term_definitions code="at0000"><ns0:items id="description">Nederlands risicoclassificatiemodel voor de diabetische voet (categorie 0-3) gebaseerd op PS-verlies, PAV, ulcushistorie en andere risicofactoren.</ns0:items><ns0:items id="text">Sims-risicoclassificatie</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0001"><ns0:items id="description">Boomstructuur.</ns0:items><ns0:items id="text">Boom</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0002"><ns0:items id="description">Risicoclassificatie van de diabetische voet volgens Sims.</ns0:items><ns0:items id="text">Sims-categorie</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0003"><ns0:items id="description">Intacte protectieve sensibiliteit, geen PAV, geen ulcushistorie. Jaarlijkse controle door huisarts.</ns0:items><ns0:items id="text">Categorie 0 — Geen risicofactoren</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0004"><ns0:items id="description">Verlies van protectieve sensibiliteit (PS-verlies), geen PAV, geen ulcushistorie. Halfjaarlijkse controle, podotherapie.</ns0:items><ns0:items id="text">Categorie 1 — Neuropathie</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0005"><ns0:items id="description">PS-verlies + PAV en/of standsafwijkingen. Driemaandelijkse controle, specialistische podotherapie.</ns0:items><ns0:items id="text">Categorie 2 — Neuropathie + bijkomend risico</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0006"><ns0:items id="description">Eerder ulcus, amputatie of Charcot in de voorgeschiedenis. Maandelijkse tot zeswekelijkse controle, specialistische multidisciplinaire zorg.</ns0:items><ns0:items id="text">Categorie 3 — Ulcus/amputatie in VG</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0007"><ns0:items id="description">Protectieve sensibiliteit verloren, vastgesteld met monofilament-test (score ≤5/8).</ns0:items><ns0:items id="text">Verlies protectieve sensibiliteit</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0008"><ns0:items id="description">Aanwezigheid van perifeer arterieel vaatlijden (PAV), vastgesteld via pulsaties en/of EAI.</ns0:items><ns0:items id="text">Perifeer arterieel vaatlijden</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0009"><ns0:items id="description">Aanwezigheid van voet- of teenstandafwijkingen die drukpunten veroorzaken.</ns0:items><ns0:items id="text">Standsafwijkingen</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0010"><ns0:items id="description">Eerder voetulcus in de voorgeschiedenis.</ns0:items><ns0:items id="text">Historie ulcus</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0011"><ns0:items id="description">Eerdere (deel)amputatie van de voet of het been.</ns0:items><ns0:items id="text">Historie amputatie</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0012"><ns0:items id="description">Charcot-osteoarthropathie in de voorgeschiedenis.</ns0:items><ns0:items id="text">Charcot in voorgeschiedenis</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0013"><ns0:items id="description">Aanbevolen frequentie van voetcontrole op basis van de Sims-categorie.</ns0:items><ns0:items id="text">Aanbevolen controlefrequentie</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0014"><ns0:items id="description">Aanvullende opmerkingen bij de Sims-classificatie.</ns0:items><ns0:items id="text">Opmerking</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0015"><ns0:items id="description">Protocol.</ns0:items><ns0:items id="text">Protocol</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0016"><ns0:items id="description">Naam of rol van de beoordelaar.</ns0:items><ns0:items id="text">Beoordelaar</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0017"><ns0:items id="description">Datum en tijd van de beoordeling.</ns0:items><ns0:items id="text">Datum beoordeling</ns0:items></ns0:term_definitions></ns0:children>
