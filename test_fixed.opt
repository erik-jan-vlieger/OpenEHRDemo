                <ns0:archetype_id><ns0:value>openEHR-EHR-OBSERVATION.exam.v1</ns0:value></ns0:archetype_id><ns0:term_definitions code="at0000"><ns0:items id="description">Während der körperlichen Untersuchung eines Patienten beobachtete Befunde.</ns0:items><ns0:items id="text">Ergebnisse der körperlichen Untersuchung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0001"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Event Series</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0002"><ns0:items id="description">Ein Standardwert, ein spezifizierter Zeitpunkt oder ein Intervallereignis, welches explizit in einem Template oder während der Laufzeit definiert werden kann.</ns0:items><ns0:items id="text">Jedes Ereignis</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0003"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0004"><ns0:items id="description">Beschreibung der Gesamtbefunde, die bei der körperlichen Untersuchung eines Patienten beobachtet wurden.</ns0:items><ns0:items id="text">Beschreibung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0005"><ns0:items id="description">Strukturierte Details der körperlichen Untersuchung.</ns0:items><ns0:items id="text">Untersuchungsdetails</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0006"><ns0:items id="description">Einzelnes Wort, Ausdruck oder Kurzbeschreibung der klinischen Bedeutung und Aussagekraft der körperlichen Untersuchungsbefunde.</ns0:items><ns0:items id="text">Interpretation</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0007"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0008"><ns0:items id="description">Beschreibung aller zufälligen Faktoren, die zu den Ergebnissen der körperlichen Untersuchung beigetragen haben könnten.</ns0:items><ns0:items id="text">Störfaktoren</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0009"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0010"><ns0:items id="description">Details über jedes Gerät, welches bei der körperlichen Untersuchung verwendet wurde.</ns0:items><ns0:items id="text">Gerätedetails</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0011"><ns0:items id="description">Zusätzlicher Freitext über die allgemeinen körperlichen Untersuchungsergebnisse, die in anderen Bereichen nicht erfasst werden konnten.</ns0:items><ns0:items id="text">Kommentar</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0012"><ns0:items id="description">Zusätzliche Information, die für die Erfassung des lokalen Kontexts oder für die Anpassung an andere Referenzmodelle/Formalismen benötigt wird.</ns0:items><ns0:items id="text">Erweiterung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0013"><ns0:items id="description">Die Position der untersuchten Person während der Untersuchung.</ns0:items><ns0:items id="text">Position</ns0:items></ns0:term_definitions></ns0:children>
