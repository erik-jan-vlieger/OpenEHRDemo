                <ns0:archetype_id><ns0:value>openEHR-EHR-ACTION.health_education.v1</ns0:value></ns0:archetype_id><ns0:term_definitions code="at0000"><ns0:items id="description">Kommunikation zur Verbesserung der Gesundheitskompetenz und der Lebenskompetenzen.</ns0:items><ns0:items id="text">Gesundheitsberatung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0001"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0002"><ns0:items id="description">Identifizierung des Themas der Gesundheitsberatung mit Namen.</ns0:items><ns0:items id="text">Thema</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0003"><ns0:items id="description">Beschreibung der Gesundheitsberatung.</ns0:items><ns0:items id="text">Beschreibung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0004"><ns0:items id="description">Methode, mit der die Gesundheitsberatung der Person erteilt wurde.</ns0:items><ns0:items id="text">Methode</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0006"><ns0:items id="description">Beratung ist geplant, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</ns0:items><ns0:items id="text">Beratung geplant</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0007"><ns0:items id="description">Termin für die Beratung festgelegt.</ns0:items><ns0:items id="text">Beratung terminiert</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0008"><ns0:items id="description">Beratungssitzung oder Material angeboten.</ns0:items><ns0:items id="text">Beratung angeboten</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0010"><ns0:items id="description">Grund, warum der Pathway-Schritt für die identifizierte Gesundheitsberatung durchgeführt wurde.</ns0:items><ns0:items id="text">Grund</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0013"><ns0:items id="description">Alle geplanten Beratungsaktivitäten wurden erfolgreich abgeschlossen.</ns0:items><ns0:items id="text">Beratung abgeschlossen</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0014"><ns0:items id="description">Die Beratung wurde noch vor Beginn verschoben.</ns0:items><ns0:items id="text">Beratung verschoben</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0015"><ns0:items id="description">Die Beratung wurde noch vor Beginn abgesagt.</ns0:items><ns0:items id="text">Beratung abgesagt</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0016"><ns0:items id="description">Die Beratungssitzungen wurde vor Abschluss abgebrochen.</ns0:items><ns0:items id="text">Beratung nicht abgeschlossen</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0017"><ns0:items id="description">Geplante Beratungssitzungen wurden nach Beginn ausgesetzt.</ns0:items><ns0:items id="text">Beratung unterbrochen</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0018"><ns0:items id="description">Beratung wurde empfohlen, aber es wurden keine Schritte unternommen, um Beratung zu initiieren.</ns0:items><ns0:items id="text">Beratung empfohlen</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0019"><ns0:items id="description">Beschreibung des Ergebnisses der Gesundheitsberatung.</ns0:items><ns0:items id="text">Ergebnis</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0020"><ns0:items id="description">Nummer der Beratungssitzung in einem Kurs mit mehreren Sitzungen.</ns0:items><ns0:items id="text">Sitzungsnummer</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0021"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0023"><ns0:items id="description">Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle/Formalismen.</ns0:items><ns0:items id="text">Erweiterung</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0025"><ns0:items id="description">Strukturierte Angaben zum Beratungsmaterial, das der Person zur Verfügung gestellt wird.</ns0:items><ns0:items id="text">Material</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0026"><ns0:items id="description">Datum und / oder Uhrzeit der Durchführung der Beratungsaktivität.</ns0:items><ns0:items id="text">Termin Datum/Uhrzeit</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0027"><ns0:items id="description">Zusätzliche Beschreibung über den Aktivitäts- oder Pflegeschritt, der in anderen Feldern nicht erfasst wurde.</ns0:items><ns0:items id="text">Kommentar</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0028"><ns0:items id="description">Angaben über den Gesundheitsdienstleister oder die Organisation, die die Beratung anfordert.</ns0:items><ns0:items id="text">Anforderer</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0029"><ns0:items id="description">Angaben zu dem Gesundheitsdienstleister oder der Organisation, die die Anforderung zur Beratung erhalten hat.</ns0:items><ns0:items id="text">Empfänger</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0030"><ns0:items id="description">Die lokale ID, die dem Auftrag von dem Gesundheitsdienstleister oder der Organisation, die die Beratung anfordert, zugewiesen wurde.</ns0:items><ns0:items id="text">Anforderer ID</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0031"><ns0:items id="description">Die ID, die dem Antrag von dem Gesundheitsdienstleister oder der Organisation zugewiesen wurde, die den Antrag auf Beratung erhalten hat. Dies wird auch als Filler Order Identifier bezeichnet.</ns0:items><ns0:items id="text">Empfänger ID</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0032"><ns0:items id="description">Empfänger der Gesundheitsberatung.</ns0:items><ns0:items id="text">Beratungsempfänger</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0033"><ns0:items id="description">Zusätzliche strukturierte Angaben zur Gesundheitsberatung.</ns0:items><ns0:items id="text">Zusätzliche Angaben</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0034"><ns0:items id="description">Angaben zum Dolmetscher.</ns0:items><ns0:items id="text">Dolmetscher</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0035"><ns0:items id="description">Der klinische Grund für die Beratungsaktivität.</ns0:items><ns0:items id="text">Klinische Indikation</ns0:items></ns0:term_definitions></ns0:children>
