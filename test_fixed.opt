                <ns0:archetype_id><ns0:value>openEHR-EHR-OBSERVATION.laboratory_test_result.v1</ns0:value></ns0:archetype_id><ns0:term_definitions code="at0000"><ns0:items id="description">*The result, including findings and the laboratory's interpretation, of an investigation performed on specimens collected from an individual or related to that individual.(en)</ns0:items><ns0:items id="text">*Laboratory test result(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0001"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Event Series</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0002"><ns0:items id="description">*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</ns0:items><ns0:items id="text">*Any event(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0003"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0004"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0005"><ns0:items id="description">Naam van het laboratorium onderzoek dat vericht is op het specimen.</ns0:items><ns0:items id="text">Naam van de Test</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0017"><ns0:items id="description">*Details of the laboratory which received the request and has overall responsibility to manage reporting of the test, even if other labs perform specific aspects.(en)</ns0:items><ns0:items id="text">*Receiving laboratory(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0035"><ns0:items id="description">*Details of additional clinicians or organisations who require a copy of the test result.(en)</ns0:items><ns0:items id="text">*Distribution list(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0037"><ns0:items id="description">*This is a partial (e.g. initial, interim or preliminary) Test Result: data in the Test Result may be incomplete or unverified.(en)</ns0:items><ns0:items id="text">*Partial(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0038"><ns0:items id="description">*The Test result is complete and verified by an authorised person.(en)</ns0:items><ns0:items id="text">*Final(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0040"><ns0:items id="description">*The result has been modified subsequent to being Final, and is complete and verified by the responsible pathologist, and result data has been changed.(en)</ns0:items><ns0:items id="text">*Amended(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0057"><ns0:items id="description">*Narrative description of the key findings.(en)</ns0:items><ns0:items id="text">*Conclusion(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0062"><ns0:items id="description">*The local identifier assigned by the requesting clinical system.(en)</ns0:items><ns0:items id="text">*Requester order identifier(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0063"><ns0:items id="description">*The local identifier assigned to the test order by the order filler, usually by the Laboratory Information System (LIS).(en)</ns0:items><ns0:items id="text">*Receiver order identifier(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0065"><ns0:items id="description">*Details about the physical substance that has been analysed.(en)</ns0:items><ns0:items id="text">*Specimen detail(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0068"><ns0:items id="description">*A local identifier assigned by the receiving Laboratory Information System (LIS) to track the test process.(en)</ns0:items><ns0:items id="text">*Laboratory internal identifier(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0073"><ns0:items id="description">*The status of the laboratory test result as a whole.(en)</ns0:items><ns0:items id="text">*Overall test status(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0074"><ns0:items id="description">*The result is unavailable because the test was not started or not completed (also sometimes called 'aborted').(en)</ns0:items><ns0:items id="text">*Cancelled(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0075"><ns0:items id="description">*The date and/or time that ‘Overall test status’ was issued.(en)</ns0:items><ns0:items id="text">*Overall test status timestamp(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0077"><ns0:items id="description">*The diagnostic service or discipline that is responsible for the laboratory test result.(en)</ns0:items><ns0:items id="text">*Diagnostic service category(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0090"><ns0:items id="description">*Details of the clinician or organisation requesting the laboratory test result.(en)</ns0:items><ns0:items id="text">*Requester(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0094"><ns0:items id="description">*Details about the test request.(en)</ns0:items><ns0:items id="text">*Test request details(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0097"><ns0:items id="description">*Results of the test performed on the specimen(s).(en)</ns0:items><ns0:items id="text">*Test result(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0098"><ns0:items id="description">*Single word, phrase or brief description that represents the clinical meaning and significance of the laboratory test result.(en)</ns0:items><ns0:items id="text">*Test diagnosis(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0100"><ns0:items id="description">*Description of clinical information available at the time of interpretation of results.(en)</ns0:items><ns0:items id="text">*Clinical information provided(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0101"><ns0:items id="description">*Additional narrative about the test result not captured in other fields.(en)</ns0:items><ns0:items id="text">*Comment(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0106"><ns0:items id="description">*Name of the original laboratory test requested.(en)</ns0:items><ns0:items id="text">*Original test requested name(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0107"><ns0:items id="description">*The existence of the test is registered in the Laboratory Information System, but there is nothing yet available.(en)</ns0:items><ns0:items id="text">*Registered(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0110"><ns0:items id="description">*Structured details about the method of analysis, device or interpretation used.(en)</ns0:items><ns0:items id="text">*Testing details(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0111"><ns0:items id="description">*This indicates whether the test was performed directly at Point-of-Care (POCT) as opposed to a formal result from a laboratory or other service delivery organisation.(en)</ns0:items><ns0:items id="text">*Point-of-care test(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0112"><ns0:items id="description">@ internal @</ns0:items><ns0:items id="text">Tree</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0113"><ns0:items id="description">*Issues or circumstances that impact on the accurate interpretation of the measurement or test result.(en)</ns0:items><ns0:items id="text">*Confounding factors(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0114"><ns0:items id="description">*Details of issues or circumstances that impact on the accurate interpretation of the measurement or test result.(en)</ns0:items><ns0:items id="text">*Structured confounding factors(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0115"><ns0:items id="description">*The result has been modified subsequent to being Final, and is complete and verified by the responsible pathologist. This is a sub-category of 'Amended'.(en)</ns0:items><ns0:items id="text">*Corrected(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0116"><ns0:items id="description">*The Test Result has been withdrawn following previous Final release.(en)</ns0:items><ns0:items id="text">*Entered in error(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0117"><ns0:items id="description">*Additional information required to capture local content or to align with other reference models/formalisms.(en)</ns0:items><ns0:items id="text">*Extension(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0118"><ns0:items id="description">*Digital image, video or diagram representing the test result.(en)</ns0:items><ns0:items id="text">*Multimedia representation(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0119"><ns0:items id="description">*Subsequent to being final, the report has been modified by adding new content. The existing content is unchanged. This is a sub-category of 'Amended'.(en)</ns0:items><ns0:items id="text">*Appended(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0120"><ns0:items id="description">*Verified early results are available, but not all results are final. This is a sub-category of 'Partial'.(en)</ns0:items><ns0:items id="text">*Preliminary(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0121"><ns0:items id="description">*Description about the method used to perform the test.(en)</ns0:items><ns0:items id="text">*Test method(en)</ns0:items></ns0:term_definitions><ns0:term_definitions code="at0122"><ns0:items id="description">*A structured or complex diagnosis for the laboratory test.(en)</ns0:items><ns0:items id="text">*Structured test diagnosis(en)</ns0:items></ns0:term_definitions></ns0:children>
            <ns0:children xsi:type="C_ARCHETYPE_ROOT">
                <ns0:rm_type_name>OBSERVATION</ns0:rm_type_name><ns0:occurrences>
                    <ns0:lower_included>true</ns0:lower_included><ns0:upper_included>true</ns0:upper_included><ns0:lower_unbounded>false</ns0:lower_unbounded><ns0:upper_unbounded>true</ns0:upper_unbounded><ns0:lower xsi:type="xs:int">0</ns0:lower>
