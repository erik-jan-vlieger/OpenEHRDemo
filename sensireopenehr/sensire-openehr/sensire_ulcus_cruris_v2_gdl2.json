{
  "id": "sensire_ulcus_cruris_v2",
  "gdl_version": "2.0",
  "concept": "gt0001",
  "language": {
    "original_language": "ISO_639-1::en"
  },
  "description": {
    "original_author": {
      "date": "2026-03-29",
      "name": "Erik-Jan Vlieger",
      "organisation": "Sensire / Het Instituut Bedrijfskunde",
      "email": "info@erik-janvlieger.nl"
    },
    "other_contributors": [],
    "lifecycle_state": "Author draft",
    "details": {
      "en": {
        "id": "en",
        "purpose": "Clinical decision support for the Ulcus Cruris (venous leg ulcer) care pathway in home care. Covers triage (new vs existing patient), DM screening and routing, oedema assessment with Stemmer test, three-layer ABPI assessment (measurement → ratio → interpretation), compression therapy selection (UrgoK2/UrgoK2 Lite via therapeutic_item_order), wound stagnation escalation, and closure criteria.",
        "keywords": ["ulcus cruris", "venous leg ulcer", "ABPI", "ankle brachial pressure index", "EAI", "compression therapy", "UrgoK2", "Stemmer sign", "lymphedema", "wound stagnation", "home care"],
        "use": "Use for patients presenting with wounds on the lower leg or foot. Template: Ulcus_Cruris_Assessment_Sensire.v1. Routes to Diabetic_Foot_Assessment_Sensire.v1 if DM present, and to Wound_Assessment_Sensire.v1 for actual wound treatment.",
        "misuse": "Not a standalone wound treatment guideline. Always use with Wound_Assessment_Sensire.v1 for wound care. Not validated for inpatient settings.",
        "copyright": "© 2026 Sensire"
      },
      "nl": {
        "id": "nl",
        "purpose": "Klinische beslisondersteuning voor het Ulcus Cruris zorgpad in de thuiszorg. Omvat triage, DM-screening, oedeembeoordeling met Stemmer-test, drielaags ABPI-beoordeling, compressiekeuze via therapeutic_item_order, en escalatie bij wondstagnatie.",
        "keywords": ["ulcus cruris", "veneus beenulcus", "ABPI", "enkel-arm index", "EAI", "compressietherapie", "UrgoK2", "teken van Stemmer", "lymfoedeem", "wondstagnatie", "thuiszorg"],
        "use": "Gebruik voor patiënten met wonden aan het onderbeen of de voet. Template: Ulcus_Cruris_Assessment_Sensire.v1.",
        "misuse": "Niet gebruiken als zelfstandig wondbehandelprotocol. Altijd combineren met Wound_Assessment_Sensire.v1.",
        "copyright": "© 2026 Sensire"
      }
    }
  },
  "definition": {
    "data_bindings": {
      "gt0002": {
        "id": "gt0002",
        "model_id": "openEHR-EHR-OBSERVATION.ankle_brachial_pressure_index.v0",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0003": {
            "id": "gt0003",
            "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0004]",
            "description": "ABPI ratio value (calculated quotient, e.g. 0.82). Source: C-4 layer 2 — Norwegian draft archetype adopted locally."
          },
          "gt0004": {
            "id": "gt0004",
            "path": "/data[at0001]/events[at0002]/time",
            "description": "Date/time of ABPI measurement"
          }
        }
      },
      "gt0005": {
        "id": "gt0005",
        "model_id": "openEHR-EHR-EVALUATION.problem_diagnosis.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0006": {
            "id": "gt0006",
            "path": "/data[at0001]/items[at0002]",
            "description": "Diagnosis name — used to check for Diabetes Mellitus and vascular diagnosis (arterial/venous/mixed)"
          },
          "gt0047": {
            "id": "gt0047",
            "path": "/data[at0001]/items[at0073]",
            "description": "Diagnostic certainty — maps to physician-confirmed diagnosis"
          }
        }
      },
      "gt0007": {
        "id": "gt0007",
        "model_id": "openEHR-EHR-CLUSTER.exam_stemmer_test.v0",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0008": {
            "id": "gt0008",
            "path": "/items[at0001]",
            "description": "Stemmer test result: positive (skin fold not liftable → lymphedema) / negative (liftable → venous oedema). Source: C-5 new archetype."
          },
          "gt0048": {
            "id": "gt0048",
            "path": "/items[at0002]",
            "description": "Test location (dorsal side 2nd toe)"
          },
          "gt0049": {
            "id": "gt0049",
            "path": "/items[at0003]",
            "description": "Interpretation (lymphedema / venous oedema)"
          }
        }
      },
      "gt0009": {
        "id": "gt0009",
        "model_id": "openEHR-EHR-CLUSTER.exam.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0010": {
            "id": "gt0010",
            "path": "/items[at0001]",
            "description": "Oedema presence (finding within general exam cluster)"
          }
        }
      },
      "gt0011": {
        "id": "gt0011",
        "model_id": "openEHR-EHR-EVALUATION.clinical_synopsis.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0012": {
            "id": "gt0012",
            "path": "/data[at0001]/items[at0002]",
            "description": "Wound duration — coded from clinical synopsis or wound stagnation assessment"
          },
          "gt0013": {
            "id": "gt0013",
            "path": "/data[at0001]/items[at0003]",
            "description": "Wound improving assessment"
          }
        }
      },
      "gt0014": {
        "id": "gt0014",
        "model_id": "openEHR-EHR-INSTRUCTION.therapeutic_item_order.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0015": {
            "id": "gt0015",
            "path": "/activities[at0001]/description[at0002]/items[at0003]",
            "description": "Therapeutic item name — compression system (UrgoK2 / UrgoK2 Lite / None)"
          },
          "gt0050": {
            "id": "gt0050",
            "path": "/activities[at0001]/description[at0002]/items[at0004]",
            "description": "Clinical indication for the compression order"
          }
        }
      },
      "gt0016": {
        "id": "gt0016",
        "model_id": "openEHR-EHR-INSTRUCTION.service_request.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0017": {
            "id": "gt0017",
            "path": "/activities[at0001]/description[at0009]/items[at0121]",
            "description": "Service name — referral type"
          },
          "gt0018": {
            "id": "gt0018",
            "path": "/activities[at0001]/description[at0009]/items[at0062]",
            "description": "Reason for request"
          },
          "gt0019": {
            "id": "gt0019",
            "path": "/activities[at0001]/description[at0009]/items[at0064]",
            "description": "Urgency"
          }
        }
      },
      "gt0020": {
        "id": "gt0020",
        "model_id": "openEHR-EHR-EVALUATION.health_risk.v1",
        "template_id": "Ulcus_Cruris_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0021": {
            "id": "gt0021",
            "path": "/data[at0001]/items[at0002]",
            "description": "Risk assessment — clinical recommendation text"
          },
          "gt0022": {
            "id": "gt0022",
            "path": "/data[at0001]/items[at0003]",
            "description": "Risk factor detail"
          }
        }
      }
    },
    "pre_conditions": [],
    "default_actions": [
      "$gt0019 = local::at0136|Routine|"
    ],
    "rules": {
      "gt0100": {
        "id": "gt0100",
        "priority": 10,
        "when": [
          "$gt0006 == local::at0001|Diabetes Mellitus|"
        ],
        "then": [
          "$gt0017 = local::at0030|Doorverwijzing Protocol Diabetische Voet|",
          "$gt0018 = 'DM vastgesteld — patiënt moet eerst door Diabetic_Foot_Assessment_Sensire.v1 voordat wondzorg start'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0101": {
        "id": "gt0101",
        "priority": 9,
        "when": [
          "$gt0012 > 3,wk",
          "$gt0013 == local::at0004|Nee, geen verbetering|"
        ],
        "then": [
          "$gt0017 = local::at0031|Vakgroep Wond|",
          "$gt0018 = 'Wondstagnatie Ulcus Cruris — wond >2-3 weken zonder verbetering. Consult via triageformulier op intranet.'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0102": {
        "id": "gt0102",
        "priority": 8,
        "when": [
          "$gt0010 == local::at0002|Aanwezig|",
          "$gt0008 == local::at0002|Positief|"
        ],
        "then": [
          "$gt0021 = 'Positief teken van Stemmer bij oedeem — wijst op lymfoedeem (niet veneus)'",
          "$gt0017 = local::at0032|Huidtherapeut|",
          "$gt0018 = 'Lymfoedeem — schakel huidtherapeut in voor MLD (manuele lymfedrainage) en therapeutisch-elastische kousen'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0103": {
        "id": "gt0103",
        "priority": 7,
        "when": [
          "$gt0003 < 0.6"
        ],
        "then": [
          "$gt0015 = local::at0010|GEEN compressie — ernstig vaatlijden|",
          "$gt0050 = 'ABPI < 0.6: ernstig perifeer arterieel vaatlijden. Compressie gecontra-indiceerd.'",
          "$gt0017 = local::at0033|Vaatchirurg|",
          "$gt0018 = 'ABPI < 0.6 — verwijs vaatchirurg. Wondzorg gaat wél door via Wound_Assessment_Sensire.v1'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0104": {
        "id": "gt0104",
        "priority": 6,
        "when": [
          "$gt0003 >= 0.6",
          "$gt0003 <= 0.8"
        ],
        "then": [
          "$gt0015 = local::at0011|UrgoK2 Lite — lichte compressie|",
          "$gt0050 = 'ABPI 0.6–0.8: gemengd veneus/arterieel vaatlijden. Lichte compressie geïndiceerd.'"
        ]
      },
      "gt0105": {
        "id": "gt0105",
        "priority": 5,
        "when": [
          "$gt0003 > 0.8",
          "$gt0003 <= 1.3"
        ],
        "then": [
          "$gt0015 = local::at0012|UrgoK2 — normale compressie|",
          "$gt0050 = 'ABPI 0.8–1.3: primair veneus ulcus. Normale compressie geïndiceerd.'"
        ]
      },
      "gt0106": {
        "id": "gt0106",
        "priority": 4,
        "when": [
          "$gt0003 > 1.3"
        ],
        "then": [
          "$gt0015 = local::at0013|Compressie on hold — ABPI onbetrouwbaar|",
          "$gt0050 = 'ABPI > 1.3: onbetrouwbare meting (mediasclerose). Nadere diagnostiek nodig.'",
          "$gt0017 = local::at0034|Huisarts|",
          "$gt0018 = 'ABPI > 1.3 — overleg huisarts voor nadere diagnostiek. Waarde wijst op mediasclerose en is onbetrouwbaar als vasculaire indicator.'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0107": {
        "id": "gt0107",
        "priority": 3,
        "when": [
          "$gt0004 < ($currentDateTime - 90,d)"
        ],
        "then": [
          "$gt0017 = local::at0035|Huisarts/Specialist — nieuwe ABPI|",
          "$gt0018 = 'ABPI-meting is ouder dan 3 maanden. Nieuwe meting aanvragen. Sensire meet niet zelf; via huisarts of specialist.'",
          "$gt0019 = local::at0137|Urgent|"
        ]
      },
      "gt0108": {
        "id": "gt0108",
        "priority": 2,
        "when": [
          "$gt0003 >= 0.6",
          "$gt0003 <= 1.3",
          "$gt0010 != local::at0002|Aanwezig|"
        ],
        "then": [
          "$gt0021 = 'ABPI in veilige range en geen oedeem — vervolg via Wound_Assessment_Sensire.v1 (Algemeen Wondprotocol)'"
        ]
      }
    }
  },
  "ontology": {
    "term_definitions": {
      "en": {
        "id": "en",
        "terms": {
          "gt0001": { "id": "gt0001", "text": "Sensire Ulcus Cruris Protocol v2", "description": "CDS for venous leg ulcer management with three-layer ABPI model, Stemmer test, and compression via therapeutic_item_order." },
          "gt0003": { "id": "gt0003", "text": "ABPI ratio", "description": "Ankle-Brachial Pressure Index calculated quotient. Source: OBSERVATION.ankle_brachial_pressure_index.v0 (C-4 layer 2, Norwegian draft adopted locally)." },
          "gt0004": { "id": "gt0004", "text": "ABPI measurement date", "description": "Date of ABPI measurement. Valid for max 3 months." },
          "gt0006": { "id": "gt0006", "text": "Diagnosis", "description": "From EVALUATION.problem_diagnosis.v1 — DM status and vascular diagnosis." },
          "gt0008": { "id": "gt0008", "text": "Stemmer test result", "description": "From CLUSTER.exam_stemmer_test.v0 (C-5). Positive = not liftable = lymphedema. Negative = liftable = venous." },
          "gt0010": { "id": "gt0010", "text": "Oedema presence", "description": "From CLUSTER.exam.v1 — oedema finding in affected limb." },
          "gt0012": { "id": "gt0012", "text": "Wound duration", "description": "Wound duration in weeks." },
          "gt0013": { "id": "gt0013", "text": "Wound improving", "description": "Whether wound shows improvement." },
          "gt0015": { "id": "gt0015", "text": "Compression order — therapeutic item", "description": "Output to INSTRUCTION.therapeutic_item_order.v1 — compression system selection." },
          "gt0017": { "id": "gt0017", "text": "Referral service name", "description": "Output to INSTRUCTION.service_request.v1 — referral type." },
          "gt0018": { "id": "gt0018", "text": "Referral reason", "description": "Clinical reasoning for the referral." },
          "gt0019": { "id": "gt0019", "text": "Urgency", "description": "Urgency level of the recommended action." },
          "gt0021": { "id": "gt0021", "text": "Risk assessment", "description": "Output to EVALUATION.health_risk.v1 — clinical recommendation." },
          "gt0050": { "id": "gt0050", "text": "Compression clinical indication", "description": "Clinical reasoning for the compression order." },
          "gt0100": { "id": "gt0100", "text": "DM present — route to Diabetic Foot Protocol", "description": "Diabetes Mellitus → route through Diabetic_Foot_Assessment_Sensire.v1 first." },
          "gt0101": { "id": "gt0101", "text": "Wound stagnation — refer Vakgroep Wond", "description": "Wound >2-3 weeks without improvement → escalate." },
          "gt0102": { "id": "gt0102", "text": "Positive Stemmer + oedema — lymphedema alert", "description": "Positive Stemmer sign = lymphedema. Refer skin therapist for MLD." },
          "gt0103": { "id": "gt0103", "text": "ABPI < 0.6 — no compression, refer vascular surgeon", "description": "Severe PAD. Compression contraindicated. Wound care continues." },
          "gt0104": { "id": "gt0104", "text": "ABPI 0.6–0.8 — UrgoK2 Lite (light compression)", "description": "Mixed venous/arterial disease." },
          "gt0105": { "id": "gt0105", "text": "ABPI 0.8–1.3 — UrgoK2 (normal compression)", "description": "Primary venous ulcer." },
          "gt0106": { "id": "gt0106", "text": "ABPI > 1.3 — unreliable, consult GP", "description": "Likely mediasclerosis. Further diagnostics needed." },
          "gt0107": { "id": "gt0107", "text": "ABPI expired (>3 months)", "description": "Request new measurement via GP/specialist." },
          "gt0108": { "id": "gt0108", "text": "Safe ABPI, no oedema — proceed to wound protocol", "description": "Route to Wound_Assessment_Sensire.v1." }
        }
      },
      "nl": {
        "id": "nl",
        "terms": {
          "gt0001": { "id": "gt0001", "text": "Sensire Ulcus Cruris Protocol v2", "description": "Beslisondersteuning voor het veneus beenulcus zorgpad met drielaags ABPI-model, Stemmer-test en compressie via therapeutic_item_order." },
          "gt0003": { "id": "gt0003", "text": "ABPI-ratio (Enkel-Arm Index)", "description": "Berekend quotiënt van de enkel-arm drukmeting. Bron: Noors draft-archetype lokaal overgenomen (C-4 laag 2)." },
          "gt0004": { "id": "gt0004", "text": "Datum ABPI-meting", "description": "Datum van de ABPI-meting. Maximaal 3 maanden geldig." },
          "gt0006": { "id": "gt0006", "text": "Diagnose", "description": "Uit EVALUATION.problem_diagnosis.v1 — DM-status en vaatdiagnose." },
          "gt0008": { "id": "gt0008", "text": "Teken van Stemmer", "description": "Uit CLUSTER.exam_stemmer_test.v0 (C-5). Positief = niet oppakbaar = lymfoedeem. Negatief = wel oppakbaar = veneus." },
          "gt0010": { "id": "gt0010", "text": "Oedeem aanwezig", "description": "Uit CLUSTER.exam.v1 — oedeembevinding in het aangedane been." },
          "gt0012": { "id": "gt0012", "text": "Wondduur", "description": "Wondduur in weken." },
          "gt0013": { "id": "gt0013", "text": "Wond verbetert", "description": "Of de wond verbetering toont." },
          "gt0015": { "id": "gt0015", "text": "Compressieorder — therapeutisch hulpmiddel", "description": "Output naar INSTRUCTION.therapeutic_item_order.v1 — keuze compressiesysteem." },
          "gt0017": { "id": "gt0017", "text": "Verwijzing — type", "description": "Output naar INSTRUCTION.service_request.v1 — verwijstype." },
          "gt0018": { "id": "gt0018", "text": "Reden verwijzing", "description": "Klinische onderbouwing van de verwijzing." },
          "gt0019": { "id": "gt0019", "text": "Urgentie", "description": "Urgentieniveau van de aanbevolen actie." },
          "gt0021": { "id": "gt0021", "text": "Risicobeoordeling", "description": "Output naar EVALUATION.health_risk.v1 — klinisch advies." },
          "gt0050": { "id": "gt0050", "text": "Klinische indicatie compressie", "description": "Klinische onderbouwing van de compressieorder." },
          "gt0100": { "id": "gt0100", "text": "DM aanwezig — doorverwijzing Protocol Diabetische Voet", "description": "Diabetes Mellitus → eerst door Diabetic_Foot_Assessment_Sensire.v1." },
          "gt0101": { "id": "gt0101", "text": "Wondstagnatie — inschakelen Vakgroep Wond", "description": "Wond >2-3 weken zonder verbetering → escalatie." },
          "gt0102": { "id": "gt0102", "text": "Positief Stemmer + oedeem — lymfoedeem", "description": "Positief teken van Stemmer = lymfoedeem. Verwijs huidtherapeut voor MLD." },
          "gt0103": { "id": "gt0103", "text": "ABPI < 0,6 — geen compressie, verwijs vaatchirurg", "description": "Ernstig PAV. Compressie gecontra-indiceerd. Wondzorg gaat door." },
          "gt0104": { "id": "gt0104", "text": "ABPI 0,6–0,8 — UrgoK2 Lite (lichte compressie)", "description": "Gemengd veneus/arterieel vaatlijden." },
          "gt0105": { "id": "gt0105", "text": "ABPI 0,8–1,3 — UrgoK2 (normale compressie)", "description": "Primair veneus ulcus." },
          "gt0106": { "id": "gt0106", "text": "ABPI > 1,3 — onbetrouwbaar, overleg huisarts", "description": "Waarschijnlijk mediasclerose. Nadere diagnostiek nodig." },
          "gt0107": { "id": "gt0107", "text": "ABPI verlopen (>3 maanden)", "description": "Nieuwe meting aanvragen via huisarts/specialist." },
          "gt0108": { "id": "gt0108", "text": "Veilige ABPI, geen oedeem — door naar wondprotocol", "description": "Vervolg via Wound_Assessment_Sensire.v1." }
        }
      }
    },
    "term_bindings": {
      "SNOMED-CT": {
        "gt0003": "SNOMED-CT::431314004 |Ankle-brachial pressure index|",
        "gt0006": "SNOMED-CT::420101004 |Venous ulcer of lower extremity|",
        "gt0008": "SNOMED-CT::404684003 |Clinical finding|"
      }
    }
  }
}
