{
  "id": "sensire_wondverzorging_v2",
  "gdl_version": "2.0",
  "concept": "gt0001",
  "language": {
    "original_language": "ISO_639-1::en"
  },
  "description": {
    "original_author": {
      "date": "2026-03-29",
      "name": "Erik-Jan Vlieger",
      "organisation": "Sensire / Het Instituut Bedrijfskunde",
      "email": "info@erik-janvlieger.nl"
    },
    "other_contributors": [],
    "lifecycle_state": "Author draft",
    "details": {
      "en": {
        "id": "en",
        "purpose": "Comprehensive clinical decision support for the General Wound Protocol (Algemeen Wondprotocol). Template: Wound_Assessment_Sensire.v1. Covers: oncological wound exclusion, TIME assessment via CLUSTER.exam_wound, WCS colour classification via CLUSTER.wound_tissue_wcs_nl.v0 (C-1), pain management via OBSERVATION.pain_scale (VAS/ALTIS), infection screening via CLUSTER.symptom_sign.v2 + OBSERVATION.body_temperature.v2, debridement safety via EVALUATION.contraindication.v0, dressing selection via INSTRUCTION.therapeutic_item_order.v1 based on WCS colour × exudate matrix, DM-specific layers (foot inspection/pressure offloading/education) via ACTION.health_education.v1, and wound stagnation escalation via INSTRUCTION.service_request.v1.",
        "keywords": ["wound care", "TIME framework", "WCS classification", "wound colour", "exudate", "debridement", "infection", "pain management", "ALTIS", "dressing selection", "therapeutic item order", "diabetic wound", "pressure offloading", "home care", "wound stagnation"],
        "use": "Central wound management guideline. Both Ulcus_Cruris_Assessment and Diabetic_Foot_Assessment route here for actual wound treatment.",
        "misuse": "Not for oncological wounds. Does not replace clinical judgment. Dressing selections must be verified against current Sensire formulary.",
        "copyright": "© 2026 Sensire"
      },
      "nl": {
        "id": "nl",
        "purpose": "Uitgebreide klinische beslisondersteuning voor het Algemeen Wondprotocol. Template: Wound_Assessment_Sensire.v1. Omvat: oncologische uitsluiting, TIME-beoordeling, WCS-kleurclassificatie (C-1), pijnmanagement (ALTIS/VAS), infectiescreening, debridement-veiligheid, verbandkeuze via therapeutic_item_order, DM-lagen, en wondstagnatie-escalatie.",
        "keywords": ["wondzorg", "TIME", "WCS classificatie", "wondkleur", "exsudaat", "debridement", "infectie", "pijnmanagement", "ALTIS", "verbandkeuze", "therapeutic item order", "diabetische wond", "drukontlasting", "thuiszorg", "wondstagnatie"],
        "use": "Centraal wondzorgprotocol. Zowel Ulcus Cruris als Diabetische Voet verwijzen hiernaar voor wondbehandeling.",
        "misuse": "Niet voor oncologische wonden. Vervangt niet het klinisch oordeel.",
        "copyright": "© 2026 Sensire"
      }
    }
  },
  "definition": {
    "data_bindings": {
      "gt0002": {
        "id": "gt0002",
        "model_id": "openEHR-EHR-EVALUATION.problem_diagnosis.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0003": { "id": "gt0003", "path": "/data[at0001]/items[at0002]", "description": "Wound diagnosis (with wound_assertion_details cluster)" },
          "gt0004": { "id": "gt0004", "path": "/data[at0001]/items[at0009]", "description": "Oncological wound status (from wound_assertion_details)" },
          "gt0005": { "id": "gt0005", "path": "/data[at0001]/items[at0010]", "description": "DM as comorbidity" }
        }
      },
      "gt0006": {
        "id": "gt0006",
        "model_id": "openEHR-EHR-CLUSTER.exam_wound.v0",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0007": { "id": "gt0007", "path": "/items[at0001]", "description": "Wound length (cm) — DV_QUANTITY" },
          "gt0008": { "id": "gt0008", "path": "/items[at0002]", "description": "Wound width (cm)" },
          "gt0009": { "id": "gt0009", "path": "/items[at0003]", "description": "Wound depth (cm)" },
          "gt0010": { "id": "gt0010", "path": "/items[at0004]", "description": "Tissue type (TIME-T): vital/granulating, necrotic, slough" },
          "gt0011": { "id": "gt0011", "path": "/items[at0005]", "description": "Wound bed colour" },
          "gt0012": { "id": "gt0012", "path": "/items[at0006]", "description": "Wound odour (presence/type)" },
          "gt0013": { "id": "gt0013", "path": "/items[at0007]", "description": "Wound edge status (TIME-E): vital, macerated, undermined, eczema, callus" },
          "gt0014": { "id": "gt0014", "path": "/items[at0008]", "description": "Undermining present (yes/no)" },
          "gt0015": { "id": "gt0015", "path": "/items[at0009]", "description": "Exudate level (TIME-M): dry, moist, wet — DV_CODED_TEXT" }
        }
      },
      "gt0016": {
        "id": "gt0016",
        "model_id": "openEHR-EHR-CLUSTER.wound_tissue_wcs_nl.v0",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0018": { "id": "gt0018", "path": "/items[at0001]", "description": "Primary WCS colour: Red/Yellow/Black — determined by most avital tissue. Source: C-1 new archetype." },
          "gt0060": { "id": "gt0060", "path": "/items[at0002]", "description": "Secondary WCS colour (if mixed wound bed)" },
          "gt0061": { "id": "gt0061", "path": "/items[at0003]", "description": "Percentage black tissue in wound bed" },
          "gt0062": { "id": "gt0062", "path": "/items[at0004]", "description": "Percentage yellow tissue in wound bed" },
          "gt0063": { "id": "gt0063", "path": "/items[at0005]", "description": "Percentage red tissue in wound bed" }
        }
      },
      "gt0017": {
        "id": "gt0017",
        "model_id": "openEHR-EHR-OBSERVATION.pain_scale.v0",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0020": { "id": "gt0020", "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0004]", "description": "Pain present (yes/no)" },
          "gt0021": { "id": "gt0021", "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0005]", "description": "ALTIS/VAS pain score value — constrained in template to support both scales" }
        }
      },
      "gt0019": {
        "id": "gt0019",
        "model_id": "openEHR-EHR-CLUSTER.symptom_sign.v2",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0023": { "id": "gt0023", "path": "/items[at0001]", "description": "Infection sign name (rubor/calor/tumor/dolor/function loss)" },
          "gt0064": { "id": "gt0064", "path": "/items[at0021]", "description": "Sign presence (present/absent)" },
          "gt0027": { "id": "gt0027", "path": "/items[at0035]", "description": "Pus/purulent discharge present" },
          "gt0029": { "id": "gt0029", "path": "/items[at0036]", "description": "Redness extent from wound edge (cm)" },
          "gt0030": { "id": "gt0030", "path": "/items[at0037]", "description": "Bone contact in wound (probe-to-bone)" }
        }
      },
      "gt0070": {
        "id": "gt0070",
        "model_id": "openEHR-EHR-OBSERVATION.body_temperature.v2",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0028": { "id": "gt0028", "path": "/data[at0002]/events[at0003]/data[at0001]/items[at0004]", "description": "Body temperature value — for fever detection in infection assessment" }
        }
      },
      "gt0031": {
        "id": "gt0031",
        "model_id": "openEHR-EHR-EVALUATION.contraindication.v0",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0032": { "id": "gt0032", "path": "/data[at0001]/items[at0002]", "description": "A-vital tissue present requiring debridement consideration" },
          "gt0033": { "id": "gt0033", "path": "/data[at0001]/items[at0003]", "description": "Coagulation disorder (contraindication)" },
          "gt0034": { "id": "gt0034", "path": "/data[at0001]/items[at0004]", "description": "Deep structures visible (contraindication)" },
          "gt0035": { "id": "gt0035", "path": "/data[at0001]/items[at0005]", "description": "Malignancy suspected (contraindication)" }
        }
      },
      "gt0036": {
        "id": "gt0036",
        "model_id": "openEHR-EHR-EVALUATION.clinical_synopsis.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0037": { "id": "gt0037", "path": "/data[at0001]/items[at0002]", "description": "Wound duration in weeks" },
          "gt0038": { "id": "gt0038", "path": "/data[at0001]/items[at0003]", "description": "Wound improving (yes/no)" }
        }
      },
      "gt0039": {
        "id": "gt0039",
        "model_id": "openEHR-EHR-INSTRUCTION.therapeutic_item_order.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0041": { "id": "gt0041", "path": "/activities[at0001]/description[at0002]/items[at0003]", "description": "Dressing/therapeutic item name" },
          "gt0065": { "id": "gt0065", "path": "/activities[at0001]/description[at0002]/items[at0004]", "description": "Clinical indication for dressing selection" }
        }
      },
      "gt0040": {
        "id": "gt0040",
        "model_id": "openEHR-EHR-INSTRUCTION.service_request.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0042": { "id": "gt0042", "path": "/activities[at0001]/description[at0009]/items[at0121]", "description": "Service name — referral type" },
          "gt0066": { "id": "gt0066", "path": "/activities[at0001]/description[at0009]/items[at0062]", "description": "Reason for referral" },
          "gt0043": { "id": "gt0043", "path": "/activities[at0001]/description[at0009]/items[at0064]", "description": "Urgency" }
        }
      },
      "gt0050": {
        "id": "gt0050",
        "model_id": "openEHR-EHR-INSTRUCTION.medication_order.v4",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0044": { "id": "gt0044", "path": "/activities[at0001]/description[at0002]/items[at0070]", "description": "Pain management medication recommendation" }
        }
      },
      "gt0051": {
        "id": "gt0051",
        "model_id": "openEHR-EHR-ACTION.health_education.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0046": { "id": "gt0046", "path": "/description[at0001]/items[at0002]", "description": "DM-specific education (Steps A/B/C)" }
        }
      },
      "gt0052": {
        "id": "gt0052",
        "model_id": "openEHR-EHR-EVALUATION.health_risk.v1",
        "template_id": "Wound_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0045": { "id": "gt0045", "path": "/data[at0001]/items[at0002]", "description": "Debridement recommendation" },
          "gt0067": { "id": "gt0067", "path": "/data[at0001]/items[at0003]", "description": "Clinical recommendation text" }
        }
      }
    },
    "pre_conditions": [
      "$gt0004 != local::at0001|Ja, oncologische wond|"
    ],
    "default_actions": [
      "$gt0043 = local::at0136|Routine|"
    ],
    "rules": {
      "gt0100": {
        "id": "gt0100", "priority": 20,
        "when": ["$gt0004 == local::at0001|Ja, oncologische wond|"],
        "then": [
          "$gt0067 = 'ONCOLOGISCHE WOND: Werkinstructie NIET geschikt voor oncologische wonden. Raadpleeg specialistisch protocol en/of Vakgroep Wond.'",
          "$gt0043 = local::at0137|Urgent|"
        ]
      },
      "gt0110": {
        "id": "gt0110", "priority": 19,
        "when": ["$gt0005 == local::at0002|Diabetes Mellitus aanwezig|", "$gt0064 == local::at0001|Aanwezig|", "$gt0028 > 38,°C"],
        "then": [
          "$gt0067 = 'ERNSTIGE INFECTIE BIJ DM: Koorts > 38°C + infectietekenen bij diabetespatiënt.'",
          "$gt0042 = local::at0030|Arts — ernstige infectie DM|",
          "$gt0066 = 'Arts dezelfde dag. Wond afdekken met schoon gaas. Geen verdere behandeling starten. Temperatuur + pols noteren. Drukontlasting!'",
          "$gt0043 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0111": {
        "id": "gt0111", "priority": 18,
        "when": ["$gt0005 == local::at0002|Diabetes Mellitus aanwezig|", "$gt0064 == local::at0001|Aanwezig|", "$gt0029 > 2,cm"],
        "then": [
          "$gt0067 = 'ERNSTIGE INFECTIE BIJ DM: Roodheid > 2cm vanaf wondrand bij diabetespatiënt.'",
          "$gt0042 = local::at0030|Arts — ernstige infectie DM|",
          "$gt0066 = 'Arts dezelfde dag. Wond afdekken met schoon gaas. Geen verdere behandeling starten.'",
          "$gt0043 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0112": {
        "id": "gt0112", "priority": 17,
        "when": ["$gt0005 == local::at0002|Diabetes Mellitus aanwezig|", "$gt0064 == local::at0001|Aanwezig|", "$gt0030 == local::at0001|Ja, botcontact|"],
        "then": [
          "$gt0067 = 'ERNSTIGE INFECTIE BIJ DM: Botcontact in wond — osteomyelitisrisico.'",
          "$gt0042 = local::at0030|Arts — ernstige infectie DM|",
          "$gt0066 = 'Arts dezelfde dag. Wond afdekken met schoon gaas. Niet verder behandelen. Drukontlasting!'",
          "$gt0043 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0120": {
        "id": "gt0120", "priority": 16,
        "when": ["$gt0020 == local::at0001|Ja, pijn aanwezig|", "$gt0021 >= 4"],
        "then": [
          "$gt0044 = 'Pijnmanagement vereist vóór wondzorg (ALTIS ≥ 4). Systemisch: Paracetamol, NSAID, Oxycodon, Fentanyl neusspray/pleisters, Amitriptyline, Butrans (wachttijd 30-60 min). Lokaal snel (10 min): Lidocaïne druppels/spray. Lokaal traag (45 min): EMLA zalf/pleister. Start handeling pas na inwerking.'"
        ]
      },
      "gt0121": {
        "id": "gt0121", "priority": 15,
        "when": ["$gt0020 == local::at0001|Ja, pijn aanwezig|", "$gt0021 < 4"],
        "then": ["$gt0044 = 'Lichte pijn (ALTIS < 4). Overweeg lokale pijnstilling (Lidocaïne spray, 10 min inwerking). Monitor tijdens handeling.'"]
      },
      "gt0130": {
        "id": "gt0130", "priority": 14,
        "when": ["$gt0032 == local::at0001|Ja, a-vitaal weefsel|", "$gt0035 == local::at0001|Ja, maligniteit|"],
        "then": [
          "$gt0045 = 'GEEN DEBRIDEMENT — maligniteitsvermoeden. Verwijzen, niet debrideren.'",
          "$gt0043 = local::at0137|Urgent|"
        ]
      },
      "gt0131": {
        "id": "gt0131", "priority": 13,
        "when": ["$gt0032 == local::at0001|Ja, a-vitaal weefsel|", "$gt0033 == local::at0001|Ja, stollingsstoornis|"],
        "then": ["$gt0045 = 'GEEN DEBRIDEMENT — stollingsstoornis. Afdekken met schoon gaas. Overleg/verwijzen naar wondverpleegkundige.'"]
      },
      "gt0132": {
        "id": "gt0132", "priority": 12,
        "when": ["$gt0032 == local::at0001|Ja, a-vitaal weefsel|", "$gt0034 == local::at0001|Ja, diepe structuren|"],
        "then": ["$gt0045 = 'GEEN DEBRIDEMENT — diepe structuren zichtbaar. Afdekken met schoon gaas. Overleg/verwijzen naar wondverpleegkundige.'"]
      },
      "gt0133": {
        "id": "gt0133", "priority": 11,
        "when": ["$gt0032 == local::at0001|Ja, a-vitaal weefsel|", "$gt0033 != local::at0001|Ja, stollingsstoornis|", "$gt0034 != local::at0001|Ja, diepe structuren|", "$gt0035 != local::at0001|Ja, maligniteit|"],
        "then": ["$gt0045 = 'DEBRIDEMENT VEILIG — verwijzing wondverpleegkundige voor scherp debridement via triageformulier.'"]
      },
      "gt0140": {
        "id": "gt0140", "priority": 10,
        "when": ["$gt0064 == local::at0001|Aanwezig|", "$gt0005 != local::at0002|Diabetes Mellitus aanwezig|"],
        "then": [
          "$gt0067 = 'Infectietekenen aanwezig (geen DM).'",
          "$gt0042 = local::at0031|Huisarts — infectie|",
          "$gt0066 = 'Infectiebeleid: 1) Lokaal antibacterieel (zilver/jodium/honing). 2) Arts raadplegen bij koorts + infectie. 3) Verwijs naar HA of poli voor diagnostiek en therapie.'"
        ]
      },
      "gt0150": {
        "id": "gt0150", "priority": 9,
        "when": ["$gt0018 == local::at0003|Zwart (necrose)|", "$gt0015 == local::at0001|Droog|"],
        "then": [
          "$gt0041 = local::at0070|Droog verband|",
          "$gt0065 = 'ZWART + DROOG: Droog verbinden (geen infectie). Materiaal: alginaat, zilver, jodiumzalf, honing.'"
        ]
      },
      "gt0151": {
        "id": "gt0151", "priority": 8,
        "when": ["$gt0018 == local::at0003|Zwart (necrose)|", "$gt0015 == local::at0002|Vochtig|"],
        "then": [
          "$gt0041 = local::at0071|Necrose-verwijderend verband|",
          "$gt0065 = 'ZWART + VOCHTIG: Necrose verwijderen. Materiaal: alginaat, zilver, jodiumzalf, honing.'"
        ]
      },
      "gt0152": {
        "id": "gt0152", "priority": 7,
        "when": ["$gt0018 == local::at0003|Zwart (necrose)|", "$gt0015 == local::at0003|Nat|"],
        "then": [
          "$gt0041 = local::at0072|Necrose-verwijderend + extra absorberend verband|",
          "$gt0065 = 'ZWART + NAT: Necrose verwijderen + extra absorberend verband.'"
        ]
      },
      "gt0153": {
        "id": "gt0153", "priority": 6,
        "when": ["$gt0018 == local::at0002|Geel (fibrine/slough)|", "$gt0015 == local::at0001|Droog|"],
        "then": [
          "$gt0041 = local::at0073|Vochtig milieu verband|",
          "$gt0065 = 'GEEL + DROOG: Debris verwijderen, vochtig milieu creëren. Materiaal: honing, alginaat, prontosan.'"
        ]
      },
      "gt0154": {
        "id": "gt0154", "priority": 5,
        "when": ["$gt0018 == local::at0002|Geel (fibrine/slough)|", "$gt0015 == local::at0002|Vochtig|"],
        "then": [
          "$gt0041 = local::at0074|Debris-verwijderend + absorberend verband|",
          "$gt0065 = 'GEEL + VOCHTIG: Debris verwijderen, exsudaat absorberen. Bij infectie: uitspoelen + absorberen + infectie bestrijden. Materiaal: honing, alginaat, zilver, jodium, prontosan.'"
        ]
      },
      "gt0155": {
        "id": "gt0155", "priority": 4,
        "when": ["$gt0018 == local::at0002|Geel (fibrine/slough)|", "$gt0015 == local::at0003|Nat|"],
        "then": [
          "$gt0041 = local::at0075|Debris-verwijderend + extra absorberend verband|",
          "$gt0065 = 'GEEL + NAT: Debris verwijderen + extra absorberend verband. Bij infectie: uitspoelen + infectie bestrijden.'"
        ]
      },
      "gt0156": {
        "id": "gt0156", "priority": 3,
        "when": ["$gt0018 == local::at0001|Rood (granulerend)|", "$gt0015 == local::at0001|Droog|"],
        "then": [
          "$gt0041 = local::at0076|Beschermend + groei-stimulerend verband|",
          "$gt0065 = 'ROOD + DROOG: Beschermen + groei stimuleren. Materiaal: siliconen gaas, schuimverband, hydrocolloïd.'"
        ]
      },
      "gt0157": {
        "id": "gt0157", "priority": 2,
        "when": ["$gt0018 == local::at0001|Rood (granulerend)|", "($gt0015 == local::at0002|Vochtig|) || ($gt0015 == local::at0003|Nat|)"],
        "then": [
          "$gt0041 = local::at0077|Vochtig milieu + absorberend verband|",
          "$gt0065 = 'ROOD + VOCHTIG/NAT: Vochtig milieu behouden + absorberen + beschermen. Materiaal: siliconen gaas, schuimverband.'"
        ]
      },
      "gt0160": {
        "id": "gt0160", "priority": 1,
        "when": ["$gt0005 == local::at0002|Diabetes Mellitus aanwezig|"],
        "then": [
          "$gt0046 = 'DM-LAAG GEACTIVEERD. Stap A — Voetinspectie: huidkleur, temp, pulsaties, monofilament, nagels, schoeisel. Stap B — Drukontlasting: hielen vrijleggen, dekenboog, schoeisel adviseren, niet blootsvoets, viltring rondom wond (arts/podo bepaalt), gips/boot alleen op arts-indicatie, verwijzing podo bij standsafwijking. Stap C — Voorlichting: geen voetenbadjes, dagelijks inspecteren (ook tussen de tenen), schoeisel controleren, voeten wassen+drogen, huid invetten (niet tussen tenen), geen warmtebron, katoen sokken (geen naad), medisch pedicure, direct contact bij wondje/roodheid. LET OP: DM = geen pleister direct op de huid! Geen strak windsel! Callus = arts/podo.'"
        ]
      },
      "gt0170": {
        "id": "gt0170", "priority": 0,
        "when": ["$gt0037 > 3,wk", "$gt0038 == local::at0002|Nee, geen verbetering|"],
        "then": [
          "$gt0042 = local::at0032|Vakgroep Wond|",
          "$gt0066 = 'Wond > 2-3 weken zonder verbetering. Triageformulier op intranet. Noord (Zutphen): 0575-469293, Oost (Winterswijk): 0543-537499, West (Doetinchem): 0314-643661, West (Liemers): 0316-242094. wondzorg@sensire.nl, ma-vr 8-17u, weekend 11-13u.'",
          "$gt0043 = local::at0137|Urgent|"
        ]
      }
    }
  },
  "ontology": {
    "term_definitions": {
      "en": {
        "id": "en",
        "terms": {
          "gt0001": { "id": "gt0001", "text": "Sensire General Wound Protocol v2", "description": "CDS for wound assessment and management with correct archetype bindings per Sensire mapping document." },
          "gt0003": { "id": "gt0003", "text": "Wound diagnosis", "description": "From EVALUATION.problem_diagnosis.v1 + CLUSTER.wound_assertion_details." },
          "gt0004": { "id": "gt0004", "text": "Oncological wound", "description": "Exclusion criterion." },
          "gt0005": { "id": "gt0005", "text": "DM status", "description": "Diabetes Mellitus as comorbidity." },
          "gt0007": { "id": "gt0007", "text": "Wound length", "description": "From CLUSTER.exam_wound.v0 (international incubator)." },
          "gt0010": { "id": "gt0010", "text": "Tissue type (TIME-T)", "description": "From exam_wound." },
          "gt0013": { "id": "gt0013", "text": "Wound edge (TIME-E)", "description": "From exam_wound — extended with NL values." },
