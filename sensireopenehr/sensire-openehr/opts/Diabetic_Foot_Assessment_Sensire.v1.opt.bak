        <term_definitions language="en">
            <items id="at0000">
                <description>Assessment of the potential and likelihood of future adverse health effects as determined by identified risk factors.</description>
                <text>Health risk assessment</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identification of the potential future disease, condition or health issue for which the risk is being assessed, by name.</description>
                <text>Health risk</text>
            </items>
            <items id="at0003">
                <description>Evaluation of the health risk.</description>
                <text>Risk assessment</text>
            </items>
            <items id="at0004">
                <description>Justification for this risk assessment.</description>
                <text>Rationale</text>
            </items>
            <items id="at0010">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0011">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0012">
                <description>Identification of the path to the archetype or data node for the evidence of risk.</description>
                <text>Link to evidence</text>
            </items>
            <items id="at0013">
                <description>Identification of the risk factor, by name.</description>
                <text>Risk factor</text>
            </items>
            <items id="at0014">
                <description>Narrative description about the risk factor.</description>
                <text>Description</text>
            </items>
            <items id="at0015">
                <description>Additional narrative about the risk assessment not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0016">
                <description>Details about each possible risk factor.</description>
                <text>Risk factors</text>
            </items>
            <items id="at0017">
                <description>Presence of the risk factor.</description>
                <text>Presence</text>
            </items>
            <items id="at0018">
                <description>The risk factor has been identified for this individual.</description>
                <text>Present</text>
            </items>
            <items id="at0019">
                <description>The risk factor has not been identified for this individual.</description>
                <text>Absent</text>
            </items>
            <items id="at0020">
                <description>Record of whether the risk assessment is a relative or absolute.</description>
                <text>Assessment type</text>
            </items>
            <items id="at0021">
                <description>Ratio of probability of a health event or condition occurring compared to a population with similar characteristics eg same age and sex.</description>
                <text>Relative risk</text>
            </items>
            <items id="at0022">
                <description>Ratio of probability of a health event or condition occurring compared to the population as a whole.</description>
                <text>Absolute risk</text>
            </items>
            <items id="at0023">
                <description>The time period during which the predicted health risk is relevant.</description>
                <text>Time period</text>
            </items>
            <items id="at0024">
                <description>The date this health risk assessment was last updated.</description>
                <text>Last updated</text>
            </items>
            <items id="at0025">
                <description>Identification of the algorithm or guideline used to make the assessment of risk.</description>
                <text>Assessment method</text>
            </items>
            <items id="at0026">
                <description>It is not possible to determine if the risk factor is present or absent.</description>
                <text>Indeterminate</text>
            </items>
            <items id="at0027">
                <description>Structured detail about other aspects of the risk factor assessment.</description>
                <text>Detail</text>
            </items>
            <items id="at0028">
                <description>The risk factor has been identified as present, but then subsequently been mitigated by treatment or investigation.</description>
                <text>Mitigated</text>
            </items>
            <items id="at0029">
                <description>The date/time that the risk factor was identified.</description>
                <text>Date identified</text>
            </items>
            <items id="at0030">
                <description>Additional narrative about the risk factor not captured in other fields.</description>
                <text>Comment</text>
            </items>
        </term_definitions>
        <term_definitions language="it">
            <items id="at0000">
                <description>Valutazione del potenziale e della probabilità di futuri effetti negativi per la salute, determinati da fattori di rischio identificati.</description>
                <text>Valutazione del rischio sanitario</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>structure</text>
            </items>
            <items id="at0002">
                <description>Identificazione della potenziale futura malattia, condizione o problema sanitario per il quale si sta valutando il rischio, per nome.</description>
                <text>Rischio sanitario</text>
            </items>
            <items id="at0003">
                <description>Valutazione del rischio per la salute.</description>
                <text>Valutazione del rischio</text>
            </items>
            <items id="at0004">
                <description>Giustificazione di questa valutazione del rischio.</description>
                <text>Motivazione</text>
            </items>
            <items id="at0010">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0011">
                <description>Informazioni aggiuntive necessarie per acquisire contenuti locali o per allinearsi con altri modelli/formalismi di riferimento.</description>
                <text>Extension</text>
            </items>
            <items id="at0012">
                <description>Identificazione del percorso dell'archetipo o del nodo dati per l'evidenza del rischio.</description>
                <text>Collegamento alle prove</text>
            </items>
            <items id="at0013">
                <description>Identificazione del fattore di rischio, per nome.</description>
                <text>Fattore di rischio</text>
            </items>
            <items id="at0014">
                <description>Descrizione narrativa del fattore di rischio.</description>
                <text>Descrizione</text>
            </items>
            <items id="at0015">
                <description>Narrativa aggiuntiva sulla valutazione del rischio non catturata in altri campi.</description>
                <text>Commento</text>
            </items>
            <items id="at0016">
                <description>Dettagliati su ogni possibile fattore di rischio.</description>
                <text>Fattori di rischio</text>
            </items>
            <items id="at0017">
                <description>Presenza del fattore di rischio.</description>
                <text>Presenza</text>
            </items>
            <items id="at0018">
                <description>Il fattore di rischio è stato identificato per questo individuo.</description>
                <text>Presente</text>
            </items>
            <items id="at0019">
                <description>Il fattore di rischio non è stato identificato per questo individuo.</description>
                <text>Assente</text>
            </items>
            <items id="at0020">
                <description>Raccordare se la valutazione del rischio è relativa o assoluta.</description>
                <text>Tipo di valutazione</text>
            </items>
            <items id="at0021">
                <description>Rapporto di probabilità che si verifichi un evento o una condizione di salute rispetto ad una popolazione con caratteristiche simili, ad esempio la stessa età e lo stesso sesso.</description>
                <text>Rischio relativo</text>
            </items>
            <items id="at0022">
                <description>Rapporto di probabilità che un evento o una condizione di salute si verifichi rispetto alla popolazione nel suo complesso.</description>
                <text>Rischio assoluto</text>
            </items>
            <items id="at0023">
                <description>Il periodo di tempo durante il quale il rischio previsto per la salute è rilevante.</description>
                <text>Periodo di tempo</text>
            </items>
            <items id="at0024">
                <description>La data dell'ultimo aggiornamento di questa valutazione del rischio per la salute.</description>
                <text>Ultimo aggiornamento</text>
            </items>
            <items id="at0025">
                <description>Identificazione dell'algoritmo o della linea guida utilizzata per effettuare la valutazione del rischio.</description>
                <text>Metodo di valutazione</text>
            </items>
            <items id="at0026">
                <description>Non è possibile determinare se il fattore di rischio è presente o assente.</description>
                <text>Indeterminato</text>
            </items>
            <items id="at0027">
                <description>Dettaglio strutturato su altri aspetti della valutazione dei fattori di rischio.</description>
                <text>Dettaglio</text>
            </items>
            <items id="at0028">
                <description>Il fattore di rischio è stato identificato come presente, ma successivamente è stato mitigato da un trattamento o da un'indagine.</description>
                <text>Mitigato</text>
            </items>
            <items id="at0029">
                <description>La data/ora in cui è stato individuato il fattore di rischio.</description>
                <text>Data identificazione rischio</text>
            </items>
            <items id="at0030">
                <description>Narrativa aggiuntiva sul fattore di rischio non catturato in altri campi.</description>
                <text>Commento</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Avaluació del potencial i probabilitat de futurs efectes adversos per a la salut segons els factors de risc identificats.</description>
                <text>Avaluació del risc sanitari</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>estructura</text>
            </items>
            <items id="at0002">
                <description>Identificació de la possible malaltia futura, condició o problema de salut per a la qual s'està avaluant el risc, pel seu nom.</description>
                <text>Risc per la salut</text>
            </items>
            <items id="at0003">
                <description>Avaluació del risc per a la salut.</description>
                <text>Avaluació del risc</text>
            </items>
            <items id="at0004">
                <description>Justificació per a aquesta avaluació de riscos.</description>
                <text>Raó del risc</text>
            </items>
            <items id="at0010">
                <description>@ internal @</description>
                <text>Abre</text>
            </items>
            <items id="at0011">
                <description>Informació addicional requerida per capturar contingut local o per alinear-se amb altres models de referència/formalismes.</description>
                <text>Extensió</text>
            </items>
            <items id="at0012">
                <description>Identificació de l'arquetip o node de dades per a l'evidència de risc.</description>
                <text>Enllaç a la prova</text>
            </items>
            <items id="at0013">
                <description>Identificació del factor de risc, pel seu nom.</description>
                <text>Factor de risc</text>
            </items>
            <items id="at0014">
                <description>Descripció sobre el factor de risc.</description>
                <text>Descripció</text>
            </items>
            <items id="at0015">
                <description>Informació addicional sobre l'avaluació del risc no capturada en altres camps.</description>
                <text>Comentari</text>
            </items>
            <items id="at0016">
                <description>Detalls sobre cada possible factor de risc.</description>
                <text>Factors de risc</text>
            </items>
            <items id="at0017">
                <description>Presència del factor de risc.</description>
                <text>Presència</text>
            </items>
            <items id="at0018">
                <description>S'ha identificat el factor de risc per a aquest pacient.</description>
                <text>Present</text>
            </items>
            <items id="at0019">
                <description>No s'ha identificat el factor de risc per a aquest pacient.</description>
                <text>Absent</text>
            </items>
            <items id="at0020">
                <description>Registre de si l'avaluació de riscos és relativa o absoluta.</description>
                <text>Tipus d'avaluació</text>
            </items>
            <items id="at0021">
                <description>Ràtio de probabilitat que es produeixi un esdeveniment o condició de salut en comparació amb una població amb característiques similars, per exemple, la mateixa edat i sexe.</description>
                <text>Risc relatiu</text>
            </items>
            <items id="at0022">
                <description>Ràtio de probabilitat que es produeixi un esdeveniment o condició de salut en comparació amb la població en el seu conjunt.</description>
                <text>Risc absolut</text>
            </items>
            <items id="at0023">
                <description>El període durant el qual el risc de salut predit és rellevant.</description>
                <text>Període de temps</text>
            </items>
            <items id="at0024">
                <description>La data en què es va actualitzar per última vegada aquesta avaluació de riscos per a la salut.</description>
                <text>Darrera actualització</text>
            </items>
            <items id="at0025">
                <description>Identificació de l'algoritme o la guia utilitzada per fer l'avaluació del risc.</description>
                <text>Mètode d'avaluació</text>
            </items>
            <items id="at0026">
                <description>No és possible determinar si el factor de risc està present o absent.</description>
                <text>Indeterminat</text>
            </items>
            <items id="at0027">
                <description>Detall estructurat sobre altres aspectes de l'avaluació dels factors de risc.</description>
                <text>Detalls</text>
            </items>
            <items id="at0028">
                <description>El factor de risc s'ha identificat com a present, però posteriorment s'ha mitigat mitjançant tractament o investigació.</description>
                <text>Mitigat</text>
            </items>
            <items id="at0029">
                <description>La data/hora en què es va identificar el factor de risc.</description>
                <text>Data d'identificació</text>
            </items>
            <items id="at0030">
                <description>Narrativa addicional sobre el factor de risc no recollida en altres camps.</description>
                <text>Comentari</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Evaluación del potencial y probabilidad de futuros efectos adversos para la salud en función de los factores de riesgo identificados.</description>
                <text>Evaluación del riesgo para la salud</text>
            </items>
            <items id="at0001">
                <description>@internal@</description>
                <text>estructura</text>
            </items>
            <items id="at0002">
                <description>Identificación de la posible enfermedad futura, condición o problema de salud para la que se está evaluando el riesgo, por su nombre.</description>
