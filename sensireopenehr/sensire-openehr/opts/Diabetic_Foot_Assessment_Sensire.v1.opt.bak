                <text>Erweiterung</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Vårdtagarens subjektiva sjukdomshistoria som registrerats direkt av vårdgivaren, eller rapporterats till en kliniker av vårdtagaren eller vårdgivaren.</description>
                <text>Sjukdomshistoria</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Ospecificerad standardhändelse vid en tidpunkt eller inom ett tidsintervall som explicit kan definieras i en mall eller genereras automatiskt av vissa IT-system.</description>
                <text>Ospecificerad händelse</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
