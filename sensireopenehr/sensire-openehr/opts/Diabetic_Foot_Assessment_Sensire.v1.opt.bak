        <term_definitions language="en">
            <items id="at0000">
                <description>Order or instruction for the creation and sequence of activities to achieve a specified management goal or treatment outcome, carried out by health professionals and/or the subject.</description>
                <text>Care plan request</text>
            </items>
            <items id="at0001">
                <description>Current Activity.</description>
                <text>Activity</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
