        <term_definitions language="sl">
            <items id="at0000">
                <description>Za dokumentiranje ugotovitev/znakov fizikalnega pregleda subjekta</description>
                <text>Ugotovitve fizičnega pregleda</text>
            </items>
            <items id="at0001">
                <description>*@ internal @(en)</description>
                <text>*Event Series(en)</text>
            </items>
            <items id="at0002">
                <description>Privzeta, nespecificirana točka v času ali intervalni dogodek, ki je lahko eksplicitno definiran v predlogi ali ob izvajanju.</description>
                <text>Dogodek</text>
            </items>
            <items id="at0003">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0004">
                <description>Opis splošnih ugotovitev opaženih med fizičnim pregledom pacienta.</description>
                <text>Opis</text>
            </items>
            <items id="at0005">
                <description>Strukturirane podrobnosti fizičnega pregleda.</description>
                <text>Podrobnosti pregleda</text>
            </items>
            <items id="at0006">
                <description>Posamezna beseda, besedna zveza ali kratek opis, ki predstavlja klinični pomen in pomembnost ugotovitev fizičnega pregleda.</description>
                <text>Interpretacija</text>
            </items>
            <items id="at0007">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0008">
                <description>Opis morebitnih naključnih dejavnikov, ki so lahko prispevali k ugotovitvam fizičnega pregleda.</description>
                <text>Moteči dejavniki</text>
            </items>
            <items id="at0009">
                <description>*@ internal @(en)</description>
                <text>*Tree(en)</text>
            </items>
            <items id="at0010">
                <description>Podrobnosti o katerikoli napravi, uporabljeni med fizičnim pregledom.</description>
                <text>Podrobnosti naprave</text>
            </items>
            <items id="at0011">
                <description>Dodatni zapisi splošnih ugotovitev fizičnega pregleda, ki niso zajete v drugih poljih.</description>
                <text>Komentar</text>
            </items>
            <items id="at0012">
                <description>Dodatne informacije, potrebne za zajemanje lokalne vsebine ali za uskladitev z drugimi referenčnimi modeli/formalizmi.</description>
                <text>Razširitev</text>
            </items>
            <items id="at0013">
                <description>Položaj telesa preiskovanca med pregledom.</description>
                <text>Položaj</text>
            </items>
        </term_definitions>
        <term_definitions language="en">
            <items id="at0000">
                <description>Findings observed during the physical examination of a subject of care.</description>
                <text>Physical examination findings</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.</description>
                <text>Any event</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Narrative description of the overall findings observed during a physical examination of a patient.</description>
                <text>Description</text>
            </items>
            <items id="at0005">
                <description>Structured details of the physical examination.</description>
                <text>Examination detail</text>
            </items>
            <items id="at0006">
                <description>Single word, phrase or brief description which represents the clinical meaning and significance of the physical examination findings.</description>
                <text>Interpretation</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Description of any incidental factors that may have contributed to the physical examination findings.</description>
                <text>Confounding factors</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Details about any device used during the physical examination.</description>
                <text>Device Details</text>
            </items>
            <items id="at0011">
                <description>Additional narrative about the overall physical examination findings not captured in other fields.</description>
                <text>Comment</text>
            </items>
            <items id="at0012">
                <description>Additional information required to capture local content or to align with other reference models/formalisms.</description>
                <text>Extension</text>
            </items>
            <items id="at0013">
                <description>The body position of the subject during the examination.</description>
                <text>Position</text>
            </items>
        </term_definitions>
        <term_definitions language="zh-cn">
            <items id="at0000">
                <description>对于特定主体对象进行体格检查过程中所获得的发现。</description>
                <text>体格检查发现</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>默认值，未加具体说明的，而可以在特定模板中或在运行时加以明确定义的时刻（时间点）型或时段（时间段、时间区间）型事件。</description>
                <text>任何事件</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>关于特定患者的体格检查过程中所观察到的全部发现的叙述型描述。</description>
                <text>描述</text>
            </items>
            <items id="at0005">
                <description>体格检查的结构化细节。</description>
                <text>检查细节</text>
            </items>
            <items id="at0006">
                <description>用于表示体格检查发现的临床含义和意义的单个词语、短语或简要描述。</description>
                <text>解释</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>关于可能对体格检查发现做出了贡献的任何偶然因素的描述。</description>
                <text>干扰因素</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>关于体格检查过程中所使用的任何装置的细节。</description>
                <text>装置细节</text>
            </items>
            <items id="at0011">
                <description>其他字段之中并未采集的关于全部体格检查发现的叙述型注释。</description>
                <text>注释</text>
            </items>
            <items id="at0012">
                <description>采集本地内容或者与其他参考模型/形式化体系进行映射时所需的额外信息。</description>
                <text>扩展</text>
            </items>
            <items id="at0013">
                <description>*The body position of the subject during the examination.(en)</description>
                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="es">
            <items id="at0000">
                <description>Hallazgos observados durante la examinación física del paciente</description>
                <text>Hallazgos de la examinación física</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</description>
                <text>*Any event(en)</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Descripción narrativa del total de los hallazgos durante la examinación física del paciente</description>
                <text>Descripción</text>
            </items>
            <items id="at0005">
                <description>Detalles estructurados de la examinación física</description>
                <text>Detalles de la examinación</text>
            </items>
            <items id="at0006">
                <description>Descripción corta que representa el significado clínico de los hallazgos</description>
                <text>Interpretación</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descripción de los factores que pueden haber obstruido o dificultado la examinación física y los hallazgos</description>
                <text>Factores de confusión</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalles sobre cualquier dispositivo utilizado durante la examinación física</description>
                <text>Detalles del dispositivo</text>
            </items>
            <items id="at0011">
                <description>Información narrativa adicional sobre los hallazgos durante la examinación física</description>
                <text>Comentario</text>
            </items>
            <items id="at0012">
                <description>Información adicional requerida para registrar contenido local o alinear con otros modelos o formalismos</description>
                <text>Extensión</text>
            </items>
            <items id="at0013">
                <description>*The body position of the subject during the examination.(en)</description>
                <text>*Position(en)</text>
            </items>
        </term_definitions>
        <term_definitions language="ca">
            <items id="at0000">
                <description>Troballes observades durant l'examen físic del pacient.</description>
                <text>Troballes de l'exploració física</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Esdeveniment predeterminat, en un interval de temps o moment no específic, que es pot definir de forma expressa en una plantilla o en temps d'execució.</description>
                <text>Qualsevol esdeveniment</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>Descripció narrativa del total de les troballes durant l'examen físic del pacient.</description>
                <text>Descripció</text>
            </items>
            <items id="at0005">
                <description>Detalls estructurats de l'examen físic.</description>
                <text>Detalls de l'examen</text>
            </items>
            <items id="at0006">
                <description>Una sola paraula, frase o descripció breu que englobi el significat clínic i la importància de les troballes de l'examen físic.</description>
                <text>Interpretació</text>
            </items>
            <items id="at0007">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0008">
                <description>Descripció dels factors que puguin haver obstruït o dificultat les troballes de l'examen físic.</description>
                <text>Factors de confusió</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Detalls sobre qualsevol dispositiu utilitzat durant l'examen físic.</description>
                <text>Detalls del dispositiu</text>
            </items>
            <items id="at0011">
                <description>Informació narrativa addicional sobre les troballes durant l'examen físic no registrats a altres camps.</description>
                <text>Comentaris</text>
            </items>
            <items id="at0012">
                <description>Informació addicional requerida per registrar contingut local o alinear amb altres models o formalismes.</description>
                <text>Ampliació</text>
            </items>
            <items id="at0013">
                <description>Posició del pacient durant l'examen.</description>
                <text>Posició</text>
            </items>
        </term_definitions>
    </component_terminologies>
    <component_terminologies archetype_id="openEHR-EHR-OBSERVATION.laboratory_test_result.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Das Ergebnis - einschließlich der Befunde und der Interpretation des Labors - einer Untersuchung, die an Proben durchgeführt wurde, die von einer Einzelperson stammen oder mit dieser Person zusammenhängen.</description>
                <text>Laborergebnis</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Jeder Zeitpunkt oder jedes Intervall, das in einem Template oder zur Laufzeit definiert werden kann.</description>
                <text>Jedes Ereignis</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0005">
                <description>Name der Laboruntersuchung, die an der/den Probe(n) durchgeführt wurde.</description>
                <text>Labortest-Bezeichnung</text>
            </items>
            <items id="at0017">
                <description>Angaben zu dem Labor, das die Anfrage erhalten hat und die Hauptverantwortung für die Verwaltung der Berichterstattung über den Test trägt, auch wenn andere Labore bestimmte Aspekte ausführen.</description>
                <text>Labor, welches den Untersuchungsauftrag annimmt</text>
            </items>
            <items id="at0035">
                <description>Details über weitere Kliniker oder Organisationen, die eine Kopie der Analyseergebnisse benötigen.</description>
                <text>Verteilerliste</text>
            </items>
            <items id="at0037">
                <description>Das Testergebnis ist als ein Teilergebnis (z.B. Initial, vorübergehend oder vorläufig) bestätigt: Daten im Testergebnis können unvollständig oder nicht verifiziert sein.</description>
                <text>Teilweise</text>
            </items>
            <items id="at0038">
                <description>Das Testergebnis ist vollständig und durch eine autorisierte Person bestätigt.</description>
                <text>Final</text>
            </items>
            <items id="at0040">
                <description>Das Ergebnis wurde nach der Finalisierung modifiziert und ist vollständig von dem verantwortlichen Untersucher verifiziert. Die Ergebnisdaten wurden geändert.</description>
                <text>Abgeändert</text>
            </items>
            <items id="at0057">
                <description>Beschreibung der wichtigsten Ergebnisse.</description>
                <text>Schlussfolgerung</text>
            </items>
            <items id="at0062">
                <description>Lokale Auftrags-ID des anfordernden/einsendenden Systems.</description>
                <text>Auftrags-ID des anfordernden/einsendenden Systems</text>
            </items>
            <items id="at0063">
                <description>Lokale Auftrags-ID, die vom auftragsempfangendem System, gewöhnlich dem Laborinformationssystem (LIS) zugewiesen wird.</description>
                <text>Auftrags-ID (Empfänger)</text>
            </items>
            <items id="at0065">
                <description>Angaben über die Beschaffenheit der analysierten Probe.</description>
                <text>Probendetail</text>
            </items>
            <items id="at0068">
                <description>Eine lokale Kennung, die vom empfangenden Laborinformationssystem (LIS) vergeben wird, um den Testvorgang zu verfolgen.</description>
                <text>Laborinterne Kennzeichnung</text>
            </items>
            <items id="at0073">
                <description>Der Status des gesamten Laborprüfergebnisses.</description>
                <text>Gesamtteststatus</text>
            </items>
            <items id="at0074">
                <description>Das Ergebnis ist nicht verfügbar, weil der Test nicht gestartet oder nicht abgeschlossen wurde (manchmal auch als "gescheitert" bezeichnet).</description>
                <text>Abgebrochen</text>
            </items>
            <items id="at0075">
                <description>Zeitpunkt an dem das Ergebnis für den oben genannten "Gesamtteststatus" ausgegeben wurde.</description>
                <text>Zeitstempel des gesamten Teststatus</text>
            </items>
            <items id="at0077">
                <description>Die diagnostische Organisationseinheit oder die Labordisziplin, die für das Laborergebnis verantwortlich ist.</description>
                <text>Diagnostische Organisationseinheit</text>
            </items>
            <items id="at0090">
                <description>Details über den Kliniker oder die Abteilung, die das Labortestergebnis angefordert hat.</description>
                <text>Einsender</text>
            </items>
            <items id="at0094">
                <description>Details zur Testanforderung.</description>
                <text>Details der Testanforderung</text>
            </items>
            <items id="at0097">
                <description>Ergebnisse der durchgeführten Untersuchungen an der/den Probe(n).</description>
                <text>Testergebnis</text>
            </items>
            <items id="at0098">
                <description>Kurze Beschreibung der klinischen Bedeutung und der Aussagekraft des Laborergebnisses.</description>
                <text>Testdiagnose</text>
            </items>
            <items id="at0100">
                <description>Beschreibung der klinischen Informationen, die zum Zeitpunkt der Auswertung der Ergebnisse verfügbar sind.</description>
                <text>Vorhandene klinische Information</text>
            </items>
            <items id="at0101">
                <description>Weitere Informationen über das Laborergebnis, welche bisher nicht in den anderen Feldern erfasst wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0106">
                <description>Name des ursprünglich angeforderten Tests.</description>
                <text>Originaler Name der angeforderten Testung</text>
            </items>
            <items id="at0107">
                <description>Der Labortest wurde im Laborinformationssystem registriert, aber es ist derzeit noch nichts verfügbar.</description>
                <text>Registriert</text>
            </items>
            <items id="at0110">
                <description>Strukturierte Details über die beim Labortest verwendete Methodik, das Gerät oder die Auswertung.</description>
                <text>Test Details</text>
            </items>
            <items id="at0111">
                <description>Dies gibt an, ob der Test direkt am Point-of-Care (POCT) durchgeführt wurde, im Gegensatz zu einem formalen Ergebnis eines Labors oder einer anderen Dienstleistungsorganisation.</description>
                <text>Point-of-care Test</text>
            </items>
            <items id="at0112">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0113">
                <description>Probleme oder Umstände, die sich auf die genaue Interpretation der Messung oder des Testergebnisses auswirken.</description>
                <text>Störfaktoren</text>
            </items>
            <items id="at0114">
                <description>Einzelheiten zu Problemen oder Umständen, die sich auf die genaue Interpretation der Messung oder des Prüfergebnisses auswirken.</description>
                <text>Strukturierte Erfassung der Störfaktoren</text>
            </items>
            <items id="at0115">
                <description>Das Ergebnis wurde nach der Finalisierung modifiziert und ist vollständig vom verantwortlichen Untersucher verifiziert. Dies ist eine Unterkategorie von "Abgeändert".</description>
                <text>Korrigiert</text>
            </items>
            <items id="at0116">
                <description>Das Testergebnis wurde nach der vorherigen Endfreigabe zurückgezogen.</description>
                <text>Irrtümlich eingegeben</text>
            </items>
            <items id="at0117">
                <description>Weitere Informationen, die erforderlich sind, um lokale Inhalte abzubilden oder das Modell an andere Referenzmodelle anzupassen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0118">
                <description>Bild, Video oder Diagramm zur Visualisierung des Testergebnisses.</description>
                <text>Multimedia-Darstellung</text>
            </items>
            <items id="at0119">
                <description>Nach der endgültigen Fassung wurde der Bericht durch Hinzufügen neuer Inhalte aktualisiert. Der bestehende Inhalt bleibt unverändert. Dies ist eine Unterkategorie von "Abgeändert".</description>
                <text>Hinzugefügt</text>
            </items>
            <items id="at0120">
                <description>Es sind erste, bestätigte Ergebnisse verfügbar, aber nicht alle Ergebnisse sind final. Dies ist eine Unterkategorie von "Teilweise".</description>
                <text>Vorläufig</text>
            </items>
            <items id="at0121">
                <description>Die Beschreibung der Methode, mit dem der Test durchgeführt wurde.</description>
                <text>Testmethode</text>
            </items>
            <items id="at0122">
                <description>Eine strukturierte oder komplexe Diagnose für die Laboruntersuchung.</description>
                <text>Strukturierte Testdiagnostik</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Resultatet av en undersökning, inklusive fynd och laboratoriets tolkning, utförd på provmaterial från en individ eller relaterad till individen. Exempel på provmaterial relaterat till individen kan vara fostervattenprov där provet tas från mammans kropp men provet avser fostret.</description>
                <text>Laboratorieresultat</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>Ospecificerad standardhändelse vid en tidpunkt eller inom ett tidsintervall som explicit kan definieras i en mall eller genereras automatiskt av vissa IT-system.</description>
                <text>Ospecificerad händelse</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0005">
                <description>Namnet på den laboratorieundersökning eller -analys som utförts på provmaterialet.</description>
                <text>Undersökningsnamn</text>
            </items>
            <items id="at0017">
                <description>Detaljer om det laboratorium som har mottagit beställningen och som har det övergripande ansvaret för att hantera rapporteringen av undersökningen, även om andra laboratorier utför specifika delar av beställningen.</description>
                <text>Ansvarigt laboratorium</text>
            </items>
            <items id="at0035">
                <description>Detaljer om ytterligare kliniker eller organisationer som behöver en kopia av undersökningsresultatet.</description>
                <text>Distributionslista</text>
            </items>
            <items id="at0037">
                <description>Detta är ett partiellt undersökningsresultat, dvs. initialt, interim eller preliminärt. Resultatdata kan vara ofullständiga eller obekräftade.</description>
                <text>Partiell</text>
            </items>
            <items id="at0038">
                <description>Undersökningsresultatet är fullständigt och verifierat av ansvarig person alternativt autoverifierat maskinellt.</description>
                <text>Slutgiltig</text>
            </items>
            <items id="at0040">
                <description>Det slutgiltiga undersökningsresultatet har reviderats. Denna status har underkategorierna "Rättad" och "Utökad".</description>
                <text>Reviderad</text>
            </items>
            <items id="at0057">
                <description>Berättande textuell beskrivning av de viktigaste resultaten.</description>
                <text>Tolkning av resultat</text>
            </items>
            <items id="at0062">
                <description>Den lokala identifierare som tilldelats av det begärande kliniska systemet.</description>
                <text>Beställarens beställningsidentifierare</text>
            </items>
            <items id="at0063">
                <description>Den lokala identifierare som tilldelats beställningen av ordermottagningssystemet, vanligtvis av laboratorieinformationssystemet (LIS).</description>
                <text>Mottagarens beställningsidenitifierare</text>
            </items>
            <items id="at0065">
                <description>Detaljer om det provmaterial som har analyserats.</description>
                <text>Detaljer om provmaterialet</text>
            </items>
            <items id="at0068">
                <description>En lokal identifierare som tilldelats av det mottagande laboratorieinformationssystemet (LIS) för att spåra analysprocessen.</description>
                <text>Laboratoriets interna identifierare</text>
            </items>
            <items id="at0073">
                <description>Status för undersökningsresultaten som helhet.</description>
                <text>Status undersökningsresultat</text>
            </items>
            <items id="at0074">
                <description>Resultatet är inte tillgängligt eftersom undersökningen inte har startats eller inte slutförts.</description>
                <text>Avbruten</text>
            </items>
            <items id="at0075">
                <description>Datum och tid för utfärdandet av övergripande resultatstatus.</description>
                <text>Tidpunkt för status undersökningsresultat</text>
            </items>
            <items id="at0077">
                <description>Den diagnostiska organisationsenhet, laboratoriedisciplin eller underdisciplin som ansvarar för laboratorieresultatet.&#13;
</description>
                <text>Laboratoriedisciplin</text>
            </items>
            <items id="at0090">
                <description>Uppgifter om den kliniker eller organisation som beställt undersökningen.</description>
                <text>Beställare</text>
            </items>
            <items id="at0094">
                <description>Detaljer om beställningen.</description>
                <text>Beställningsdetaljer</text>
            </items>
            <items id="at0097">
                <description>Resultatet av den undersökning eller analys som utförts på provmaterialet.</description>
                <text>Undersökningsresultat</text>
            </items>
            <items id="at0098">
                <description>Ett ord, en fras eller en kort beskrivning som representerar den kliniska betydelsen eller konsekvensen av laboratorietestresultatet.&#13;
</description>
                <text>Undersökningsdiagnos</text>
            </items>
            <items id="at0100">
                <description>Beskrivning av den kliniska information som finns tillgänglig vid tolkningen av resultaten.</description>
                <text>Tillgänglig klinisk information</text>
            </items>
            <items id="at0101">
                <description>Ytterligare textuell beskrivning som inte registrerats i andra fält.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0106">
                <description>Namn på den ursprungligen beställda undersökningen eller analysen.</description>
                <text>Ursprungligt undersökningsnamn</text>
            </items>
            <items id="at0107">
                <description>Undersökningen är registrerad i laboratorieinformationssystemet, men resultatet finns för närvarande inte.&#13;
&#13;
</description>
                <text>Registrerad</text>
            </items>
            <items id="at0110">
                <description>Strukturerade detaljer om undersökningsmetoden, utrustningen eller tolkningen.</description>
                <text>Detaljer om undersökningsmetod</text>
            </items>
            <items id="at0111">
                <description>Indikerar om analysen utfördes som en patientnära analys (PNA), det vill säga på vårdenhet, istället för en mer formell laboratorietjänst.</description>
                <text>Patientnära analys</text>
            </items>
            <items id="at0112">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0113">
                <description>Villkor eller omständigheter som påverkar tolkningen av laboratorieresultatet.</description>
                <text>Möjliga felkällor</text>
            </items>
            <items id="at0114">
                <description>Mer information om problem eller omständigheter som kan påverka tolkningen av mätningen eller testresultatet.</description>
                <text>Strukturerade möjliga felkällor</text>
            </items>
            <items id="at0115">
                <description>Det slutgiltiga undersökningsresultatet har rättats. Detta är en underkategori av "Reviderad".</description>
                <text>Rättad</text>
            </items>
            <items id="at0116">
                <description>Undersökningsresultatet har dragits tillbaka efter att ha varit i status "Slutgiltig".</description>
                <text>Felregistrerad</text>
            </items>
            <items id="at0117">
                <description>Ytterligare information som krävs för att registrera lokalt definierat innehåll eller för anpassning till andra referensmodeller.&#13;
</description>
                <text>Ytterligare information</text>
            </items>
            <items id="at0118">
                <description>Digital bild, video eller diagram som representerar undersökningsresultatet.</description>
                <text>Multimedia</text>
            </items>
            <items id="at0119">
                <description>Det slutgiltiga undersökningsresultatet har ändrats genom att nytt innehåll har inkluderats. Det befintliga innehållet är oförändrat. Detta är en underkategori av "Reviderad".</description>
                <text>Utökat</text>
            </items>
            <items id="at0120">
                <description>Verifierade tidiga resultat är tillgängliga, men inte alla resultat är slutgiltiga. Detta är en underkategori av status "Partiell".</description>
                <text>Preliminär</text>
            </items>
            <items id="at0121">
                <description>Beskrivning av den metod som använts för att utföra undersökningen eller analysen.</description>
                <text>Undersökningsmetod</text>
            </items>
            <items id="at0122">
                <description>En strukturerad eller komplex diagnos för laboratorieundersökningen.</description>
                <text>Strukturerad undersökningsdiagnos</text>
            </items>
        </term_definitions>
        <term_definitions language="fi">
            <items id="at0000">
                <description>*The result, including findings and the laboratory's interpretation, of an investigation performed on specimens collected from an individual or related to that individual.(en)</description>
                <text>Laboratoriokokeen tulos</text>
            </items>
            <items id="at0001">
                <description>@ internal @</description>
                <text>Event Series</text>
            </items>
            <items id="at0002">
                <description>*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)</description>
                <text>Mikä tahansa tapahtuma</text>
            </items>
            <items id="at0003">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0004">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0005">
                <description>*Name of the laboratory investigation performed on the specimen(s).(en)</description>
                <text>Tutkimusnimi</text>
            </items>
            <items id="at0017">
                <description>*Details of the laboratory which received the request and has overall responsibility to manage reporting of the test, even if other labs perform specific aspects.(en)</description>
                <text>*Receiving laboratory(en)</text>
            </items>
            <items id="at0035">
                <description>*Details of additional clinicians or organisations who require a copy of the test result.(en)</description>
                <text>*Distribution list(en)</text>
            </items>
            <items id="at0037">
                <description>*This is a partial (e.g. initial, interim or preliminary) Test Result: data in the Test Result may be incomplete or unverified.(en)</description>
                <text>*Partial(en)</text>
            </items>
            <items id="at0038">
                <description>*The Test result is complete and verified by an authorised person.(en)</description>
                <text>*Final(en)</text>
            </items>
            <items id="at0040">
                <description>*The result has been modified subsequent to being Final, and is complete and verified by the responsible pathologist, and result data has been changed.(en)</description>
                <text>*Amended(en)</text>
            </items>
            <items id="at0057">
                <description>*Narrative description of the key findings.(en)</description>
                <text>*Conclusion(en)</text>
            </items>
            <items id="at0062">
                <description>*The local identifier assigned by the requesting clinical system.(en)</description>
                <text>*Requester order identifier(en)</text>
            </items>
            <items id="at0063">
                <description>*The local identifier assigned to the test order by the order filler, usually by the Laboratory Information System (LIS).(en)</description>
                <text>*Receiver order identifier(en)</text>
            </items>
            <items id="at0065">
                <description>*Details about the physical substance that has been analysed.(en)</description>
                <text>*Specimen detail(en)</text>
            </items>
            <items id="at0068">
                <description>*A local identifier assigned by the receiving Laboratory Information System (LIS) to track the test process.(en)</description>
                <text>*Laboratory internal identifier(en)</text>
            </items>
            <items id="at0073">
                <description>*The status of the laboratory test result as a whole.(en)</description>
                <text>*Overall test status(en)</text>
            </items>
            <items id="at0074">
                <description>*The result is unavailable because the test was not started or not completed (also sometimes called 'aborted').(en)</description>
                <text>*Cancelled(en)</text>
            </items>
            <items id="at0075">
                <description>*The date and/or time that ‘Overall test status’ was issued.(en)</description>
                <text>*Overall test status timestamp(en)</text>
            </items>
            <items id="at0077">
                <description>*The diagnostic service or discipline that is responsible for the laboratory test result.(en)</description>
                <text>*Diagnostic service category(en)</text>
            </items>
            <items id="at0090">
