    <component_terminologies archetype_id="openEHR-EHR-INSTRUCTION.service_request.v1" original_language="en">
        <concept_code>at0000</concept_code>
        <term_definitions language="de">
            <items id="at0000">
                <description>Antrag auf eine gesundheitsbezogene Dienstleistung oder Aktivität, die von einem Kliniker, einer Klinik oder einer Einrichtung erbracht werden soll.</description>
                <text>Dienstleistung</text>
            </items>
            <items id="at0001">
                <description>Aktuelle Aktivität</description>
                <text>Aktuelle Aktivität</text>
            </items>
            <items id="at0008">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Lokale Auftrags-ID des anfordernden/einsendenden Systems.</description>
                <text>Auftrags-ID des anfordernden/einsendenden Systems</text>
            </items>
            <items id="at0011">
                <description>Lokale Auftrags-ID, die der Anforderung durch den Kliniker oder die Organisation, die die Leistungsanforderung erhält, zugewiesen wurde.</description>
                <text>Auftrags-ID (Empfänger)</text>
            </items>
            <items id="at0040">
                <description>Datum/Uhrzeit oder Beschreibung des Zeitplans für die Erbringung der angeforderten Dienstleistung(en).</description>
                <text>Anstehende Dienstleistung</text>
            </items>
            <items id="at0062">
                <description>Das spezifische Problem, das Aufmerksamkeit erfordert, oder die klinische Frage, die untersucht werden muss.</description>
                <text>Grund für die Anforderung</text>
            </items>
            <items id="at0064">
                <description>Narrative Beschreibung des Problems oder der klinischen Frage, die gelöst werden muss.</description>
                <text>Beschreibung des Grundes</text>
            </items>
            <items id="at0065">
                <description>Beschreibung des beabsichtigten Ergebnisses der Anfrage.</description>
                <text>Intention</text>
            </items>
            <items id="at0068">
                <description>Dringlichkeit der Anforderung der Dienstleistung.</description>
                <text>Dringlichkeit</text>
            </items>
            <items id="at0076">
                <description>Ergänzende Informationen werden auf Anfrage zur Verfügung gestellt.</description>
                <text>Ergänzende Informationen</text>
            </items>
            <items id="at0078">
                <description>Beschreibung der Zusatzinformationen.</description>
                <text>Beschreibung der Informationen</text>
            </items>
            <items id="at0112">
                <description>Zusätzliche Informationen zur Erfassung lokaler Inhalte oder Anpassung an andere Referenzmodelle / Formalismen.</description>
                <text>Erweiterung</text>
            </items>
            <items id="at0116">
                <description>Sprach-, Transport- oder andere persönliche Anforderungen, um die Beteiligung oder Teilnahme des Patienten an der Erbringung der Dienstleistung zu unterstützen.</description>
                <text>Anforderungen an Patienten</text>
            </items>
            <items id="at0121">
                <description>Der Name der angeforderten Dienstleistung(en).</description>
                <text>Name der Dienstleistung</text>
            </items>
            <items id="at0127">
                <description>Der Status des Zustellungsantrags, wie vom Antragsteller angegeben.</description>
                <text>Status der Anfrage</text>
            </items>
            <items id="at0128">
                <description>Details über weitere Kliniker, Organisationen oder Einrichtungen, die Kopien aller Mitteilungen benötigen.</description>
                <text>Verteilerliste</text>
            </items>
            <items id="at0132">
                <description>Zusätzliche Details über die angeforderte Dienstleistung.</description>
                <text>Spezifische Details</text>
            </items>
            <items id="at0135">
                <description>Narrative Beschreibung der gewünschten Dienstleistung.</description>
                <text>Beschreibung</text>
            </items>
            <items id="at0136">
                <description>Die Anforderung erfordert sofortige Behandlung.</description>
                <text>Notfall</text>
            </items>
            <items id="at0137">
                <description>Die Anforderung erfordert eine prioritäre Behandlung.</description>
                <text>Dringend</text>
            </items>
            <items id="at0138">
                <description>Die Anforderung erfordert keine priorisierte Planung.</description>
                <text>Routine</text>
            </items>
            <items id="at0141">
                <description>Details über den Kliniker oder die Abteilung, die die Dienstleistung anfordert.</description>
                <text>Einsender</text>
            </items>
            <items id="at0142">
                <description>Details über den Kliniker oder die Abteilung, die die Dienstleistung erhält.</description>
                <text>Empfänger</text>
            </items>
            <items id="at0148">
                <description>Kategorie der beantragten Dienstleistung.</description>
                <text>Art der Dienstleistung</text>
            </items>
            <items id="at0149">
                <description>Digitales Dokument, Bild, Video oder Diagramm als zusätzliche Information zur Unterstützung oder Information der Anforderung.</description>
                <text>Unterstützende Informationen</text>
            </items>
            <items id="at0150">
                <description>Weitere Informationen über die Dienstanforderung, welche bisher nicht in den anderen Feldern erfasst wurden.</description>
                <text>Kommentar</text>
            </items>
            <items id="at0151">
                <description>Einzelheiten über eine komplexe Dienstanforderung, die eine Abfolge von Zeitangaben erfordert.</description>
                <text>Komplexe Zeitplanung</text>
            </items>
            <items id="at0152">
                <description>Das Symptom, das Zeichen oder die Diagnose, die die angeforderte Leistung erforderlich macht.</description>
                <text>Klinische Indikation</text>
            </items>
            <items id="at0153">
                <description>Zusätzliche Details und Anweisungen darüber, wie die Dienstleistungen zu erbringen sind.</description>
                <text>Auftragsdetail</text>
            </items>
            <items id="at0154">
                <description>Beschreibende Information über die Person und ihre Situation, die einen relevanten Kontext für den Antrag liefern.</description>
                <text>Klinischer Kontext</text>
            </items>
            <items id="at0155">
                <description>Angaben über die benannte Kontaktperson oder Organisation und die bevorzugte Kontaktart für dringende oder notfallbedingte Benachrichtigungen im Zusammenhang mit diesem Antrag.</description>
                <text>Notfallkontakt</text>
            </items>
            <items id="at0156">
                <description>Eine Empfehlung des Anforderers an den Empfänger über die Art der Bezahlung der Dienstleistung.</description>
                <text>Abrechnungshinweise</text>
            </items>
            <items id="at0157">
                <description>Angaben zu der Person oder Organisation, die die Verantwortung für die Bezahlung der Dienstleistung übernehmen wird.</description>
                <text>Zahlungspflichtiger</text>
            </items>
            <items id="at0158">
                <description>Mitteilung des Antragstellers an den Empfänger über die Berechtigung der Person, die beantragte Dienstleistung in Anspruch zu nehmen.</description>
                <text>Genehmigungsleitlinie</text>
            </items>
        </term_definitions>
        <term_definitions language="sv">
            <items id="at0000">
                <description>Förfrågan om en hälso- och sjukvårdsrelaterad tjänst eller aktivitet som behöver genomföras av en kliniker, organisation eller myndighet.</description>
                <text>Förfrågan om hälso-och sjukvårdsrelaterad tjänst</text>
            </items>
            <items id="at0001">
                <description>Nuvarande aktivitet</description>
                <text>Nuvarande aktivitet</text>
            </items>
            <items id="at0008">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0009">
                <description>@ internal @</description>
                <text>Tree</text>
            </items>
            <items id="at0010">
                <description>Den lokala identifieraren som tilldelats av det begärande kliniska systemet.</description>
                <text>Beställar ID</text>
            </items>
            <items id="at0011">
                <description>Den lokala identifieraren (ID) som tilldelats begäran, av läkaren eller organisationen som tar emot begäran om service.</description>
                <text>Mottagar ID</text>
            </items>
            <items id="at0040">
                <description>*The date/time or description about timing for provision of the requested service/s. (en)</description>
                <text>*Service due (en)</text>
            </items>
            <items id="at0062">
                <description>*The specific problem needing attention or the clinical question that requires investigation. (en)</description>
                <text>Anledning till förfrågan</text>
            </items>
            <items id="at0064">
                <description>*Narrative description about the issue or clinical query that needs resolution.  (en)</description>
                <text>Beskrivning av anledning</text>
            </items>
            <items id="at0065">
                <description>*Description of the intended outcome of the request. (en)</description>
                <text>Avsikt</text>
            </items>
            <items id="at0068">
                <description>Brådskandegrad för tjänsten.</description>
                <text>Brådskandegrad</text>
            </items>
            <items id="at0076">
                <description>Kompletterande information kommer efter begäran.</description>
                <text>Kompletterande infromation</text>
            </items>
            <items id="at0078">
                <description>Beskrivning av kompletterande information.</description>
                <text>Beskrivning av information</text>
            </items>
            <items id="at0112">
                <description>*Additional information required to extend the model with local content or to align with other reference models or formalisms. (en)</description>
                <text>Tilläggsinformation</text>
            </items>
            <items id="at0116">
                <description>Språk, transport eller andra personliga krav för att stödja patientens närvaro eller deltagande vid tillhandahållandet av tjänsten.</description>
                <text>Patientens behov</text>
            </items>
            <items id="at0121">
                <description>*The name of the service/s requested. (en)</description>
                <text>Namn på tjänst</text>
            </items>
            <items id="at0127">
                <description>Status på begäran om tjänsten, angiven av den som frågar om tjänsten.</description>
                <text>Status på förfrågan</text>
            </items>
            <items id="at0128">
                <description>Detaljer om ytterligare kliniker, organisationer eller byråer som bör motta kopior av svar på förfrågan.</description>
                <text>Svarsmottagare</text>
            </items>
            <items id="at0132">
                <description>Ytterligare detaljer om den begärda tjänsten.</description>
                <text>Specifika detaljer</text>
            </items>
            <items id="at0135">
                <description>Detaljerad beskrivning av den efterfrågade tjänsten.</description>
                <text>Beskrivning</text>
            </items>
            <items id="at0136">
                <description>Denna förfrågan kräver omedelbar uppmärksamhet.</description>
                <text>Akut</text>
            </items>
            <items id="at0137">
                <description>Denna förfrågan kräver prioriterad uppmärksamhet.</description>
                <text>Brådskande</text>
            </items>
            <items id="at0138">
                <description>Denna förfrågan kräver inte prioriterad schemaläggning.</description>
                <text>Rutin</text>
            </items>
            <items id="at0141">
                <description>Detaljer om den kliniker eller organisation som efterfrågar tjänsten.</description>
                <text>Förfrågare</text>
            </items>
            <items id="at0142">
                <description>Detaljer om klinikern eller organisationen som får begäran om service.</description>
                <text>Mottagare</text>
            </items>
            <items id="at0148">
