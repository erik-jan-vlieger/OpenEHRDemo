{
  "id": "sensire_diabetische_voet_v2",
  "gdl_version": "2.0",
  "concept": "gt0001",
  "language": {
    "original_language": "ISO_639-1::en"
  },
  "description": {
    "original_author": {
      "date": "2026-03-29",
      "name": "Erik-Jan Vlieger",
      "organisation": "Sensire / Het Instituut Bedrijfskunde",
      "email": "info@erik-janvlieger.nl"
    },
    "other_contributors": [],
    "lifecycle_state": "Author draft",
    "details": {
      "en": {
        "id": "en",
        "purpose": "Clinical decision support for diabetic foot screening and triage in home care. Covers structured anamnesis (claudication, glucose regulation, previous ulceration), bilateral foot inspection via CLUSTER.exam_diabetic_foot (C-3), monofilament examination via OBSERVATION.monofilament_examination (C-3b), Sims risk classification via EVALUATION.sims_classification_nl (C-3c), Charcot foot detection (most urgent escalation), plantar wound triage, Wagner grading, and routing to preventive care or Wound_Assessment_Sensire.v1 with DM layer.",
        "keywords": ["diabetic foot", "Charcot", "neuropathy", "monofilament", "Sims classification", "Wagner", "plantar wound", "foot inspection", "diabetes mellitus", "prevention", "home care"],
        "use": "Use for all patients with confirmed DM. Template: Diabetic_Foot_Assessment_Sensire.v1. Activated when Ulcus_Cruris_Assessment identifies DM, or on direct referral.",
        "misuse": "Not for patients without confirmed DM. Wound treatment handled by Wound_Assessment_Sensire.v1.",
        "copyright": "© 2026 Sensire"
      },
      "nl": {
        "id": "nl",
        "purpose": "Klinische beslisondersteuning voor diabetische voetscreening en triage in de thuiszorg. Omvat anamnese, bilaterale voetinspectie (C-3), monofilamenttest (C-3b), Sims-risicoclassificatie (C-3c), Charcot-detectie, plantaire wondtriage, Wagner-classificatie, en routering.",
        "keywords": ["diabetische voet", "Charcot", "neuropathie", "monofilament", "Sims classificatie", "Wagner", "plantaire wond", "voetinspectie", "diabetes mellitus", "preventie", "thuiszorg"],
        "use": "Gebruik voor alle patiënten met bevestigde DM. Template: Diabetic_Foot_Assessment_Sensire.v1.",
        "misuse": "Niet voor patiënten zonder bevestigde DM. Wondbehandeling via Wound_Assessment_Sensire.v1.",
        "copyright": "© 2026 Sensire"
      }
    }
  },
  "definition": {
    "data_bindings": {
      "gt0002": {
        "id": "gt0002",
        "model_id": "openEHR-EHR-EVALUATION.problem_diagnosis.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0003": {
            "id": "gt0003",
            "path": "/data[at0001]/items[at0002]",
            "description": "Diagnosis name — must be Diabetes Mellitus (precondition)"
          }
        }
      },
      "gt0004": {
        "id": "gt0004",
        "model_id": "openEHR-EHR-OBSERVATION.story.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0025": {
            "id": "gt0025",
            "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0004]",
            "description": "Anamnesis narrative — structured via nested CLUSTER.symptom_sign.v2"
          }
        }
      },
      "gt0005": {
        "id": "gt0005",
        "model_id": "openEHR-EHR-CLUSTER.symptom_sign.v2",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0026": {
            "id": "gt0026",
            "path": "/items[at0001]",
            "description": "Symptom name — claudication"
          },
          "gt0027": {
            "id": "gt0027",
            "path": "/items[at0021]",
            "description": "Symptom presence (present/absent)"
          }
        }
      },
      "gt0006": {
        "id": "gt0006",
        "model_id": "openEHR-EHR-CLUSTER.exam_diabetic_foot.v0",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0007": {
            "id": "gt0007",
            "path": "/items[at0001]",
            "description": "Skin colour — C-3 new archetype"
          },
          "gt0008": {
            "id": "gt0008",
            "path": "/items[at0002]",
            "description": "Skin temperature"
          },
          "gt0009": {
            "id": "gt0009",
            "path": "/items[at0003]",
            "description": "Temperature asymmetry between feet (bilateral comparison)"
          },
          "gt0010": {
            "id": "gt0010",
            "path": "/items[at0004]",
            "description": "Pedal pulses — a. dorsalis pedis palpable (yes/no)"
          },
          "gt0028": {
            "id": "gt0028",
            "path": "/items[at0005]",
            "description": "Pedal pulses — a. tibialis posterior palpable (yes/no)"
          },
          "gt0011": {
            "id": "gt0011",
            "path": "/items[at0006]",
            "description": "Callus or fissures present"
          },
          "gt0012": {
            "id": "gt0012",
            "path": "/items[at0007]",
            "description": "Foot deformity present"
          },
          "gt0013": {
            "id": "gt0013",
            "path": "/items[at0008]",
            "description": "Oedema or swelling present"
          },
          "gt0014": {
            "id": "gt0014",
            "path": "/items[at0009]",
            "description": "Redness without trauma (Charcot indicator)"
          },
          "gt0015": {
            "id": "gt0015",
            "path": "/items[at0010]",
            "description": "Warmth without trauma (Charcot indicator)"
          },
          "gt0029": {
            "id": "gt0029",
            "path": "/items[at0011]",
            "description": "Charcot suspicion (yes/no) — composite clinical judgment"
          },
          "gt0030": {
            "id": "gt0030",
            "path": "/items[at0012]",
            "description": "Nail assessment"
          },
          "gt0031": {
            "id": "gt0031",
            "path": "/items[at0013]",
            "description": "Footwear assessment"
          }
        }
      },
      "gt0032": {
        "id": "gt0032",
        "model_id": "openEHR-EHR-OBSERVATION.monofilament_examination.v0",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0033": {
            "id": "gt0033",
            "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0010]",
            "description": "Total score — number of locations where sensation is present (out of 8 or 10 locations). Source: C-3b new OBSERVATION archetype."
          }
        }
      },
      "gt0034": {
        "id": "gt0034",
        "model_id": "openEHR-EHR-CLUSTER.exam_wound.v0",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0017": {
            "id": "gt0017",
            "path": "/items[at0001]",
            "description": "Wound present (yes/no)"
          },
          "gt0018": {
            "id": "gt0018",
            "path": "/items[at0002]",
            "description": "Wound location (with anatomical_location cluster)"
          }
        }
      },
      "gt0035": {
        "id": "gt0035",
        "model_id": "openEHR-EHR-OBSERVATION.diabetic_wound_wagner.v0",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0036": {
            "id": "gt0036",
            "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0004]",
            "description": "Wagner grade (0-5)"
          }
        }
      },
      "gt0037": {
        "id": "gt0037",
        "model_id": "openEHR-EHR-EVALUATION.health_risk.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0038": {
            "id": "gt0038",
            "path": "/data[at0001]/items[at0016]",
            "description": "DM risk factors — aggregated risk assessment"
          }
        }
      },
      "gt0039": {
        "id": "gt0039",
        "model_id": "openEHR-EHR-OBSERVATION.laboratory_test_result.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "INPUT",
        "elements": {
          "gt0040": {
            "id": "gt0040",
            "path": "/data[at0001]/events[at0002]/data[at0003]/items[at0078]",
            "description": "HbA1c value — glucose regulation indicator"
          }
        }
      },
      "gt0041": {
        "id": "gt0041",
        "model_id": "openEHR-EHR-INSTRUCTION.service_request.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0020": {
            "id": "gt0020",
            "path": "/activities[at0001]/description[at0009]/items[at0121]",
            "description": "Service name — referral type"
          },
          "gt0021": {
            "id": "gt0021",
            "path": "/activities[at0001]/description[at0009]/items[at0062]",
            "description": "Reason for request"
          },
          "gt0022": {
            "id": "gt0022",
            "path": "/activities[at0001]/description[at0009]/items[at0064]",
            "description": "Urgency"
          }
        }
      },
      "gt0042": {
        "id": "gt0042",
        "model_id": "openEHR-EHR-ACTION.health_education.v1",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0023": {
            "id": "gt0023",
            "path": "/description[at0001]/items[at0002]",
            "description": "Education topic — preventive care instructions"
          }
        }
      },
      "gt0043": {
        "id": "gt0043",
        "model_id": "openEHR-EHR-EVALUATION.sims_classification_nl.v0",
        "template_id": "Diabetic_Foot_Assessment_Sensire.v1",
        "type": "OUTPUT",
        "elements": {
          "gt0044": {
            "id": "gt0044",
            "path": "/data[at0001]/items[at0002]",
            "description": "Sims category (0, 1, 2, 3). Source: C-3c new EVALUATION archetype."
          },
          "gt0045": {
            "id": "gt0045",
            "path": "/data[at0001]/items[at0003]",
            "description": "Protective sensation loss (boolean factor)"
          },
          "gt0046": {
            "id": "gt0046",
            "path": "/data[at0001]/items[at0004]",
            "description": "PAD signs present (boolean factor)"
          }
        }
      }
    },
    "pre_conditions": [
      "$gt0003 == local::at0001|Diabetes Mellitus|"
    ],
    "default_actions": [
      "$gt0022 = local::at0136|Routine|"
    ],
    "rules": {
      "gt0100": {
        "id": "gt0100",
        "priority": 12,
        "when": [
          "$gt0029 == local::at0001|Ja|"
        ],
        "then": [
          "$gt0020 = local::at0030|Arts — Charcot vermoeden|",
          "$gt0021 = 'CHARCOT VERMOEDEN: Rode, warme, gezwollen voet zonder trauma. Niet belasten! Voet hoogleggen. Noteer bevindingen. Arts neemt over.'",
          "$gt0022 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0101": {
        "id": "gt0101",
        "priority": 11,
        "when": [
          "$gt0014 == local::at0001|Aanwezig|",
          "$gt0015 == local::at0001|Aanwezig|",
          "$gt0013 == local::at0001|Aanwezig|"
        ],
        "then": [
          "$gt0020 = local::at0030|Arts — Charcot vermoeden|",
          "$gt0021 = 'Rode + warme + gezwollen voet zonder trauma — Charcot vermoeden. Arts bellen direct. Niet belasten! Voet hoogleggen.'",
          "$gt0022 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0102": {
        "id": "gt0102",
        "priority": 10,
        "when": [
          "$gt0009 == local::at0001|Aanwezig|"
        ],
        "then": [
          "$gt0020 = local::at0030|Arts — Charcot vermoeden|",
          "$gt0021 = 'Temperatuurverschil tussen beide voeten — Charcot vermoeden. Artsconsult dezelfde dag.'",
          "$gt0022 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      },
      "gt0103": {
        "id": "gt0103",
        "priority": 9,
        "when": [
          "($gt0010 == local::at0002|Afwezig|) || ($gt0028 == local::at0002|Afwezig|)"
        ],
        "then": [
          "$gt0020 = local::at0031|Huisarts — vaatonderzoek|",
          "$gt0021 = 'Pulsaties afwezig (a. dorsalis pedis en/of a. tibialis posterior) — perifeer vaatlijden. Vaatonderzoek aanvragen via huisarts.'",
          "$gt0022 = local::at0137|Urgent|"
        ]
      },
      "gt0104": {
        "id": "gt0104",
        "priority": 8,
        "when": [
          "$gt0033 <= 5"
        ],
        "then": [
          "$gt0020 = local::at0032|Arts — neuropathie|",
          "$gt0021 = 'Monofilament-score ≤5/8: significant verlies van beschermend gevoel (neuropathie). Bespreken met arts.'",
          "$gt0045 = true",
          "$gt0022 = local::at0137|Urgent|"
        ]
      },
      "gt0105": {
        "id": "gt0105",
        "priority": 7,
        "when": [
          "$gt0017 == local::at0001|Ja, wond aanwezig|",
          "$gt0018 == local::at0003|Plantair (voetzool)|"
        ],
        "then": [
          "$gt0020 = local::at0033|Arts — plantaire wond DM|",
          "$gt0021 = 'Plantaire wond bij DM patiënt — arts beoordeling binnen 24 uur. Schone afdekking, geen belasting. Noteer datum, locatie, afmeting. Wondzorg gaat door via Wound_Assessment_Sensire.v1 met DM-laag.'",
          "$gt0022 = local::at0138|Meest urgent — binnen 24 uur|"
        ]
      },
      "gt0106": {
        "id": "gt0106",
        "priority": 6,
        "when": [
          "$gt0017 == local::at0001|Ja, wond aanwezig|",
          "$gt0018 != local::at0003|Plantair (voetzool)|"
        ],
        "then": [
          "$gt0020 = local::at0034|Wound_Assessment_Sensire.v1 met DM-laag|",
          "$gt0021 = 'Wond aanwezig (niet-plantair) bij DM patiënt — vervolg via Algemeen Wondprotocol met DM-laag geactiveerd (Stap A: voetinspectie, Stap B: drukontlasting, Stap C: voorlichting).'",
          "$gt0022 = local::at0137|Urgent|"
        ]
      },
      "gt0107": {
        "id": "gt0107",
        "priority": 5,
        "when": [
          "$gt0017 == local::at0002|Nee, geen wond|"
        ],
        "then": [
          "$gt0023 = 'PREVENTIEVE VOETZORG: Huid invetten (niet tussen tenen), voeten wassen + goed afdrogen, niet blootsvoets, passend schoeisel inspecteren, medisch pedicure inschakelen, geen warmtebron bij voeten, dagelijks beide voeten inspecteren (ook tussen de tenen), katoen sokken zonder naad, direct contact bij wondje of roodheid. Herhaal elk zorgmoment.'"
        ]
      },
      "gt0108": {
        "id": "gt0108",
        "priority": 4,
        "when": [
          "$gt0040 > 53,mmol/mol"
        ],
        "then": [
          "$gt0020 = local::at0035|Arts/diabetesverpleegkundige — glucoseregulatie|",
          "$gt0021 = 'HbA1c > 53 mmol/mol: glucoseregulatie niet adequaat — verhoogd risico op voetcomplicaties. Bespreken met arts of diabetesverpleegkundige.'"
        ]
      },
      "gt0109": {
        "id": "gt0109",
        "priority": 3,
        "when": [
          "$gt0026 == local::at0001|Claudicatio intermittens|",
          "$gt0027 == local::at0002|Aanwezig|"
        ],
        "then": [
          "$gt0020 = local::at0031|Huisarts — vaatonderzoek|",
          "$gt0021 = 'Claudicatio intermittens klachten — perifeer vaatlijden. Vaatonderzoek aanvragen via huisarts.'",
          "$gt0046 = true"
        ]
      },
      "gt0110": {
        "id": "gt0110",
        "priority": 2,
        "when": [
          "$gt0045 == true",
          "$gt0046 == true"
        ],
        "then": [
          "$gt0044 = local::at0007|Sims categorie 2|",
          "$gt0021 = 'Sims-categorie ≥2: zowel PS-verlies (neuropathie) als PAV-tekenen. Verhoogd risico — intensief preventief zorgprofiel aanbevolen.'"
        ]
      },
      "gt0111": {
        "id": "gt0111",
        "priority": 1,
        "when": [
          "$gt0036 >= 3"
        ],
        "then": [
          "$gt0020 = local::at0036|Arts — hoog-risico Wagner graad|",
          "$gt0021 = 'Wagner graad ≥3: diepe wond met abces, osteomyelitis of gangreen. Directe artsbeoordeling en mogelijk ziekenhuisverwijzing vereist.'",
          "$gt0022 = local::at0138|Meest urgent — dezelfde dag|"
        ]
      }
    }
  },
